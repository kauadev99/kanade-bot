const sendStickerFromUrl = async (to, url) => {
try {
var names = Date.now() / 10000;
var download = function (uri, filename, callback) {
request.head(uri, function (err, res, body) {
request(uri)
.pipe(fs.createWriteStream(filename))
.on("close", callback);
});
};
download(url, "./arquivos/sticker" + names + ".png", async function () {
let filess = "./arquivos/sticker" + names + ".png";
let asw = "./arquivos/sticker" + names + ".webp";
exec(
`ffmpeg -i ${filess} -vcodec libwebp -filter:v fps=fps=15 -lossless 1 -loop 0 -preset default -an -vsync 0 -s 800:800 ${asw}`,
async (err) => {
