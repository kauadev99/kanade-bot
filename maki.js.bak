case 'nome': {
try {

if (!q) return reply('вқҢ Digite um nome\nEx: .nome Pedro Henrique');

reply('рҹ”Һ Buscando informaГ§Гөes...');

const axios = require('axios');

let res = await axios.get(`http://node.tconect.xyz:1116/api/consulta/nome/v1?apikey=PNSAPIS&nome=${encodeURIComponent(q)}`);

if (!res.data || res.data.status !== "true") return reply('вқҢ Nenhum resultado encontrado');

let total = res.data.resultado?.total || 0;
let dados = res.data.resultado?.resultados;

if (!dados || !dados.length) return reply('вқҢ Nenhum resultado encontrado');

let lista = dados.slice(0, 10).map((p, i) => {
return `рҹ”№ ${i + 1}Вә Resultado
вҖў Nome: ${p.nome || 'NГЈo informado'}
вҖў CPF: ${p.cpf || 'NГЈo informado'}
вҖў Nascimento: ${p.nascimento || 'NГЈo informado'}
вҖў MГЈe: ${p.mae || 'NГЈo informado'}
вҖў Sexo: ${p.sexo || 'NГЈo informado'}
вҖў RG: ${p.rg || 'NГЈo informado'}`;
}).join('\n\n');

let texto = `рҹ”Қ CONSULTA POR NOME

вң… API FUNCIONANDO
рҹ“Ў Status: ${res.data.status}

в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
рҹ“Ҡ TOTAL ENCONTRADO: ${total}

рҹ“Ӣ MOSTRANDO 10 RESULTADOS

${lista}

в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
KANADE SEMPRE NO CONTROLE`;

reply(texto);

} catch (e) {
console.log(e);
reply('вқҢ Erro ao consultar nome');
}

break;
}
