if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const userData = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!userData) return reply(`*VocГӘ nГЈo possui registro de coins.*`);

if (!userData.porcoesPorca || userData.porcoesPorca <= 0) {
return reply(
`рҹ’Җ VocГӘ nГЈo tem poГ§Гөes porca para usar! Compre com ${prefix}comprarporca.`
);
}

// Usa 1 poГ§ГЈo
userData.porcoesPorca -= 1;

const agora = Date.now();

// Efeitos possГӯveis da poГ§ГЈo porca
const efeitos = [
() => {
const ganho = Math.floor(Math.random() * 41) + 30; // 30-70 coins
userData.coins += ganho;
const msgs = [
`рҹҚҖ Sorte! VocГӘ ganhou *${ganho} N-Coins*!`,
`рҹҺү Que sorte! +${ganho} coins para vocГӘ!`,
`рҹ’° VocГӘ achou umas moedas extras! +${ganho} N-Coins.`,
];
return msgs[Math.floor(Math.random() * msgs.length)];
},
() => {
const ganho = Math.floor(Math.random() * 81) + 70; // 70-150 coins + proteГ§ГЈo
userData.coins += ganho;
userData.pocaoPorca = true;
userData.pocaoPorcaExpira = agora + 300000; // 5 minutos proteГ§ГЈo
const msgs = [
`рҹҚҖ Sorte grande! VocГӘ ganhou *${ganho} N-Coins* e estГЎ protegido contra roubos por 5 minutos!`,
`рҹӣЎпёҸ Protegido + coins! +${ganho} N-Coins e escudo ativo por 5 min.`,
];
return msgs[Math.floor(Math.random() * msgs.length)];
},
() => {
const perda = Math.min(
userData.coins,
Math.floor(Math.random() * 51) + 20
); // perde 20-70 coins
userData.coins -= perda;
const msgs = [
`вҳ пёҸ Azar! VocГӘ perdeu *${perda} N-Coins*.`,
`рҹ’Җ Que azar... VocГӘ perdeu ${perda} coins.`,
];
return msgs[Math.floor(Math.random() * msgs.length)];
},
() => {
const msgs = [
`рҹҳҗ Nada aconteceu dessa vez.`,
`рҹӨ·вҖҚвҷӮпёҸ Sem sorte nem azar.`,
];
return msgs[Math.floor(Math.random() * msgs.length)];
},
() => {
userData.pocaoPorca = true;
userData.pocaoPorcaExpira = agora + 300000; // 5 minutos proteГ§ГЈo
const msgs = [
`рҹӣЎпёҸ VocГӘ ativou a proteГ§ГЈo contra roubos por 5 minutos.`,
`рҹӣЎпёҸ Escudo ativo por 5 minutos!`,
];
return msgs[Math.floor(Math.random() * msgs.length)];
},
() => {
userData.pocaoAzarExpira = agora + 300000; // 5 min azar (nГЈo pode roubar)
const msgs = [
`вҳ пёҸ VocГӘ ficou azarado! NГЈo pode tentar roubar ninguГ©m por 5 minutos.`,
`рҹҳө Azar ativado! Sem roubar por 5 minutos.`,
];
return msgs[Math.floor(Math.random() * msgs.length)];
},
];

const efeitoEscolhido =
efeitos[Math.floor(Math.random() * efeitos.length)];
const mensagem = efeitoEscolhido();

CoinsUpdate(RG_SCOINS);

await reply(
`${mensagem}\nPoГ§Гөes porca restantes: ${userData.porcoesPorca}`
);

break;
}

case 'addcoins': {
if (!isGroup) return reply(mess.onlyGroup())
if (!isModoCoins)
return reply(`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙңsбҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ бҙҸ sЙӘsбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`)
if (!SoDono) return reply(mess.onlyOwner())

// padroniza formato @user/valor
barra = q.replace(" /", "/").replace("/ ", "/").replace(" / ", "/")
var [nmr, valor] = barra.split('/')

if (!nmr || !valor || isNaN(valor))
return await mention(
`рҹҸҰ *BANCO DE COINS MAKI*\n\n` +
`рҹ‘Ө Informe o usuГЎrio e a quantidade de coins.\n` +
`вҖў Exemplo: *${prefix + command} @${nmrdn.split('@')[0]}/100*`
)

// define usuГЎrio corretamente
const alvo = menc_os2
? menc_os2
: (nmr.includes('@')
? nmr.split('@')[1] + "@s.whatsapp.net"
: nmr + "@s.whatsapp.net")

const quantidade = parseInt(valor)

// busca usuГЎrio
const userAlvo = RG_SCOINS[ID_G_COINS]?.usus.find(u => u.id === alvo)
if (!userAlvo)
return reply(`вқҢ O usuГЎrio mencionado nГЈo possui registro de coins.`)

// adiciona coins
userAlvo.coins += quantidade
CoinsUpdate(RG_SCOINS)

// mensagem final
await maki.sendMessage(from, {
text:
`в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—
в•‘ рҹҸҰ BANCO DE COINS MAKI
в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј
в•‘ вң… TransaГ§ГЈo realizada
в•‘ вһ• AdiГ§ГЈo de N-Coins
в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј
в•‘ рҹ‘Ө UsuГЎrio:
в•‘ @${alvo.split("@")[0]}
в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј
в•‘ рҹ’° Valor:
в•‘ +${quantidade} N-Coins
в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј
в•‘ рҹ’і Saldo Atual:
в•‘ ${userAlvo.coins} N-Coins
в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј
в•‘ рҹ“… ${new Date().toLocaleString("pt-BR")}
в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј
в•‘ рҹ“Ң Status: CONCLUГҚDO
в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ`,
mentions: [alvo]
}, { quoted: selo })

break
}

case 'mecoins':
case 'meuscoins': {
