return reply(`Use 1 pra ativar ou 0 pra desativar. Caso deseja ativar, use essa forma: ${prefix + command} 1, caso seja desativar e sГі trocar o 1 pelo 0.`);
if (Number(args[0]) === 1) {
if (isAntiStatus) return reply("бҙҸ КҖбҙҮбҙ„бҙңКҖsбҙҸ бҙ…бҙҮ бҙҖЙҙбҙӣЙӘ sбҙӣбҙҖбҙӣбҙңs бҙҠбҙҖ бҙҮsбҙӣбҙҖ бҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ.");
dataGp[0].antistatus = true;
setGp(dataGp);
reply("бҙҖбҙӣЙӘбҙ бҙҸбҙң бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ бҙҸ бҙҖЙҙбҙӣЙӘ sбҙӣбҙҖбҙӣбҙңs ЙҙбҙҮsбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ. рҹ’ҷ");
} else if (Number(args[0]) === 0) {
if (!isAntiStatus) return reply("бҙҸ КҖбҙҮбҙ„бҙңКҖsбҙҸ бҙ…бҙҮ бҙҖЙҙбҙӣЙӘ sбҙӣбҙҖбҙӣбҙңs бҙҠбҙҖ бҙҮsбҙӣбҙҖ бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ.");
dataGp[0].antistatus = false;
setGp(dataGp);
reply("бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҸбҙң бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ бҙҸ бҙҖЙҙбҙӣЙӘ sбҙӣбҙҖбҙӣбҙңs ЙҙбҙҮsбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ. рҹ’ҷ");
} else {
reply("1 бҙҳбҙҖКҖбҙҖ бҙҖбҙӣЙӘбҙ бҙҖКҖ, 0 бҙҳбҙҖКҖбҙҖ бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҖКҖ.");
}
break;


case 'antipv':
if (!SoDono) return reply(mess.onlyOwner());
if (!isAntiPv) {
nescessario.antipv = true;
setNes(nescessario);
reply(`бҙҸ бҙҖЙҙбҙӣЙӘбҙҳбҙ  Т“бҙҸЙӘ бҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ. sбҙҮЙҙКңбҙҸКҖ(бҙҖ)! рҹ’ҷ`);
} else if (isAntiPv) {
nescessario.antipv = false;
setNes(nescessario);
reply("бҙҸ бҙҖЙҙбҙӣЙӘбҙҳбҙ  Т“бҙҸЙӘ бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ. sбҙҮЙҙКңбҙҸКҖ(бҙҖ)! рҹ’ҷ");
}
break;

case 'antipv2':
if (!SoDono) return reply(mess.onlyOwner());
if (!isAntiPv2) {
nescessario.antipv2 = true;
setNes(nescessario);
reply("бҙҸ бҙҖЙҙбҙӣЙӘбҙҳбҙ 2 Т“бҙҸЙӘ бҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ. sбҙҮЙҙКңбҙҸКҖ(бҙҖ)! рҹ’ҷ");
} else if (isAntiPv2) {
nescessario.antipv2 = false;
setNes(nescessario);
reply("бҙҸ бҙҖЙҙбҙӣЙӘбҙҳбҙ 2 Т“бҙҸЙӘ бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ. sбҙҮЙҙКңбҙҸКҖ(бҙҖ)! рҹ’ҷ");
}
break;

case 'antipv3':
if (!SoDono) return reply(mess.onlyOwner());
if (!isAntiPv3) {
nescessario.antipv3 = true;
setNes(nescessario);
reply("бҙҸ бҙҖЙҙбҙӣЙӘбҙҳбҙ 3 Т“бҙҸЙӘ бҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ. sбҙҮЙҙКңбҙҸКҖ(бҙҖ)! рҹ’ҷ");
} else if (isAntiPv3) {
nescessario.antipv3 = false;
setNes(nescessario);
reply("бҙҸ бҙҖЙҙбҙӣЙӘбҙҳбҙ 3 Т“бҙҸЙӘ бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ. sбҙҮЙҙКңбҙҸКҖ(бҙҖ)! рҹ’ҷ");
}
break;

case 'getquoted':
case 'getinfo':
case 'get':
case 'mek':
reply(JSON.stringify(info, null, 3));
break;

case 'advertir':
case 'adv': {
if (!isGroup) return reply(mess.onlyGroup())
if (!isGroupAdmins) return reply(mess.onlyAdmins())

if (!menc_os2)
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҚбҙҖКҖЗӯбҙңбҙҮ бҙҸ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ З«бҙңбҙҮ бҙ…бҙҮкңұбҙҮбҙҠбҙҖ бҙҖбҙ…бҙ бҙҮКҖбҙӣЙӘКҖ.*`)

if (menc_os2 == botNumberLID)
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | ЙҙбҙҖМғбҙҸ бҙҳбҙҸбҙ…бҙҮ бҙҖбҙ…бҙ бҙҮКҖбҙӣЙӘКҖ бҙҸ бҙҳКҖбҙҸМҒбҙҳКҖЙӘбҙҸ КҷбҙҸбҙӣ.*`)

if (menc_os2 == nmrdn)
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | ЙҙбҙҖМғбҙҸ бҙҳбҙҸбҙ…бҙҮ бҙҖбҙ…бҙ бҙҮКҖбҙӣЙӘКҖ бҙҸ бҙ…бҙҸЙҙбҙҸ бҙ…бҙҸ КҷбҙҸбҙӣ.*`)

if (groupAdmins.includes(menc_os2))
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | ЙҙбҙҖМғбҙҸ бҙҮМҒ бҙҳбҙҸкңұкңұЙӘМҒбҙ бҙҮКҹ бҙҖбҙ…бҙ бҙҮКҖбҙӣЙӘКҖ бҙҖбҙ…бҙҚЙӘЙҙЙӘкңұбҙӣКҖбҙҖбҙ…бҙҸКҖ.*`)

if (!JSON.stringify(groupMembers).includes(menc_os2))
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҸ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ ЙҙбҙҖМғбҙҸ бҙҮкңұбҙӣбҙҖМҒ ЙҙбҙҮкңұбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ.*`)

// Adiciona advertГӘncia
ADVT.push(menc_os2)
setGp(dataGp)

setTimeout(async () => {
let quantidade = ADVT.filter(x => x == menc_os2).length
let textoAdvertencia = mess.warningAdvertencia(menc_os2, quantidade)

if (!textoAdvertencia.includes("3/3")) {
await sleep(1500)
await mentions(`гҖҢрҹ’ҷгҖҚ\n- *рҹ§Ҡ | ${textoAdvertencia}*`, [menc_os2])
} else {
await maki.sendMessage(from, {
text: `гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | ${mess.finishAdvertencia(menc_os2)}*`,
contextInfo: canalInfo([menc_os2])
}, { quoted: selo })

await sleep(1500)
await maki.groupParticipantsUpdate(from, [menc_os2], "remove")

// Remover todas as ocorrГӘncias sem reatribuir ADVT
for (let i = ADVT.length - 1; i >= 0; i--) {
if (ADVT[i] === menc_os2) ADVT.splice(i, 1)
}
setGp(dataGp)
}
}, 3000)
}
break

case 'deladv':
case 'rmadv': {
if (!isGroup) return reply(mess.onlyGroup())
if (!isGroupAdmins) return reply(mess.onlyAdmins())

if (!menc_os2)
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҚбҙҖКҖЗӯбҙңбҙҮ бҙҸ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ З«бҙңбҙҮ бҙ…бҙҮкңұбҙҮКҖ КҖбҙҮбҙҚбҙҸбҙ бҙҮКҖ бҙҖ бҙҖбҙ…бҙ бҙҮКҖбҙӣбҙҮМӮЙҙбҙ„ЙӘбҙҖ.*`)

let advIndex = ADVT.indexOf(menc_os2)
if (advIndex < 0)
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҮкңұбҙӣбҙҮ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ ЙҙбҙҖМғбҙҸ бҙҳбҙҸкңұкңұбҙңЙӘ бҙҖбҙ…бҙ бҙҮКҖбҙӣбҙҮМӮЙҙбҙ„ЙӘбҙҖ.*`)

ADVT.splice(advIndex, 1)
setGp(dataGp)

await maki.sendMessage(from, {
text: `гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҖ бҙҖбҙ…бҙ бҙҮКҖбҙӣбҙҮМӮЙҙбҙ„ЙӘбҙҖ бҙ…бҙҮ @${menc_os2.split("@")[0]} кң°бҙҸЙӘ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҖ.*`,
contextInfo: canalInfo([menc_os2])
}, { quoted: selo })
}
break
case 'deladv': {
if (!isGroup) return reply(mess.onlyGroup())
if (!isGroupAdmins) return reply(mess.onlyAdmins())

if (!menc_os2)
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҸ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ.*`)

let advIndex = ADVT.indexOf(menc_os2)

if (advIndex < 0)
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҮкңұбҙӣбҙҮ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ ЙҙбҙҖМғбҙҸ бҙҳбҙҸкңұкңұбҙңЙӘ бҙҖбҙ…бҙ бҙҮКҖбҙӣбҙҮМӮЙҙбҙ„ЙӘбҙҖ.*`)

ADVT.splice(advIndex, 1)
setGp(dataGp)

await maki.sendMessage(from, {
text: `гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҖ бҙҖбҙ…бҙ бҙҮКҖбҙӣбҙҮМӮЙҙбҙ„ЙӘбҙҖ бҙ…бҙҮ @${menc_os2.split("@")[0]} кң°бҙҸЙӘ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҖ.*`,
contextInfo: canalInfo([menc_os2])
}, { quoted: selo })

}
break

case 'mute':
case 'mutar':
if (!isGroup) return reply(mess.onlyGroup());
if (!isGroupAdmins) return reply(mess.onlyAdmins());
if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin());
if (!menc_os2 || menc_jid2[1])
return reply(`рҹҺҜ бҙҳбҙҸКҖТ“бҙҖбҙ бҙҸКҖ, бҙҚбҙҮЙҙбҙ„ЙӘбҙҸЙҙбҙҮ бҙҸ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ бҙҸбҙң бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҖ бҙҚбҙҮЙҙsбҙҖЙўбҙҮбҙҚ бҙ…бҙҸ бҙҖКҹбҙ бҙҸ З«бҙңбҙҮ бҙ бҙҸбҙ„бҙҮМӮ бҙ…бҙҮsбҙҮбҙҠбҙҖ бҙҚбҙңбҙӣбҙҖКҖ.`);
if (menc_os2 == botNumber)
return reply("вқҢпёҸпёҸ ЙҙбҙҖМғбҙҸ бҙҮМҒ бҙҳбҙҸssЙӘМҒбҙ бҙҮКҹ бҙҚбҙңбҙӣбҙҖКҖ бҙҸ КҷбҙҸбҙӣ!");
if (menc_os2 == SoDono)
return reply("вқҢ бҙ бҙҸбҙ„бҙҮМӮ ЙҙбҙҖМғбҙҸ бҙҳбҙҸбҙ…бҙҮ бҙҚбҙңбҙӣбҙҖКҖ бҙҸ бҙҚбҙҮбҙң бҙҳКҖбҙҸбҙҳКҖЙӘбҙҮбҙӣбҙҖМҒКҖЙӘбҙҸ!");
if (vip.map((i) => i.id).includes(menc_os2))
return reply("вқҢпёҸпёҸ ЙҙбҙҖМғбҙҸ бҙҮМҒ бҙҳбҙҸssЙӘМҒбҙ бҙҮКҹ бҙҚбҙңбҙӣбҙҖКҖ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸs З«бҙңбҙҮ бҙ„бҙҸЙҙбҙӣбҙҮМӮбҙҚ бҙ ЙӘбҙҳ ЙҙбҙҸ КҷбҙҸбҙӣ!");
if (groupAdmins.includes(menc_os2))
return reply("вқҢпёҸ ЙҙбҙҖМғбҙҸ бҙҮМҒ бҙҳбҙҸssЙӘМҒбҙ бҙҮКҹ бҙҚбҙңбҙӣбҙҖКҖ бҙңбҙҚ(бҙҖ) бҙҖбҙ…бҙҚЙӘЙҙЙӘsбҙӣКҖбҙҖбҙ…бҙҸКҖ(бҙҖ) бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ.");
if (!JSON.stringify(groupMembers).includes(menc_os2))
return reply("вқҢпёҸ ЙҙбҙҖМғбҙҸ бҙҮМҒ бҙҳбҙҸssЙӘМҒбҙ бҙҮКҹ бҙҚбҙңбҙӣбҙҖКҖ бҙңбҙҚбҙҖ бҙҳбҙҮssбҙҸбҙҖ З«бҙңбҙҮ ЙҙбҙҖМғбҙҸ бҙҳбҙҖКҖбҙӣЙӘбҙ„ЙӘбҙҳбҙҖ бҙҚбҙҖЙӘs бҙ…бҙҮsбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ.");
if (muted[muted.map((i) => i.grupo).indexOf(from)].usus.includes(menc_os2))
return maki.sendMessage(from, {
text: `бҙҸ бҙҳбҙҖКҖбҙӣЙӘбҙ„ЙӘбҙҳбҙҖЙҙбҙӣбҙҮ @${menc_os2.split("@")[0]} бҙҠбҙҖМҒ бҙҮsбҙӣбҙҖМҒ ЙҙбҙҖ КҹЙӘsбҙӣбҙҖ бҙ…бҙҮ бҙҚбҙңбҙӣбҙҖбҙ…бҙҸs, бҙҳбҙҖКҖбҙҖ бҙ…бҙҮsбҙҚбҙңбҙӣбҙҖКҖ бҙңsбҙҮ: ${prefix}desmute.`,
mentions: [menc_os2]
}, { quoted: selo });

await maki.sendMessage(from, {
text: `рҹ”Ү бҙҸ бҙҳбҙҖКҖбҙӣЙӘбҙ„ЙӘбҙҳбҙҖЙҙбҙӣбҙҮ @${menc_os2.split("@")[0]} Т“бҙҸЙӘ бҙҚбҙңбҙӣбҙҖбҙ…бҙҸ бҙҳбҙҮКҹбҙҸ бҙҖбҙ…бҙҚЙӘЙҙЙӘsбҙӣКҖбҙҖбҙ…бҙҸКҖ @${sender.split("@")[0]}. sбҙҮ бҙҮКҹбҙҮ(бҙҖ) Т“бҙҖКҹбҙҖКҖ бҙҖКҹЙўбҙңбҙҚбҙҖ бҙ„бҙҸЙӘsбҙҖ, sбҙҮКҖбҙҖМҒ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҸ бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ!`,
mentions: [menc_os2, sender]
}, { quoted: selo });

muted[muted.map((i) => i.grupo).indexOf(from)].usus.push(menc_os2);
fs.writeFileSync("./arquivos/database/grupos/muted.json", JSON.stringify(muted, null, 2));
break;
case 'desmute':
case 'desmutar':
if (!isGroup) return reply(mess.onlyGroup());
if (!isGroupAdmins) return reply(mess.onlyAdmins());
if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin());
if (!menc_os2 || menc_jid2[1])
return reply(`рҹҺҜ бҙҳбҙҸКҖТ“бҙҖбҙ бҙҸКҖ, бҙҚбҙҮЙҙбҙ„ЙӘбҙҸЙҙбҙҮ бҙҸ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ бҙҸбҙң бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҖ бҙҚбҙҮЙҙsбҙҖЙўбҙҮбҙҚ бҙ…бҙҸ бҙҖКҹбҙ бҙҸ З«бҙңбҙҮ бҙ бҙҸбҙ„бҙҮМӮ бҙ…бҙҮsбҙҮбҙҠбҙҖ бҙ…бҙҮsбҙҚбҙңбҙӣбҙҖКҖ.`);
if (!muted[muted.map((i) => i.grupo).indexOf(from)].usus.includes(menc_os2))
return maki.sendMessage(from, {
text: `бҙҸ бҙҳбҙҖКҖбҙӣЙӘбҙ„ЙӘбҙҳбҙҖЙҙбҙӣбҙҮ @${menc_os2.split("@")[0]} ЙҙбҙҖМғбҙҸ бҙҮsбҙӣбҙҖМҒ ЙҙбҙҖ КҹЙӘsбҙӣбҙҖ бҙ…бҙҮ бҙҚбҙңбҙӣбҙҖбҙ…бҙҸs бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ.`,
mentions: [menc_os2]
}, { quoted: selo });

await maki.sendMessage(from, {
text: `рҹ”Ҡ бҙҸ бҙҳбҙҖКҖбҙӣЙӘбҙ„ЙӘбҙҳбҙҖЙҙбҙӣбҙҮ @${menc_os2.split("@")[0]} Т“бҙҸЙӘ бҙ…бҙҮsбҙҚбҙңбҙӣбҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ бҙҳбҙҮКҹбҙҸ бҙҖбҙ…бҙҚЙӘЙҙЙӘsбҙӣКҖбҙҖбҙ…бҙҸКҖ @${sender.split("@")[0]}.`,
mentions: [menc_os2, sender]
}, { quoted: selo });

muted[muted.map((i) => i.grupo).indexOf(from)].usus.splice(
muted[muted.map((i) => i.grupo).indexOf(from)].usus.indexOf(menc_os2),
1
);
fs.writeFileSync("./arquivos/database/usuarios/muted.json", JSON.stringify(muted, null, 2));
break;

case 'mutelist':
case 'listamutados':
if (muted[muted.map((i) => i.grupo).indexOf(from)].usus.length == 0)
return reply(`ЙҙбҙҖМғбҙҸ бҙҮxЙӘsбҙӣбҙҮ ЙҙбҙҮЙҙКңбҙңбҙҚ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ бҙҚбҙңбҙӣбҙҖбҙ…бҙҸ ЙҙбҙҮsбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ.`);
usus__ = `[бҙӣбҙҸбҙӣбҙҖКҹ: *${muted[muted.map((i) => i.grupo).indexOf(from)].usus.length}*] - КҹЙӘsбҙӣбҙҖ бҙ…бҙҮ бҙҳбҙҖКҖбҙӣЙӘбҙ„ЙӘбҙҳбҙҖЙҙбҙӣбҙҮs бҙҚбҙңбҙӣбҙҖбҙ…бҙҸs ЙҙбҙҸ ЙўКҖбҙңбҙҳбҙҸ:\nвҖ“\n`;
usus__ += muted[muted.map((i) => i.grupo).indexOf(from)].usus
.map((v, index) => `вҖў *[${index + 1}]* - @${v.split("@")[0]}`)
.join("\n");

await maki.sendMessage(from, {
text: usus__,
mentions: muted[muted.map((i) => i.grupo).indexOf(from)].usus
}, { quoted: selo });
break;

case 'add':
case 'unkick':
if (!isGroupAdmins && !SoDono) return reply(mess.onlyAdmins());
if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin());
if (!q && info.message.extendedTextMessage === null)
return reply(
"бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҖ бҙҚбҙҮЙҙsбҙҖЙўбҙҮбҙҚ бҙҸбҙң бҙ„бҙҸКҹбҙҸЗ«бҙңбҙҮ бҙҸ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ бҙ…бҙҮ З«бҙңбҙҮбҙҚ бҙ бҙҸбҙ„бҙҮМӮ З«бҙңбҙҮКҖ бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖКҖ ЙҙбҙҸ ЙўКҖбҙңбҙҳбҙҸ."
);

try {
useradd = `${args.join(" ").replace(/\D/g, "")}`
? `${args.join(" ").replace(/\D/g, "")}`
: info.message.extendedTextMessage.contextInfo.participant;

let id = `${useradd.replace(/\D/g, "")}`;
if (!id) return reply(`ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ ЙӘЙҙбҙ бҙҖМҒКҹЙӘбҙ…бҙҸ.`);

let [result] = await maki.onWhatsApp(id);
if (!result)
return reply(`бҙҮssбҙҮ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ ЙҙбҙҖМғбҙҸ бҙҮsбҙӣбҙҖМҒ КҖбҙҮЙўЙӘsбҙӣКҖбҙҖбҙ…бҙҸ ЙҙбҙҸ бҙЎКңбҙҖбҙӣsбҙҖбҙҳбҙҳ.`);

let response = await maki.groupParticipantsUpdate(
from,
[result.jid],
"add"
);

if (response[0].status == "409") {
await maki.sendMessage(
from,
{
text: `бҙҮКҹбҙҮ бҙҠбҙҖМҒ бҙҮsбҙӣбҙҖМҒ ЙҙбҙҸ ЙўКҖбҙңбҙҳбҙҸ, бҙ„бҙҸбҙҚбҙҸ бҙҮбҙң бҙ бҙҸбҙң бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖКҖ?`,
mentions: [result.jid, sender],
},
{ quoted: selo }
);

} else if (response[0].status == "403") {
await maki.sendMessage(
from,
{
text: `ЙҙбҙҖМғбҙҸ бҙ„бҙҸЙҙsбҙҮЙўбҙңЙӘ бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖКҖ бҙҸ @${result.jid.split("@")[0]} бҙҳбҙҸКҖЗ«бҙңбҙҮ бҙҮКҹбҙҮ бҙҳКҖЙӘбҙ бҙҸбҙң бҙҖ бҙ„бҙҸЙҙбҙӣбҙҖ.`,
mentions: [result.jid, sender],
},
{ quoted: selo }
);

} else if (response[0].status == "408") {
await maki.sendMessage(
from,
{
text: `ЙҙбҙҖМғбҙҸ бҙ„бҙҸЙҙsбҙҮЙўбҙңЙӘ бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖКҖ бҙҸ @${result.jid.split("@")[0]} бҙҳбҙҸКҖЗ«бҙңбҙҮ бҙҮКҹбҙҮ sбҙҖЙӘбҙң КҖбҙҮбҙ„бҙҮЙҙбҙӣбҙҮбҙҚбҙҮЙҙбҙӣбҙҮ бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ.`,
mentions: [result.jid, sender],
},
{ quoted: selo }
);

} else if (response[0].status == "401") {
await maki.sendMessage(
from,
{
text: `ЙҙбҙҖМғбҙҸ бҙ„бҙҸЙҙsбҙҮЙўбҙңЙӘ бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖКҖ бҙҸ @${result.jid.split("@")[0]} бҙҳбҙҸКҖЗ«бҙңбҙҮ бҙҮКҹбҙҮ КҷКҹбҙҸЗ«бҙңбҙҮбҙҸбҙң бҙҸ КҷбҙҸбҙӣ.`,
mentions: [result.jid, sender],
},
{ quoted: selo }
);

} else if (response[0].status == "200") {
await maki.sendMessage(
from,
{
text: `бҙҳКҖбҙҸЙҙбҙӣЙӘЙҙКңбҙҸ, Т“ЙӘбҙў бҙҸ З«бҙңбҙҮ бҙ бҙҸбҙ„бҙҮМӮ бҙҳбҙҮбҙ…ЙӘбҙң.`,
mentions: [result.jid, sender],
},
{ quoted: selo }
);

} else {
await maki.sendMessage(
from,
{
text: `бҙҸбҙ„бҙҸКҖКҖбҙҮбҙң бҙңбҙҚ бҙҮКҖКҖбҙҸ бҙҖбҙҸ бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖКҖ бҙҸ(a) *@${result.jid.split("@")[0]}* ЙҙбҙҸ ЙўКҖбҙңбҙҳбҙҸ.`,
mentions: [result.jid, sender],
},
{ quoted: selo }
);
}

} catch (error) {
reply(mess.error());
}
break;

case 'idade':
if (!q) return reply(`- Exemplo: ${prefix}idade 23/12/2007`)
try {
let txt; 
const regexData = /^(\d{2})\/(\d{2})\/(\d{4})$/
if (!regexData.test(q)) return reply(`- Exemplo: ${prefix}idade 23/12/2007`)
const [dia, mes, ano] = q.split('/').map(Number)
const dataNascimento = new Date(ano, mes - 1, dia)
const hoje = new Date()
if (dataNascimento > hoje || isNaN(dataNascimento)) {
return reply(`*бҙ„бҙҸКҹбҙҸЗ«бҙңбҙҮ бҙ…бҙҖ Т“бҙҸКҖбҙҚбҙҖ бҙ„бҙҮКҖбҙӣбҙҖ КҷбҙҖЙӘбҙӣбҙҸКҹбҙҖ рҹҳЎ*`)
}
const diffMs = hoje - dataNascimento
const idadeData = new Date(diffMs)
const anos = idadeData.getUTCFullYear() - 1970
const meses = idadeData.getUTCMonth()
const dias = idadeData.getUTCDate() - 1
const diasVividos = Math.floor(diffMs / (1000 * 60 * 60 * 24))
const horasVividas = diasVividos * 24
const minutosVividos = horasVividas * 60
const proximoAniversario = new Date(hoje.getFullYear(), mes - 1, dia)
if (proximoAniversario <= hoje) proximoAniversario.setFullYear(hoje.getFullYear() + 1)
const diasParaAniversario = Math.ceil((proximoAniversario - hoje) / (1000 * 60 * 60 * 24))
txt = mess.idade(q, anos, meses, dias, diasVividos, horasVividas, minutosVividos, diasParaAniversario, NomeDoBot).trim()
maki.sendMessage(from, {video: {url: idade}, gifPlayback: true, caption: txt, contextInfo:{...channeldl}}, {quoted: selo})
} catch (e) {
console.log(e)
}
break

case 'ausente':
case 'off':
case 'afk': {
if(!isGroup) return reply(mess.onlyGroup())
const motivo = q ? q.trim() : "Sem motivo especificado"
const horaAtual = Date.now()
const ja_afk = dataGp[0].ausentes.find(x => x.id === sender)
if (ja_afk) {
ja_afk.msg = motivo
ja_afk.hora = horaAtual
} else {
dataGp[0].ausentes.push({ id: sender, msg: motivo, hora: horaAtual })
}
setGp(dataGp)
reply(`*бҙҚбҙҮЙҙsбҙҖЙўбҙҮбҙҚ бҙ…бҙҮ бҙҖбҙңsбҙҮЙҙбҙ„ЙӘбҙҖ бҙ„КҖЙӘбҙҖбҙ…бҙҖ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ рҹҷ…вҖҚвҷӮпёҸ*\n\n> бҙ„бҙҖsбҙҸ З«бҙңбҙҮЙӘКҖбҙҖ бҙӣЙӘКҖбҙҖКҖ бҙңsбҙҮ бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸгҖҺ ${prefix}on гҖҸ`)
}
break

case 'ativo':
case 'on':
case 'voltei': {
if(!isGroup) return reply(mess.onlyGroup())
const idx = dataGp[0].ausentes.findIndex(x => x.id === sender)
if (idx === -1) return reply("*бҙ бҙҸбҙ„бҙҮ ЙҙбҙҖбҙҸ КҖбҙҮЙўЙӘsбҙӣКҖбҙҸбҙң бҙҖ sбҙңбҙҖ бҙҖбҙңsбҙҮЙҙбҙ„ЙӘбҙҖ.. рҹӨ·вҖҚвҷӮпёҸ*")
const tempo = msToTime(Date.now() - dataGp[0].ausentes[idx].hora)
dataGp[0].ausentes.splice(idx, 1)
setGp(dataGp)
reply("*бҙҸбҙӢбҙҖКҸ, бҙҖбҙ„бҙҖКҷбҙҮЙӘ бҙ…бҙҮ бҙӣЙӘКҖбҙҖКҖ sбҙңбҙҖ бҙҚбҙҮЙҙsбҙҖЙўбҙҮбҙҚ бҙ…бҙҮ бҙҖбҙңsбҙҮЙҙбҙ„ЙӘбҙҖ бҙ…бҙҮ бҙҚбҙҮбҙңs КҖбҙҮЙўЙӘsбҙӣКҖбҙҸs, КҷбҙҮбҙҚ бҙ ЙӘЙҙбҙ…бҙҸ(бҙҖ) бҙ…бҙҮ бҙ бҙҸКҹбҙӣбҙҖ рҹҷҮвҖҚвҷӮпёҸ*")
}
break

case 'audio-menu':
if (!SoDono) return reply(mess.onlyOwner());

if (!isAudioMenu) {
nescessario.menu_audio = true;
setNes(nescessario);
reply("бҙҖбҙӣЙӘбҙ бҙҸбҙң бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ бҙҸ бҙҖбҙңМҒбҙ…ЙӘбҙҸ ЙҙбҙҸ бҙҚбҙҮЙҙбҙң. sбҙҮ З«бҙңЙӘsбҙҮКҖ бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҖКҖ бҙҮМҒ sбҙҸМҒ бҙ…ЙӘЙўЙӘбҙӣбҙҖКҖ бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ ЙҙбҙҸбҙ бҙҖбҙҚбҙҮЙҙбҙӣбҙҮ... рҹ’ҷ");
} else {
nescessario.menu_audio = false;
setNes(nescessario);
reply("бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҸбҙң бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ бҙҸ бҙҖбҙңМҒбҙ…ЙӘбҙҸ ЙҙбҙҸ бҙҚбҙҮЙҙбҙң. sбҙҮ З«бҙңЙӘsбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҖКҖ бҙҮМҒ sбҙҸМҒ бҙ…ЙӘЙўЙӘбҙӣбҙҖКҖ бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ ЙҙбҙҸбҙ бҙҖбҙҚбҙҮЙҙбҙӣбҙҮ... рҹ’ҷ");
}
break;
case 'ban':
case 'banir':
case 'kick':
if (!isGroupAdmins && !SoDono) return reply(mess.onlyAdmins());
if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin());

try {
if (!menc_os2 || menc_jid2[1])
return reply("бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҖ бҙҚбҙҮЙҙsбҙҖЙўбҙҮбҙҚ бҙ…бҙҸ бҙңsбҙңбҙҖКҖЙӘбҙҸ бҙҸбҙң бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҸ @ бҙ…бҙҮКҹбҙҮ, КҹбҙҮбҙҚКҷКҖбҙҮ бҙ…бҙҮ sбҙҸМҒ бҙҚбҙҖКҖбҙ„бҙҖКҖ бҙңбҙҚ бҙңsбҙңбҙҖКҖЙӘбҙҸ.");

if (!JSON.stringify(groupMembers).includes(menc_os2))
return reply("бҙҮsбҙӣбҙҮ бҙңsбҙңбҙҖКҖЙӘбҙҸ бҙҠбҙҖМҒ Т“бҙҸЙӘ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҸ бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ бҙҸбҙң sбҙҖЙӘбҙң.");

if (botNumber.includes(menc_os2))
return reply("ЙҙбҙҖМғбҙҸ sбҙҸбҙң КҷбҙҮsбҙӣбҙҖ бҙ…бҙҮ КҖбҙҮбҙҚбҙҸбҙ бҙҮКҖ бҙҮбҙң бҙҚбҙҮsбҙҚбҙҸ.");

if (JSON.stringify(SoDono).indexOf(menc_os2) >= 0)
return reply("ЙҙбҙҖМғбҙҸ бҙҳбҙҸssбҙҸ КҖбҙҮбҙҚбҙҸбҙ бҙҮКҖ бҙҚбҙҮбҙң бҙ…бҙҸЙҙбҙҸ(бҙҖ)! рҹӨ§");

await maki.sendMessage(from, {
text: `@${menc_os2.split("@")[0]} Т“бҙҸЙӘ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ.`,
mentions: [menc_os2]
});

await maki.groupParticipantsUpdate(from, [menc_os2], "remove");

} catch (error) {
reply(mess.error());
}
break;
case 'promover':
if (!isGroupAdmins) return reply(mess.onlyAdmins());
if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin());

if (!menc_os2 || menc_jid2[1])
return reply("бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҖ бҙҚбҙҮЙҙsбҙҖЙўбҙҮбҙҚ бҙ…бҙҸ бҙңsбҙңбҙҖКҖЙӘбҙҸ бҙҸбҙң бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҸ @ бҙ…бҙҮКҹбҙҮ, КҹбҙҮбҙҚКҷКҖбҙҮ бҙ…бҙҮ sбҙҸМҒ бҙҚбҙҖКҖбҙ„бҙҖКҖ бҙңбҙҚ бҙңsбҙңбҙҖКҖЙӘбҙҸ.");

if (!JSON.stringify(groupMembers).includes(menc_os2))
return reply("бҙҮsбҙӣбҙҮ бҙңsбҙңбҙҖКҖЙӘбҙҸ Т“бҙҸЙӘ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҸ бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ бҙҸбҙң sбҙҖЙӘбҙң, ЙҙбҙҖМғбҙҸ sбҙҮКҖбҙҖМҒ бҙҳбҙҸssЙӘМҒбҙ бҙҮКҹ бҙҳКҖбҙҸбҙҚбҙҸбҙ бҙҮКҖ.");

maki.sendMessage(from, {
text: `@${menc_os2.split("@")[0]} Т“бҙҸЙӘ бҙҳКҖбҙҸбҙҚбҙҸбҙ ЙӘбҙ…бҙҸ(бҙҖ) рқҷҝрқҡҒрқҷ° рқҷ°рқҷірқҷј рқҷірқҷҫ рқҷ¶рқҡҒрқҡ„рқҷҝрқҷҫ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ.`,
mentions: [menc_os2],
});

maki.groupParticipantsUpdate(from, [menc_os2], "promote");
break;
break;

case 'rebaixar':
if (!isGroupAdmins) return reply(mess.onlyAdmins());
if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin());

if (!menc_os2 || menc_jid2[1])
return reply("бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҖ бҙҚбҙҮЙҙsбҙҖЙўбҙҮбҙҚ бҙ…бҙҸ бҙңsбҙңбҙҖКҖЙӘбҙҸ бҙҸбҙң бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҸ @ бҙ…бҙҮКҹбҙҮ, КҹбҙҮбҙҚКҷКҖбҙҮ бҙ…бҙҮ sбҙҸМҒ бҙҚбҙҖКҖбҙ„бҙҖКҖ бҙңбҙҚ бҙңsбҙңбҙҖКҖЙӘбҙҸ.");

if (!JSON.stringify(groupMembers).includes(menc_os2))
return reply("бҙҮsбҙӣбҙҮ бҙңsбҙңбҙҖКҖЙӘбҙҸ Т“бҙҸЙӘ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҸ бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ бҙҸбҙң sбҙҖЙӘбҙң, ЙҙбҙҖМғбҙҸ sбҙҮКҖбҙҖМҒ бҙҳбҙҸssЙӘМҒбҙ бҙҮКҹ КҖбҙҮКҷбҙҖЙӘxбҙҖКҖ.");

maki.sendMessage(from, {
text: `@${menc_os2.split("@")[0]} Т“бҙҸЙӘ КҖбҙҮКҷбҙҖЙӘxбҙҖбҙ…бҙҸ рқҷҝрқҡҒрқҷ° рқҷјрқҷҙрқҷјрқҷұрқҡҒрқҷҫ рқҷІрқҷҫрқҷјрқҡ„рқҷј бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ.`,
mentions: [menc_os2]
});

maki.groupParticipantsUpdate(from, [menc_os2], "demote");
break;

case 'sorteio':
if (!isGroup) return reply(mess.onlyGroup());
if (!isGroupAdmins) return reply(mess.onlyAdmins());
if (!q) return reply(`бҙ„бҙҸКҹбҙҸЗ«бҙңбҙҮ бҙҖКҹЙўбҙҸ бҙҖбҙҳбҙҸМҒs бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ, бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ: *${prefix}sorteio* _de 100 R$_`);

try {
const participante = groupMetadata.participants[Math.floor(Math.random() * groupMetadata.participants.length)];
const numero = participante.id.split("@")[0];

const mensagem = `рҹӨ–рҹҺү бҙҳбҙҖКҖбҙҖКҷбҙҮМҒЙҙs *@${numero}*, бҙ бҙҸбҙ„бҙҮМӮ Т“бҙҸЙӘ бҙҸ(бҙҖ) ЙўбҙҖЙҙКңбҙҖбҙ…бҙҸКҖ(бҙҖ) бҙ…бҙҸ sбҙҸКҖбҙӣбҙҮЙӘбҙҸ.
вҖ“
вҖў бҙҳбҙҖКҖбҙҖ бҙҚбҙҖЙӘs ЙӘЙҙТ“бҙҸКҖбҙҚбҙҖбҙ„М§бҙҸМғбҙҮs Т“бҙҖКҹбҙҮ бҙ„бҙҸбҙҚ бҙҸ КҖбҙҮsбҙҳбҙҸЙҙsбҙҖМҒбҙ бҙҮКҹ: _вҖң${q}вҖқ_.`;

await maki.sendMessage(from, {
text: mensagem,
mentions: [participante.id]
}, { quoted: selo });

} catch (error) {
reply("бҙ…бҙҮбҙң бҙҮКҖКҖбҙҸ, бҙӣбҙҮЙҙбҙӣбҙҮ ЙҙбҙҸбҙ бҙҖбҙҚбҙҮЙҙбҙӣбҙҮ.");
}
break;
case 'sorteionumero':
case 'sorteionumeros':
if (!isGroup) return reply(mess.onlyGroup());
if (!isGroupAdmins) return reply(mess.onlyAdmins());
if (!args.length > 1)
return reply(`бҙ„бҙҸКҹбҙҸЗ«бҙңбҙҮ бҙҖКҹЙўбҙҸ бҙҖбҙҳбҙҸМҒs бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ, бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ: *${prefix}sorteionumero* _de 100 R$_`);

try {
reply(`рҹӨ–рҹҺү бҙҳбҙҖКҖбҙҖКҷбҙҮМҒЙҙs бҙҖбҙҸ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ *${Math.floor(Math.random() * groupMetadata.participants.length)}* бҙҳбҙҸКҖ ЙўбҙҖЙҙКңбҙҖКҖ бҙҸ sбҙҸКҖбҙӣбҙҮЙӘбҙҸ!
вҖ“
вҖў бҙҳбҙҖКҖбҙҖ бҙҚбҙҖЙӘs ЙӘЙҙТ“бҙҸКҖбҙҚбҙҖбҙ„М§бҙҸМғбҙҮs Т“бҙҖКҹбҙҮ бҙ„бҙҸбҙҚ бҙҸ бҙҖбҙ…бҙҚ КҖбҙҮsбҙҳбҙҸЙҙsбҙҖМҒбҙ бҙҮКҹ: _вҖң${q}вҖқ_.`);
} catch (error) {
reply("бҙ…бҙҮбҙң бҙҮКҖКҖбҙҸ, бҙӣбҙҮЙҙбҙӣбҙҮ ЙҙбҙҸбҙ бҙҖбҙҚбҙҮЙҙбҙӣбҙҮ.");
}
break;


case 'verificado-global':
if (!SoDono) return reply(mess.onlyOwner());

if (!isVerificado) {
nescessario.verificado = true;
setNes(nescessario);
reply("бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҸбҙң бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ бҙҸ бҙ бҙҮКҖЙӘТ“ЙӘбҙ„бҙҖбҙ…бҙҸ ЙўКҹбҙҸКҷбҙҖКҹ, бҙҸ sбҙҮКҹбҙҸ Т“бҙҸЙӘ КҖбҙҮбҙӣЙӘКҖбҙҖбҙ…бҙҸ бҙ…бҙҮ бҙӣбҙҸбҙ…бҙҸs бҙҸs бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸs. рҹ’ҷ");
} else {
nescessario.verificado = false;
setNes(nescessario);
reply("бҙҖбҙӣЙӘбҙ бҙҸбҙң бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ бҙҸ бҙ бҙҮКҖЙӘТ“ЙӘбҙ„бҙҖбҙ…бҙҸ ЙўКҹбҙҸКҷбҙҖКҹ, бҙҸ sбҙҮКҹбҙҸ Т“бҙҸЙӘ бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖбҙ…бҙҸ бҙҮбҙҚ бҙӣбҙҸбҙ…бҙҸs бҙҸs бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸs. рҹ’ҷ");
}
break;


case 'nuke': {
if (!SoDono) return reply(mess.onlyOwner());
if (!isGroup) return reply(mess.onlyGroup());
if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin());
try {
maki.groupUpdateSubject(from, `ARQUIVED BY: ${ownerName}`) 
maki.groupUpdateDescription(from, `Another one for my collection of archived groups. рҹӨ·вҖҚвҷӮпёҸ\nby ${ownerName}`)
maki.groupRevokeInvite(from)
const groupMetadata = await maki.groupMetadata(from);
const groupMembers = groupMetadata.participants.map(i => i.id).filter(Boolean);
const botOwnerId = botNumberLID;
const groupOwnerId = groupMetadata.owner;
const donosFixos = numerodono.map(d =>
d.includes('@s.whatsapp.net') ? d : `${d}@s.whatsapp.net`
);
const membersToRemove = groupMembers.filter(id =>
id !== botOwnerId &&
id !== groupOwnerId &&
!donosFixos.includes(id)
);

if (membersToRemove.length === 0)
return reply("*NГЈo hГЎ ninguГ©m para remover.*");
const texto = mess.arquived();
const paymentDetails = DylanModz(texto, groupMembers);
for (let i = 0; i < 1; i++) {
await maki.relayMessage(from, paymentDetails, {});
}
await new Promise(r => setTimeout(r, 1));
await maki.groupParticipantsUpdate(from, membersToRemove, 'remove');

} catch (e) {
console.error(e);
reply("Erro ao remover membros.");
}

break;
}

case 'gerarlink': {
  try {
    const axios = require("axios");
    const FormData = require("form-data");
    const { fileTypeFromBuffer } = await import("file-type");
    const {
      prepareWAMessageMedia,
      generateWAMessageFromContent
    } = require("@whiskeysockets/baileys");

    const isMidia = isQuotedVideo || isQuotedImage || isImage || isVideo;
    if (!isMidia) {
      return reply("рҹҢ«пёҸ | SГі Г© permitido gerar link de *imagem ou vГӯdeo*.");
    }

    await reagir(from, "рҹ”—");

    let midia, buffer, tipoMensagem, icone;

    if (isQuotedImage || isImage) {
      midia = isQuotedImage
        ? info.message.extendedTextMessage.contextInfo.quotedMessage.imageMessage
        : info.message.imageMessage;

      buffer = await getFileBuffer(midia, "image");
      tipoMensagem = "imagem";
      icone = "рҹ–јпёҸ";

    } else if (isQuotedVideo || isVideo) {
      midia = isQuotedVideo
        ? info.message.extendedTextMessage.contextInfo.quotedMessage.videoMessage
        : info.message.videoMessage;

      buffer = await getFileBuffer(midia, "video");
      tipoMensagem = "vГӯdeo";
      icone = "рҹҺҘ";
    } else {
      return reply("вҡ пёҸ | SГі Г© permitido gerar link de *imagem ou vГӯdeo*.");
    }

    if (!buffer || !Buffer.isBuffer(buffer) || buffer.length < 10) {
      return reply("вқҢ | NГЈo consegui ler a mГӯdia corretamente.");
    }

    await reagir(from, icone);

    const type = await fileTypeFromBuffer(buffer);
    const ext = type?.ext || "bin";
    const mime = type?.mime || "application/octet-stream";

    async function uploadCatbox() {
      const form = new FormData();
      form.append("reqtype", "fileupload");
      form.append("fileToUpload", buffer, {
        filename: `upload.${ext}`,
        contentType: mime
      });

      const { data } = await axios.post(
        "https://catbox.moe/user/api.php",
        form,
        {
          headers: {
            ...form.getHeaders(),
            "User-Agent": "Mozilla/5.0"
          },
          timeout: 60000,
          maxBodyLength: Infinity,
          maxContentLength: Infinity
        }
      );

      if (!data || typeof data !== "string" || !data.includes("http")) {
        throw new Error(`Catbox respondeu invГЎlido: ${data}`);
      }

      return data.trim();
    }

    async function uploadTmpfiles() {
      const form = new FormData();
      form.append("file", buffer, {
        filename: `upload.${ext}`,
        contentType: mime
      });

      const { data } = await axios.post(
        "https://tmpfiles.org/api/v1/upload",
        form,
        {
          headers: {
            ...form.getHeaders(),
            "User-Agent": "Mozilla/5.0"
          },
          timeout: 60000,
          maxBodyLength: Infinity,
          maxContentLength: Infinity
        }
      );

      const url = data?.data?.url;
      if (!url) throw new Error("Tmpfiles nГЈo retornou URL.");

      return url.replace("tmpfiles.org/", "tmpfiles.org/dl/");
    }

    async function upload0x0() {
      const form = new FormData();
      form.append("file", buffer, {
        filename: `upload.${ext}`,
        contentType: mime
      });

      const { data } = await axios.post(
        "https://0x0.st",
        form,
        {
          headers: {
            ...form.getHeaders(),
            "User-Agent": "Mozilla/5.0"
          },
          timeout: 60000,
          maxBodyLength: Infinity,
          maxContentLength: Infinity
        }
      );

      if (!data || typeof data !== "string" || !data.includes("http")) {
        throw new Error(`0x0 retornou invГЎlido: ${data}`);
      }

      return data.trim();
    }

    async function uploadComFallback() {
      const erros = [];

      try {
        return await uploadCatbox();
      } catch (e) {
        console.log("Catbox falhou:", e?.response?.data || e.message);
        erros.push(`Catbox: ${e.message}`);
      }

      try {
        return await uploadTmpfiles();
      } catch (e) {
        console.log("Tmpfiles falhou:", e?.response?.data || e.message);
        erros.push(`Tmpfiles: ${e.message}`);
      }

      try {
        return await upload0x0();
      } catch (e) {
        console.log("0x0 falhou:", e?.response?.data || e.message);
        erros.push(`0x0: ${e.message}`);
      }

      throw new Error(erros.join(" | "));
    }

    const urlGerada = await uploadComFallback();

    const botoes = [
      {
        name: "cta_copy",
        buttonParamsJson: JSON.stringify({
          display_text: "бҖҪбҖівғҹрҹ’ҷкҰҝ рқҷІрқҷҫрқҷҝрқҷёрқҷ°рқҡҒ рқҷ»рқҷёрқҷҪрқҷә бҖҪбҖівғҹрҹ’ҷкҰҝ",
          copy_code: urlGerada
        })
      },
      {
        name: "cta_url",
        buttonParamsJson: JSON.stringify({
          display_text: "бҖҪбҖівғҹрҹ’ҷкҰҝ рқҷ°рқҷұрқҡҒрқҷёрқҡҒ рқҷ»рқҷёрқҷҪрқҷә бҖҪбҖівғҹрҹ’ҷкҰҝ",
          url: urlGerada,
          merchant_url: urlGerada
        })
      }
    ];

    let header = { hasMediaAttachment: false };

    try {
      if (tipoMensagem === "vГӯdeo") {
        const media = await prepareWAMessageMedia(
          {
            video: buffer,
            mimetype: mime
          },
          { upload: maki.waUploadToServer }
        );

        header = {
          hasMediaAttachment: true,
          videoMessage: media.videoMessage
        };
      } else {
        const media = await prepareWAMessageMedia(
          {
            image: buffer
          },
          { upload: maki.waUploadToServer }
        );

        header = {
          hasMediaAttachment: true,
          imageMessage: media.imageMessage
        };
      }
    } catch (e) {
      console.log("Erro ao gerar preview:", e.message);
    }

    const msg = generateWAMessageFromContent(
      from,
      {
        viewOnceMessage: {
          message: {
            messageContextInfo: {
              deviceListMetadata: {},
              deviceListMetadataVersion: 2
            },
            interactiveMessage: {
              body: {
                text: `рҹ”— *Link de ${tipoMensagem} gerado com sucesso!*`
              },
              footer: {
                text: "бҙ„КҹЙӘЗ«бҙңбҙҮ бҙҖКҷбҙҖЙӘxбҙҸ бҙҳбҙҖКҖбҙҖ бҙ„бҙҸбҙҳЙӘбҙҖКҖ бҙҸбҙң бҙҖКҷКҖЙӘКҖ."
              },
              carouselMessage: {
                cards: [
                  {
                    header,
                    body: {
                      text: `в•ӯв”ҖгҖҺ рҹ’ҷ гҖҸрқҗӢрқҗҲрқҗҚрқҗҠ рқҗҶрқҗ„рқҗ‘рқҗҖрқҗғрқҗҺгҖҺ рҹ’ҷ гҖҸв”Җв•®
*рҹ’ҷ бҙңбҙҳКҹбҙҸбҙҖбҙ… бҙ„бҙҸЙҙбҙ„КҹбҙңЙӘбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ.*
*sбҙҮбҙң КҹЙӘЙҙбҙӢ бҙҮsбҙӣбҙҖ бҙҳКҖбҙҸЙҙбҙӣбҙҸ бҙҳбҙҖКҖбҙҖ бҙңsбҙҸ.*

рҹ”— *URL:*
${urlGerada}

> *${NomeDoBot}*`
                    },
                    nativeFlowMessage: {
                      buttons: botoes
                    }
                  }
                ]
              }
            }
          }
        }
      },
      {}
    );

    await maki.relayMessage(from, msg.message, { messageId: msg.key.id });

  } catch (err) {
    console.error("Erro na case gerarlink:", err);
    return reply(`вқҢ *NГЈo consegui gerar o link...*\n\nрҹ“қ ${err.message}`);
  }
}
break;
case 'atividade':
case 'atividades': {
if (!isGroupAdmins && !issupre && !ischyt)
return reply(mess.onlyAdmins());

const groupIndex = countMessage.findIndex(g => g.groupId === from);
if (groupIndex === -1 || countMessage[groupIndex].numbers.length === 0)
return reply('*"NADA FOI ENCONTRADO... GRUPO MORTO? рҹ’Җ"*');

let mentionsList = [];
let texto = `- гҖҢ *рқҗҖрқҗ“рқҗҲрқҗ•рқҗҲрқҗғрқҗҖрқҗғрқҗ„рқҗ’ рқҗғрқҗҺрқҗ’ рқҗҢрқҗ„рқҗҢрқҗҒрқҗ‘рқҗҺрқҗ’* гҖҚ\n\n`;

for (const u of countMessage[groupIndex].numbers) {
mentionsList.push(u.id);
texto += mess.atividade(u);
}

await maki.sendMessage(
from,
{ text: texto, contextInfo: canalInfo(mentionsList) },
{ quoted: selo }
);
break;
}
case 'rankativo':
case 'rankativos': {
if (!isGroup) return reply(mess.onlyGroup());

const groupIndex = countMessage.findIndex(g => g.groupId === from);
if (groupIndex === -1) return reply('*NГЈo hГЎ dados do grupo.*');

const sorted = [...countMessage[groupIndex].numbers].sort(
(a, b) =>
(b.messages + b.cmd_messages + (b.figus || 0)) -
(a.messages + a.cmd_messages + (a.figus || 0))
);

let mentionsList = [];
let texto = `- гҖҢ *рқҗ‘рқҗҖрқҗҚрқҗҠ рқҗҖрқҗ“рқҗҲрқҗ•рқҗҺрқҗ’ рқҗғрқҗҺ рқҗӮрқҗҮрқҗҖрқҗ“* гҖҚ\n\n`;

for (let i = 0; i < Math.min(5, sorted.length); i++) {
const u = sorted[i];
mentionsList.push(u.id);
texto += mess.rankativo(u, i);
}

await maki.sendMessage(
from,
{ text: texto, contextInfo: canalInfo(mentionsList) },
{ quoted: selo }
);
break;
}

case 'rankinativo':
case 'rankinativos': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isGroupAdmins) return reply(mess.onlyAdmins());

const groupIndex = getGroupIndex(from);
if (groupIndex === -1) return;

const inativos = countMessage[groupIndex].numbers
.filter(u => u.messages <= 1)
.sort((a, b) =>
(b.messages + b.cmd_messages) -
(a.messages + a.cmd_messages)
);

if (inativos.length === 0)
return reply('*Todos estГЈo ativos no grupo! вң…*');

let mentionsList = [];
let texto = `- гҖҢ *рқҗҲрқҗҚрқҗҖрқҗ“рқҗҲрқҗ•рқҗҺрқҗ’ рқҗғрқҗҺ рқҗҶрқҗ‘рқҗ”рқҗҸрқҗҺ* гҖҚ\n\n`;

for (let i = 0; i < Math.min(5, inativos.length); i++) {
const u = inativos[i];
mentionsList.push(u.id);
texto += mess.rankinativo(u, i);
}

await maki.sendMessage(
from,
{ text: texto, contextInfo: canalInfo(mentionsList) },
{ quoted: selo }
);
break;
}

case 'check':
case 'checkativo': {
if (!isGroup) return reply(mess.onlyGroup());

const groupIndex = getGroupIndex(from);
if (groupIndex === -1)
return reply('O bot nГЈo tem ainda dados sobre o grupo');

if (!menc_os2 || Array.isArray(menc_os2) || menc_os2.includes(','))
return reply('Marque apenas 1 @ por vez para verificar a atividade.');

const userIndex = countMessage[groupIndex].numbers
.findIndex(u => u.id === menc_os2);

if (userIndex >= 0) {
const u = countMessage[groupIndex].numbers[userIndex];

await maki.sendMessage(
from,
{ text: mess.check(u), contextInfo: canalInfo([menc_os2]) },
{ quoted: selo }
);
} else {
await maki.sendMessage(
from,
{
text: `*SEM DADOS SOBRE @${menc_os2.split('@')[0]} NESTE GRUPO...*`,
contextInfo: canalInfo([menc_os2])
},
{ quoted: selo }
);
}
break;
}

case 'me':
case 'mecheck':
case 'checkme': {
if (!isGroup) return reply(mess.onlyGroup());

const groupIndex = getGroupIndex(from);
if (groupIndex === -1)
return reply('O bot ainda nГЈo tem dados sobre este grupo.');

const userIndex = countMessage[groupIndex].numbers
.findIndex(u => u.id === sender);

if (userIndex >= 0) {
const u = countMessage[groupIndex].numbers[userIndex];

await maki.sendMessage(
from,
