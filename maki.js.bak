let legenda = `рҹҺү рқ‘«рқ‘Ёрқ‘«рқ‘¶рқ‘ә рқ‘«рқ‘¶ рқ‘·рқ‘¬рқ‘№рқ‘ӯрқ‘°рқ‘і рҹҺү

рҹ‘Ө ЙҙЙӘбҙ„бҙӢ: ${user}
рҹ“ұ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ: ${numeroUser}
рҹ—’пёҸ КҷЙӘбҙҸ: ${recado}
рҹ’Һ бҙ ЙӘбҙҳ: (${vipStatus ? "Sim" : "NГЈo"}) ${isChVip}
рҹ§° бҙ„бҙҖКҖЙўбҙҸ: ${isCargo}
рҹҸҳпёҸ ЙўКҖбҙңбҙҳбҙҸ: ${NomeGrupo}

рҹ“Ҡ рқҗҖЙҙбҙҖМҒКҹЙӘsбҙҮ бҙ…бҙҸ бҙҳбҙҮКҖкң°ЙӘКҹ

рҹҗӮ ЙҙЙӘбҙ бҙҮКҹ ЙўбҙҖбҙ…бҙҸ: ${levelGado}
рҹҳӢ ЙўбҙҸкңұбҙӣбҙҸкңұбҙңКҖбҙҖ: ${levelGostosura}
рҹҸіпёҸвҖҚрҹҢҲ ЙўбҙҖКҸ: ${gay}
рҹ”һ бҙҳбҙңбҙӣбҙҖКҖЙӘбҙҖ: ${puta}
рҹ’° бҙҳКҖбҙҸЙўКҖбҙҖбҙҚбҙҖ: ${valorPrograma}

рҹҢ«пёҸ *Conselho do Dia:*
_"espera, nГЈo pare ainda, ainda vai piorar mais do que jГЎ tГЎ agora_"

> ${NomeDoBot}`;

await maki.sendMessage(
