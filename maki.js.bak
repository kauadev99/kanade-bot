case 'play': {
try {
if (!q || !q.trim())
return reply(`вқҢ Exemplo: ${prefix + command} nome da mГәsica`);

const yts = require("yt-search");

// рҹ’ҷ REAГҮГғO
await reagir(from, "рҹҺ§");

// рҹ’ҷ FRASES DE CARREGAMENTO
const frases = [
"рҹҺ§ Kanade estГЎ buscando sua mГәsica...",
"рҹ’ҷ Conectando ao mundo musical...",
"рҹҺ¶ Preparando sua melodia...",
"вҡЎ Carregando frequГӘncia sonora...",
"рҹ’« Sincronizando com YouTube...",
"рҹҺј Afinando notas perfeitas..."
];

const fraseRandom = frases[Math.floor(Math.random() * frases.length)];

await reply(`в•ӯв”Ғв”Ғв”ҒгҖ” рҹ’ҷ KANADE PLAYER рҹ’ҷ гҖ•в”Ғв”Ғв”Ғв¬Ј
в”ғ ${fraseRandom}
в•°в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв¬Ј`);

// рҹ”Һ BUSCA
const search = await yts(q);

if (!search || !search.videos || search.videos.length === 0)
return reply("вқҢ NГЈo encontrei resultados.");

const video = search.videos[0];

const title = video.title;
const channel = video.author.name;
const duration = video.timestamp;
const thumbnail = video.thumbnail;
const url = video.url;
const views = video.views.toLocaleString();
const ago = video.ago || "Desconhecido";

// рҹ’ҷ CARD API
const card =
API_URL + `/canvas/musicard2` +
`?nome=${encodeURIComponent(title)}` +
`&autor=${encodeURIComponent(channel)}` +
`&logo=${encodeURIComponent(thumbnail)}` +
`&thumb=${encodeURIComponent(thumbnail)}` +
`&end=${encodeURIComponent(duration)}` +
`&apikey=` + API_KEY_TOKITO;

// рҹ’ҷ INFORMAГҮГ•ES BONITAS
const corpoCard =
`рҹҺ§ MГәsica pronta!
вҸұпёҸ ${duration}
рҹ‘ҒпёҸ ${views} views
рҹ‘Ө ${channel}
рҹ“… ${ago}`;

// рҹ’ҷ FRASE FINAL
const fraseFinal = `
в•ӯв”Ғв”Ғв”ҒгҖ” рҹ’ҷDOWNLOAD CONCLUГҚDA рҹ’ҷ гҖ•в”Ғв”Ғв”Ғв¬Ј
в”ғ рҹҺ¶ ${title}
в”ғ рҹ‘Ө ${channel}
в”ғ вҸұпёҸ ${duration}
в”ғ рҹ‘ҒпёҸ ${views}
в•°в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв¬Ј
рҹ’ҷ Aproveite sua mГәsica com a Kanade вңЁ
`;

// рҹ”Ҡ URL ГҒUDIO
let audioUrl =
API_URL + `/api/youtube-audio?q=${encodeURIComponent(url)}&apikey=` + API_KEY_TOKITO;

try {

// рҹ’ҷ ENVIO DO ГҒUDIO
await maki.sendMessage(
from, {
audio: { url: audioUrl },
mimetype: 'audio/mpeg',
ptt: false,
contextInfo: {
externalAdReply: {
title: title,
body: corpoCard,
thumbnailUrl: card,
mediaType: 1,
renderLargerThumbnail: true,
showAdAttribution: false,
sourceUrl: "https://tokito-apis.site",
mediaUrl: url
},
isForwarded: true,
forwardedNewsletterMessageInfo: {
newsletterJid: setting.channeldl,
newsletterName: NomeDoBot,
serverMessageId: -1
}
}
}, { quoted: selo }
);

// рҹ’ҷ MENSAGEM FINAL
await reply(fraseFinal);

} catch (err) {

// рҹ”Ғ FALLBACK
audioUrl = API_URL + `/api/youtube-audio?q=${encodeURIComponent(`${title} ${channel}`)}&apikey=` + API_KEY_TOKITO;

await maki.sendMessage(
from, {
audio: { url: audioUrl },
mimetype: 'audio/mpeg',
ptt: false,
contextInfo: {
externalAdReply: {
title: title,
body: corpoCard,
thumbnailUrl: card,
mediaType: 1,
renderLargerThumbnail: true,
showAdAttribution: false,
sourceUrl: "https://tokito-apis.site",
mediaUrl: url
},
isForwarded: true,
forwardedNewsletterMessageInfo: {
newsletterJid: setting.channeldl,
newsletterName: NomeDoBot,
serverMessageId: -1
}
}
}, { quoted: selo }
);

// рҹ’ҷ fallback msg
await reply(`рҹ’ҷ Kanade conseguiu recuperar sua mГәsica mesmo com falha вңЁ`);

}

} catch (e) {
console.log(e);
reply("вқҢ Erro ao buscar o ГЎudio.");
}
}
break;



