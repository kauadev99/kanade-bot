                title: "вҡҷпёҸ рқҗ…рқҗ”рқҗҚрқҗӮМ§рқҗҺМғрқҗ„рқҗ’ рқҗғрқҗ„ рқҗҸрқҗ‘рқҗҺрқҗ“рқҗ„рқҗӮМ§рқҗҖМғрқҗҺ вҡҷпёҸ",
                highlight_label: "рқҷҪрқҷ°рқҷ»рқҷірқҷҫ",
                rows: [
                    { header: "рҹ”— Anti Link", title: "Ativar/Desativar Anti Link", id: prefix + "anti_link" },
                    { header: "рҹ’Ҙ Anti Flood", title: "Ativar/Desativar Anti Flood", id: prefix + "anti_flood" },
                    { header: "рҹҡ« Anti Spam", title: "Ativar/Desativar Anti Spam", id: prefix + "anti_spam" },
                    { header: "рҹ–јпёҸ Anti Imagem", title: "Ativar/Desativar Anti Imagem", id: prefix + "anti_img" },
                    { header: "рҹ“Һ Anti Arquivo", title: "Ativar/Desativar Anti Arquivo", id: prefix + "anti_file" }
                ]
            }
        ]
    };

    const botoes = [{
        name: "single_select",
        buttonParamsJson: JSON.stringify(listaMenus)
    }];

    const textok = `в•ӯв”Җрҹ’ҷ рқҗҢрқҗ„рқҗҚрқҗ” рқҗҸрқҗ‘рқҗҺрқҗ“рқҗ„рқҗӮМ§рқҗҖМғрқҗҺ рҹ’ҷ
в”ғ р–Өҗ рқҷҪрқҷҫрқҷјрқҷҙ: ${NomeDoBot}
в”ғ р–Өҗ рқҡ„рқҡӮрқҷҙрқҡҒ: ${pushname}
в”ғ р–Өҗ рқҷҝрқҡҒрқҷҙрқҷөрқҷёрқҡҮрқҷҫ: [ ${prefix} ]
в•°в”Җрҹ’ҷ бҙҮsбҙ„бҙҸКҹКңбҙҖ бҙңбҙҚбҙҖ бҙҳКҖбҙҸбҙӣбҙҮбҙ„М§бҙҖМғбҙҸ бҙҖбҙӣЙӘбҙ бҙҖКҖ`;

    const carouselMessage = {
        cards: [{
            header: { hasMediaAttachment: false },
            headerType: "TEXT",
            body: { text: textok },
            footer: { text: "бҙҮsбҙ„бҙҸКҹКңбҙҖ бҙҖ бҙҸбҙҳГ§ГЈбҙҸ бҙҖКҷбҙҖЙӘxбҙҸ" },
            nativeFlowMessage: { buttons: botoes }
        }]
    };

    const msg = generateWAMessageFromContent(from, {
        interactiveMessage: {
            contextInfo: {
                participant: sender,
                quotedMessage: {
                    conversation: "в–‘вғҹвғӣрҹ’ҷ бҙҖЗ«бҙңЙӘ бҙҮsбҙӣбҙҖ sбҙҮбҙң бҙҚбҙҮЙҙбҙң в–‘вғҹвғӣрҹ’ҷ"
                }
            },
            body: { text: "*рҹ’ҷ бҙҚбҙҮЙҙбҙң Т“бҙңКҖЙӘЙҙбҙҖ бҙ в…қ рҹ’ҷ*" },
            carouselMessage
        }
    }, {});

    await maki.relayMessage(from, msg.message, { messageId: msg.key.id });

} catch (error) {
    console.error("Erro menu:", error);
    await maki.sendMessage(from, { text: mess.error() }, { quoted: selo });
}
break;
}

