if (invalidos.length)resp += `\n*ЙӘЙҙбҙ бҙҖКҹЙӘбҙ…бҙҸs: ${invalidos.join(', ')} вқ—*`;
await maki.sendMessage(from,{text: resp, contextInfo: { ...channeldl, mentionedJid: [alvo]}}, { quoted: selo });
break;
}


