case 'spotify':
case 'sp': {
if (!q) return reply(
`рҹҺ§ *кңұбҙҳбҙҸбҙӣЙӘкң°КҸ*\n\n` +
`Envie apenas um link do Spotify.\n\n` +
`рҹ“Ң Exemplo:\n${prefix + command} https://open.spotify.com/track/...`
);

const isSpotifyLink = /^https?:\/\/open\.spotify\.com\/(track|album)\/[a-zA-Z0-9]+/i.test(q.trim());
if (!isSpotifyLink)
return reply('*вқҢ URL invГЎlida: envie apenas o link do Spotify*');

try {

await reagir(from, "рҹҺ§");

// рҹ”Ҡ URL da API
const audioUrl =
API_URL +
`/api/spotify?url=${encodeURIComponent(q.trim())}` +
`&download=true` +
`&proxy=true` +
`&apikey=` + API_KEY_TOKITO;
const response = await axios.get(audioUrl, {
responseType: "arraybuffer",
timeout: 60000
});
const contentType = response.headers["content-type"] || "";
if (!contentType.includes("audio")) {
return reply("вқҢ Erro: a API nГЈo retornou ГЎudio vГЎlido.");
}
await maki.sendMessage(
from,
{
audio: Buffer.from(response.data),
mimetype: "audio/mpeg",
ptt: false
},
{ quoted: info }
);

} catch (err) {
console.log("Erro Spotify:", err?.response?.data || err.message);
reply("вқҢ Erro ao processar Spotify.");
}
}
break;


