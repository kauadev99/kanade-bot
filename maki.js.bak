newsletterName: `${NomeDoBot}`,
serverMessageId: "",
},...channeldl
},
}, { quoted: selo });
}
}

async function verificarVipExpirado(maki) {
let alterou = false;
const agora = Date.now();

for (let i = vip.length - 1; i >= 0; i--) {
const v = vip[i];

if (v.infinito) continue;

const duracaoMs = v.dias * 24 * 60 * 60 * 1000;
const expiraEm = v.inicio + duracaoMs;

if (agora >= expiraEm) {
vip.splice(i, 1);
alterou = true;

await maki.sendMessage(v.id, {
text:
`рҹ’ҷвңЁ *бҙ ЙӘбҙҳ бҙҮxбҙҳЙӘКҖбҙҖбҙ…бҙҸ* вңЁрҹ’ҷ
рҹ‘Ө @${v.id.split("@")[0]} вҖ” *sбҙҮбҙң бҙҳбҙҮКҖЙӘМҒбҙҸбҙ…бҙҸ бҙ ЙӘбҙҳ Т“бҙҸЙӘ Т“ЙӘЙҙбҙҖКҹЙӘбҙўбҙҖбҙ…бҙҸ.*
вҸі *бҙҖЙўКҖбҙҖбҙ…бҙҮбҙ„бҙҮбҙҚбҙҸs бҙҳбҙҸКҖ бҙӣбҙҮКҖ Т“бҙҖбҙўЙӘбҙ…бҙҸ бҙҳбҙҖКҖбҙӣбҙҮ бҙ…бҙҖ ЙҙбҙҸssбҙҖ бҙ„бҙҸбҙҚбҙңЙҙЙӘбҙ…бҙҖбҙ…бҙҮ.*
рҹ’ӯ *sбҙҮбҙҠбҙҖ sбҙҮбҙҚбҙҳКҖбҙҮ КҷбҙҮбҙҚ-бҙ ЙӘЙҙбҙ…бҙҸ бҙҳбҙҖКҖбҙҖ КҖбҙҮбҙӣбҙҸКҖЙҙбҙҖКҖ.*
рҹ’ҷ *бҙҳбҙҖКҖбҙҖ КҖбҙҮбҙҖбҙӣЙӘбҙ бҙҖКҖ, Т“бҙҖКҹбҙҮ бҙ„бҙҸбҙҚ бҙҸ бҙҖбҙ…бҙҚЙӘЙҙ.*`,
mentions: [v.id]
});
}
}

if (alterou) {
fs.writeFileSync(
'./arquivos/database/usuarios/vip.json',
JSON.stringify(vip, null, 2)
);
}
}

//====================вү вү ===============\\

const largeNumber = (value) => {
if (Number(value) < 0) return "O nГәmero precisa ser вүҘ 0";
nmr = `${Number(value).toFixed(0)}`;
if (nmr.length >= 4) {
const existPoint = (nmr) => {
if (Number(nmr) !== 0) return "." + `${nmr}`;
return ``;
};
if (nmr.length >= 4)
txt =
nmr.slice(0, nmr.length - 3) +
existPoint(nmr.slice(nmr.length - 3, nmr.length - 2)) +
"K";
if (nmr.length >= 7)
txt =
nmr.slice(0, nmr.length - 6) +
existPoint(nmr.slice(nmr.length - 6, nmr.length - 5)) +
"M";
if (nmr.length >= 10)
txt =
nmr.slice(0, nmr.length - 9) +
existPoint(nmr.slice(nmr.length - 9, nmr.length - 8)) +
"B";
if (nmr.length >= 13)
txt =
nmr.slice(0, nmr.length - 12) +
existPoint(nmr.slice(nmr.length - 12, nmr.length - 11)) +
"T";
} else {
txt = nmr;
}
return txt;
};

