вҖ” "бҙҮ sбҙҮ бҙӣбҙңбҙ…бҙҸ бҙҖбҙ„бҙҖКҷбҙҖssбҙҮ бҙҖЙўбҙҸКҖбҙҖ? бҙҸ З«бҙңбҙҮ бҙ бҙҸбҙ„ГӘ Т“бҙҖКҖЙӘбҙҖ?"
вҖў
- *${NomeDoBot} вҖ” бҙңбҙҚ КҷбҙҸбҙӣ бҙ„КҖЙӘбҙҖбҙ…бҙҸ бҙҳбҙҖКҖбҙҖ бҙҮЙҙбҙӣКҖбҙҮЙўбҙҖКҖ КҖбҙҖбҙҳЙӘбҙ…бҙҮбҙў, бҙ…бҙҮsбҙҮбҙҚбҙҮЙҙКңбҙҸ бҙҮ бҙ„бҙҸЙҙТ“ЙӘбҙҖКҷЙӘКҹЙӘбҙ…бҙҖбҙ…бҙҮ. бҙҮsбҙҳбҙҮКҖбҙҸ З«бҙңбҙҮ бҙ бҙҸбҙ„ГӘ ЙўбҙҸsбҙӣбҙҮ бҙ…бҙҸ бҙҚбҙҮбҙң бҙӣКҖбҙҖКҷбҙҖКҹКңбҙҸ. рҹҘҮ*
вҖў
> ${NomeDoBot}`,
contextInfo: {
mentionedJid: [sender],
isForwarded: true,
forwardingScore: 1,
forwardedNewsletterMessageInfo: {
newsletterJid: setting.channeldl,
newsletterName: NomeDoBot,
serverMessageId: ""
}
}
},
{ quoted: selo }
);

} catch (e) {
console.error("Erro na case criador:", e);
await maki.sendMessage(from, { text: mess.error() }, { quoted: selo });
}
break;
//==========[ CASES N-COINS ]============\\

// Case para mostrar saldo e estatГӯsticas
case 'coins': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ З«бҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘsбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const usuario = RG_SCOINS[ID_G_COINS]?.usus[ID_USU_COINS] || {
coins: 0,
chances: { minerar: 0, cassino: 0 },
};

await maki.sendMessage(from, {
text:
`вҶі ${tempo} вҶқ @${sender.split("@")[0]} вҶҙ

в•ӯв”Җв¬Ј гҖҺ рҹҸҰ рқ—•рқ—”рқ—Ўрқ—–рқ—ў рқ——рқ—ҳ рқ—–рқ—ўрқ—ңрқ—Ўрқ—Ұ рқ— рқ—”рқ—һрқ—ң гҖҸ
в”Ӯ
в”Ӯ рҹ’° рқ—Ұрқ—®рқ—№рқ—ұрқ—ј рқ—”рқҳҒрқҳӮрқ—®рқ—№
в”Ӯ вһҘ ${usuario.coins} N-Coins
в”Ӯ
в”Ӯ вӣҸпёҸ рқ— рқ—¶рқ—»рқ—Ірқ—ҝрқ—®рқ—°М§рқ—®Мғрқ—ј
в”Ӯ вһҘ ${usuario.chances.minerar}/6 tentativas
в”Ӯ
в”Ӯ рҹҺ° рқ—–рқ—®рқҳҖрқҳҖрқ—¶рқ—»рқ—ј
в”Ӯ вһҘ ${usuario.chances.cassino}/5 tentativas
в”Ӯ
в•°в”Җв¬Ј гҖҺ рҹ“Ҡ рқ—ҳрқҳҖрқҳҒрқ—®рқҳҒрқ—¶МҒрқҳҖрқҳҒрқ—¶рқ—°рқ—®рқҳҖ рқ—ұрқ—ј рқ—ЁрқҳҖрқҳӮрқ—®МҒрқ—ҝрқ—¶рқ—ј гҖҸ
`,
mentions: [sender] // рҹ”Ҙ ISSO faz aparecer @usuario
}, { quoted: selo });

break;
}

// Case para sorteio de N-Coins
case 'sorteiocoins':
case 'sortcoins': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);
if (!SoDono) return reply(mess.onlyOwner());
if (q.match(/[a-z]/i))
return reply("пёҸпёҸрҹҳӯрҹҢҹ Por favor, insira um valor numГ©rico vГЎlido para sortear.");

const participantes = RG_SCOINS[ID_G_COINS]?.usus || [];
if (participantes.length === 0)
return reply("NГЈo hГЎ usuГЎrios registrados no sistema para o sorteio.");

const randomIndex = Math.floor(Math.random() * participantes.length);
const LuckyUser = participantes[randomIndex].id;

await maki.sendMessage(from, {
text: `рҹҺүрҹҢҹ ParabГ©ns @${LuckyUser.split("@")[0]}, vocГӘ acaba de ganhar: ${q.trim()} N-Coins. *Gaste com moderaГ§ГЈo!*`,
mentions: [LuckyUser]
}, { quoted: selo });

SYSTEM_COIN.AdicionarCoins(LuckyUser, Math.floor(q.trim()));
break;
}

case 'dadoapostado': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const [numberDado, amountBet] = q.split("/");
if (!numberDado)
return reply(
`VocГӘ esqueceu de escolher o nГәmero. Ex:\nвҖў *${prefix + command} nГәmero/aposta*`
);
if (!amountBet)
return reply(`VocГӘ esqueceu de colocar o valor da aposta.`);
if (isNaN(numberDado) || isNaN(amountBet))
return reply(`Por favor, insira apenas nГәmeros vГЎlidos!`);

const numDado = parseInt(numberDado);
const aposta = parseInt(amountBet);

if (aposta > 500)
return reply(`NГЈo Г© possГӯvel apostar mais de 500 N-Coins.`);
if (numDado < 1 || numDado > 6)
return reply(`NГәmero invГЎlido! Escolha de 1 a 6.`);

const saldoAtual = SYSTEM_COIN.VerificarCampo(sender, "coins");
if (saldoAtual < aposta)
return reply(`Saldo insuficiente! Use '${prefix}saldo'.`);

await reagir(from, "рҹҺІ");
await reply(`Sorteando dado(s)! вҸіпёҸ`);

const drawQuantity = Math.floor(Math.random() * 6) + 1;

setTimeout(async () => {
if (drawQuantity === numDado) {
const winMessages = [
`рҹҺІ ParabГ©ns @${sender.split("@")[0]}, vocГӘ ganhou ${aposta} N-Coins!`,
`рҹ’° Sucesso @${sender.split("@")[0]}! VocГӘ acertou e ganhou ${aposta} N-Coins!`,
];

await maki.sendMessage(from, {
text: winMessages[Math.floor(Math.random() * winMessages.length)],
mentions: [sender]
}, { quoted: selo });

await SYSTEM_COIN.AdicionarCoins(sender, aposta);
} else {
const lossMessages = [
`рҹӨ§ Infelizmente @${sender.split("@")[0]}, vocГӘ errou e perdeu ${aposta} N-Coins!`,
`рҹҳҝ @${sender.split("@")[0]}, nГЈo foi dessa vezвҖҰ perdeu ${aposta} N-Coins.`,
];

await maki.sendMessage(from, {
text: lossMessages[Math.floor(Math.random() * lossMessages.length)],
mentions: [sender]
}, { quoted: selo });

await SYSTEM_COIN.RemoverCoins(sender, aposta);
}
}, 5000);

break;
}


case 'cassino':
case 'slot':
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙңsбҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ бҙҸ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const usuario = RG_SCOINS[ID_G_COINS].usus[ID_USU_COINS];

if (usuario.chances.cassino >= 5) {
return maki.sendMessage(from, {
text: `гҖҢрҹҺ°гҖҚ бҙ бҙҸКҹбҙӣбҙҮ бҙҖбҙҚбҙҖЙҙhГЈ! КҸбҙҸбҙң бҙҠбҙҖ бҙңsбҙҸбҙң бҙӣбҙҸбҙ…бҙҖs бҙҖs 5 бҙ„КңбҙҖЙҙбҙ„бҙҮs бҙ…бҙҸ бҙ…ЙӘбҙҖ ЙҙбҙҸ бҙ„бҙҖssЙӘЙҙбҙҸ!`,
mentions: [sender]
});
}

if (usuario.coins < 30) {
return maki.sendMessage(from, {
text: `гҖҢрҹҺ°гҖҚ бҙӣбҙҮбҙң sбҙҖКҹбҙ…бҙҸ бҙҮМҒ ЙӘЙҙsбҙңТ“ЙӘбҙ„ЙӘбҙҮЙҙбҙӣбҙҮ! бҙҚЙӘЙҙЙӘбҙҚбҙҸ 30 N-Coins бҙҳбҙҖКҖбҙҖ бҙңsбҙҖКҖ бҙҸ бҙ„бҙҖssЙӘЙҙбҙҸ.`,
mentions: [sender]
});
}

usuario.chances.cassino++;
CoinsUpdate(RG_SCOINS);

const getResultSlot = ["рҹҚ“", "рҹҚ’", "рҹҚҺ", "рҹҚү"];
const V_ = Array.from(
{ length: 3 },
() => getResultSlot[Math.floor(Math.random() * getResultSlot.length)]
);

const slotMensagem = async (mensagem) => {
await maki.sendMessage(from, {
text: 
`гҖҢрҹҺ°гҖҚ бҙ„бҙҖssЙӘЙҙбҙҸ вҶҙ

гҖҺрҹ’ҺгҖҸ [ ${V_[0]} | ${V_[1]} | ${V_[2]} ]

${mensagem}

*_${usuario.chances.cassino}/5 бҙ„КңбҙҖЙҙбҙ„бҙҮs бҙ…бҙҸ бҙ…ЙӘбҙҖ._*`,
mentions: [sender]
});
};

if (V_[0] === V_[1] && V_[1] === V_[2]) {
await SYSTEM_COIN.AdicionarCoins(sender, 65);
const mensagensVitoria = [
"вңЁ Que sorte! VocГӘ ganhou +65 N-Coins! Aproveite! рҹ’°",
"рҹҺү VitГіria incrГӯvel! 65 N-Coins agora sГЈo seus! рҹ’Һ",
"рҹҢҹ Surpresa! A sorte sorriu para vocГӘ: +65 N-Coins! рҹ•№пёҸ",
];
await slotMensagem(
mensagensVitoria[Math.floor(Math.random() * mensagensVitoria.length)]
);
} else {
await SYSTEM_COIN.RemoverCoins(sender, 5);
const mensagensDerrota = [
"рҹҳ“ Que pena! -5 N-Coins hoje, mas continue tentando! рҹ’«",
"рҹҘә Hoje a sorte nГЈo estava do seu ladoвҖҰ -5 N-Coins! рҹҚҖ",
"рҹ’Ө NГЈo foi dessa vez! -5 N-Coins. AmanhГЈ Г© outro dia! рҹ’Һ",
];
await slotMensagem(
mensagensDerrota[Math.floor(Math.random() * mensagensDerrota.length)]
);
}
break;

case 'minerar':
case 'minerarcoins':
// Verifica se o comando estГЎ sendo usado em um grupo
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

// Verifica se o modo de coins estГЎ ativado no grupo
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

// Verifica se o usuГЎrio jГЎ atingiu o limite de tentativas de mineraГ§ГЈo
if (RG_SCOINS[ID_G_COINS].usus[ID_USU_COINS].chances.minerar >= 6) {
return reply(
`Sinto muito, vocГӘ nГЈo tem mais chance para minerar hoje, porque vocГӘ completou: 6/6.`
);
}

// Incrementa a chance de mineraГ§ГЈo para o usuГЎrio
if (!RG_SCOINS[ID_G_COINS].usus[ID_USU_COINS]) {
RG_SCOINS[ID_G_COINS].usus[ID_USU_COINS].chances.minerar = 1;
} else {
RG_SCOINS[ID_G_COINS].usus[ID_USU_COINS].chances.minerar += 1;
}

// Atualiza os dados de coins no arquivo JSON
CoinsUpdate(RG_SCOINS);

// Define um valor aleatГіrio para determinar o sucesso ou falha na mineraГ§ГЈo
const aleatValor = Math.floor(Math.random() * 2);
const rndg = Math.floor(Math.random() * 300); // Valor aleatГіrio de coins encontrado

if (aleatValor === 0) {
// Mensagens de sucesso na mineraГ§ГЈo
const randomMining = [
`VocГӘ estava minerando nas ilhas savitas e encontrou ${rndg} N-Coins em minerais preciosos! рҹ’°`,
`рҹ—Јрҹ’° VocГӘ invadiu uma mina proibida e achou ${rndg} N-Coins em troca de ouro!`,
`рҹ’Һрҹ‘·рҹҸ»вҖҚвҷҖпёҸ Em uma mina de diamantes, vocГӘ encontrou 2 diamantes equivalentes a ${rndg} N-Coins.`,
`вӣҸпёҸрҹ‘·рҹҸ»вҖҚвҷҖпёҸ VocГӘ escavou uma mina de ouro subterrГўnea em Minas Gerais e encontrou ${rndg} N-Coins!`,
// Adicione mais mensagens conforme necessГЎrio...
];

// Envia uma mensagem aleatГіria de sucesso
await reply(
randomMining[Math.floor(Math.random() * randomMining.length)]
);

// Adiciona as coins ao usuГЎrio
SYSTEM_COIN.AdicionarCoins(sender, rndg);
} else {
// Mensagens de falha na mineraГ§ГЈo
const miningFailureRX = [
"рҹҳҘ Em sua tentativa de mineraГ§ГЈo, nГЈo foi possГӯvel encontrar nenhum mineral valioso!",
"рҹҳҝ VocГӘ nГЈo deu sorte em sua escavaГ§ГЈo. Tente novamente mais tarde!",
"вӣҸпёҸрҹ’Һ Em Minas Gerais, famosa por suas minas de diamantes, vocГӘ nГЈo encontrou nada desta vez.",
// Adicione mais mensagens conforme necessГЎrio...
];

// Seleciona uma mensagem de falha aleatГіria
let miningFailure =
miningFailureRX[
Math.floor(Math.random() * miningFailureRX.length)
];

// Adiciona informaГ§Гөes sobre as chances restantes
miningFailure +=
RG_SCOINS[ID_G_COINS].usus[ID_USU_COINS].chances.minerar >= 6
? "\n> Infelizmente vocГӘ nГЈo tem mais chances para minerar hoje, volte amanhГЈ..."
: `\n> Ainda restam ${6 - RG_SCOINS[ID_G_COINS].usus[ID_USU_COINS].chances.minerar} tentativas para minerar hoje.`;

// Envia a mensagem de falha
await reply(miningFailure);
}
break;

case 'trabalhar':
case 'trabalho': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

// Inicializa estrutura se nГЈo existir
if (!RG_SCOINS[ID_G_COINS]) RG_SCOINS[ID_G_COINS] = { usus: {} };
if (!RG_SCOINS[ID_G_COINS].usus) RG_SCOINS[ID_G_COINS].usus = {};
if (!RG_SCOINS[ID_G_COINS].usus[ID_USU_COINS]) {
RG_SCOINS[ID_G_COINS].usus[ID_USU_COINS] = {
chances: {},
trabalharData: null,
trabalharCount: 0,
};
}

const userData = RG_SCOINS[ID_G_COINS].usus[ID_USU_COINS];
const hoje = new Date().toLocaleDateString("pt-BR");

// Reseta o contador se for dia diferente
if (userData.trabalharData !== hoje) {
userData.trabalharData = hoje;
userData.trabalharCount = 0;
}

if (userData.trabalharCount >= 5) {
return reply(
`рҹ“ӣ VocГӘ jГЎ trabalhou 5 vezes hoje! Limite atingido (5/5).`
);
}

// Incrementa contador
userData.trabalharCount++;

// Sorteia valor de coins
const salario = Math.floor(Math.random() * 251) + 50; // 50 a 300

// Array de mensagens de trabalho
const trabalhos = [
`рҹҡ• Hoje vocГӘ trabalhou como motorista de app e ganhou ${salario} N-Coins!`,
`рҹ‘ЁвҖҚрҹҚі VocГӘ passou o dia na cozinha e recebeu ${salario} N-Coins como cozinheiro.`,
`рҹӣ пёҸ Seu dia de mecГўnico rendeu ${salario} N-Coins!`,
`рҹ’» Programando atГ© tarde, vocГӘ garantiu ${salario} N-Coins como programador.`,
`рҹ§№ Como faxineiro, seu esforГ§o rendeu ${salario} N-Coins.`,
`рҹ“Ұ De entregador, vocГӘ correu pela cidade e ganhou ${salario} N-Coins.`,
`рҹ’ҷ Como designer criativo, vocГӘ recebeu ${salario} N-Coins por seus trabalhos.`,
];

// Atualiza coins do usuГЎrio (supondo essa funГ§ГЈo)
SYSTEM_COIN.AdicionarCoins(sender, salario);

// Salva as alteraГ§Гөes
CoinsUpdate(RG_SCOINS);

// Envia mensagem aleatГіria
await reply(
trabalhos[Math.floor(Math.random() * trabalhos.length)]
);

break;
}

case 'comprarcerveja': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const userData = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!userData) return reply(`*VocГӘ nГЈo possui registro de coins.*`);

const precoCerveja = 50;
const estoqueMaximo = 15;
const hoje = new Date().toLocaleDateString("pt-BR");

// Inicializa o controle de estoque se nГЈo existir
if (!RG_SCOINS[ID_G_COINS].cervejaEstoqueInfo) {
RG_SCOINS[ID_G_COINS].cervejaEstoqueInfo = {
data: hoje,
estoque: estoqueMaximo,
};
}

// Reseta estoque se for um novo dia
if (RG_SCOINS[ID_G_COINS].cervejaEstoqueInfo.data !== hoje) {
RG_SCOINS[ID_G_COINS].cervejaEstoqueInfo.data = hoje;
RG_SCOINS[ID_G_COINS].cervejaEstoqueInfo.estoque = estoqueMaximo;
}

const estoqueAtual =
RG_SCOINS[ID_G_COINS].cervejaEstoqueInfo.estoque;

if (estoqueAtual <= 0) {
return reply(
`рҹҡ« A cerveja acabou no estoque do grupo hoje. Volte amanhГЈ!`
);
}

if (userData.coins < precoCerveja) {
return reply(
`вқҢ VocГӘ nГЈo tem coins suficientes para comprar uma cerveja. Custa *${precoCerveja} N-Coins*.`
);
}

// Inicializa o campo de cervejas do usuГЎrio se ainda nГЈo tiver
if (typeof userData.cervejas !== "number") userData.cervejas = 0;

// Atualiza os dados: desconto, estoque e inventГЎrio
userData.coins -= precoCerveja;
userData.cervejas += 1;
RG_SCOINS[ID_G_COINS].cervejaEstoqueInfo.estoque -= 1;

CoinsUpdate(RG_SCOINS);

await reply(
`рҹҚ» *Compra realizada!*\n\n` +
`вң… VocГӘ comprou 1 cerveja por *${precoCerveja} N-Coins*.\n` +
`рҹ“Ұ Estoque do grupo hoje: *${RG_SCOINS[ID_G_COINS].cervejaEstoqueInfo.estoque}/${estoqueMaximo}* restantes.\n` +
`рҹҚә Seu estoque pessoal: *${userData.cervejas} cerveja(s)*\n` +
`рҹ’° Saldo atual: *${userData.coins} N-Coins*`
);

break;
}

case 'bebercerveja': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const userData = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!userData) return reply(`*VocГӘ nГЈo possui registro de coins.*`);

// Se o campo de cervejas ainda nГЈo existir
if (
typeof userData.cervejas !== "number" ||
userData.cervejas <= 0
) {
return reply(
`рҹҚә VocГӘ nГЈo tem nenhuma cerveja pra beber! Compre usando *${prefix}comprarcerveja*`
);
}

// Usa 1 cerveja
userData.cervejas -= 1;

// BГҙnus aleatГіrio ao beber
const bonus = Math.floor(Math.random() * 41) + 10; // de 10 a 50 coins
userData.coins += bonus;

CoinsUpdate(RG_SCOINS);

await reply(
`рҹҚ» *VocГӘ bebeu uma cerveja!*\n\n` +
`рҹҺү BГҙnus recebido: *${bonus} N-Coins*\n` +
`рҹҚә Cervejas restantes: *${userData.cervejas}*\n` +
`рҹ’° Seu saldo atual: *${userData.coins} N-Coins*`
);

break;
}


case 'doarcoins': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`Esse comando sГі pode ser usado quando o sistema ${prefix}modocoins estiver ativo.`
);

const mentionedJid =
info.message?.extendedTextMessage?.contextInfo?.mentionedJid || [];
if (!args[0] || !mentionedJid.length) {
return reply(`Uso correto: ${prefix}doarcoins quantia @usuГЎrio`);
}

const valorDoacao = parseInt(args[0]);
if (isNaN(valorDoacao) || valorDoacao <= 0)
return reply("Valor invГЎlido para doaГ§ГЈo.");

const remetente = sender;
const destinatario = mentionedJid[0];
const grupoCoins = RG_SCOINS[ID_G_COINS];

// Procura usuГЎrios
let userRemetente = grupoCoins.usus.find(u => u.id === remetente);
let userDestinatario = grupoCoins.usus.find(u => u.id === destinatario);

// Cria se nГЈo existir
if (!userRemetente) {
userRemetente = {
id: remetente,
coins: 0,
chances: { minerar: 0, cassino: 0 },
data: new Date().toLocaleDateString(),
};
grupoCoins.usus.push(userRemetente);
}

if (!userDestinatario) {
userDestinatario = {
id: destinatario,
coins: 0,
chances: { minerar: 0, cassino: 0 },
data: new Date().toLocaleDateString(),
};
grupoCoins.usus.push(userDestinatario);
}

// Verifica saldo
if (userRemetente.coins < valorDoacao) {
return reply(
`VocГӘ nГЈo tem coins suficientes para doar. Seu saldo: ${userRemetente.coins} N-Coins.`
);
}

// TransferГӘncia
userRemetente.coins -= valorDoacao;
userDestinatario.coins += valorDoacao;

CoinsUpdate(RG_SCOINS);

// рҹ”Ҙ ENVIO IGUAL ADDVIP
await maki.sendMessage(from, {
text: `в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—
в•‘ рҹҸҰ KANADE BOT  BANK - PIX рҹҸҰ
в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј
в•‘ рҹ‘Ө Remetente: @${remetente.split("@")[0]}
в•‘ рҹҺҜ DestinatГЎrio: @${destinatario.split("@")[0]}
в•‘
в•‘ рҹ’ё Valor transferido: ${valorDoacao} N-Coins
в•‘ рҹ’° Saldo atual: ${userRemetente.coins} N-Coins
в•‘
в•‘ рҹ“… Data: ${new Date().toLocaleDateString("pt-BR", { timeZone: "Africa/Maputo" })}
в•‘ рҹ•‘ HorГЎrio: ${new Date().toLocaleTimeString("pt-BR", { timeZone: "Africa/Maputo" })}
в•‘
в•‘ рҹ”– Tipo: PIX INSTANTГӮNEO
в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј
в•‘ вң… DoaГ§ГЈo realizada com sucesso!
в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ`,
mentions: [remetente, destinatario]
}, { quoted: selo });

break;
}

case 'roubarcoins': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`Esse comando sГі pode ser usado quando o sistema ${prefix}modocoins estiver ativo.`
);

// ====== QUOTED / MENTION ======
const quoted = info.quoted || {};
const isQuoted =
info.message?.extendedTextMessage?.contextInfo?.quotedMessage;

let alvo = null;
const mentions =
info.message?.extendedTextMessage?.contextInfo?.mentionedJid || [];

if (mentions.length > 0) {
alvo = mentions[0];
} else if (isQuoted && quoted.sender) {
alvo = quoted.sender;
} else {
return reply(`VocГӘ precisa mencionar ou responder quem deseja roubar!`);
}

if (alvo === sender)
return reply(`VocГӘ nГЈo pode roubar de vocГӘ mesmo!`);

// ====== USUГҒRIOS ======
const userRemetente = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
const userAlvo = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === alvo
);

if (!userRemetente)
return reply(`VocГӘ nГЈo possui registro de coins.`);
if (!userAlvo)
return reply(`O usuГЎrio mencionado nГЈo possui registro de coins.`);
if (userAlvo.coins <= 0)
return reply(`O alvo nГЈo possui coins para serem roubadas.`);
if (userRemetente.coins <= 0)
return reply(`VocГӘ nГЈo possui coins para tentar roubar.`);

// ====== рҹӣЎпёҸ ESCUDO ======
if (userAlvo.pocaoProtecao) {
const agora = Date.now();
const expira = userAlvo.pocaoProtecaoExpira || 0;

if (agora < expira) {
return maki.sendMessage(from, {
text: `рҹӣЎпёҸ O usuГЎrio @${alvo.split("@")[0]} estГЎ protegido por um escudo!`,
mentions: [alvo],
});
} else {
delete userAlvo.pocaoProtecao;
delete userAlvo.pocaoProtecaoExpira;
CoinsUpdate(RG_SCOINS);
}
}

// ====== рҹ“Ҷ LIMITE DIГҒRIO ======
const hoje = new Date().toLocaleDateString("pt-BR");

if (!userRemetente.limitesRoubo || userRemetente.limitesRoubo.data !== hoje) {
userRemetente.limitesRoubo = {
data: hoje,
totalHoje: 0,
roubadosHoje: {},
};
}

if (userRemetente.limitesRoubo.totalHoje >= 3)
return reply(`рҹҡ« VocГӘ jГЎ atingiu o limite de 3 roubos hoje.`);

if (userRemetente.limitesRoubo.roubadosHoje[alvo])
return maki.sendMessage(from, {
text: `рҹҡ« VocГӘ jГЎ roubou @${alvo.split("@")[0]} hoje.`,
mentions: [alvo],
});

// ====== рҹҡ“ POLГҚCIA ======
if (Math.random() < 0.2) {
let punicao = "";

if (userRemetente.coins >= 1000) {
userRemetente.coins -= 1000;
punicao = `рҹҡ“ A polГӯcia te pegou tentando roubar!\nVocГӘ pagou 1000 N-Coins de multa.`;
} else {
punicao = `рҹҡ“ A polГӯcia te pegou tentando roubar!\nVocГӘ perdeu todas as suas coins.`;
userRemetente.coins = 0;
}

if (userRemetente.pocaoProtecao && Math.random() < 0.3) {
delete userRemetente.pocaoProtecao;
delete userRemetente.pocaoProtecaoExpira;
punicao += `\nрҹӣЎпёҸ Seu escudo foi quebrado!`;
}

CoinsUpdate(RG_SCOINS);
return reply(punicao);
}

// ====== рҹ’° ROUBO ======
const maxRoubar = Math.max(1, Math.floor(userAlvo.coins * 0.2));
const valorRoubo = Math.floor(Math.random() * maxRoubar) + 1;

userAlvo.coins -= valorRoubo;
userRemetente.coins += valorRoubo;

userRemetente.limitesRoubo.totalHoje += 1;
userRemetente.limitesRoubo.roubadosHoje[alvo] = true;

CoinsUpdate(RG_SCOINS);

await maki.sendMessage(from, {
text: `рҹ”« Roubo realizado com sucesso!
VocГӘ roubou ${valorRoubo} N-Coins de @${alvo.split("@")[0]}.

рҹ’° Seu saldo: ${userRemetente.coins} N-Coins
рҹҳў Saldo da vГӯtima: ${userAlvo.coins} N-Coins`,
mentions: [alvo],
});

break;
}

case 'comprarescudo': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const precoEscudo = 100;

const userData = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!userData) return reply(`*VocГӘ nГЈo possui registro de coins.*`);

if (userData.coins < precoEscudo) {
return reply(
`рҹӣЎпёҸ VocГӘ nГЈo tem coins suficientes para comprar um escudo. Custo: ${precoEscudo} N-Coins.`
);
}

// Deduz o valor
userData.coins -= precoEscudo;

// Ativa a proteГ§ГЈo por 2 horas (2h em milissegundos = 7.200.000)
userData.pocaoProtecao = true;
userData.pocaoProtecaoExpira = Date.now() + 7200000;

CoinsUpdate(RG_SCOINS);

await reply(
`рҹӣЎпёҸ Escudo comprado com sucesso! VocГӘ estГЎ protegido contra roubos por 2 horas.`
);

break;
}

case 'comprarbomba': {
