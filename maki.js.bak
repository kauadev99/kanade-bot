case 'linkgroup':
if(!isGroup) return reply(mess.onlyGroup())
if(!isGroupAdmins) return reply(mess.onlyAdmins())
if(!isBotGroupAdmins) return reply(mess.onlyBotAdmin())
let metadata = await maki.groupMetadata(from)
linkgc = await maki.groupInviteCode(from)
reply(`*вңЁ вҶ’ бҙҖбҙ„бҙҮкңұкңұбҙҮ бҙҸ КҹЙӘЙҙбҙӢ бҙ…бҙҸ ЙўКҖбҙңбҙ©бҙҸ бҙҖбҙӣбҙңбҙҖКҹ бҙҖКҷбҙҖЙӘxбҙҸ вҶҙ*\nhttps://chat.whatsapp.com/` + linkgc)
break

case 'redefinir':
case 'revlinkgp':
case 'revlinkgroup':
if(!isGroup) return reply(mess.onlyGroup())
if(!isGroupAdmins) return reply(mess.onlyAdmins())
if(!isBotGroupAdmins) return reply(mess.onlyBotAdmin())
await maki.groupRevokeInvite(from)
reply(`*КҹЙӘЙҙбҙӢ бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ КҖбҙҮбҙ…бҙҮТ“ЙӘЙҙЙӘбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ рҹҷҮвҖҚвҷӮпёҸ*`)
break

case 'configurar-bot':
await maki.sendMessage(from, {text: getInfo.configbot(prefix)}, {quoted: selo});
break;

case 'totag':
case 'cita':
case 'hidetag':
case 'citar': {
if (!isGroup) return reply(mess.onlyGroup())
if (!isGroupAdmins) return reply(mess.onlyAdmins())
if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin())
const quotedMsg = info.message?.extendedTextMessage?.contextInfo?.quotedMessage
const TDS_GP = groupMembers.map(i => i.id)
if (quotedMsg?.pollCreationMessageV3) {
const poll = quotedMsg.pollCreationMessageV3
const titulo = poll.name
const opcoes = poll.options.map(o => o.optionName)
const aviso = await maki.sendMessage(from, { 
text: `${q}`,
contextInfo: { mentionedJid: TDS_GP }
})
await maki.sendMessage(from, {
poll: {
name: titulo,
values: opcoes,
selectableCount: poll.selectableCount || 1
}, mentions: TDS_GP }, { quoted: aviso })
break
}
if (!quotedMsg && args.length > 0) {
return await maki.sendMessage(from, { text: args.join(" "), contextInfo: { mentionedJid: TDS_GP }})}
if (quotedMsg) {
const messageTypes = ['imageMessage', 'videoMessage', 'audioMessage', 'documentMessage', 'documentWithCaptionMessage']
for (const type of messageTypes) {
const message = quotedMsg?.viewOnceMessageV2?.message?.[type] || quotedMsg?.[type]?.message?.documentMessage || quotedMsg?.[type]
if (message?.caption) {message.caption = args.length > 0 ? args.join(' ').trim() : message.caption}}
return await maki.sendMessage(from, { forward: { key: info.key, message: quotedMsg }, contextInfo: { mentionedJid: TDS_GP }})}
return reply(`*бҙңsбҙҮ бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ бҙ…бҙҮ бҙ…бҙңбҙҖs бҙҚбҙҖЙҙбҙҮЙӘКҖбҙҖs рҹҷҮвҖҚвҷӮпёҸ*\n> *1.* бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҖ бҙҚбҙҮЙҙsбҙҖЙўбҙҮбҙҚ (Т“бҙҸбҙӣбҙҸ, бҙ ЙӘбҙ…бҙҮбҙҸ, бҙҖбҙңбҙ…ЙӘбҙҸ, бҙҮЙҙЗ«бҙңбҙҮбҙӣбҙҮ, бҙҮбҙӣбҙ„)> *2.* бҙҸбҙң бҙ…ЙӘЙўЙӘбҙӣбҙҮ *${prefix + command}* sбҙҮЙўбҙңЙӘбҙ…бҙҸ бҙ…бҙҖ sбҙңбҙҖ бҙҚбҙҮЙҙsбҙҖЙўбҙҮбҙҚ`)
}
break;

case 'modoaluguel':
try {
if(!SoDono) return reply(mess.onlyOwner())

	if (!nescessario.aluguel) {

		nescessario.aluguel = true;

		fs.writeFileSync(`./configs/INFO_DADOS/nescessario.json`, JSON.stringify(nescessario, null, 2) + "\n");

		reply(`*бҙҸ КҖбҙҮбҙ„бҙңКҖsбҙҸ Т“бҙҸЙӘ бҙҖбҙӣЙӘбҙ бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ рҹҷҮвҖҚвҷӮпёҸ*`)
	} else if (nescessario.aluguel) {

		nescessario.aluguel = false

		fs.writeFileSync(`./configs/INFO_DADOS/nescessario.json`, JSON.stringify(nescessario, null, 2) + "\n");

		reply(`*бҙҸ КҖбҙҮбҙ„бҙңКҖsбҙҸ Т“бҙҸЙӘ бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ рҹҷ…вҖҚвҷӮпёҸ*`)
	}
} catch (e) {
	console.error(e);
	reply("Houve um erro no comando!");
}
break;

case 'delaluguel':
case 'removealuguel':
case 'rm_aluguel': {
if (!isModoAluguel)
return reply(`гҖҢрҹ’ҷгҖҚ бҙҸ бҙҚбҙҸбҙ…бҙҸ бҙҖКҹбҙңЙўбҙңбҙҮКҹ ЙҙбҙҖМғбҙҸ бҙҮsбҙӣбҙҖМҒ бҙҖбҙӣЙӘбҙ бҙҸ, ЙҙбҙҮЙҙКңбҙңбҙҚбҙҖ бҙҖКҹбҙңЙўбҙңбҙҮКҹ Т“бҙҸЙӘ бҙӣбҙҮбҙ„ЙӘбҙ…бҙҖ. рҹ§Ҡ`)

if (!SoDono) return reply(mess.onlyOwner())

if (args[0]) {
const index = parseInt(args[0]) - 1
if (isNaN(index) || index < 0 || index >= gruposAutorizados.length)
return reply(`гҖҢрҹ’ҷгҖҚ бҙңsбҙҮ: rm_aluguel 1`)

const alvo = gruposAutorizados[index]
desativarAluguelGrupo(alvo.id)
gruposAutorizados.splice(index, 1)

return reply(`гҖҢрҹ§ҠгҖҚбҙҸ бҙҖКҹбҙңЙўбҙңбҙҮКҹ Т“бҙҸЙӘ КҖбҙҸбҙҚбҙҳЙӘбҙ…бҙҖ вҖ”
бҙҸ бҙҖКҹбҙңЙўбҙңбҙҮКҹ бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ Т“бҙҸЙӘ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҸ бҙ„бҙҸбҙҚ кңұбҙңбҙ„бҙҮкңұкңұбҙҸ.`)
}

if (!isGroup) return reply(mess.onlyGroup())

const grupo = gruposAutorizados.find(g => g.id === from)
if (!grupo)
return reply(`гҖҢрҹ’ҷгҖҚ бҙҮsбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ ЙҙбҙҖМғбҙҸ бҙҮsбҙӣбҙҖМҒ бҙҳКҖбҙҮsбҙҸ бҙҖМҖ ЙҙбҙҮЙҙКңбҙңбҙҚбҙҖ бҙҖКҹбҙңЙўбҙңбҙҮКҹ. рҹ§Ҡ`)

desativarAluguelGrupo(from)
gruposAutorizados = gruposAutorizados.filter(g => g.id !== from)

reply(`гҖҢрҹ§ҠгҖҚ бҙҖ бҙӣбҙҮЙӘбҙҖ Т“бҙҸЙӘ бҙ„бҙҸКҖбҙӣбҙҖбҙ…бҙҖ вҖ”
бҙҸ бҙҖКҹбҙңЙўбҙңбҙҮКҹ бҙ…бҙҮsбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ Т“бҙҸЙӘ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҸ.`)
}
break

case 'lista-aluguel': {
if (!isModoAluguel)
return reply(`гҖҢрҹ’ҷгҖҚ бҙҸ бҙҚбҙҸбҙ…бҙҸ бҙҖКҹбҙңЙўбҙңбҙҮКҹ ЙҙбҙҖМғбҙҸ бҙҮsбҙӣбҙҖМҒ бҙҖбҙӣЙӘбҙ бҙҸ.`)

if (gruposAutorizados.length === 0)
return reply(`гҖҢрҹ§ҠгҖҚ ЙҙбҙҮЙҙКңбҙңбҙҚбҙҖ бҙҖКҹбҙңЙўбҙңбҙҮКҹ Т“бҙҸЙӘ бҙӣбҙҮбҙ„ЙӘбҙ…бҙҖ бҙҖбҙӣбҙҮМҒ бҙҸ бҙҚбҙҸбҙҚбҙҮЙҙбҙӣбҙҸ.`)

let texto = `гҖҢрҹ’ҷгҖҚбҙҖКҹбҙңЙўбҙңбҙҮКҹ бҙҖбҙӣЙӘбҙ бҙҸs ЙҙбҙҸ кңұЙӘкңұбҙӣбҙҮбҙҚбҙҖ вҖ”\n\n`

for (let i = 0; i < gruposAutorizados.length; i++) {
const g = gruposAutorizados[i]
try {
const meta = await maki.groupMetadata(g.id)
const nome = meta.subject || 'ЙўКҖбҙңбҙҳбҙҸ sбҙҮбҙҚ ЙҙбҙҸбҙҚбҙҮ'
const membros = meta.participants.length || 0
const inviteCode = await maki.groupInviteCode(g.id).catch(() => null)
const link = inviteCode ? `https://chat.whatsapp.com/${inviteCode}` : 'рҹ”’ КҹЙӘЙҙбҙӢ ЙӘЙҙбҙ…ЙӘsбҙҳбҙҸЙҙГӯбҙ бҙҮКҹ'

const agora = new Date()
const expira = new Date(g.expiraEm)
const restante = expira - agora

const dias = Math.floor(restante / (1000 * 60 * 60 * 24))
const horas = Math.floor((restante / (1000 * 60 * 60)) % 24)
const minutos = Math.floor((restante / (1000 * 60)) % 60)

// ===== BATERIA DE ALUGUEL =====
const totalHoras = (g.duracaoDias || 1) * 24
const horasRestantes = (dias * 24) + horas
let porcentagem = Math.max(0, Math.min(100, (horasRestantes / totalHoras) * 100))

const barras = Math.round(porcentagem / 10)
const barra = "в–Ҳ".repeat(barras) + "в–’".repeat(10 - barras)

texto += `рҹ§Ҡ ${i + 1}. ${nome}
рҹ”— ${link}
рҹ‘Ө ${membros} бҙҚбҙҮбҙҚКҖбҙҸs
вҸі ${dias}бҙ… ${horas}Кң ${minutos}бҙҚ
рҹ”Ӣ ${porcentagem.toFixed(0)}%гҖҳ${barra}гҖҷ

`
} catch {
texto += `рҹ§Ҡ ${i + 1}. ЙҙбҙҖМғбҙҸ Т“бҙҸЙӘ бҙҳбҙҸssЙӘМҒбҙ бҙҮКҹ КҹбҙҮКҖ бҙҸ ЙўКҖбҙңбҙҳбҙҸ
рҹҶ” ${g.id}\n\n`
}
}

reply(texto.trim())
}
break


case 'veraluguel':
case 'ver_aluguel': {
if (!isGroup) return reply(mess.onlyGroup())
if (!isModoAluguel)
return reply(`гҖҢрҹ’ҷгҖҚ бҙҸ бҙҚбҙҸбҙ…бҙҸ бҙҖКҹбҙңЙўбҙңбҙҮКҹ ЙҙбҙҖМғбҙҸ бҙҮsбҙӣбҙҖМҒ бҙҖбҙӣЙӘбҙ бҙҸ.`)

const grupo = gruposAutorizados.find(g => g.id === from)
if (!grupo)
return reply(`гҖҢрҹ§ҠгҖҚ бҙҮsбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ ЙҙбҙҖМғбҙҸ бҙҳбҙҸssбҙңЙӘ бҙҖКҹбҙңЙўбҙңбҙҮКҹ бҙҖбҙӣЙӘбҙ бҙҖ.`)

const agora = new Date()
const expira = new Date(grupo.expiraEm)
if (isNaN(expira))
return reply(`гҖҢрҹ’ҷгҖҚ бҙҮКҖКҖбҙҸ бҙҖбҙҸ КҹбҙҮКҖ бҙҸ бҙӣбҙҮбҙҚбҙҳбҙҸ бҙ…бҙҖ бҙҖКҹбҙңЙўбҙңбҙҮКҹ.`)

if (agora > expira) {
desativarAluguelGrupo(from)
return reply(`гҖҢрҹ§ҠгҖҚ бҙҖ бҙҖКҹбҙңЙўбҙңбҙҮКҹ бҙ…бҙҮsбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ бҙҠбҙҖМҒ кңұбҙҮ КҖбҙҸбҙҚбҙҳбҙҮбҙң.`)
}

const diff = expira - agora
const dias = Math.floor(diff / (1000 * 60 * 60 * 24))
const horas = Math.floor((diff / (1000 * 60 * 60)) % 24)
const min = Math.floor((diff / (1000 * 60)) % 60)
const dataFormada = expira.toLocaleString('pt-BR', { timeZone: 'Africa/Maputo' })

// ===== BATERIA =====
const totalHoras = (grupo.duracaoDias || 1) * 24
const horasRestantes = (dias * 24) + horas
let porcentagem = Math.max(0, Math.min(100, (horasRestantes / totalHoras) * 100))

const barras = Math.round(porcentagem / 10)
const barra = "в–Ҳ".repeat(barras) + "в–’".repeat(10 - barras)

const texto = `гҖҢрҹ’ҷгҖҚбҙҖКҹбҙңЙўбҙңбҙҮКҹ бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ
рҹ“… Expira em: ${dataFormada}
вҸі ${dias}бҙ… ${horas}Кң ${min}бҙҚ КҖбҙҮsбҙӣбҙҖЙҙбҙӣбҙҮs
рҹ”Ӣ ${porcentagem.toFixed(0)}%гҖҳ${barra}гҖҷ
рҹ§Ҡ Enquanto a aluguel existir, o grupo permanece protegido.`

reply(texto)
}
break
case 'rgaluguel':
case 'aluguel': {
if (!isModoAluguel)
return reply(`гҖҢрҹ’ҷгҖҚ бҙҸ бҙҚбҙҸбҙ…бҙҸ бҙҖКҹбҙңЙўбҙңбҙҮКҹ ЙҙбҙҖМғбҙҸ бҙҮsбҙӣбҙҖМҒ бҙҖбҙӣЙӘбҙ бҙҸ.`)

if (!isGroup) return reply(mess.onlyGroup())
if (!SoDono) return reply(mess.onlyOwner())

if (!args[0])
return reply(`гҖҢрҹ§ҠгҖҚ бҙ…ЙӘЙўЙӘбҙӣбҙҮ бҙҸ бҙӣбҙҮбҙҚбҙҳбҙҸ бҙ…бҙҖ бҙҖКҹбҙңЙўбҙңбҙҮКҹ бҙҮбҙҚ бҙ…ЙӘбҙҖs бҙҮ КңбҙҸКҖбҙҖs.
бҙҮx: ${prefix}aluguel 2 4`)

const dias = parseInt(args[0]) || 0
const horas = parseInt(args[1]) || 0

ativarAluguelGrupo(from, dias, horas)

const agora = new Date()
const expira = new Date(agora.getTime() + (dias * 24 + horas) * 60 * 60 * 1000)
const dataFormatada = expira.toLocaleString('pt-BR', { timeZone: 'Africa/Maputo' })

reply(mess.rgaluguel(dataFormatada))
}
break

case 'baixarapp': {
  try {
    if (!q) {
      return reply(`вҡ пёҸ Digite o nome do aplicativo\nExemplo: .${command} Roblox`);
    }

    const apiUrl = `http://br1.nextshost.com:2000/api/pesquisa/playstore?apikey=bluxmodz&query=${encodeURIComponent(q)}`;
    const res = await fetch(apiUrl);

    if (!res.ok) throw new Error('Erro na API');

    const json = await res.json();
    const app = json?.resultado?.resultado?.[0];

    if (!app) {
      return reply('вқҢ Nenhum aplicativo encontrado');
    }

    const format = (v, padrao = 'NГЈo informado') => v ? v : padrao;

    const texto = `
рҹ“І ${format(app.name)}

рҹ‘ЁвҖҚрҹ’» Desenvolvedor: ${format(app.developer)}
вӯҗ AvaliaГ§ГЈo: ${format(app.rating)} (${format(app.ratingCount, '0')})

рҹ“Ҙ InstalaГ§Гөes: ${format(app.installs)}
рҹ“Ұ Tamanho: ${format(app.size)}
рҹ”ў VersГЈo: ${format(app.version)}
рҹ“ұ Sistema: ${format(app.os)}

рҹ—“пёҸ Atualizado: ${format(app.updated)}
рҹ’° PreГ§o: ${format(app.price)}

рҹҢҗ Download:
${format(app.link)}
`.trim();

    if (app.miniatura) {
      await maki.sendMessage(from, {
        image: { url: app.miniatura },
        caption: texto
      }, { quoted: info });
    } else {
      await reply(texto);
    }

  } catch (err) {
    console.error(err);
    reply('вқҢ Erro ao buscar o aplicativo');
  }
}
break;
case 'calendario':
case 'dados': {
setTimeout(() => {
reagir(from, "рҹ’ҷ");
}, 300);

// Hora e data
const hora = moment.tz("Africa/Maputo").format("HH:mm:ss");
const data = moment.tz("Africa/Maputo").format("DD/MM/YYYY");

// Grupos ativos
const getGroups = await maki.groupFetchAllParticipating();
const totalGrupos = Object.keys(getGroups).length;

let texto = `- *рҹ’ҷ | бҙҖбҙӣбҙңбҙҖКҹЙӘбҙўбҙҖЙҙбҙ…бҙҸ кңұбҙңбҙҖкңұ ЙӘЙҙкң°бҙҸКҖбҙҚбҙҖбҙ„М§бҙҸМғбҙҮкңұвҖҰ* вҶҙ

гҖҺрҹ’§гҖҸ *ЙўКҖбҙңбҙҳбҙҸ:* ${isGroup ? groupName : "бҙҳКҖЙӘбҙ бҙҖбҙ…бҙҸ"}
гҖҺрҹ“…гҖҸ *бҙ…бҙҖбҙӣбҙҖ:* ${data}
гҖҺвҸ°гҖҸ *КңбҙҸКҖбҙҖ:* ${hora2}
гҖҺрҹӨ–гҖҸ *КҷбҙҸбҙӣ:* ${NomeDoBot}
гҖҺрҹ‘‘гҖҸ *бҙҳКҖбҙҸбҙҳКҖЙӘбҙҮбҙӣбҙҖМҒКҖЙӘбҙҸ:* ${ownerName}
гҖҺрҹҢҗгҖҸ *бҙҖбҙӣЙӘбҙ бҙҸ бҙҮбҙҚ:* ${totalGrupos} ЙўКҖбҙңбҙҳбҙҸs`;

// ===== SISTEMA DE ALUGUEL =====
if (isGroup && isModoAluguel) {
const grupo = gruposAutorizados.find(g => g.id === from);

if (grupo) {
const agora = new Date();
const expira = new Date(grupo.expiraEm);

if (!isNaN(expira) && agora < expira) {
const diff = expira - agora;

const dias = Math.floor(diff / (1000 * 60 * 60 * 24));
const horas = Math.floor((diff / (1000 * 60 * 60)) % 24);
const minutos = Math.floor((diff / (1000 * 60)) % 60);

const totalHoras = (grupo.duracaoDias || 1) * 24;
const horasRestantes = (dias * 24) + horas;
const porcentagem = Math.max(
0,
Math.min(100, (horasRestantes / totalHoras) * 100)
);

const barras = Math.round(porcentagem / 10);
const barra = "в–Ҳ".repeat(barras) + "в–’".repeat(10 - barras);

texto += `

вҖ”вҖ”вҖ”
гҖҢрҹ§ҠгҖҚ *кңұЙӘкңұбҙӣбҙҮбҙҚбҙҖ бҙ…бҙҮ бҙҖКҹбҙңЙўбҙңбҙҮКҹ* вҶҙ

гҖҺвҸігҖҸ *бҙӣбҙҮбҙҚбҙҳбҙҸ КҖбҙҮкңұбҙӣбҙҖЙҙбҙӣбҙҮ:* ${dias}бҙ… ${horas}Кң ${minutos}бҙҚ
гҖҺрҹ”ӢгҖҸ *бҙ„бҙҖКҖЙўбҙҖ:* ${porcentagem.toFixed(0)}%гҖҳ${barra}гҖҷ
> *рҹ’ҷ | бҙҸ бҙҖКҹбҙңЙўбҙңбҙҮКҹ бҙҖЙӘЙҙбҙ…бҙҖ бҙҳКҖбҙҸбҙӣбҙҮЙўбҙҮ бҙҮкңұбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ.*`;
}
}
}

reply(texto, { mentions: [sender] });
}
break;

case 'fechargp':
case 'fechargrupo': {
if (!isGroupAdmins) return reply(`гҖҢрҹ§ҠгҖҚ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ бҙҳбҙҸбҙ…бҙҮ КҖбҙҸбҙ…бҙҖКҖ бҙҖбҙҳбҙҮЙҙбҙҖкңұ бҙҳбҙҸКҖ бҙҖбҙ…бҙҚЙӘЙҙs рҹ’ҷ`);
if (!isBotGroupAdmins) return reply(`гҖҢрҹ’ҷгҖҚ бҙҸ КҷбҙҸбҙӣ бҙ…бҙҮбҙ бҙҮ sбҙҮКҖ бҙҖбҙ…бҙҚЙӘЙҙ бҙҳбҙҖКҖбҙҖ КңбҙҖКҷЙӘКҹЙӘбҙӣбҙҖКҖ бҙҮкңұбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ рҹ§Ҡ`);
if (!isModohorario) return reply(`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙңsбҙҖбҙ…бҙҸ З«бҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘsбҙӣбҙҮбҙҚбҙҖ ${prefix}modohorario бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹ’ҷ*`);
try {
let barra = q.trim();
if (!barra.includes(':')) return reply(`гҖҢрҹ§ҠгҖҚ кң°бҙҸКҖбҙҚбҙҖбҙӣбҙҸ ЙӘЙҙбҙ бҙҖМҒКҹЙӘбҙ…бҙҸ, бҙңкңұбҙҮ 00:00 рҹ’ҷ`);

let [horas, minutos] = barra.split(':');
if (!horas || !minutos) return reply(`гҖҢрҹ§ҠгҖҚ КңбҙҸКҖбҙҖКҖЙӘбҙҸ ЙӘЙҙбҙ„бҙҸбҙҚбҙҳКҹбҙҮбҙӣбҙҸ вҡ пёҸ`);
if (isNaN(horas) || isNaN(minutos)) return reply(`гҖҢрҹ’ҷгҖҚ бҙңкңұбҙҮ бҙҖбҙҳбҙҮЙҙбҙҖкңұ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸкңұ рҹ”ў`);

horas = horas.padStart(2, '0');
minutos = minutos.padStart(2, '0');

if (parseInt(horas) > 23 || parseInt(minutos) > 59)
return reply(`гҖҢрҹ§ҠгҖҚ КңбҙҸКҖбҙҖМҒКҖЙӘбҙҸ ЙӘЙҙбҙ бҙҖМҒКҹЙӘбҙ…бҙҸ вқҢ`);

let horarioFinal = `${horas}:${minutos}:00`;
definirFechamento(from, horarioFinal);

await reply(
`гҖҢрҹ’ҷгҖҚбҙҸ ЙўКҖбҙңбҙҳбҙҸ кң°ЙӘбҙ„бҙҖКҖбҙҖМҒ кң°бҙҮбҙ„КңбҙҖбҙ…бҙҸ aМҖкңұ ${horarioFinal}.
рҹ§Ҡ бҙҖ бҙҳбҙҖКҖбҙӣЙӘКҖ бҙ…бҙҮsбҙӣбҙҮ КңбҙҸКҖбҙҖМҒКҖЙӘбҙҸ, sбҙҸбҙҚбҙҮЙҙбҙӣбҙҮ бҙҖбҙ…бҙҚЙӘЙҙs бҙҳбҙҸбҙ…бҙҮКҖбҙҖМғбҙҸ бҙҮЙҙбҙ ЙӘбҙҖКҖ бҙҚбҙҮЙҙsбҙҖЙўбҙҮЙҙs.
рҹ’ҷ бҙҚбҙҖЙҙбҙӣбҙҮЙҙКңбҙҖбҙҚ бҙҖ бҙҸКҖбҙ…бҙҮбҙҚ бҙҮ бҙҖЙўбҙңбҙҖКҖбҙ…бҙҮбҙҚ бҙҖ бҙҖКҷбҙҮКҖбҙӣбҙңКҖбҙҖ.`
);
} catch (e) {
console.error('erro ao definir fechamento:', e);
reply(`гҖҢрҹ§ҠгҖҚ бҙҸбҙ„бҙҸКҖКҖбҙҮбҙң бҙңбҙҚ бҙҮКҖКҖбҙҸ бҙҖбҙҸ бҙ…бҙҮкң°ЙӘЙҙЙӘКҖ бҙҸ КңбҙҸКҖбҙҖКҖЙӘбҙҸ вқҢ`);
}
}
break;

case 'abrirgp':
case 'abrirgrupo': {
if (!isGroupAdmins) return reply(`гҖҢрҹ§ҠгҖҚ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ бҙҳбҙҸбҙ…бҙҮ КҖбҙҸбҙ…бҙҖКҖ бҙҖбҙҳбҙҮЙҙбҙҖкңұ бҙҳбҙҸКҖ бҙҖбҙ…бҙҚЙӘЙҙs рҹ’ҷ`);
if (!isBotGroupAdmins) return reply(`гҖҢрҹ’ҷгҖҚ бҙҸ КҷбҙҸбҙӣ бҙ…бҙҮбҙ бҙҮ sбҙҮКҖ бҙҖбҙ…бҙҚЙӘЙҙ бҙҳбҙҖКҖбҙҖ КңбҙҖКҷЙӘКҹЙӘбҙӣбҙҖКҖ бҙҮкңұбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ рҹ§Ҡ`);
if (!isModohorario) return reply(`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙңsбҙҖбҙ…бҙҸ З«бҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘsбҙӣбҙҮбҙҚбҙҖ ${prefix}modohorario бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹ’ҷ*`);
try {
let barra = q.trim();
if (!barra.includes(':')) return reply(`гҖҢрҹ§ҠгҖҚ кң°бҙҸКҖбҙҚбҙҖбҙӣбҙҸ ЙӘЙҙбҙ бҙҖМҒКҹЙӘбҙ…бҙҸ, бҙңкңұбҙҮ 07:00 рҹ’ҷ`);

let [horas, minutos] = barra.split(':');
if (!horas || !minutos) return reply(`гҖҢрҹ§ҠгҖҚ КңбҙҸКҖбҙҖКҖЙӘбҙҸ ЙӘЙҙбҙ„бҙҸбҙҚбҙҳКҹбҙҮбҙӣбҙҸ вҡ пёҸ`);
if (isNaN(horas) || isNaN(minutos)) return reply(`гҖҢрҹ’ҷгҖҚ бҙңкңұбҙҮ бҙҖбҙҳбҙҮЙҙбҙҖкңұ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸкңұ рҹ”ў`);

horas = horas.padStart(2, '0');
minutos = minutos.padStart(2, '0');

if (parseInt(horas) > 23 || parseInt(minutos) > 59)
return reply(`гҖҢрҹ§ҠгҖҚ КңбҙҸКҖбҙҖМҒКҖЙӘбҙҸ ЙӘЙҙбҙ бҙҖМҒКҹЙӘбҙ…бҙҸ вқҢ`);

let horarioFinal = `${horas}:${minutos}:00`;
definirAbertura(from, horarioFinal);

reply(
`гҖҢрҹ’ҷгҖҚбҙҸ ЙўКҖбҙңбҙҳбҙҸ кңұбҙҮКҖбҙҖМҒ бҙҖКҷбҙҮКҖбҙӣбҙҸ aМҖкңұ ${horarioFinal}.
рҹ§Ҡ бҙҖ бҙҳбҙҖКҖбҙӣЙӘКҖ бҙ…бҙҮsбҙӣбҙҮ КңбҙҸКҖбҙҖМҒКҖЙӘбҙҸ, бҙҸ бҙ„КңбҙҖбҙӣ бҙҮкңұбҙӣбҙҖКҖбҙҖМҒ КҹЙӘКҷбҙҮКҖбҙҖбҙ…бҙҸ бҙҳбҙҖКҖбҙҖ бҙӣбҙҸбҙ…бҙҸs.
рҹ’ҷ бҙңкңұбҙҮбҙҚ бҙҸ ЙўКҖбҙңбҙҳбҙҸ бҙ„бҙҸбҙҚ КҖбҙҮкңұбҙҳбҙҸЙҙкңұбҙҖКҷЙӘКҹЙӘбҙ…бҙҖбҙ…бҙҮ.`
);

} catch (e) {
console.error('erro ao definir abertura:', e);
reply(`гҖҢрҹ§ҠгҖҚ бҙҸбҙ„бҙҸКҖКҖбҙҮбҙң бҙңбҙҚ бҙҮКҖКҖбҙҸ бҙҖбҙҸ бҙ…бҙҮкң°ЙӘЙҙЙӘКҖ бҙҸ КңбҙҸКҖбҙҖКҖЙӘбҙҸ вқҢ`);
}
}
break;

case 'delhorario':
case 'remover_horario':
case 'removerhorario': {
if (!isGroupAdmins) return reply(`гҖҢрҹ§ҠгҖҚ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ бҙҳбҙҸбҙ…бҙҮ КҖбҙҸбҙ…бҙҖКҖ бҙҖбҙҳбҙҮЙҙбҙҖкңұ бҙҳбҙҸКҖ бҙҖбҙ…бҙҚЙӘЙҙs рҹ’ҷ`);
if (!isBotGroupAdmins) return reply(`гҖҢрҹ’ҷгҖҚ бҙҸ КҷбҙҸбҙӣ бҙ…бҙҮбҙ бҙҮ sбҙҮКҖ бҙҖбҙ…бҙҚЙӘЙҙ бҙҳбҙҖКҖбҙҖ КҖбҙҮбҙҚбҙҸбҙ бҙҮКҖ КңбҙҸКҖбҙҖМҒКҖЙӘбҙҸкңұ рҹ§Ҡ`);
if (!isModohorario) return reply(`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙңsбҙҖбҙ…бҙҸ З«бҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘsбҙӣбҙҮбҙҚбҙҖ ${prefix}modohorario бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹ’ҷ*`);
try {
if (!horarios[from])
return reply(`гҖҢрҹ§ҠгҖҚ ЙҙбҙҖМғбҙҸ КңбҙҖМҒ КңбҙҸКҖбҙҖМҒКҖЙӘбҙҸкңұ бҙҳКҖбҙҸЙўКҖбҙҖбҙҚбҙҖбҙ…бҙҸкңұ бҙҳбҙҖКҖбҙҖ бҙҮкңұбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ рҹ’ҷ`);

removerHorarios(from);
reply(`гҖҢрҹ’ҷрҹ§ҠгҖҚ КңбҙҸКҖбҙҖМҒКҖЙӘбҙҸкңұ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҸкңұ бҙ„бҙҸбҙҚ кңұбҙңбҙ„бҙҮкңұкңұбҙҸ вң…`);

} catch (e) {
console.error('erro ao remover horario:', e);
reply(`гҖҢрҹ§ҠгҖҚ ЙҙбҙҖМғбҙҸ кң°бҙҸЙӘ бҙҳбҙҸssЙӘМҒбҙ бҙҮКҹ КҖбҙҮбҙҚбҙҸбҙ бҙҮКҖ бҙҸкңұ КңбҙҸКҖбҙҖМҒКҖЙӘбҙҸкңұ вқҢ`);
}
}
break;

case 'modohorario': {
if (!isGroup) return reply(mess.only.group);
if (!isGroupAdmins) return reply(mess.only.admins);

// Ativa ou desativa
if (isGroup && dataGp[0].isModohorario) {
dataGp[0].isModohorario = false;
setGp(dataGp);
reply(`гҖҢрҹ’ҷгҖҚ вҖў бҙҖбҙңбҙӣбҙҸ КңбҙҸКҖбҙҖМҒКҖЙӘбҙҸ бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ рҹҷҮрҹҸ»вҖҚвҷӮпёҸ`);
} else {
if (isGroup) {
dataGp[0].isModohorario = true;
setGp(dataGp);
}
reply(`гҖҢрҹ’ҷгҖҚ вҖў бҙҖбҙңбҙӣбҙҸ КңбҙҸКҖбҙҖМҒКҖЙӘбҙҸ бҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ рҹҷҮрҹҸ»вҖҚвҷӮпёҸ`);
}
}
break;

case 'grupo': {
try {
if (!isGroup) return reply(mess.onlyGroup())
if (!isGroupAdmins) return reply(mess.onlyAdmins())
if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin())
if (args.length < 1) return reply(`*бҙҮsбҙӣбҙҖ Т“бҙҖКҹбҙӣбҙҖЙҙбҙ…бҙҸ бҙҖКҹЙўбҙҸ бҙҖЙӘ КҖбҙҖбҙҳбҙҖбҙў рҹӨ·вҖҚвҷӮпёҸ*\n\n> бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ: ${prefix}ЙўКҖбҙңбҙҳбҙҸ бҙҖгҖҺ бҙҳбҙҖКҖбҙҖ бҙҖКҷКҖЙӘКҖ гҖҸ\n> ${prefix}ЙўКҖбҙңбҙҳбҙҸ Т“гҖҺ бҙҳбҙҖКҖбҙҖ Т“бҙҮбҙ„КңбҙҖКҖ гҖҸ`);
const metadata = await maki.groupMetadata(from)
const isFechado = metadata.announce === true 
if (args[0] === 'a') {
if (!isFechado) return reply(`*бҙҸ ЙўКҖбҙңбҙҳбҙҸ бҙҠбҙҖ бҙҮsбҙӣбҙҖ бҙҖКҷбҙҮКҖбҙӣбҙҸ sбҙҮЙҙКңбҙҸКҖ(бҙҖ) рҹ’ҒвҖҚвҷӮпёҸ*`)
await maki.groupSettingUpdate(from, 'not_announcement')
reply(`*ЙўКҖбҙңбҙҳбҙҸ бҙҖКҷбҙҮКҖбҙӣбҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ sбҙҮЙҙКңбҙҸКҖ(бҙҖ) рҹҷҮвҖҚвҷӮпёҸ*`)
} 
else if (args[0] === 'f') {
if (isFechado) return reply(`*бҙҸ ЙўКҖбҙңбҙҳбҙҸ бҙҠбҙҖ бҙҮsбҙӣбҙҖ Т“бҙҮбҙ„КңбҙҖбҙ…бҙҸ sбҙҮЙҙКңбҙҸКҖ(бҙҖ) рҹ’ҒвҖҚвҷӮпёҸ*`)
await maki.groupSettingUpdate(from, 'announcement')
reply(`*ЙўКҖбҙңбҙҳбҙҸ Т“бҙҮбҙ„КңбҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ sбҙҮЙҙКңбҙҸКҖ(бҙҖ) рҹҷҮвҖҚвҷӮпёҸ*`)
} 
else {
reply(`*бҙҮsбҙӣбҙҖ Т“бҙҖКҹбҙӣбҙҖЙҙбҙ…бҙҸ бҙҖКҹЙўбҙҸ бҙҖЙӘ КҖбҙҖбҙҳбҙҖбҙў рҹӨ·вҖҚвҷӮпёҸ*\n\n> бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ: ${prefix}ЙўКҖбҙңбҙҳбҙҸ бҙҖгҖҺ бҙҳбҙҖКҖбҙҖ бҙҖКҷКҖЙӘКҖ гҖҸ\n> ${prefix}ЙўКҖбҙңбҙҳбҙҸ Т“гҖҺ бҙҳбҙҖКҖбҙҖ Т“бҙҮбҙ„КңбҙҖКҖ гҖҸ`)
}
} catch (e) {
console.error(e)
}
break
}

case 'marcar': case 'marcar2':
if(!isGroup) return reply(mess.onlyGroup())
if(!isGroupAdmins) return reply(mess.onlyAdmins())
if(!isBotGroupAdmins) return reply(mess.onlyBotAdmin())
async function marcac() {
bla = []
blad = `*аҰ”а§ЈНЎНңаҜҖНңвқҘрқҷјрқҷ°рқҡҒрқҷІрқҷ°рқҷҪрқҷірқҷҫ рқҡғрқҷҫрқҷірқҷҫрқҡӮ рқҷҫрқҡӮ рқҷјрқҷҙрқҷјрқҷұрқҡҒрқҷҫрқҡӮ рқҷірқҷҫ рқҷ¶рқҡҒрқҡ„рқҷҝрқҷҫв—ҚбіқаЈӘ.вӢ•р–ҘҫбӨў*\nвҖў\n*вҖўвһӘ рқҷ¶рқҡҒрқҡ„рқҷҝрқҷҫ вҶ’ ${groupName}*${!q ? "" : `\n*вҖўвһӘ рқҷјрқҷҙрқҷҪрқҡӮрқҷ°рқҷ¶рқҷҙрқҷј вҶ’* ${q}`}\n\n`
for( let i of somembros ) {
blad += `вҠ№ р–Өҗ @${i.split("@")[0]}\n`
bla.push(i)
}
blam = JSON.stringify(somembros)
if(blam.length == 2) return reply(`NГЈo contГ©m nenhum membro comum no grupo.`)
await mentions(blad, bla, true)
}
marcac().catch((error) => {
console.log(error)
})
break


case 'marcarwa':
if(!isGroup) return reply(mess.onlyGroup())
if(!isGroupAdmins) return reply(mess.onlyAdmins())
if(!isBotGroupAdmins) return reply(mess.onlyBotAdmin())

if (q && q.includes(prefix)) {
return reply("вқҢ NГЈo Г© permitido usar comandos dentro deste comando.");
}

async function marcarwa() {
try {

let grpmdt = await maki.groupMetadata(from);
const membros_ = grpmdt.participants;
const normalizar = alvo => membros_.find(v => v.lid === alvo)?.jid || alvo;

let mencoes = [];
let texto = `*аҰ”а§ЈНЎНңаҜҖНңвқҘрқҷ»рқҷёрқҷҪрқҷәрқҡӮ рқҷірқҷҫрқҡӮ рқҷјрқҷҙрқҷјрқҷұрқҡҒрқҷҫрқҡӮ рқҷірқҷҫ рқҷ¶рқҡҒрқҡ„рқҷҝрқҷҫв—ҚбіқаЈӘ.вӢ•р–ҘҫбӨў*\nвҖў\n`
texto += `*вҖўвһӘ рқҷ¶рқҡҒрқҡ„рқҷҝрқҷҫ вҶ’ ${groupName}*`
texto += `${!q ? "" : `\n*вҖўвһӘ рқҷјрқҷҙрқҷҪрқҡӮрқҷ°рқҷ¶рқҷҙрқҷј вҶ’* ${q}`}\n\n`

for (let membro of membros_) {
const participante = normalizar(membro.id);
const numero = participante.split("@")[0];

// Impede marcar bot e dono
if (participante === botNumber || numerodono.includes(participante)) continue;

texto += `вҠ№ р–Өҗ @${numero}\n`
texto += `в•°вһҘ https://wa.me/${numero}\n\n`

mencoes.push(participante);
}

if (mencoes.length === 0)
return reply("вқҢ NГЈo contГ©m nenhum membro comum no grupo.");

await maki.sendMessage(
from,
{ text: texto, mentions: mencoes },
{ quoted: info }
);

} catch (e) {
console.error(e);
reply("вҡ пёҸ Erro ao gerar os links dos membros.");
}
}

marcarwa();
break;

case 'sender':
reply(sender.replace('@s.whatsapp.net', ''));
break;

case 'totalcmd':
case 'totalcomando': {
if (!SoDono && !isnit && !info.key.fromMe)
return reply(mess.onlyOwner());
const fs = require("fs");

fs.readFile("./maki.js", "utf8", (err, data) => {
if (err) {
console.error(err);
return reply("вқҢ Erro ao ler o arquivo de comandos.");
}

// conta quantos cases existem
const regex = /case\s'([^']+)'/g;
let total = 0;

while (regex.exec(data) !== null) {
total++;
}

reply(
`*КҷбҙҸбҙҚ бҙ…ЙӘбҙҖ ${pushname}!*

рҹӨ– вҖў бҙҮбҙң бҙ„бҙҸЙҙбҙӣбҙҮЙҙКңбҙҸ:
вң… *${total} бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸs* бҙҖбҙӣЙӘбҙ бҙҸs вҷҘпёҸ`
);
});
}
break;

case 'sair_all':
if (!SoDono && !info.key.fromMe) return reply("Este comando sГі pode ser executado pelo dono do bot.");
try {
const grupos = await maki.groupFetchAllParticipating();
for (let idGrupo in grupos) {
await maki.groupLeave(grupos[idGrupo].id);
}
reply("O bot saiu de todos os grupos com sucesso.");
} catch (erro) {
reply("Erro ao tentar sair dos grupos: " + String(erro));
}
break;

case 'clima':
case 'tempo':
maki.sendMessage(from, { react: { text: `рҹ“Ў`, key: info.key } })
if (args.length < 1) return reply(`*Sintaxe correta para uso:* ${prefix + command} nome da cidade\nвҖў Caso tenha algum acento, retire ok?`)
cidade = body.slice(7)
clima = await axios.get(`https://api.openweathermap.org/data/2.5/weather?q=${q}&appid=f5c0840c2457fbb64188a6d4be05618f&units=metric&lang=pt_br`)
if (clima.error) return reply(resposta.erro)
jr = `рҹҢһ Temperatura agora: ${clima.data.main.temp}ВәC\nрҹҸҷпёҸ Cidade: ${clima.data.name}\nрҹ”Ҙ Temperatura MГЎxima: ${clima.data.main.temp_max}В°C\nвқ„ Temperatura MГӯnima: ${clima.data.main.temp_min}В°C\nрҹҢҰ Clima: ${clima.data.weather[0].description}\nрҹ’§ Umidade de ar: ${clima.data.main.humidity}%\nрҹҢ« Ventos: ${clima.data.wind.speed}

Solicitado por: ${pushname}`
await maki.sendMessage(from, { text: jr }, { quoted: selo, contextInfo: { "mentionedJid": jr } })
break

case 'gtts': {
try {

if (args.length < 2)
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ бҙ…бҙҮ бҙңкңұбҙҸ:*
вһӨ ${prefix}gtts pt Oi tudo bem`)

const idioma = args[0].toLowerCase()
const texto = args.slice(1).join(" ")

if (texto.length > 200)
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҸ бҙҚбҙҖМҒxЙӘбҙҚбҙҸ бҙҳбҙҮКҖбҙҚЙӘбҙӣЙӘбҙ…бҙҸ бҙҮМҒ 200 бҙ„бҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖбҙҮкңұ.*`)

const url = `https://translate.google.com/translate_tts?ie=UTF-8&q=${encodeURIComponent(texto)}&tl=${idioma}&client=tw-ob`

const buffer = await getBuffer(url)

await maki.sendMessage(from, {
audio: buffer,
mimetype: 'audio/mpeg',
ptt: false,
contextInfo: canalInfo([])
}, { quoted: selo })

} catch (err) {

console.log(err)

reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҮКҖКҖбҙҸ бҙҖбҙҸ ЙўбҙҮКҖбҙҖКҖ бҙҸ бҙҖМҒбҙңбҙ…ЙӘбҙҸ.*`)

}
}
break

case 'gemini': {
try {

// вқҢ Sem pergunta
if (!q) {
return reply(
"вқ— VocГӘ precisa escrever uma pergunta junto com o comando."
);
}

// рҹ•’ DATA E HORA ATUAL (BR)
const agora = new Date();
const dataAtual = agora.toLocaleDateString('pt-BR', {
weekday: 'long',
day: '2-digit',
month: 'long',
year: 'numeric'
});
const horaAtual = agora.toLocaleTimeString('pt-BR', {
hour: '2-digit',
minute: '2-digit'
});

// вҸі Mensagem de processamento
const { key } = await maki.sendMessage(
from,
{ text: `вҸі Processando...` },
{ quoted: selo }
);

// рҹ§  PROMPT COM CONTEXTO TEMPORAL
const prompt = `
Data atual: ${dataAtual}
Hora atual: ${horaAtual}

VocГӘ Г© uma inteligГӘncia artificial assistente.
Use SEMPRE a data e hora acima como referГӘncia.

Pergunta do usuГЎrio:
${q}
`.trim();

// рҹҢҗ RequisiГ§ГЈo Г  API Gemini (PADRONIZADA)
const data = await fetchJson(
API_URL + `/api/gemini?texto=${encodeURIComponent(prompt)}&apikey=` + API_KEY_TOKITO
);

// рҹ§  NormalizaГ§ГЈo da resposta
let resposta = '';

if (typeof data?.resposta === 'string') {
resposta = data.resposta.trim();

} else if (data?.resposta?.candidates?.length) {
resposta = data.resposta.candidates[0]?.content?.parts
?.map(p => p.text || '')
.join('')
.trim();

} else if (data?.candidates?.length) {
resposta = data.candidates[0]?.content?.parts
?.map(p => p.text || '')
.join('')
.trim();
}

if (!resposta) resposta = 'Sem resposta da IA рҹҳ•';

// вңүпёҸ Edita a mensagem inicial com a resposta final
await maki.sendMessage(
from,
{
text: resposta,
edit: key,
linkPreview: false
}
);

} catch (err) {
console.error('Erro no comando Gemini:', err);
reply(mess.error());
}
}
break;

case 'perfil': {
