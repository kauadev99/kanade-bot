// Usa a menГ§ГЈo se existir
const usur = marc_tds;

if (!JSON.stringify(vip).includes(usur)) return reply("вқҢ Este nГәmero nГЈo estГЎ incluso atualmente na lista de usuГЎrios VIP.");

AB = vip.map(i => i.id).indexOf(usur);
