await maki.sendMessage(
ChatID,
{
image: fs.readFileSync(imageDir),
caption: TextM,
contextInfo: contextMessageInfo,
},
{ quoted: selo }
);
} catch (errorMessage) {
return reply(String(errorMessage));
}
};

async function desativarAluguelGrupo(from) {
try {
gruposAutorizados = gruposAutorizados.filter(g => g.id !== from)
salvarGrupos()

const meta = await maki.groupMetadata(from)
const midia = carregarMidia("fotomenu")

const msg = {
caption: mess.aluguel(ownerNumber, NumeroDoBot, NomeDoBot),
contextInfo: canalInfo(meta.participants.map(p => p.id))
}

if (midia.type === "video") {
msg.video = midia.data
msg.gifPlayback = true
} else if (midia.type === "image") {
msg.image = midia.data
} else {
msg.text = msg.caption
}

await maki.sendMessage(from, msg)
} catch (e) {
console.log("Erro ao desativar aluguel:", e)
}
}

function isGrupoAutorizado(from) {
const grupo = gruposAutorizados.find(g => g.id === from)
if (!grupo) return false

const agora = new Date()
const expira = new Date(grupo.expiraEm)

if (agora > expira) {
desativarAluguelGrupo(from)
return false
}
return true
}

if (isGroup && isModoAluguel && !SoDono && !isGrupoAutorizado(from)) {
 return
}

function msToTime(ms) {
let seg = Math.floor(ms / 1000)
let min = Math.floor(seg / 60)
let hr = Math.floor(min / 60)
let dia = Math.floor(hr / 24)
let ano = Math.floor(dia / 365)
seg %= 60
min %= 60
hr %= 24
dia %= 365
let partes = []
if (ano) partes.push(`${ano} бҙҖЙҙбҙҸ${ano > 1 ? 'кңұ' : ''}`)
if (dia) partes.push(`${dia} бҙ…ЙӘбҙҖ${dia > 1 ? 'кңұ' : ''}`)
if (hr) partes.push(`${hr} КңбҙҸКҖбҙҖ${hr > 1 ? 'кңұ' : ''}`)
if (min) partes.push(`${min} бҙҚЙӘЙҙбҙңбҙӣбҙҸ${min > 1 ? 'кңұ' : ''}`)
if (seg) partes.push(`${seg} кңұбҙҮЙўбҙңЙҙбҙ…бҙҸ${seg > 1 ? 'кңұ' : ''}`)
return partes.length ? partes.join(', ').replace(/,([^,]*)$/, ' e$1') : 'бҙҖЙўбҙҸКҖбҙҖ КңбҙҖ бҙ©бҙҸбҙңбҙ„бҙҸ'
}

