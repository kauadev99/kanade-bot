const isVideo = command === 'bratvid';
const apiUrl = API_URL + (isVideo ? `/api/stickers/brat-vid?text=${encodeURIComponent(q)}&apikey=` + API_KEY_TOKITO : `/api/stickers/brat-img?text=${encodeURIComponent(q)}&apikey=` + API_KEY_TOKITO);
const buffer = await getBuffer(apiUrl);
if (!buffer) return reply("Erro ao gerar figurinha.");
