    );

    const estilos = res.data?.resultado || res.data?.result || res.data || [];
    if (!estilos || estilos.length === 0) 
      return reply("вқҢ NГЈo achei estilos pra esse nome.");

    const rows = estilos.map((item, i) => ({
      title: item.nome || `рҹ’  Estilo ${i + 1}`,
      description: item.texto || item.nick || item,
      rowId: `copiar_${i}`
    }));

    const media = await prepareWAMessageMedia(
      { image: { url: "https://files.catbox.moe/eclip9.jpg" } },
      { upload: maki.waUploadToServer }
    );

    await maki.relayMessage(from, {
      messageContextInfo: { deviceListMetadata: {}, deviceListMetadataVersion: 2 },
      interactiveMessage: proto.Message.InteractiveMessage.create({
        header: {
          hasMediaAttachment: true,
          imageMessage: media.imageMessage
        },
        body: {
