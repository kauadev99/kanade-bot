chances: { cassino: 0, minerar: 0 },
},
],
});
CoinsUpdate(RG_SCOINS);
} else if (
RG_SCOINS.some((i) => i.grupo === from) &&
!RG_SCOINS[ID_G_COINS]?.usus?.some((i) => i?.id === sender)
) {
RG_SCOINS[ID_G_COINS].usus.push({
id: sender,
coins: 0,
data: 0,
chances: { cassino: 0, minerar: 0 },
});
CoinsUpdate(RG_SCOINS);
}

