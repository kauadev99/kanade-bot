reply(`*бҙҸ ЙўКҖбҙңбҙҳбҙҸ Т“бҙҸЙӘ КҷбҙҖЙҙЙӘбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ, бҙҖЙўбҙҸКҖбҙҖ ЙҙЙӘЙҙЙўбҙңбҙҮбҙҚ бҙҳбҙҸбҙ…бҙҮКҖбҙҖ бҙңsбҙҖКҖ бҙҚбҙҮбҙңs бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸs рҹҷҮвҖҚвҷӮпёҸ*`)
} else {
if(!isBanchat) return reply(`*бҙҮsбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ бҙҠбҙҖ бҙҮsбҙӣбҙҖ бҙ…бҙҮsКҷбҙҖЙҙЙӘбҙ…бҙҸ sбҙҮЙҙКңбҙҸКҖ(бҙҖ) рҹӨ·вҖҚвҷӮпёҸ*`)
dataGp[0].bangp = false
setGp(dataGp)
reply(`*бҙҸ ЙўКҖбҙңбҙҳбҙҸ Т“бҙҸЙӘ бҙ…бҙҮsКҷбҙҖЙҙЙӘбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ sбҙҮЙҙКңбҙҸКҖ(бҙҖ), бҙҖЙўбҙҸКҖбҙҖ бҙӣбҙҸбҙ…бҙҸs бҙ…бҙҮssбҙҮ ЙўКҖбҙңбҙҳбҙҸ бҙҳбҙҸбҙ…бҙҮ бҙңsбҙҖКҖ бҙҚбҙҮбҙңs бҙ„бҙҸбҙҚбҙҖЙҙбҙҸs рҹҷҮвҖҚвҷӮпёҸ*`)
}
break

case 'addautorm':
