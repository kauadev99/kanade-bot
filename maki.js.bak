}, 
{ quoted: selo }
);
} catch (error) {
console.error(error);
return reply(mess.error());
}
} else {
reply(`*бҙҚбҙҮЙҙбҙ„ЙӘбҙҸЙҙбҙҮ бҙңбҙҚбҙҖ ЙӘбҙҚбҙҖЙўбҙҮбҙҚ бҙҳбҙҖКҖбҙҖ бҙҖбҙҳКҹЙӘбҙ„бҙҖКҖ бҙҸ бҙҮТ“бҙҮЙӘбҙӣбҙҸ Кңбҙ…* рҹҷҮвҖҚвҷӮпёҸ`);
}
break;

case 'sair':
case 'sairgp':
if(isGroup && !SoDono && !info.key.fromMe) return reply("Este comando sГі o bot ou o dono pode executar..")
try {
