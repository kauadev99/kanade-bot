case 'numero-dono':
if (!SoDono && !isnit && !info.key.fromMe)
return reply(mess.onlyOwner());
if (q.match(/[a-z]/i)) return reply("Гү apenas nГәmeros..");
setting.ownerNumber = q
.trim()
.replace(new RegExp("[()+-/ +/]", "gi"), "");
fs.writeFileSync(
"./configs/INFO_DADOS/settings.json",
JSON.stringify(setting, null, 2)
);
reply(`рҹ“һ *бҙҸ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ бҙ…бҙҸ бҙ…бҙҸЙҙбҙҸ Т“бҙҸЙӘ бҙ„бҙҸЙҙТ“ЙӘЙўбҙңКҖбҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ бҙҳбҙҖКҖбҙҖ:* ${q}`);
break;

