if(q.trim() > 1) return reply(`*бҙ„бҙҖКҹбҙҚбҙҖ бҙҖЙӘ бҙҳбҙҖЙӘбҙўбҙҖбҙңбҙҚ, бҙҸ бҙҳКҖбҙҮТ“ЙӘxбҙҸ sбҙҸ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖбҙ…бҙҸ бҙңбҙҚ бҙ…бҙҮ бҙ„бҙҖбҙ…бҙҖ бҙ бҙҮбҙў рҹҷ…вҖҚвҷӮпёҸ*`)
if(dataGp[0].prefixos.indexOf(q.trim()) >= 0) return reply(`*бҙҮsбҙӣбҙҮ бҙҳКҖбҙҮТ“ЙӘxбҙҸ ЙҙбҙҖбҙҸ бҙҮsбҙӣбҙҖ ЙӘЙҙбҙ„КҹбҙңsбҙҸ рҹҷҶвҖҚвҷӮпёҸ*`)
