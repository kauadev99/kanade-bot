let blcp = numero + "@s.whatsapp.net"

if (!ban.includes(blcp))
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҮкңұбҙӣбҙҮ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ ЙҙбҙҖМғбҙҸ бҙҮкңұбҙӣбҙҖМҒ ЙҙбҙҖ КҹЙӘкңұбҙӣбҙҖ бҙ…бҙҮ КҷКҹбҙҸЗ«бҙңбҙҮбҙҖбҙ…бҙҸкңұ.*`)

