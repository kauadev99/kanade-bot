        nativeFlowMessage: {
          buttons: [{
            name: "single_select",
            buttonParamsJson: JSON.stringify({
              title: "SELECIONAR ESTILO",
              sections: [{ title: "Estilos", rows }]
            })
          }]
        }
      })
    }, { quoted: info });

