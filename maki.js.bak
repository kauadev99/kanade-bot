case 'comerdajob': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

