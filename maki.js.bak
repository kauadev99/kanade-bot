try {

await maki.sendMessage(from, { react: { text: "вқӨпёҸвҖҚрҹ”Ҙ", key: info.key } });

const user = pushname || sender_ou_n?.split("@")[0];

let perfil = await maki.profilePictureUrl(sender_ou_n, 'image')
.catch(_ => "https://files.catbox.moe/yet8m8.jpg");

