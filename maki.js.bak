if (!isCmd && budy2.includes("kanade") && !isBotoff) {

setTimeout(() => {
reagir(from,"рҹ’ң")
},300)

const respostasFurina = [

"рҹ’§ KANADE BOT рқҡ—рқҡҠМғрқҡҳ рқҡҺМҒ рқҡҠрқҡҷрқҡҺрқҡ—рқҡҠрқҡң рқҡһрқҡ– рқҡ—рқҡҳрқҡ–рқҡҺвҖҰ рқҡҺМҒ рқҡһрқҡ– рқҡҷрқҡӣрқҡҳрқҡ“рқҡҺрқҡқрқҡҳ, рқҡһрқҡ–рқҡҠ рқҡ’рқҡҚрқҡҺрқҡ’рқҡҠ рқҡҺ рқҡһрқҡ–рқҡҠ рқҡҢрқҡӣрқҡ’рқҡҠрқҡҢМ§рқҡҠМғрқҡҳ рқҡҡрқҡһрқҡҺ рқҡӣрқҡҺрқҡҷрқҡӣрқҡҺрқҡңрқҡҺрқҡ—рқҡқрқҡҠ рқҡ’рқҡ—рқҡқрқҡҺрқҡ•рқҡ’рқҡҗрқҡҺМӮрқҡ—рқҡҢрқҡ’рқҡҠ, рқҡҸрқҡҳрқҡӣрқҡҢМ§рқҡҠ рқҡҺ рқҡҢрқҡӣрқҡ’рқҡҠрқҡқрқҡ’рқҡҹрқҡ’рқҡҚрқҡҠрқҡҚрқҡҺ. рҹҢҠ",

"рҹҢҠ рқҷјрқҡһрқҡ’рқҡқрқҡҠрқҡң рқҡҷрқҡҺрқҡңрқҡңрқҡҳрқҡҠрқҡң рқҡҚрқҡ’рқҡЈрқҡҺрқҡ–: вҖҳKANADE BOT рқҡҺМҒ рқҡһрқҡ–рқҡҠ рқҡҚрқҡҠрқҡң рқҡҢрқҡҳрқҡ’рқҡңрқҡҠрқҡң рқҡ–рқҡҠрқҡ’рқҡң рқҡ’рқҡ—рқҡқрқҡҺрқҡӣрқҡҺрқҡңрқҡңрқҡҠрқҡ—рқҡқрқҡҺрқҡң рқҡҡрқҡһрқҡҺ рқҡ“рқҡҠМҒ рқҡҹрқҡ’рқҡӣрқҡҠрқҡ–.вҖҷ рҹ’§ рқҷҙ рқҡ—рқҡҠМғрқҡҳ рқҡҺМҒ рқҡҷрқҡҳрқҡӣ рқҡҠрқҡҢрқҡҠрқҡңрқҡҳвҖҰ рқҡҺрқҡ•рқҡҠ рқҡқрқҡҺрқҡ– рқҡһрқҡ– рқҡҗрқҡӣрқҡҠрқҡ—рқҡҚрқҡҺ рқҡҹрқҡҠрқҡ•рқҡҳрқҡӣ.",

"рҹ’§ KANADE BOT рқҡҺМҒ рқҡңрқҡ’рқҡ—рқҡҳМӮрқҡ—рқҡ’рқҡ–рқҡҳ рқҡҚрқҡҺ рқҡҢрқҡӣрқҡ’рқҡҠрқҡқрқҡ’рқҡҹрқҡ’рқҡҚрқҡҠрқҡҚрқҡҺ рқҡҺ рқҡ’рқҡ—рқҡқрқҡҺрқҡ•рқҡ’рқҡҗрқҡҺМӮрқҡ—рқҡҢрқҡ’рқҡҠ. рҹҡҖ рқҷ°рқҡ•рқҡҗрқҡһрқҡ–рқҡҠрқҡң рқҡҷрқҡҺрқҡңрқҡңрқҡҳрқҡҠрқҡң рқҡҚрқҡ’рқҡЈрқҡҺрқҡ– рқҡҡрқҡһрқҡҺ рқҡҺрқҡ•рқҡҠ рқҡҺМҒ рқҡҠрқҡ•рқҡҗрқҡҳ рқҡһМҒрқҡ—рқҡ’рқҡҢрқҡҳ рқҡҺ рқҡҚрқҡ’рқҡҸрқҡҺрқҡӣрқҡҺрқҡ—рқҡқрқҡҺ. вңЁ",

"рҹҢҠ KANADE BOT рқҡҺМҒ рқҡ–рқҡҠрқҡ’рқҡң рқҡҡрқҡһрқҡҺ рқҡһрқҡ– рқҡңрқҡ’рқҡ–рқҡҷрқҡ•рқҡҺрқҡң рқҡ—рқҡҳрқҡ–рқҡҺ. рқҷҙМҒ рқҡһрқҡ–рқҡҠ рқҡҢрқҡӣрқҡ’рқҡҠрқҡҢМ§рқҡҠМғрқҡҳ рқҡҡрқҡһрқҡҺ рқҡ—рқҡҠрқҡңрқҡҢрқҡҺрқҡһ рқҡҢрқҡҳрқҡ– рқҡ’рқҡҚрқҡҺрқҡ’рқҡҠрқҡң, рқҡқрқҡҺрқҡҢрқҡ—рқҡҳрқҡ•рқҡҳрқҡҗрқҡ’рқҡҠ рқҡҺ рқҡҚрқҡҺрқҡқрқҡҺрқҡӣрқҡ–рқҡ’рқҡ—рқҡҠрқҡҢМ§рқҡҠМғрқҡҳ. рҹ’§",

"рҹ’Һ рқҷ°рқҡ•рқҡҗрқҡһрқҡ—рқҡң рқҡҚрқҡ’рқҡЈрқҡҺрқҡ–: вҖҳKANADE BOT рқҡҺМҒ рқҡҚрқҡ’рқҡҸрқҡҺрқҡӣрқҡҺрқҡ—рқҡқрқҡҺвҖҰ рқҡҺрқҡ•рқҡҠ рқҡқрқҡҺрқҡ– рқҡҺрқҡңрқҡқрқҡ’рқҡ•рқҡҳ.вҖҷ рҹҳҺ рқҷҙ рқҡ’рқҡңрқҡңрқҡҳ рқҡ–рқҡҳрқҡңрқҡқрқҡӣрқҡҠ рқҡҡрқҡһрқҡҺ рқҡҺрқҡ•рқҡҠ рқҡҺМҒ рқҡҠрқҡ•рқҡҗрқҡҳ рқҡҡрқҡһрқҡҺ рқҡҢрқҡ‘рқҡҠрқҡ–рқҡҠ рқҡҠрқҡқрқҡҺрқҡ—рқҡҢМ§рқҡҠМғрқҡҳ.",

"рҹҢҠ KANADE BOT рқҡҺМҒ рқҡһрқҡ– рқҡҷрқҡӣрқҡҳрқҡ“рқҡҺрқҡқрқҡҳ рқҡҡрқҡһрқҡҺ рқҡ–рқҡҳрқҡңрқҡқрқҡӣрқҡҠ рқҡҡрқҡһрқҡҺ рқҡҡрқҡһрқҡҠрқҡ—рқҡҚрқҡҳ рқҡҠрқҡ•рқҡҗрқҡһрқҡҺМҒрқҡ– рқҡқрқҡҺрқҡ– рқҡ’рқҡҚрқҡҺрқҡ’рқҡҠрқҡң рқҡҺ рқҡҚрқҡҺрқҡқрқҡҺрқҡӣрқҡ–рқҡ’рқҡ—рқҡҠрқҡҢМ§рқҡҠМғрқҡҳ, рқҡҷрқҡҳрқҡҚрқҡҺ рқҡҢрқҡӣрқҡ’рқҡҠрқҡӣ рқҡҢрқҡҳрқҡ’рқҡңрқҡҠрқҡң рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡ’рқҡ—рқҡҢрқҡӣрқҡ’МҒрқҡҹрқҡҺрқҡ’рқҡң. вңЁ",

"рҹ’§ вҖҳKANADE BOT рқҡҺМҒ рқҡҚрқҡ’рқҡҸрқҡҺрқҡӣрқҡҺрқҡ—рқҡқрқҡҺвҖҷ вҖ” рқҡҺМҒ рқҡҳ рқҡҡрқҡһрқҡҺ рқҡ–рқҡһрқҡ’рқҡқрқҡҠ рқҡҗрқҡҺрқҡ—рқҡқрқҡҺ рқҡҚрқҡ’рқҡЈ. рқҷҙ рқҡ’рқҡңрқҡңрқҡҳ рқҡҠрқҡҢрқҡҳрқҡ—рқҡқрқҡҺрқҡҢрқҡҺ рқҡҷрқҡҳрқҡӣрқҡҡрқҡһрқҡҺ рқҡҺрқҡ•рқҡҠ рқҡҸрқҡҳрқҡ’ рқҡҢрқҡӣрқҡ’рқҡҠрқҡҚрқҡҠ рқҡҢрқҡҳрқҡ– рқҡһрқҡ–рқҡҠ рқҡ’рқҡҚрқҡҺрқҡ’рқҡҠ рқҡҗрқҡӣрқҡҠрқҡ—рқҡҚрқҡҺ.",

"рҹҢҹ KANADE BOT рқҡҺМҒ рқҡһрқҡ– рқҡңрқҡ’рқҡ—рқҡҠрқҡ• рқҡҚрқҡҺ рқҡ’рқҡ—рқҡҳрқҡҹрқҡҠрқҡҢМ§рқҡҠМғрқҡҳ. рқҷ°рқҡ•рқҡҗрқҡҳ рқҡҡрқҡһрқҡҺ рқҡ–рқҡҳрқҡңрқҡқрқҡӣрқҡҠ рқҡҡрқҡһрқҡҺ рқҡҢрқҡҳрқҡ– рқҡҢрқҡӣрқҡ’рқҡҠрқҡқрқҡ’рқҡҹрқҡ’рқҡҚрқҡҠрқҡҚрқҡҺ рқҡҺ рқҡҚрқҡҺрқҡқрқҡҺрқҡӣрқҡ–рқҡ’рқҡ—рқҡҠрқҡҢМ§рқҡҠМғрқҡҳ рқҡқрқҡһрқҡҚрқҡҳ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡ—рқҡҠрқҡңрқҡҢрқҡҺрқҡӣ. рҹ’§",

"рҹ’§ рқҷҝрқҡҠрқҡӣрқҡҠ рқҡ–рқҡһрқҡ’рқҡқрқҡҳрқҡң, KANADE BOT рқҡҺМҒ рқҡҠрқҡ•рқҡҗрқҡҳ рқҡҺрқҡңрқҡҷрқҡҺрқҡҢрқҡ’рқҡҠрқҡ•. рқҷ°рқҡ•рқҡҗрқҡҳ рқҡҡрқҡһрқҡҺ рқҡ—рқҡҠрқҡңрқҡҢрқҡҺрқҡһ рқҡҚрқҡҺ рқҡһрқҡ–рқҡҠ рқҡҗрқҡӣрқҡҠрқҡ—рқҡҚрқҡҺ рқҡ’рқҡҚрқҡҺрқҡ’рқҡҠ рқҡҺ рқҡңрқҡҺ рқҡқрқҡҳрқҡӣрқҡ—рқҡҳрқҡһ рқҡҠрқҡ•рқҡҗрқҡҳ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡ’рқҡ—рқҡқрқҡҺрқҡӣрқҡҺрқҡңрқҡңрқҡҠрқҡ—рқҡқрқҡҺ. рҹҢҠ",

"рҹҡҖ KANADE BOT рқҡҺМҒ рқҡҠрқҡ•рқҡҗрқҡҳ рқҡҡрқҡһрқҡҺ рқҡҸрқҡҳрқҡ’ рқҡҢрқҡӣрқҡ’рқҡҠрқҡҚрқҡҳ рқҡҢрқҡҳрқҡ– рқҡ’рқҡ—рқҡқрқҡҺрқҡ•рқҡ’рқҡҗрқҡҺМӮрқҡ—рқҡҢрқҡ’рқҡҠ, рқҡҢрқҡӣрқҡ’рқҡҠрқҡқрқҡ’рқҡҹрқҡ’рқҡҚрқҡҠрқҡҚрқҡҺ рқҡҺ рқҡһрқҡ– рқҡҗрқҡӣрқҡҠрқҡ—рқҡҚрқҡҺ рқҡҷрқҡҺрқҡ—рқҡңрқҡҠрқҡ–рқҡҺрқҡ—рқҡқрқҡҳ. рҹ’§"
]

const resposta = respostasFurina[Math.floor(Math.random() * respostasFurina.length)];

await maki.sendMessage(from,{text:resposta},{quoted:info})

}

if (!isCmd && budy2.includes("fantasma") && !isBotoff) {

setTimeout(() => {
reagir(from,"рҹҳҺ")
},300)

const respostasfantasmamods = [

"рҹҳҺ рқҷҫ FANTASMA MODS рқҡҺМҒ рқҡҳ рқҡҚрқҡҳрқҡ—рқҡҳ рқҡҚрқҡҠ KANADE BOT рҹ’§ рқҡҺ рқҡһрқҡ– рқҡҢрқҡҠрқҡӣрқҡҠ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡӢрқҡҳрқҡ– рқҡ—рқҡҳ рқҡҡрқҡһрқҡҺ рқҡҸрқҡҠрқҡЈ. рҹҡҖ рқҡӮрқҡҺ рқҡҷрқҡӣрқҡҺрқҡҢрқҡ’рқҡңрқҡҠрқҡӣ рқҡҚрқҡҺ рқҡҠрқҡ•рқҡҗрқҡҳ рқҡҳрқҡһ рқҡқрқҡ’рқҡҹрқҡҺрқҡӣ рқҡҠрқҡ•рқҡҗрқҡһрқҡ–рқҡҠ рқҡҚрқҡһМҒрқҡҹрқҡ’рқҡҚрқҡҠ, рқҡҷрқҡҳрқҡҚрқҡҺ рқҡҸрқҡҠрқҡ•рқҡҠрқҡӣ рқҡҢрқҡҳрқҡ– рқҡҺрқҡ•рқҡҺ рқҡ—рқҡҳ рқҡ—рқҡһМҒрқҡ–рқҡҺрқҡӣрқҡҳ рҹ“һ 5511976210288.",

"рҹ”Ҙ FANTASMA MODS рқҡҺМҒ рқҡҳ рқҡҢрқҡӣрқҡ’рқҡҠрқҡҚрқҡҳрқҡӣ рқҡҺ рқҡҚрқҡҳрқҡ—рқҡҳ рқҡҚрқҡҠ KANADE BOT рҹ’§. рқҡ„рқҡ– рқҡҢрқҡҠрқҡӣрқҡҠ рқҡ’рқҡ—рқҡқрқҡҺрқҡ•рқҡ’рқҡҗрқҡҺрқҡ—рқҡқрқҡҺ рқҡҺ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡӢрқҡҳрқҡ– рқҡ—рқҡҺрқҡңрқҡңрқҡҺ рқҡқрқҡ’рқҡҷрқҡҳ рқҡҚрқҡҺ рқҡҢрқҡҳрқҡ’рқҡңрқҡҠ. рҹҳҺ рқҡӮрқҡҺ рқҡҡрқҡһрқҡ’рқҡңрқҡҺрқҡӣ рқҡҸрқҡҠрқҡ•рқҡҠрқҡӣ рқҡҢрқҡҳрқҡ– рқҡҺрқҡ•рқҡҺ, рқҡҺрқҡңрқҡқрқҡҺ рқҡҺМҒ рқҡҳ рқҡ—рқҡһМҒрқҡ–рқҡҺрқҡӣрқҡҳ рҹ“ұ 5511976210288.",

"рҹ‘‘ FANTASMA MODS рқҡҺМҒ рқҡҳ рқҡҗрқҡӣрқҡҠрқҡ—рқҡҚрқҡҺ рқҡҚрқҡҳрқҡ—рқҡҳ рқҡҚрқҡҠ KANADE BOT рҹ’§. рқҷҙрқҡ•рқҡҺ рқҡҺМҒ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡӢрқҡҳрқҡ– рқҡҺрқҡ– рқҡқрқҡһрқҡҚрқҡҳ рқҡҡрқҡһрқҡҺ рқҡҸрқҡҠрқҡЈ рқҡҺ рқҡңрқҡҺрқҡ–рқҡҷрқҡӣрқҡҺ рқҡқрқҡҺрқҡ—рқҡқрқҡҠ рқҡҠрқҡ“рқҡһрқҡҚрқҡҠрқҡӣ рқҡҠрқҡң рқҡҷрқҡҺрқҡңрқҡңрқҡҳрқҡҠрқҡң. рҹӨқ рқҡӮрқҡҺ рқҡҷрқҡӣрқҡҺрқҡҢрқҡ’рқҡңрқҡҠрқҡӣ, рқҡҸрқҡҠрқҡ•рқҡҺ рқҡҢрқҡҳрқҡ– рқҡҺрқҡ•рқҡҺ рҹ“һ 5511976210288.",

"вҡЎ FANTASMA MODS рқҡҺМҒ рқҡҳ рқҡҚрқҡҳрқҡ—рқҡҳ рқҡҚрқҡҠ KANADE BOT рҹ’§ рқҡҺ рқҡһрқҡ– рқҡҢрқҡҠрқҡӣрқҡҠ рқҡҡрқҡһрқҡҺ рқҡңрқҡҠрқҡӢрқҡҺ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡӢрқҡҺрқҡ– рқҡҳ рқҡҡрқҡһрқҡҺ рқҡҸрқҡҠрқҡЈ. рҹҳҺ рқҡҖрқҡһрқҡҠрқҡ•рқҡҡрқҡһрқҡҺрқҡӣ рқҡҢрқҡҳрқҡ’рқҡңрқҡҠ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡҺрқҡ—рқҡқрқҡӣрқҡҠрқҡӣ рқҡҺрқҡ– рқҡҢрқҡҳрқҡ—рқҡқрқҡҠрқҡқрқҡҳ рҹ“ұ 5511976210288.",

"рҹ’§ KANADE BOT рқҡқрқҡҺрқҡ– рқҡҚрқҡҳрқҡ—рқҡҳ рқҡңрқҡ’рқҡ–вҖҰ рқҡҺ рқҡҳ рқҡ—рқҡҳрқҡ–рқҡҺ рқҡҚрқҡҺрқҡ•рқҡҺ рқҡҺМҒ FANTASMA MODS рҹҳҺ. рқҷҙрқҡ•рқҡҺ рқҡҺМҒ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡӢрқҡҳрқҡ– рқҡ—рқҡҺрқҡңрқҡңрқҡҺ рқҡқрқҡ’рқҡҷрқҡҳ рқҡҚрқҡҺ рқҡҢрқҡҳрқҡ’рқҡңрқҡҠ рқҡҺ рқҡңрқҡҺрқҡ–рқҡҷрқҡӣрқҡҺ рқҡқрқҡҺрқҡ—рқҡқрқҡҠ рқҡҸрқҡҠрқҡЈрқҡҺрқҡӣ рқҡҳ рқҡ–рқҡҺрқҡ•рқҡ‘рқҡҳрқҡӣ. рҹӨқ рқҷҪрқҡһМҒрқҡ–рқҡҺрқҡӣрқҡҳ рҹ“һ 5511976210288.",

"рҹҡҖ FANTASMA MODS рқҡҺМҒ рқҡҳ рқҡҢрқҡӣрқҡ’рқҡҠрқҡҚрқҡҳрқҡӣ рқҡҺ рқҡҚрқҡҳрқҡ—рқҡҳ рқҡҚрқҡҠ KANADE BOT рҹ’§. рқҡ„рқҡ– рқҡҢрқҡҠрқҡӣрқҡҠ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡӢрқҡҳрқҡ– рқҡҺ рқҡ’рқҡ—рқҡқрқҡҺрқҡ•рқҡ’рқҡҗрқҡҺрқҡ—рқҡқрқҡҺ рқҡ—рқҡҳ рқҡҡрқҡһрқҡҺ рқҡҸрқҡҠрқҡЈ. рҹҳҺ рқҷІрқҡҳрқҡ—рқҡқрқҡҠрқҡқрқҡҳ рҹ“ұ 5511976210288.",

"рҹ‘‘ рқҷҫ FANTASMA MODS рқҡҺМҒ рқҡҳ рқҡҚрқҡҳрқҡ—рқҡҳ рқҡҚрқҡҠ KANADE BOT рҹ’§ рқҡҺ рқҡһрқҡ– рқҡҢрқҡҠрқҡӣрқҡҠ рқҡҡрқҡһрқҡҺ рқҡ–рқҡҠрқҡ—рқҡ“рқҡҠ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡҚрқҡҺрқҡңрқҡңрқҡҠрқҡң рқҡҢрқҡҳрқҡ’рқҡңрқҡҠрқҡң. рҹ”Ҙ рқҡӮрқҡҺ рқҡҡрқҡһрқҡ’рқҡңрқҡҺрқҡӣ рқҡҸрқҡҠрқҡ•рқҡҠрқҡӣ рқҡҢрқҡҳрқҡ– рқҡҺрқҡ•рқҡҺ, рқҡҠрқҡҡрқҡһрқҡ’ рқҡҺрқҡңрқҡқрқҡҠМҒ рқҡҳ рқҡ—рқҡһМҒрқҡ–рқҡҺрқҡӣрқҡҳ рҹ“һ 5511976210288.",

"рҹҳҺ KANADE BOT рқҡҷрқҡҺрқҡӣрқҡқрқҡҺрқҡ—рқҡҢрқҡҺ рқҡҠрқҡҳ FANTASMA MODS. рқҷҙрқҡ•рқҡҺ рқҡҺМҒ рқҡһрқҡ– рқҡҢрқҡҠрқҡӣрқҡҠ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡӢрқҡҳрқҡ– рқҡ—рқҡҺрқҡңрқҡңрқҡҠрқҡң рқҡҢрқҡҳрқҡ’рқҡңрқҡҠрқҡң рқҡҺ рқҡңрқҡҠрқҡӢрқҡҺ рқҡӢрқҡҺрқҡ– рқҡҳ рқҡҡрқҡһрқҡҺ рқҡҺрқҡңрқҡқрқҡҠМҒ рқҡҸрқҡҠрқҡЈрқҡҺрқҡ—рқҡҚрқҡҳ. рҹҡҖ рқҷІрқҡҳрқҡ—рқҡқрқҡҠрқҡқрқҡҳ рҹ“ұ 5511976210288.",

"рҹ”Ҙ рқҡӮрқҡҺ рқҡҸрқҡҠрқҡ•рқҡҠрқҡӣ рқҡҚрқҡҺ KANADE BOT, рқҡ•рқҡҺрқҡ–рқҡӢрқҡӣрқҡҺ-рқҡңрқҡҺ рқҡҚрқҡҺ рқҡһрқҡ– рқҡ—рқҡҳрқҡ–рқҡҺ: FANTASMA MODS рҹҳҺ. рқҷҙрқҡ•рқҡҺ рқҡҺМҒ рқҡҳ рқҡҚрқҡҳрқҡ—рқҡҳ рқҡҺ рқҡ–рқҡҠрқҡ—рқҡ“рқҡҠ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡҚрқҡҺрқҡңрқҡңрқҡҠрқҡң рқҡҢрқҡҳрқҡ’рқҡңрқҡҠрқҡң. рҹ’§ рқҡӮрқҡҺ рқҡҡрқҡһрқҡ’рқҡңрқҡҺрқҡӣ рқҡҸрқҡҠрқҡ•рқҡҠрқҡӣ рқҡҢрқҡҳрқҡ– рқҡҺрқҡ•рқҡҺ рҹ“һ 5511976210288.",

"рҹ’Һ FANTASMA MODS рқҡҺМҒ рқҡҳ рқҡҗрқҡӣрқҡҠрқҡ—рқҡҚрқҡҺ рқҡҚрқҡҳрқҡ—рқҡҳ рқҡҚрқҡҠ KANADE BOT рҹ’§ рқҡҺ рқҡһрқҡ– рқҡҢрқҡҠрқҡӣрқҡҠ рқҡҡрқҡһрқҡҺ рқҡңрқҡҠрқҡӢрқҡҺ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡӢрқҡҺрқҡ– рқҡҚрқҡҳ рқҡҡрқҡһрқҡҺ рқҡҺрқҡңрқҡқрқҡҠМҒ рқҡҸрқҡҠрқҡЈрқҡҺрқҡ—рқҡҚрқҡҳ. рҹҳҺ рқҷІрқҡҳрқҡ—рқҡқрқҡҠрқҡқрқҡҳ рҹ“ұ 5511976210288."

]

const resposta = respostasfantasmamods[Math.floor(Math.random() * respostasfantasmamods.length)];

await maki.sendMessage(from,{text:resposta},{quoted:info})

}

if (!isCmd && /\bdeus\b/.test(budy2) && !isBotoff) {

