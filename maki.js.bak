case 'addvip': {
if (!SoDono) return reply(mess.onlyOwner());

// Padroniza a barra e separa nГәmero e dias
barra = q.replace(" /", "/").replace("/ ", "/").replace(" / ", "/");
var [nmr, tempo50] = barra.split('/');
if (!nmr || !tempo50) return await mention(`рҹ’« бҙҚбҙҮЙҙбҙ„ЙӘбҙҸЙҙбҙҮ бҙҸ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ бҙ…бҙҸ бҙңsбҙңбҙҖКҖЙӘбҙҸ бҙҮ бҙҖ З«бҙңбҙҖЙҙбҙӣЙӘбҙ…бҙҖбҙ…бҙҮ бҙ…бҙҮ бҙ…ЙӘбҙҖs бҙ…бҙҸ бҙ ЙӘбҙҳ.\nвҖў Exemplo: *${prefix + command} @${nmrdn.split('@')[0]}/30*\nвҖў Para VIP infinito, use *0*.`);

// Define usuГЎrio usando menГ§ГЈo se houver
usur = menc_os2 ? menc_os2 : (nmr.includes('@') ? nmr.split('@')[1] + "@s.whatsapp.net" : nmr + "@s.whatsapp.net");
mega = Number(tempo50) > 0 ? false : true;
dvip = moment.tz('Africa/Maputo').format('DD');

bla = JSON.stringify(vip).includes(usur);

if (bla) {
AB = vip.map(i => i.id).indexOf(usur);
if (vip[AB].infinito == true) return reply("вқҢ NГЈo Г© possГӯvel adicionar dias a um usuГЎrio com VIP infinito.");
vip[AB].dias += Number(tempo50);
fs.writeFileSync('./arquivos/database/usuarios/vip.json', JSON.stringify(vip, null, 2));
await maki.sendMessage(from, {
text: `рҹ—“пёҸ ${tempo50} dia${Number(tempo50) > 1 ? 's' : ''} fo${Number(tempo50) > 1 ? 'ram' : 'i'} adicionado${Number(tempo50) > 1 ? 's' : ''} ao usuГЎrio @${usur.split("@")[0]}`,
mentions: [usur]
}, { quoted: selo });
} else {
vip.push({ id: usur, dias: Number(tempo50), save: Number(dvip), infinito: mega });
fs.writeFileSync('./arquivos/database/usuarios/vip.json', JSON.stringify(vip, null, 2));
await maki.sendMessage(from, {
text: `${Number(tempo50) > 0 ? `@${usur.split("@")[0]} *бҙҮТ“бҙҮбҙӣбҙңбҙҸ бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖбҙ…бҙҸ бҙҖ КҹЙӘsбҙӣбҙҖ бҙ…бҙҸ бҙ ЙӘбҙҳ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ!*` : `@${usur.split("@")[0]} *Т“бҙҸЙӘ бҙҖЙўКҖбҙҖбҙ„ЙӘбҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ бҙҸ КҷбҙҮЙҙбҙҮТ“ЙӘМҒбҙ„ЙӘбҙҸ бҙ…бҙҸ бҙ ЙӘбҙҳ ЙӘЙҙТ“ЙӘЙҙЙӘбҙӣбҙҸ!*`}`,
mentions: [usur]
}, { quoted: selo });
}
}
break;


case 'vervip': {
const alvo = menc_os2 ? menc_os2 : sender
const cek = vip.find(v => v.id === alvo)

if (!cek) {
return await maki.sendMessage(from, {
text: `вқҢ @${alvo.split("@")[0]} ЙҙбҙҖМғбҙҸ бҙҳбҙҸssбҙңЙӘ бҙ ЙӘбҙҳ бҙҖбҙӣЙӘбҙ бҙҸ.`,
mentions: [alvo]
}, { quoted: selo })
}

if (cek.infinito === true) {
return await maki.sendMessage(from, {
text: `рҹ’Һ бҙ ЙӘбҙҳ ЙӘЙҙТ“ЙӘЙҙЙӘбҙӣбҙҸ\n\nрҹ‘Ө бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ: @${alvo.split("@")[0]}\nвңЁ sбҙӣбҙҖбҙӣбҙңs: бҙҖбҙӣЙӘбҙ бҙҸ\nвҸі бҙ…бҙңКҖбҙҖбҙ„М§бҙҖМғбҙҸ: вҲһ`,
mentions: [alvo]
}, { quoted: selo })
}

const hoje = moment.tz('Africa/Maputo').format('DD')
const passados = hoje - cek.save
const restantes = cek.dias - passados

if (restantes <= 0) {
vip.splice(vip.indexOf(cek), 1)
fs.writeFileSync('./arquivos/database/usuarios/vip.json', JSON.stringify(vip, null, 2))
return await maki.sendMessage(from, {
text: `вқҢ @${alvo.split("@")[0]} sбҙҮбҙң бҙ ЙӘбҙҳ бҙҮxбҙҳЙӘКҖбҙҸбҙң.`,
mentions: [alvo]
}, { quoted: selo })
}

await maki.sendMessage(from, {
text: `рҹ’Һ бҙ ЙӘбҙҳ бҙҖбҙӣЙӘбҙ бҙҸ\n\nрҹ‘Ө бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ: @${alvo.split("@")[0]}\nрҹ“Ҷ бҙ…ЙӘбҙҖs КҖбҙҮsбҙӣбҙҖЙҙбҙӣбҙҮs: ${restantes}\nвңЁ sбҙӣбҙҖбҙӣбҙңs: бҙҖбҙӣЙӘбҙ бҙҸ`,
mentions: [alvo]
}, { quoted: selo })
}
break;

case 'servip': {
if (!SoDono) return reply(mess.onlyOwner());

// pega os dias direto
if (!q) return reply(
`рҹ’« бҙ…бҙҮТ“ЙӘЙҙбҙҖ бҙҖ З«бҙңбҙҖЙҙбҙӣЙӘбҙ…бҙҖбҙ…бҙҮ бҙ…бҙҮ бҙ…ЙӘбҙҖs бҙ…бҙҸ бҙ ЙӘбҙҳ.\n` +
`вҖў Exemplo: *${prefix + command} 30*\n` +
`вҖў Para VIP infinito, use *0*.`
);

const tempo = Number(q);
if (isNaN(tempo)) return reply("вқҢ Use apenas nГәmeros.");

const usur = sender; // o prГіprio dono
const mega = tempo > 0 ? false : true;
const dvip = moment.tz('Africa/Maputo').format('DD');

const jaVip = vip.find(v => v.id === usur);

if (jaVip) {
if (jaVip.infinito) {
return reply("вқҢ VocГӘ jГЎ possui VIP infinito.");
}

if (mega) {
jaVip.infinito = true;
jaVip.dias = 0;
} else {
jaVip.dias += tempo;
}

fs.writeFileSync(
'./arquivos/database/usuarios/vip.json',
JSON.stringify(vip, null, 2)
);

await maki.sendMessage(from, {
text: mega
? `рҹ‘‘ *бҙ ЙӘбҙҳ ЙӘЙҙТ“ЙӘЙҙЙӘбҙӣбҙҸ бҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ!*`
: `рҹ—“пёҸ *${tempo} dia${tempo > 1 ? 's' : ''} бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖбҙ…бҙҸ${tempo > 1 ? 's' : ''} бҙҖбҙҸ sбҙҮбҙң бҙ ЙӘбҙҳ!*`
}, { quoted: selo });

} else {
vip.push({
id: usur,
dias: mega ? 0 : tempo,
save: Number(dvip),
infinito: mega
});

fs.writeFileSync(
'./arquivos/database/usuarios/vip.json',
JSON.stringify(vip, null, 2)
);

await maki.sendMessage(from, {
text: mega
? `рҹ‘‘ *бҙ бҙҸбҙ„бҙҮМӮ Т“бҙҸЙӘ бҙҖЙўКҖбҙҖбҙ„ЙӘбҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ бҙ ЙӘбҙҳ ЙӘЙҙТ“ЙӘЙҙЙӘбҙӣбҙҸ!*`
: `вңЁ *бҙ ЙӘбҙҳ бҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙҳбҙҸКҖ ${tempo} dia${tempo > 1 ? 's' : ''}!*`
}, { quoted: selo });
}

}
break;


case 'rmservip': {
