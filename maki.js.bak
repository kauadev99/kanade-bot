return reply(mess.onlyOwner());
setting.prefix = q.trim();
fs.writeFileSync(
"./configs/INFO_DADOS/settings.json",
JSON.stringify(setting, null, 2)
);
reply(`вҡҷпёҸ *бҙҸ бҙҳКҖбҙҮТ“ЙӘxбҙҸ Т“бҙҸЙӘ бҙҖКҹбҙӣбҙҮКҖбҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ бҙҳбҙҖКҖбҙҖ:* ${setting.prefix}`);
break;

case 'audiomenu':
case 'fundoaudio': {
if (!SoDono) return reply(mess.onlyOwner());

const msg =
info.message?.extendedTextMessage?.contextInfo?.quotedMessage
|| info.message
|| {};

const a =
msg.audioMessage
|| msg.viewOnceMessage?.message?.audioMessage
|| msg.viewOnceMessageV2?.message?.audioMessage;

const pastaAudios = './arquivos/database/data/media/audios';
if (!fs.existsSync(pastaAudios)) fs.mkdirSync(pastaAudios, { recursive: true });

const audioPath = `${pastaAudios}/menu.mp3`;

if (a) {
reagir(from, "вҸі");

const buffer = await getFileBuffer(a, 'audio');

// sempre sobrescreve o ГЎudio antigo
fs.writeFileSync(audioPath, buffer);

reagir(from, "вң…");
return reply('*бҙҮЙӘ бҙҚбҙҮsбҙӣКҖбҙҮ, бҙҸ бҙҖбҙңМҒбҙ…ЙӘбҙҸ бҙ…бҙҸ бҙҚбҙҮЙҙбҙң Т“бҙҸЙӘ бҙҖбҙӣбҙңбҙҖКҹЙӘбҙўбҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ кңұбҙңбҙ„бҙҮкңұкңұбҙҸ рҹҺ§*');
}

reply('*бҙҮЙӘ бҙҚбҙҮsбҙӣКҖбҙҮ, бҙҚбҙҖЙҙбҙ…бҙҮ бҙңбҙҚ бҙҖбҙңМҒбҙ…ЙӘбҙҸ (бҙҸбҙң КҖбҙҮкңұбҙҳбҙҸЙҙбҙ…бҙҖ бҙңбҙҚ) бҙҳКҖбҙҖ бҙҚбҙңбҙ…бҙҖКҖ бҙҸ бҙҖбҙңМҒбҙ…ЙӘбҙҸ бҙ…бҙҸ бҙҚбҙҮЙҙбҙң рҹҷҮвҖҚвҷӮпёҸ*');
}
break;

case 'logoicon':
case 'iconmenu': {
if (!SoDono) return reply(mess.onlyOwner());

const msg =
info.message?.extendedTextMessage?.contextInfo?.quotedMessage
|| info.message
|| {};

const img =
