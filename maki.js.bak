let tempo = msToTime(Date.now() - afkUser.hora);
await maki.sendMessage(from, {
text: mess.ausente(afkUser, tempo, m),
contextInfo: { ...channeldl, mentionedJid: [m] }
}, {quoted: selo})
}
}
