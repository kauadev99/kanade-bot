case 'hd':
if ((isMedia && !info.message.videoMessage) || isQuotedImage) {
post = isQuotedImage 
? JSON.parse(JSON.stringify(info).replace('quotedM', 'm')).message.extendedTextMessage.contextInfo.message.imageMessage 
: info.message.imageMessage;
