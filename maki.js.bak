}
break


// ===============================
// CASE: MODOPARCERIA
// ativa / desativa o sistema
// ===============================
case 'modoparceria': {
try {
if (!SoDono) return reply('вқҢ Somente o dono pode ativar ou desativar o modo parceria.')

if (!isGroup) return reply('вқҢ Esse comando sГі pode ser usado em grupos.')

if (!global.db.data.chats[from]) global.db.data.chats[from] = {}
if (!global.db.data.chats[from].parceria) {
global.db.data.chats[from].parceria = {
ativo: false,
usuarios: {}
}
}

const opcao = (q || '').trim().toLowerCase()

if (!opcao) {
return reply(`рҹ’ҷ *MODO PARCERIA* рҹ’ҷ

вҖў Status: ${global.db.data.chats[from].parceria.ativo ? 'ATIVADO' : 'DESATIVADO'}

рҹ“Ң *Como usar:*
вҖў ${prefix + command} on
вҖў ${prefix + command} off`)
}

if (opcao === 'on') {
global.db.data.chats[from].parceria.ativo = true
reply('вң… Modo parceria foi *ativado* com sucesso neste grupo.')
} else if (opcao === 'off') {
global.db.data.chats[from].parceria.ativo = false
reply('вң… Modo parceria foi *desativado* com sucesso neste grupo.')
} else {
reply(`вқҢ Use corretamente:\nвҖў ${prefix + command} on\nвҖў ${prefix + command} off`)
}
} catch (e) {
console.log(e)
reply('вқҢ Erro ao alterar o modo parceria.')
}
}
break



// ===============================
// CASE: ADDPARCERIA
// adiciona ou remove pessoa da parceria
// define limite de links
// ===============================
case 'addparceria': {
try {
if (!SoDono) return reply('вқҢ Somente o dono pode gerenciar a parceria.')
if (!isGroup) return reply('вқҢ Esse comando sГі pode ser usado em grupos.')

if (!global.db.data.chats[from]) global.db.data.chats[from] = {}
if (!global.db.data.chats[from].parceria) {
global.db.data.chats[from].parceria = {
ativo: false,
usuarios: {}
}
}

const parceria = global.db.data.chats[from].parceria

let alvo = mentionedJid && mentionedJid[0]
? mentionedJid[0]
: (m.quoted ? m.quoted.sender : null)

const argsTexto = (q || '').trim()

if (!argsTexto) {
return reply(`рҹ’ҷ *ADD PARCERIA* рҹ’ҷ

рҹ“Ң *Adicionar com limite:*
вҖў ${prefix + command} @membro 3

рҹ“Ң *Remover da parceria:*
вҖў ${prefix}delparceria @membro

рҹ“Ң *Ver lista:*
вҖў ${prefix}listaparceria

в„№пёҸ Marque a pessoa ou responda a mensagem dela.`)
}

if (!alvo) return reply('вқҢ Marque a pessoa ou responda a mensagem dela.')
if (alvo.endsWith('@g.us')) return reply('вқҢ Marque um usuГЎrio, nГЈo um grupo.')

const limite = parseInt(argsTexto.replace(/[^\d]/g, ''))

if (isNaN(limite) || limite < 1) {
return reply('вқҢ Informe um limite vГЎlido.\n\nExemplo:\n' + `${prefix + command} @membro 3`)
}

if (!parceria.usuarios) parceria.usuarios = {}

parceria.usuarios[alvo] = {
limite: limite,
usados: 0
}

reply(`вң… UsuГЎrio @${alvo.split('@')[0]} adicionado na *parceria* com limite de *${limite} links*.`, {
mentions: [alvo]
})
} catch (e) {
console.log(e)
reply('вқҢ Erro ao adicionar parceria.')
}
}
break



// ===============================
// CASE: DELPARCERIA
// remove pessoa da parceria
// ===============================
case 'delparceria': {
try {
if (!SoDono) return reply('вқҢ Somente o dono pode remover da parceria.')
if (!isGroup) return reply('вқҢ Esse comando sГі pode ser usado em grupos.')

if (!global.db.data.chats[from]) global.db.data.chats[from] = {}
if (!global.db.data.chats[from].parceria) {
global.db.data.chats[from].parceria = {
ativo: false,
usuarios: {}
}
}

const parceria = global.db.data.chats[from].parceria

let alvo = mentionedJid && mentionedJid[0]
? mentionedJid[0]
: (m.quoted ? m.quoted.sender : null)

if (!alvo) return reply(`вқҢ Marque a pessoa ou responda a mensagem dela.\n\nExemplo:\n${prefix + command} @membro`)

if (!parceria.usuarios[alvo]) {
return reply('вқҢ Esse usuГЎrio nГЈo estГЎ na lista de parceria.')
}

delete parceria.usuarios[alvo]

reply(`вң… UsuГЎrio @${alvo.split('@')[0]} foi removido da parceria.`, {
mentions: [alvo]
})
} catch (e) {
console.log(e)
reply('вқҢ Erro ao remover parceria.')
}
}
break



// ===============================
// CASE: LISTAPARCERIA
// mostra quem estГЎ autorizado
// ===============================
case 'listaparceria': {
try {
if (!isGroup) return reply('вқҢ Esse comando sГі pode ser usado em grupos.')

if (!global.db.data.chats[from]) global.db.data.chats[from] = {}
if (!global.db.data.chats[from].parceria) {
global.db.data.chats[from].parceria = {
ativo: false,
usuarios: {}
}
}

const parceria = global.db.data.chats[from].parceria
const usuarios = parceria.usuarios || {}
const ids = Object.keys(usuarios)

if (ids.length === 0) {
return reply(`рҹ’ҷ Nenhum usuГЎrio estГЎ cadastrado na parceria neste grupo.`)
}

let txt = `в•ӯв”ҖвқҚ *LISTA DA PARCERIA* вқҚ\n`
txt += `в”Ӯ\n`
txt += `в”ң *Status:* ${parceria.ativo ? 'ATIVADO' : 'DESATIVADO'}\n`
txt += `в”ң *Total de parceiros:* ${ids.length}\n`
txt += `в”Ӯ\n`

for (let i = 0; i < ids.length; i++) {
let id = ids[i]
let info = usuarios[id]
let restante = Math.max(0, (info.limite || 0) - (info.usados || 0))

txt += `в”ң ${i + 1}. @${id.split('@')[0]}\n`
txt += `в”ң Limite: ${info.limite}\n`
txt += `в”ң Usados: ${info.usados || 0}\n`
txt += `в”ң Restantes: ${restante}\n`
txt += `в”Ӯ\n`
}

txt += `в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ`

reply(txt, { mentions: ids })
} catch (e) {
console.log(e)
reply('вқҢ Erro ao listar parceria.')
}
}
break

case 'resetparceria': {
try {
if (!SoDono) return reply('вқҢ Somente o dono pode resetar os links.')
if (!isGroup) return reply('вқҢ Esse comando sГі pode ser usado em grupos.')

if (!global.db.data.chats[from]) global.db.data.chats[from] = {}
if (!global.db.data.chats[from].parceria) {
global.db.data.chats[from].parceria = {
ativo: false,
usuarios: {}
}
}

const parceria = global.db.data.chats[from].parceria

let alvo = mentionedJid && mentionedJid[0]
? mentionedJid[0]
: (m.quoted ? m.quoted.sender : null)

if (!alvo) return reply(`вқҢ Marque a pessoa ou responda a mensagem dela.\n\nExemplo:\n${prefix + command} @membro`)

if (!parceria.usuarios[alvo]) {
return reply('вқҢ Esse usuГЎrio nГЈo estГЎ na parceria.')
}

parceria.usuarios[alvo].usados = 0

reply(`вң… Os links usados de @${alvo.split('@')[0]} foram resetados com sucesso.`, {
mentions: [alvo]
})
} catch (e) {
console.log(e)
reply('вқҢ Erro ao resetar parceria.')
}
}
break
case 'listagp':
if (!SoDono && !isnit && !info.key.fromMe) return reply(mess.onlyOwner());
await reagir(from, "рҹҚӮ")
try {
const getGroups = await maki.groupFetchAllParticipating();
const groups = Object.values(getGroups);
groups.sort((a, b) => b.participants.length - a.participants.length);
let teks1 = `*бҙҮsбҙӣбҙҸбҙң бҙҖбҙӣбҙңбҙҖКҹбҙҚбҙҮЙҙбҙӣбҙҮ бҙҸбҙҳбҙҮКҖбҙҖЙҙбҙ…бҙҸ бҙҮбҙҚ ${groups.length} ЙўКҖбҙңбҙҳбҙҸs бҙҸбҙң бҙ„бҙҸбҙҚбҙңЙҙЙӘбҙ…бҙҖбҙ…бҙҮs. рҹҷҮвҖҚвҷӮпёҸ*\n`;
for (let i = 0; i < groups.length; i++) {
const group = groups[i];
try {
const metadt = await maki.groupMetadata(group.id);
const linkdogp = await maki.groupInviteCode(group.id);
teks1 += `гҖҺ ${i + 1} гҖҸЙҙбҙҸбҙҚбҙҮ бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ: ${group.subject}\n`;
teks1 += `ЙӘбҙ… бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ: ${group.id}\n`;
teks1 += `КҹЙӘЙҙбҙӢ: https://chat.whatsapp.com/${linkdogp}\n`;
teks1 += `бҙ„КҖЙӘбҙҖбҙ…бҙҸ бҙҮбҙҚ: ${moment(group.creation * 1000)
.tz('Africa/Maputo')
.format('DD/MM/YYYY HH:mm:ss')}\n`;
teks1 += `бҙҚбҙҮбҙҚКҷКҖбҙҸs: ${group.participants.length}\nвҖ”\n`;
} catch (err) {
teks1 += `гҖҺ ${i + 1} гҖҸЙҙбҙҸбҙҚбҙҮ бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ: ${group.subject}\n`;
teks1 += `ЙӘбҙ… бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ: ${group.id}\n`;
teks1 += `КҹЙӘЙҙбҙӢ бҙ…бҙҸ ЙўКҖбҙңбҙҳбҙҸ: NГЈo foi possГӯvel puxar o link.\n`;
teks1 += `ЙҙбҙҖбҙҸ Т“бҙҸЙӘ бҙҳбҙҸssЙӘбҙ бҙҮКҹ бҙҳбҙҮЙўбҙҖКҖ бҙҖs ЙӘЙҙТ“бҙҸКҖбҙҚбҙҖбҙ„бҙҸбҙҮs\n\n`;
}
await new Promise((resolve) => setTimeout(resolve, 100));
}
reply(teks1);
} catch (error) {
console.error(error);
reply(mess.error());
}
break;
case 'npm': { 
if (!q) return reply("вҖў ForneГ§a um termo de pesquisa para *NPM*\nвҖў `Exemplo: " + prefix + command + " @whiskeysockets/baileys`");
await reply("*Buscando resultados...*");
try {
const searchQuery = encodeURIComponent(q.trim());
const searchUrl = `https://registry.npmjs.org/-/v1/search?text=${searchQuery}&size=5`;

axios.get(searchUrl)
.then(response => {
const packages = response.data.objects;

if (!packages || packages.length === 0) {
return reply(`*NГЈo encontrei nenhum resultado para "${q}" na busca de NPM.*`);
}
//nunu x franky
let results = packages.map(pkg => ({
name: pkg.package.name,
description: pkg.package.description || 'DescriГ§ГЈo nГЈo disponГӯvel',
author: pkg.package.author ? pkg.package.author.name : 'Autor desconhecido',
version: pkg.package.version,
link: `https://www.npmjs.com/package/${pkg.package.name}`
}));

let message = `вҖў рҹ–Ё рқҷүрқҷҠрқҳҝрқҷҖ рқҷӢрқҳјрқҳҫрқҷҶрқҳјрқҷӮрқҷҖ рқҷҲрқҳјрқҷүрқҳјрқҷӮрқҷҖрқҷҚ вңЁ вҖў\n\nрҹ”Қ *Resultados da pesquisa npm para "${q}":вҶҙ*\n\n`;
results.forEach(result => {
message += `${"в”Җ".repeat(10)}\n\n`;
message += "рҹ“Ұ вҶқ `Nome:` "+ result.name + " вҶҙ\n-\n";
message += "рҹ“„ вҶқ `DescriГ§ГЈo:` " + result.description + "\n";
message += "рҹ‘Ө вҶқ `Autor:` "+ result.author + "\n";
message += "рҹ”–вҶқ `VersГЈo:` " + result.version + "\n";
message += "рҹ”— вҶқ `Link:` " + result.link + `\n\n`;
});

reply(message);
})
.catch(error => {
console.error(error);
reply('Erro ao realizar a pesquisa no npm. Por favor, tente novamente mais tarde.');
});
} catch (error) {
console.error(error);
reply('Ocorreu um erro ao processar sua solicitaГ§ГЈo para npm.');
}

break; 
}

case 'seradm':
