case 'ephemeral':
case 'msgtemp':
if (!isGroup) return reply(mess.onlyGroup());
if (!isGroupAdmins) return reply(mess.onlyAdmins());
if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin());

getInfoG = await maki.groupMetadata(from);

if (getInfoG.ephemeralDuration == undefined) {
reply("бҙҖбҙӣЙӘбҙ бҙҸбҙң бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ бҙҖs бҙҚбҙҮЙҙsбҙҖЙўбҙҮЙҙs бҙӣбҙҮбҙҚбҙҳбҙҸКҖбҙҖМҒКҖЙӘбҙҖs ЙҙбҙҮsбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ. рҹ’ҷ");
await maki.sendMessage(from, {
disappearingMessagesInChat: WA_DEFAULT_EPHEMERAL,
});
} else if (getInfoG.ephemeralDuration > 1) {
reply("бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҸбҙң бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ бҙҖs бҙҚбҙҮЙҙsбҙҖЙўбҙҮЙҙs бҙӣбҙҮбҙҚбҙҳбҙҸКҖбҙҖМҒКҖЙӘбҙҖs ЙҙбҙҮsбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ. рҹ’ҷ");
await maki.sendMessage(from, {
disappearingMessagesInChat: false,
});
}
break;
