case 'tel': {
try {
if(!q) return reply(`рҹ’ҷ Kanade diz...\n\nрҹ“һ Use: ${prefix}tel 11999999999`)

let res = await fetchJson(`https://zero-two-apis.com.br/consultas/serasa/telefone?query=${q}&apikey=OFF_KYY`)

if(!res?.status) return reply("рҹ’” Nenhum resultado encontrado...")

let raw = res.resultado.data

// вң… GARANTE STRING
if (typeof raw !== "string") {
raw = JSON.stringify(raw)
}

// рҹ”Ҙ LIMPEZA
raw = raw
.replace(/\\n/g, '\n')
.replace(/\\r/g, '')
.replace(/\*/g, '')

// рҹ”Һ separar por CPF
let partes = raw.split(/CPF:\s*/g).slice(1)
partes = partes.slice(0, 10)

let txt = `
в•ӯв”Ғв”Ғв”ҒгҖ” рҹ’ҷ KANADE TEL рҹ’ҷ гҖ•в”Ғв”Ғв”Ғв¬Ј
в”ғ рҹ“һ *Consulta:* ${q}
в”ғ рҹ”Һ *Resultados:* ${partes.length}
в”ғ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
`

partes.forEach((p, i) => {

let cpf = p.match(/^\d{11}/)?.[0] || "NГЈo consta"
let nome = p.match(/NOME:\s*([^\n]+)/)?.[1] || "NГЈo consta"

txt += `
в”ғ рҹ‘Ө *${i+1}. ${nome.trim()}*
в”ғ рҹ”Һ CPF: ${cpf}
в”ғ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ`
})

txt += `
в•°в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв¬Ј

рҹ’ҷ Kanade diz...
"Agora sim... tudo faz sentido."
`

await maki.sendMessage(from, {
image: { url: "https://tokito-apis.site/4d32e3.jpg" },
caption: txt,
footer: "рҹ’ҷ KANADE V4",
buttons: [
{
buttonId: prefix + "menu",
buttonText: { displayText: "рҹ’ҷ MENU рҹ’ҷ" }
}
],
headerType: 6,
viewOnce: false
}, { quoted: info })

} catch (e) {
console.log(e)
reply("рҹ’” Erro na consulta... tenta novamente рҹ’ӯ")
}
}
break;

