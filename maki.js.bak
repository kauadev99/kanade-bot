if(dataGp[0].prefixos.indexOf(q.trim()) < 0) return reply(`*бҙҮsбҙӣбҙҮ бҙҳКҖбҙҮТ“ЙӘxбҙҸ ЙҙбҙҖбҙҸ бҙҮsбҙӣбҙҖ ЙӘЙҙбҙ„КҹбҙңsбҙҸ рҹҷҶвҖҚвҷӮпёҸ*`)
if(dataGp[0].prefixos.length == 1) return reply("*бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҮ бҙҸбҙңбҙӣКҖбҙҸ бҙҳКҖбҙҮТ“ЙӘxбҙҸ бҙҳбҙҖКҖбҙҖ бҙҳбҙҸбҙ…бҙҮКҖ бҙӣЙӘКҖбҙҖКҖ бҙҮssбҙҮ... рҹӨ·вҖҚвҷӮпёҸ*")
