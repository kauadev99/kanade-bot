const respostasSolitario = [

"рҹҳ” рқҷ° рқҡңрқҡҳрқҡ•рқҡ’рқҡҚрқҡҠМғрқҡҳ рқҡҠМҖрқҡң рқҡҹрқҡҺрқҡЈрқҡҺрқҡң рқҡҷрқҡҠрқҡӣрқҡҺрқҡҢрқҡҺ рқҡҷрқҡҺрқҡңрқҡҠрқҡҚрқҡҠ, рқҡ–рқҡҠрқҡң рқҡ•рқҡҺрқҡ–рқҡӢрқҡӣрқҡҺ-рқҡңрқҡҺ: рқҡҺрқҡ•рқҡҠ рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡҷрқҡҳрқҡҚрқҡҺ рқҡңрқҡҺрқҡӣ рқҡһрқҡ– рқҡ–рқҡҳрқҡ–рқҡҺрқҡ—рқҡқрқҡҳ рқҡҷрқҡҠрқҡӣрқҡҠ рқҡңрқҡҺ рқҡҢрқҡҳрқҡ—рқҡ‘рқҡҺрқҡҢрқҡҺрқҡӣ рқҡ–рқҡҺрқҡ•рқҡ‘рқҡҳрқҡӣ. рҹҢҷ",

"рҹҢҢ рқҷјрқҡҺрқҡңрқҡ–рқҡҳ рқҡҡрқҡһрқҡҺ рқҡҠрқҡҗрқҡҳрқҡӣрқҡҠ рқҡҹрқҡҳрқҡҢрқҡҺМӮ рқҡңрқҡҺ рқҡңрқҡ’рқҡ—рқҡқрқҡҠ рқҡңрқҡҳрқҡ•рқҡ’рқҡқрқҡҠМҒрқҡӣрқҡ’рқҡҳ, рқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠ рқҡҠрқҡ’рқҡ—рқҡҚрқҡҠ рқҡқрқҡҺрқҡ– рқҡ–рқҡһрқҡ’рқҡқрқҡҠрқҡң рқҡҷрқҡҺрқҡңрқҡңрқҡҳрқҡҠрқҡң рқҡҡрқҡһрқҡҺ рқҡҹрқҡҠМғрқҡҳ рқҡҠрқҡҷрқҡҠрқҡӣрқҡҺрқҡҢрқҡҺрқҡӣ рқҡ—рқҡҳ рқҡңрқҡҺрқҡһ рқҡҢрқҡҠрқҡ–рқҡ’рқҡ—рқҡ‘рқҡҳ.",

"вңЁ рқҷ° рқҡңрқҡҳрқҡ•рқҡ’рқҡҚрқҡҠМғрқҡҳ рқҡ—рқҡҠМғрқҡҳ рқҡңрқҡ’рқҡҗрқҡ—рқҡ’рқҡҸрқҡ’рқҡҢрқҡҠ рқҡҡрқҡһрқҡҺ рқҡҹрқҡҳрқҡҢрқҡҺМӮ рқҡ—рқҡҠМғрқҡҳ рқҡҺМҒ рқҡҠрқҡ–рқҡҠрқҡҚрқҡҳ. рқҷ°МҖрқҡң рқҡҹрқҡҺрқҡЈрқҡҺрқҡң рқҡҺМҒ рқҡҠрқҡҷрқҡҺрқҡ—рқҡҠрқҡң рқҡһрқҡ–рқҡҠ рқҡҸрқҡҠрқҡңрқҡҺ рқҡҚрқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠ.",

"рҹҢҷ рқҷ°рқҡң рқҡҺрқҡңрқҡқрқҡӣрқҡҺрқҡ•рқҡҠрқҡң рқҡӢрқҡӣрқҡ’рқҡ•рқҡ‘рқҡҠрқҡ– рқҡ–рқҡҠрқҡ’рқҡң рқҡҡрқҡһрқҡҠрқҡ—рқҡҚрқҡҳ рқҡҠ рқҡ—рқҡҳрқҡ’рқҡқрқҡҺ рқҡҺМҒ рқҡҺрқҡңрқҡҢрқҡһрқҡӣрқҡҠ. рҹҢҹ рқҷ°рқҡңрқҡңрқҡ’рқҡ– рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡҹрқҡҳрқҡҢрқҡҺМӮ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡӢрқҡӣрқҡ’рқҡ•рқҡ‘рқҡҠрқҡӣ рқҡ–рқҡҺрқҡңрқҡ–рқҡҳ рқҡҺрқҡ– рқҡ–рқҡҳрқҡ–рқҡҺрқҡ—рқҡқрқҡҳрқҡң рқҡңрқҡҳрқҡ•рқҡ’рқҡқрқҡҠМҒрқҡӣрқҡ’рқҡҳрқҡң."

]

const resposta = respostasSolitario[Math.floor(Math.random() * respostasSolitario.length)];

await maki.sendMessage(from,{text:resposta},{quoted:info})

}

if (!isCmd && /(amigo|amiga|amigos|amigas)/.test(budy2) && !isBotoff) {

setTimeout(() => {
reagir(from,"рҹӨқ")
},300)

const respostasAmigos = [

"рҹӨқ рқҷ°рқҡ–рқҡ’рқҡҗрқҡҳрқҡң рқҡҹрқҡҺрқҡӣрқҡҚрқҡҠрқҡҚрқҡҺрқҡ’рқҡӣрқҡҳрқҡң рқҡңрқҡҠМғрқҡҳ рқҡҠрқҡҡрқҡһрқҡҺрқҡ•рқҡҺрқҡң рқҡҡрқҡһрқҡҺ рқҡҺрқҡңрқҡқрқҡҠМғрқҡҳ рқҡҠрқҡҳ рқҡңрқҡҺрқҡһ рқҡ•рқҡҠрқҡҚрқҡҳ рқҡ—рқҡҠМғрқҡҳ рқҡңрқҡҳМҒ рқҡ—рқҡҳрқҡң рқҡ–рқҡҳрқҡ–рқҡҺрқҡ—рқҡқрқҡҳрқҡң рқҡҸрқҡҺрқҡ•рқҡ’рқҡЈрқҡҺрқҡң, рқҡ–рқҡҠрқҡң рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡ—рқҡҳрқҡң рқҡ–рқҡҳрқҡ–рқҡҺрқҡ—рқҡқрқҡҳрқҡң рқҡҚрқҡ’рқҡҸрқҡ’МҒрқҡҢрқҡҺрқҡ’рқҡң. рҹ’ҷ",

"рҹҢҹ рқҷ°рқҡ–рқҡ’рқҡҗрқҡҳрқҡң рқҡңрқҡҠМғрқҡҳ рқҡҢрқҡҳрқҡ–рқҡҳ рқҡҺрқҡңрқҡқрқҡӣрқҡҺрқҡ•рқҡҠрқҡң: рқҡ–рқҡҺрқҡңрқҡ–рқҡҳ рқҡҡрқҡһрқҡҠрқҡ—рқҡҚрқҡҳ рқҡ—рқҡҠМғрқҡҳ рқҡҳрқҡң рқҡҹрқҡҺрқҡ–рқҡҳрқҡң, рқҡңрқҡҠрқҡӢрқҡҺрқҡ–рқҡҳрқҡң рқҡҡрқҡһрқҡҺ рқҡҺрқҡ•рқҡҺрқҡң рқҡҺрқҡңрқҡқрқҡҠМғрқҡҳ рқҡ•рқҡҠМҒ. вңЁ",

"рҹӨ— рқҡ„рқҡ– рқҡҠрқҡ–рқҡ’рқҡҗрқҡҳ рқҡҹрқҡҺрқҡӣрқҡҚрқҡҠрқҡҚрқҡҺрқҡ’рқҡӣрқҡҳ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡ–рқҡһрқҡҚрқҡҠрқҡӣ рқҡһрқҡ– рқҡҚрқҡ’рқҡҠ рқҡқрқҡӣрқҡ’рқҡңрқҡқрқҡҺ рқҡҺрқҡ– рқҡһрқҡ– рқҡҚрқҡ’рқҡҠ рқҡҢрқҡ‘рқҡҺрқҡ’рқҡҳ рқҡҚрқҡҺ рқҡҺрқҡңрқҡҷрқҡҺрқҡӣрқҡҠрқҡ—рқҡҢМ§рқҡҠ."

]

const resposta = respostasAmigos[Math.floor(Math.random() * respostasAmigos.length)];

await maki.sendMessage(from,{text:resposta},{quoted:info})

}

if (!isCmd && budy2 && budy2.toLowerCase().includes("vida") && !isBotoff) {

setTimeout(() => {
reagir(from,"рҹҢҺ")
},300)

const respostasVida = [

"рҹҢҺ рқҷ° рқҡҹрқҡ’рқҡҚрқҡҠ рқҡҺМҒ рқҡҢрқҡ‘рқҡҺрқҡ’рқҡҠ рқҡҚрқҡҺ рқҡҚрқҡҺрқҡңрқҡҠрқҡҸрқҡ’рқҡҳрқҡң, рқҡ–рқҡҠрқҡң рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡҚрқҡҺ рқҡҳрқҡҷрқҡҳрқҡӣрқҡқрқҡһрқҡ—рқҡ’рқҡҚрқҡҠрқҡҚрқҡҺрқҡң.",

"вңЁ рқҷ° рқҡҹрқҡ’рқҡҚрқҡҠ рқҡ—рқҡҠМғрқҡҳ рқҡҺМҒ рқҡҷрқҡҺрқҡӣрқҡҸрқҡҺрқҡ’рқҡқрқҡҠ, рқҡ–рқҡҠрқҡң рқҡҷрқҡҳрқҡҚрқҡҺ рқҡңрқҡҺрқҡӣ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡӢрқҡҳрқҡ—рқҡ’рқҡқрқҡҠ.",

"рҹҢ… рқҷІрқҡҠрқҡҚрқҡҠ рқҡҚрқҡ’рқҡҠ рқҡҚрқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠ рқҡҺМҒ рқҡһрқҡ–рқҡҠ рқҡ—рқҡҳрқҡҹрқҡҠ рқҡҢрқҡ‘рқҡҠрқҡ—рқҡҢрқҡҺ.",

"рҹ’ӯ рқҷ° рқҡҹрқҡ’рқҡҚрқҡҠ рқҡҺМҒ рқҡһрқҡ–рқҡҠ рқҡ“рқҡҳрқҡӣрқҡ—рқҡҠрқҡҚрқҡҠ рқҡҚрқҡҺ рқҡҠрқҡҷрқҡӣрқҡҺрқҡ—рқҡҚрқҡ’рқҡЈрқҡҠрқҡҚрқҡҳ.",

"рҹҢҝ рқҷ° рқҡҹрқҡ’рқҡҚрқҡҠ рқҡңрқҡҺрқҡ–рқҡҷрқҡӣрқҡҺ рқҡҺрқҡ—рқҡңрқҡ’рқҡ—рқҡҠ рқҡҠрқҡ•рқҡҗрқҡҳ рқҡ—рқҡҳрқҡҹрқҡҳ.",

"рҹ’Ў рқҷ° рқҡҹрқҡ’рқҡҚрқҡҠ рқҡҺМҒ рқҡ–рқҡҠрқҡ’рқҡң рқҡҚрқҡҳ рқҡҡрқҡһрқҡҺ рқҡҷрқҡӣрқҡҳрқҡӢрқҡ•рқҡҺрқҡ–рқҡҠрқҡңвҖҰ рқҡҺрқҡ•рқҡҠ рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡҺМҒ рқҡҺрқҡңрқҡҷрқҡҺрқҡӣрқҡҠрқҡ—рқҡҢМ§рқҡҠ.",

"рҹҢҹ рқҡ…рқҡ’рқҡҹрқҡҠ рқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠ рқҡҢрқҡҳрқҡ– рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҠМғрқҡҳ рқҡ•рқҡҺрқҡҹрқҡҺ.",

"рҹ•ҠпёҸ рқҷ° рқҡҹрқҡ’рқҡҚрқҡҠ рқҡңрқҡҺрқҡ–рқҡҷрқҡӣрқҡҺ рқҡҚрқҡҠМҒ рқҡ—рқҡҳрқҡҹрқҡҠрқҡң рқҡҢрқҡ‘рқҡҠрқҡ—рқҡҢрқҡҺрқҡң.",

"рҹҢ» рқҷ° рқҡҹрқҡ’рқҡҚрқҡҠ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡңрқҡһрқҡӣрқҡҷрқҡӣрқҡҺрқҡҺрқҡ—рқҡҚрқҡҺрқҡӣ.",

"рҹ’« рқҷҪрқҡһрқҡ—рқҡҢрқҡҠ рқҡҚрқҡҺрқҡңрқҡ’рқҡңрқҡқрқҡҠ рқҡҚрқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠ."
]

const resposta = respostasVida[Math.floor(Math.random() * respostasVida.length)]

await maki.sendMessage(from,{text:resposta},{quoted:info})

}

if (!isCmd && budy2 && budy2.toLowerCase().includes("saudade") && !isBotoff) {

setTimeout(() => {
reagir(from,"рҹҘҖ")
},300)

const respostasSaudade = [

"рҹҘҖ рқҡӮрқҡҠрқҡһрқҡҚрқҡҠрқҡҚрқҡҺ рқҡҺМҒ рқҡҠ рқҡҷрқҡӣрқҡҳрқҡҹрқҡҠ рқҡҚрқҡҺ рқҡҡрқҡһрқҡҺ рқҡҠрқҡ•рқҡҗрқҡһрқҡҺМҒрқҡ– рқҡҸрқҡҳрқҡ’ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡ’рқҡ–рқҡҷрқҡҳрқҡӣрқҡқрқҡҠрқҡ—рқҡқрқҡҺ рқҡ—рқҡҠ рқҡңрқҡһрқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠ.",

"рҹҢҷ рқҷ°МҖрқҡң рқҡҹрқҡҺрқҡЈрқҡҺрқҡң рқҡҠ рқҡңрқҡҠрқҡһрқҡҚрқҡҠрқҡҚрқҡҺ рқҡҚрқҡҳрқҡ’, рқҡ–рқҡҠрқҡң рқҡҺрқҡ•рқҡҠ рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡ–рқҡҳрқҡңрқҡқрқҡӣрқҡҠ рқҡҡрқҡһрқҡҠрқҡ—рқҡқрқҡҳ рқҡҳ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡҸрқҡҳрқҡ’ рқҡҹрқҡҺрқҡӣрқҡҚрқҡҠрқҡҚрқҡҺрқҡ’рқҡӣрқҡҳ.",

"рҹ’ӯ рқҡӮрқҡҠрқҡһрқҡҚрқҡҠрқҡҚрқҡҺ рқҡҺМҒ рқҡҳ рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҠМғрқҡҳ рқҡ•рқҡҺрқҡ–рқҡӢрқҡӣрқҡҠрқҡ—рқҡҚрқҡҳ рқҡҚрқҡҺ рқҡ–рқҡҳрқҡ–рқҡҺрқҡ—рқҡқрқҡҳрқҡң рқҡҡрқҡһрқҡҺ рқҡҸрқҡҳрқҡӣрқҡҠрқҡ– рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡҺрқҡңрқҡҷрқҡҺрқҡҢрқҡ’рқҡҠрқҡ’рқҡң.",

"рҹҢҢ рқҡҖрқҡһрқҡҺрқҡ– рқҡңрқҡҺрқҡ—рқҡқрқҡҺ рқҡңрқҡҠрқҡһрқҡҚрқҡҠрқҡҚрқҡҺ рқҡңрқҡ’рқҡҗрқҡ—рқҡ’рқҡҸрқҡ’рқҡҢрқҡҠ рқҡҡрқҡһрқҡҺ рқҡһрқҡ– рқҡҚрқҡ’рқҡҠ рқҡҹрқҡ’рқҡҹрқҡҺрқҡһ рқҡ–рқҡҳрқҡ–рқҡҺрқҡ—рқҡқрқҡҳрқҡң рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡ•рқҡ’рқҡ—рқҡҚрқҡҳрқҡң.",

"рҹ’” рқҷ° рқҡңрқҡҠрқҡһрқҡҚрқҡҠрқҡҚрқҡҺ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡңрқҡҺрқҡӣ рқҡҚрқҡҳрқҡ•рқҡҳрқҡӣрқҡҳрқҡңрқҡҠ, рқҡ–рқҡҠрқҡң рқҡҺрқҡ•рқҡҠ рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡҺМҒ рқҡһрқҡ–рқҡҠ рқҡ•рқҡҺрқҡ–рқҡӢрқҡӣрқҡҠрқҡ—рқҡҢМ§рқҡҠ рқҡҚрқҡҺ рқҡҠрқҡ–рқҡҳрқҡӣ.",

"вңЁ рқҡӮрқҡҠрқҡһрқҡҚрқҡҠрқҡҚрқҡҺ рқҡҺМҒ рқҡҠ рқҡҷрқҡӣрқҡҳрқҡҹрқҡҠ рқҡҚрқҡҺ рқҡҡрқҡһрқҡҺ рқҡҳ рқҡқрқҡҺрқҡ–рқҡҷрқҡҳ рқҡҷрқҡҠрқҡңрқҡңрқҡҠ, рқҡ–рқҡҠрқҡң рқҡҳ рқҡңрқҡҺрқҡ—рқҡқрқҡ’рқҡ–рқҡҺрқҡ—рқҡқрқҡҳ рқҡҸрқҡ’рқҡҢрқҡҠ.",

"рҹҢ№ рқҷ°рқҡ•рқҡҗрқҡһрқҡ–рқҡҠрқҡң рқҡҷрқҡҺрқҡңрқҡңрқҡҳрқҡҠрқҡң рқҡңрқҡҺ рқҡҹрқҡҠМғрқҡҳ, рқҡ–рқҡҠрқҡң рқҡҠрқҡң рқҡ•рқҡҺрқҡ–рқҡӢрқҡӣрқҡҠрқҡ—рқҡҢМ§рқҡҠрқҡң рқҡ—рқҡһрқҡ—рқҡҢрқҡҠ рқҡңрқҡҠрқҡҺрқҡ–.",

"рҹ•ҠпёҸ рқҷ° рқҡңрқҡҠрқҡһрқҡҚрқҡҠрқҡҚрқҡҺ рқҡ—рқҡҠМғрқҡҳ рқҡңрқҡ’рқҡҗрқҡ—рқҡ’рқҡҸрқҡ’рқҡҢрқҡҠ рқҡҷрқҡҺрқҡӣрқҡҚрқҡҠвҖҰ рқҡңрқҡ’рқҡҗрқҡ—рқҡ’рқҡҸрқҡ’рқҡҢрқҡҠ рқҡҡрқҡһрқҡҺ рқҡҳ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡҸрқҡҳрқҡ’ рқҡҹрқҡҺрқҡӣрқҡҚрқҡҠрқҡҚрқҡҺрқҡ’рқҡӣрқҡҳ.",

"рҹҢҷ рқҷ° рқҡңрқҡҠрқҡһрқҡҚрқҡҠрқҡҚрқҡҺ рқҡҺМҒ рқҡҳ рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҠМғрқҡҳ рқҡҹрқҡ’рқҡҠрқҡ“рқҡҠрқҡ—рқҡҚрқҡҳ рқҡҠрқҡқрқҡҺМҒ рқҡҳ рқҡҷрқҡҠрқҡңрқҡңрқҡҠрқҡҚрқҡҳ.",

"рҹ’« рқҷҫ рқҡқрқҡҺрқҡ–рқҡҷрқҡҳ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡҷрқҡҠрқҡңрқҡңрқҡҠрқҡӣ, рқҡ–рқҡҠрқҡң рқҡҠ рқҡңрқҡҠрқҡһрқҡҚрқҡҠрқҡҚрқҡҺ рқҡҗрқҡһрқҡҠрқҡӣрқҡҚрқҡҠ рқҡ–рқҡҺрқҡ–рқҡҳМҒрқҡӣрқҡ’рқҡҠрқҡң."
]

const resposta = respostasSaudade[Math.floor(Math.random() * respostasSaudade.length)]

await maki.sendMessage(from,{text:resposta},{quoted:info})

}

// DETECTAR PALAVRA "Гіdio"
if (!isCmd && budy2 && budy2.toLowerCase().includes("odio") && !isBotoff) {

setTimeout(() => {
reagir(from,"рҹҳЎ")
},300)

const respostasOdio = [

"вҡ пёҸ рқҷҫ рқҡҳМҒрқҡҚрқҡ’рқҡҳ рқҡҺМҒ рқҡһрқҡ– рқҡңрқҡҺрқҡ—рқҡқрқҡ’рқҡ–рқҡҺрқҡ—рқҡқрқҡҳ рқҡҡрқҡһрқҡҺ рқҡҷрқҡҺрқҡңрқҡҠ рқҡ—рқҡҳ рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҠМғрқҡҳ. рқҷјрқҡҠрқҡң рқҡ•рқҡҺрқҡ–рқҡӢрқҡӣрқҡҺ-рқҡңрқҡҺ: рқҡҡрқҡһрқҡҺрқҡ– рқҡҢрқҡҠрқҡӣрқҡӣрқҡҺрқҡҗрқҡҠ рқҡҳМҒрқҡҚрқҡ’рқҡҳ рқҡңрқҡҳрқҡҸрқҡӣрқҡҺ рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡ–рқҡҠрқҡ’рқҡң рқҡҚрқҡҳ рқҡҡрқҡһрқҡҺрқҡ– рқҡҳ рқҡңрқҡҺрқҡһ рқҡ’рқҡ—рқҡ’рқҡ–рқҡ’рқҡҗрқҡҳ. рҹӨҚ рқҷ»рқҡ’рқҡӢрқҡҺрқҡӣрқҡқрқҡҺ-рқҡңрқҡҺ рқҡҚрқҡҺрқҡ•рқҡҺ.",

"рҹҳЎ рқҷҫ рқҡҳМҒрқҡҚрқҡ’рқҡҳ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡ—рқҡҠрқҡңрқҡҢрқҡҺрқҡӣ рқҡҚрқҡҺ рқҡҚрқҡҳрқҡӣ, рқҡҚрқҡҺ рқҡӣрқҡҠрқҡ’рқҡҹрқҡҠ рқҡҳрқҡһ рқҡҚрқҡҺ рқҡҚрқҡҺрқҡҢрқҡҺрқҡҷрқҡҢМ§рқҡҠМғрқҡҳ. рқҷјрқҡҠрқҡң рқҡңрқҡҺ рқҡҹрқҡҳрқҡҢрқҡҺМӮ рқҡҠрқҡ•рқҡ’рқҡ–рқҡҺрқҡ—рқҡқрқҡҠрқҡӣ рқҡҺрқҡңрқҡңрқҡҺ рқҡңрқҡҺрқҡ—рқҡқрқҡ’рқҡ–рқҡҺрқҡ—рқҡқрқҡҳ, рқҡҺрқҡ•рқҡҺ рқҡҹрқҡҠрқҡ’ рқҡңрқҡҳМҒ рқҡҠрқҡһрқҡ–рқҡҺрқҡ—рқҡқрқҡҠрқҡӣ. рқҡғрқҡҺрқҡ—рқҡқрқҡҺ рқҡқрқҡӣрқҡҳрқҡҢрқҡҠрқҡӣ рқҡҳ рқҡҳМҒрқҡҚрқҡ’рқҡҳ рқҡҷрқҡҳрқҡӣ рқҡҷрқҡҠрқҡЈ. рҹ•ҠпёҸ",

"рҹ”Ҙ рқҷҫ рқҡҳМҒрқҡҚрқҡ’рқҡҳ рқҡҺМҒ рқҡҢрқҡҳрқҡ–рқҡҳ рқҡһрқҡ– рқҡҸрқҡҳрқҡҗрқҡҳ: рқҡңрқҡҺ рқҡҹрқҡҳрқҡҢрқҡҺМӮ рқҡҠрқҡ•рқҡ’рқҡ–рқҡҺрқҡ—рқҡқрқҡҠ, рқҡҺрқҡ•рқҡҺ рқҡҢрқҡӣрқҡҺрқҡңрқҡҢрқҡҺ. рқҷјрқҡҠрқҡң рқҡңрқҡҺ рқҡҹрқҡҳрқҡҢрқҡҺМӮ рқҡҷрқҡҠрқҡӣрқҡҠрқҡӣ рқҡҚрқҡҺ рқҡҠрқҡ•рқҡ’рқҡ–рқҡҺрқҡ—рқҡқрқҡҠрқҡӣ, рқҡҺрқҡ•рқҡҺ рқҡңрқҡҺ рқҡҠрқҡҷрқҡҠрқҡҗрқҡҠ.",

"рҹ’ӯ рқҷ° рқҡҹрқҡ’рқҡҚрқҡҠ рқҡҺМҒ рқҡҢрқҡһрқҡӣрқҡқрқҡҠ рқҡҚрқҡҺрқҡ–рқҡҠрқҡ’рқҡң рқҡҷрқҡҠрқҡӣрқҡҠ рқҡңрқҡҺрқҡӣ рқҡҗрқҡҠрқҡңрқҡқрқҡҠ рқҡҢрқҡҳрқҡ– рқҡҳМҒрқҡҚрқҡ’рқҡҳ. рқҡҖрқҡһрқҡҠрқҡ—рқҡҚрқҡҳ рқҡҹрқҡҳрқҡҢрқҡҺМӮ рқҡңрқҡҳрқҡ•рқҡқрқҡҠ рқҡҺрқҡңрқҡңрқҡҺ рқҡҷрқҡҺрқҡңрқҡҳ, рқҡҳ рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҠМғрқҡҳ рқҡҸрқҡ’рқҡҢрқҡҠ рқҡ–рқҡҠрқҡ’рқҡң рқҡ•рқҡҺрқҡҹрқҡҺ.",

"рҹ§  рқҷ°МҖрқҡң рқҡҹрқҡҺрқҡЈрқҡҺрқҡң рқҡҳ рқҡҳМҒрқҡҚрқҡ’рқҡҳ рқҡҺМҒ рқҡҠрқҡҷрқҡҺрқҡ—рқҡҠрқҡң рқҡҚрқҡҳрқҡӣ рқҡ—рқҡҠМғрқҡҳ рқҡҢрқҡһрқҡӣрқҡҠрқҡҚрқҡҠ. рқҡҖрқҡһрқҡҺрқҡ– рқҡҢрқҡһрқҡӣрқҡҠ рқҡҳ рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҠМғрқҡҳ рқҡ—рқҡҠМғрқҡҳ рқҡҷрқҡӣрқҡҺрқҡҢрқҡ’рқҡңрқҡҠ рқҡҢрқҡҠрқҡӣрқҡӣрқҡҺрқҡҗрқҡҠрқҡӣ рқҡӣрқҡҠрқҡ’рқҡҹрқҡҠ.",

"рҹҢҝ рқҡғрқҡӣрқҡҳрқҡҢрқҡҠрқҡӣ рқҡҳ рқҡҳМҒрқҡҚрқҡ’рқҡҳ рқҡҷрқҡҳрқҡӣ рқҡҷрқҡҺрқҡӣрқҡҚрқҡҠМғрқҡҳ рқҡ—рқҡҠМғрқҡҳ рқҡҺМҒ рқҡҸрқҡӣрқҡҠрқҡҡрқҡһрқҡҺрқҡЈрқҡҠ. рқҷҙМҒ рқҡһрқҡ–рқҡҠ рқҡҚрқҡҠрқҡң рқҡ–рқҡҠрқҡ’рқҡҳрқҡӣрқҡҺрқҡң рқҡҸрқҡҳрқҡӣрқҡҢМ§рқҡҠрқҡң рқҡҡрқҡһрқҡҺ рқҡһрқҡ–рқҡҠ рқҡҷрқҡҺрқҡңрқҡңрқҡҳрқҡҠ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡқрқҡҺрқҡӣ.",

"рҹ’Ў рқҷ° рқҡ–рқҡҺрқҡ•рқҡ‘рқҡҳрқҡӣ рқҡҹрқҡ’рқҡ—рқҡҗрқҡҠрқҡ—рқҡҢМ§рқҡҠ рқҡҢрқҡҳрқҡ—рқҡқрқҡӣрқҡҠ рқҡҳ рқҡҳМҒрқҡҚрқҡ’рқҡҳ рқҡҺМҒ рқҡҹрқҡ’рқҡҹрқҡҺрқҡӣ рқҡҺрқҡ– рқҡҷрқҡҠрқҡЈ.",

"рҹҢҺ рқҡӮрқҡҺ рқҡҳ рқҡ–рқҡһрқҡ—рқҡҚрқҡҳ рқҡқрқҡҺрқҡ– рқҡ–рқҡһрқҡ’рқҡқрқҡҳ рқҡҳМҒрқҡҚрқҡ’рқҡҳ, рқҡқрқҡҺрқҡ—рқҡқрқҡҺ рқҡңрқҡҺрқҡӣ рқҡһрқҡ–рқҡҠ рқҡҷрқҡҺрқҡңрқҡңрқҡҳрқҡҠ рқҡҡрқҡһрқҡҺ рқҡ•рқҡҺрқҡҹрқҡҠ рқҡҷрқҡҠрқҡЈ.",

"вңЁ рқҷҫ рқҡҳМҒрқҡҚрқҡ’рқҡҳ рқҡҺрқҡңрқҡҢрқҡһрқҡӣрқҡҺрқҡҢрқҡҺ рқҡҳ рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҠМғрқҡҳ, рқҡ–рқҡҠрқҡң рқҡҠ рқҡӢрқҡҳрқҡ—рқҡҚрқҡҠрқҡҚрқҡҺ рқҡ’рқҡ•рқҡһрқҡ–рқҡ’рқҡ—рқҡҠ.",

"рҹӨҚ рқҡҖрқҡһрқҡҺрқҡ– рқҡҺрқҡңрқҡҢрқҡҳрқҡ•рқҡ‘рқҡҺ рқҡҠ рқҡҷрқҡҠрқҡЈ рқҡ—рқҡҠМғрқҡҳ рқҡҷрқҡҺрқҡӣрқҡҚрқҡҺ рқҡ—рқҡҠрқҡҚрқҡҠ, рқҡҷрқҡҺрқҡ•рқҡҳ рқҡҢрқҡҳрқҡ—рқҡқрқҡӣрқҡҠМҒрқҡӣрқҡ’рқҡҳвҖҰ рқҡҗрқҡҠрқҡ—рқҡ‘рқҡҠ рқҡ•рқҡ’рқҡӢрқҡҺрқҡӣрқҡҚрқҡҠрқҡҚрқҡҺ."
]

const resposta = respostasOdio[Math.floor(Math.random() * respostasOdio.length)]

await maki.sendMessage(from,{text:resposta},{quoted:info})

}

if (!isCmd && budy2 && budy2.toLowerCase().includes("triste") && !isBotoff) {

setTimeout(() => {
reagir(from,"рҹҳў")
},300)

const respostasTriste = [

"рҹ’” рқҡғрқҡӣрқҡ’рқҡңрқҡқрқҡҺрқҡЈрқҡҠ рқҡҸрқҡҠрқҡЈ рқҡҷрқҡҠрқҡӣрқҡқрқҡҺ рқҡҚрқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠвҖҰ рқҡ–рқҡҠрқҡң рқҡ•рқҡҺрқҡ–рқҡӢрқҡӣрқҡҺ-рқҡңрқҡҺ: рқҡ—рқҡҺрқҡ—рқҡ‘рқҡһрқҡ–рқҡҠ рқҡҚрқҡҳрқҡӣ рқҡҚрқҡһрқҡӣрқҡҠ рқҡҷрқҡҠрқҡӣрқҡҠ рқҡңрқҡҺрқҡ–рқҡҷрқҡӣрқҡҺ. рҹҢ… рқҷјрқҡҺрқҡңрқҡ–рқҡҳ рқҡҠрқҡң рқҡ—рқҡҳрқҡ’рқҡқрқҡҺрқҡң рқҡ–рқҡҠрқҡ’рқҡң рқҡҺрқҡңрқҡҢрқҡһрқҡӣрқҡҠрқҡң рқҡңрқҡҺрқҡ–рқҡҷрқҡӣрқҡҺ рқҡқрқҡҺрқҡӣрқҡ–рқҡ’рқҡ—рқҡҠрқҡ– рқҡҢрқҡҳрқҡ– рқҡҳ рқҡ—рқҡҠрқҡңрқҡҢрқҡҺрқҡӣ рқҡҚрқҡҳ рқҡңрқҡҳрқҡ•.",

"рҹҳў рқҡӮрқҡҺ рқҡҳ рқҡңрқҡҺрқҡһ рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҠМғрқҡҳ рқҡҺрқҡңрқҡқрқҡҠМҒ рқҡқрқҡӣрқҡ’рқҡңрқҡқрқҡҺ, рқҡӣрқҡҺрқҡңрқҡҷрқҡ’рқҡӣрқҡҺ рқҡҸрқҡһрқҡ—рқҡҚрқҡҳ. рқҷ° рқҡҹрқҡ’рқҡҚрқҡҠ рқҡҠМҖрқҡң рқҡҹрқҡҺрқҡЈрқҡҺрқҡң рқҡҷрқҡҺрқҡңрқҡҠ, рқҡ–рқҡҠрқҡң рқҡҠрқҡ’рқҡ—рқҡҚрқҡҠ рқҡҺрқҡЎрқҡ’рқҡңрқҡқрқҡҺрқҡ– рқҡ–рқҡһрқҡ’рқҡқрқҡҠрқҡң рқҡҢрқҡҳрқҡ’рқҡңрқҡҠрқҡң рқҡӢрқҡҳрқҡ—рқҡ’рқҡқрқҡҠрқҡң рқҡҡрқҡһрқҡҺ рқҡҠрқҡ’рқҡ—рқҡҚрқҡҠ рқҡҹрқҡҠМғрқҡҳ рқҡҠрқҡҢрқҡҳрқҡ—рқҡқрқҡҺрқҡҢрқҡҺрқҡӣ.",

"рҹҢ§пёҸ рқҷ°рқҡқрқҡҺМҒ рқҡҠ рқҡҢрқҡ‘рқҡһрқҡҹрқҡҠ рқҡ–рқҡҠрқҡ’рқҡң рқҡҸрқҡҳрқҡӣрқҡқрқҡҺ рқҡһрқҡ– рқҡҚрқҡ’рқҡҠ рқҡҷрқҡҠрқҡӣрқҡҠ. рқҷ°рқҡңрқҡңрқҡ’рқҡ– рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡҺМҒ рқҡҠ рқҡқрқҡӣрқҡ’рқҡңрқҡқрқҡҺрқҡЈрқҡҠ. рқҷҙрқҡ•рқҡҠ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡҹрқҡ’рқҡӣ, рқҡ–рқҡҠрқҡң рқҡ—рқҡҠМғрқҡҳ рқҡҸрқҡ’рқҡҢрқҡҠ рқҡҷрқҡҠрқҡӣрқҡҠ рқҡңрқҡҺрқҡ–рқҡҷрқҡӣрқҡҺ.",

"рҹ’ҷ рқҡӮрқҡҺ рқҡ‘рқҡҳрқҡ“рқҡҺ рқҡҹрқҡҳрқҡҢрқҡҺМӮ рқҡҺрқҡңрқҡқрқҡҠМҒ рқҡқрқҡӣрқҡ’рқҡңрқҡқрқҡҺ, рқҡ—рқҡҠМғрқҡҳ рқҡҷрқҡҺрқҡӣрқҡҢрқҡҠ рқҡҠ рқҡҺрқҡңрқҡҷрқҡҺрқҡӣрқҡҠрқҡ—рқҡҢМ§рқҡҠ. рқҷ°рқҡң рқҡҚрқҡ’рқҡҸрқҡ’рқҡҢрқҡһрқҡ•рқҡҚрқҡҠрқҡҚрқҡҺрқҡң рқҡҚрқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠ рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡңрқҡҺрқҡӣрқҡҹрқҡҺрқҡ– рқҡҷрқҡҠрқҡӣрқҡҠ рқҡ—рқҡҳрқҡң рқҡқрқҡҳрқҡӣрқҡ—рқҡҠрқҡӣ рқҡ–рқҡҠрқҡ’рқҡң рқҡҸрқҡҳрқҡӣрқҡқрқҡҺрқҡң.",

"рҹ•ҠпёҸ рқҷҪрқҡҺрқҡ– рқҡқрқҡҳрқҡҚрқҡҠ рқҡ•рқҡҠМҒрқҡҗрқҡӣрқҡ’рқҡ–рқҡҠ рқҡҺМҒ рқҡҚрқҡҺ рқҡҸрқҡӣрқҡҠрқҡҡрқҡһрқҡҺрқҡЈрқҡҠ. рқҷ°МҖрқҡң рқҡҹрқҡҺрқҡЈрқҡҺрқҡң рқҡҺрқҡ•рқҡҠрқҡң рқҡңрқҡҠМғрқҡҳ рқҡҠ рқҡ–рқҡҠрқҡ—рқҡҺрқҡ’рқҡӣрқҡҠ рқҡҚрқҡҳ рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҠМғрқҡҳ рқҡңрқҡҺ рқҡҢрқҡһрқҡӣрқҡҠрқҡӣ.",

"рҹҢҷ рқҡҖрқҡһрқҡҠрқҡ—рқҡҚрқҡҳ рқҡҠ рқҡқрқҡӣрқҡ’рқҡңрқҡқрқҡҺрқҡЈрқҡҠ рқҡҠрқҡҷрқҡҠрқҡӣрқҡҺрқҡҢрқҡҺ, рқҡ•рқҡҺрқҡ–рқҡӢрқҡӣрқҡҺ-рқҡңрқҡҺ: рқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠ рқҡңрқҡҺрқҡ–рқҡҷрқҡӣрқҡҺ рқҡҚрқҡҠМҒ рқҡ—рқҡҳрқҡҹрқҡҠрқҡң рқҡҳрқҡҷрқҡҳрқҡӣрқҡқрқҡһрқҡ—рқҡ’рқҡҚрқҡҠрқҡҚрқҡҺрқҡң.",

"рҹ’« рқҡ„рқҡ– рқҡҚрқҡ’рқҡҠ рқҡҹрқҡҳрқҡҢрқҡҺМӮ рқҡҹрқҡҠрқҡ’ рқҡҳрқҡ•рқҡ‘рқҡҠрқҡӣ рқҡҷрқҡҠрқҡӣрқҡҠ рқҡқрқҡӣрқҡҠМҒрқҡң рқҡҺ рқҡҷрқҡҺрқҡӣрқҡҢрқҡҺрқҡӢрқҡҺрқҡӣ рқҡҡрқҡһрқҡҺ рқҡҠрқҡқрқҡҺМҒ рқҡҠрқҡң рқҡҸрқҡҠрқҡңрқҡҺрқҡң рқҡқрқҡӣрқҡ’рқҡңрқҡқрқҡҺрқҡң рқҡқрқҡҺ рқҡҺрқҡ—рқҡңрқҡ’рқҡ—рқҡҠрқҡӣрқҡҠрқҡ– рқҡҠ рқҡңрқҡҺрқҡӣ рқҡ–рқҡҠрқҡ’рқҡң рқҡҸрқҡҳрқҡӣрқҡқрқҡҺ.",

"рҹҢ» рқҷјрқҡҺрқҡңрқҡ–рқҡҳ рқҡҺрқҡ– рқҡҚрқҡ’рқҡҠрқҡң рқҡқрқҡӣрқҡ’рқҡңрқҡқрқҡҺрқҡң, рқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠ рқҡҠрқҡ’рқҡ—рқҡҚрқҡҠ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡңрқҡһрқҡӣрқҡҷрқҡӣрқҡҺрқҡҺрқҡ—рқҡҚрқҡҺрқҡӣ рқҡҢрқҡҳрқҡ– рқҡҠрқҡ•рқҡҗрқҡҳ рқҡӢрқҡҳрқҡ—рқҡ’рқҡқрқҡҳ.",

"рҹ’ҷ рқҷҪрқҡҠМғрқҡҳ рқҡңрқҡҺ рқҡңрқҡҺрқҡ—рқҡқрқҡҠ рқҡңрқҡҳрқҡЈрқҡ’рқҡ—рқҡ‘рқҡҳ. рқҡғрқҡҳрқҡҚрқҡҳ рқҡ–рқҡһрқҡ—рқҡҚрқҡҳ рқҡҺрқҡ—рқҡҸрқҡӣрқҡҺрқҡ—рқҡқрқҡҠ рқҡ–рқҡҳрқҡ–рқҡҺрқҡ—рқҡқрқҡҳрқҡң рқҡқрқҡӣрқҡ’рқҡңрқҡқрқҡҺрқҡң, рқҡ–рқҡҠрқҡң рқҡҺрқҡ•рқҡҺрқҡң рқҡ—рқҡҠМғрқҡҳ рқҡҚрқҡһрқҡӣрқҡҠрқҡ– рқҡҷрқҡҠрқҡӣрқҡҠ рқҡңрқҡҺрқҡ–рқҡҷрқҡӣрқҡҺ.",

"вңЁ рқҡӮрқҡҺ рқҡ‘рқҡҳрқҡ“рқҡҺ рқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠ рқҡҷрқҡҠрқҡӣрқҡҺрқҡҢрқҡҺ рқҡҷрқҡҺрқҡңрқҡҠрқҡҚрқҡҠ, рқҡ—рқҡҠМғрқҡҳ рқҡҚрқҡҺрқҡңрқҡ’рқҡңрқҡқрқҡҠ. рқҷҫ рқҡҸрқҡһрқҡқрқҡһрқҡӣрқҡҳ рқҡҠрқҡ’рқҡ—рқҡҚрқҡҠ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡқрқҡӣрқҡҠрқҡЈрқҡҺрқҡӣ рқҡ–рқҡһрқҡ’рқҡқрқҡҠ рқҡҸрқҡҺрқҡ•рқҡ’рқҡҢрқҡ’рқҡҚрқҡҠрқҡҚрқҡҺ."
]

const resposta = respostasTriste[Math.floor(Math.random() * respostasTriste.length)];

await maki.sendMessage(from,{text:resposta},{quoted:info})

}

// DETECTAR PALAVRA "amor"
if (!isCmd && budy2 && budy2.toLowerCase().includes("amor") && !isBotoff) {

setTimeout(() => {
reagir(from,"рҹ–Ө")
},300)

const respostasAmor = [

"рҹ’– рқҷҫ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡ—рқҡҠМғрқҡҳ рқҡҺМҒ рқҡҠрқҡҷрқҡҺрқҡ—рқҡҠрқҡң рқҡһрқҡ–рқҡҠ рқҡҷрқҡҠрқҡ•рқҡҠрқҡҹрқҡӣрқҡҠвҖҰ рқҡҺМҒ рқҡһрқҡ– рқҡңрқҡҺрқҡ—рқҡқрқҡ’рқҡ–рқҡҺрқҡ—рқҡқрқҡҳ рқҡҷрқҡӣрқҡҳрқҡҸрқҡһрқҡ—рқҡҚрқҡҳ рқҡҡрқҡһрқҡҺ рқҡ—рқҡҠрқҡңрқҡҢрқҡҺ рқҡҚрқҡҺрқҡ—рқҡқрқҡӣрқҡҳ рқҡҚрқҡҳ рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҠМғрқҡҳ. рқҷҙрқҡ•рқҡҺ рқҡқрқҡҺрқҡ– рқҡҳ рқҡҷрқҡҳрқҡҚрқҡҺрқҡӣ рқҡҚрқҡҺ рқҡқрқҡӣрқҡҠрқҡ—рқҡңрқҡҸрқҡҳрқҡӣрқҡ–рқҡҠрқҡӣ рқҡҹрқҡ’рқҡҚрқҡҠрқҡң рқҡҺ рқҡҚрқҡҠрқҡӣ рқҡңрқҡҺрқҡ—рқҡқрқҡ’рқҡҚрқҡҳ рқҡҠМҖ рқҡҺрқҡЎрқҡ’рқҡңрқҡқрқҡҺМӮрқҡ—рқҡҢрқҡ’рқҡҠ. рқҷјрқҡҠрқҡң рқҡ•рқҡҺрқҡ–рқҡӢрқҡӣрқҡҺ-рқҡңрқҡҺ: рқҡ—рқҡһрқҡ—рқҡҢрқҡҠ рқҡӢрқҡӣрқҡ’рқҡ—рқҡҡрқҡһрқҡҺ рқҡҢрқҡҳрқҡ– рқҡҳ рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҠМғрқҡҳ рқҡҚрқҡҺ рқҡҠрқҡ•рқҡҗрқҡһрқҡҺМҒрқҡ–. рҹ’” рқҷҝрқҡҳрқҡ’рқҡң рқҡҠрқҡң рқҡҸрқҡҺрқҡӣрқҡ’рқҡҚрқҡҠрқҡң рқҡҚрқҡҳ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡңрқҡҠМғрқҡҳ рқҡҠрқҡң рқҡ–рқҡҠрқҡ’рқҡң рқҡҚрқҡ’рқҡҸрқҡ’МҒрқҡҢрқҡҺрқҡ’рқҡң рқҡҚрқҡҺ рқҡҢрқҡһрқҡӣрқҡҠрқҡӣ.",

"вқӨпёҸ рқҷҫ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡҹрқҡҺрқҡӣрқҡҚрқҡҠрқҡҚрқҡҺрқҡ’рқҡӣрқҡҳ рқҡ—рқҡҠМғрқҡҳ рқҡҺМҒ рқҡһрқҡ– рқҡ“рқҡҳрқҡҗрқҡҳ рқҡҺ рқҡ—рқҡҺрқҡ– рқҡһрқҡ– рқҡҷрқҡҠрқҡңрқҡңрқҡҠрқҡқрқҡҺрқҡ–рқҡҷрқҡҳ. рқҷҙМҒ рқҡһрқҡ– рқҡҢрқҡҳрқҡ–рқҡҷрқҡӣрқҡҳрқҡ–рқҡ’рқҡңрқҡңрқҡҳ рқҡҷрқҡӣрқҡҳрқҡҸрқҡһрқҡ—рқҡҚрқҡҳ рқҡҺрқҡ—рқҡқрқҡӣрқҡҺ рқҡҚрқҡҳрқҡ’рқҡң рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҳМғрқҡҺрқҡң. рҹӨқ рқҡҖрқҡһрқҡҺрқҡ– рқҡҠрқҡ–рқҡҠ рқҡҚрқҡҺ рқҡҹрқҡҺрқҡӣрқҡҚрқҡҠрқҡҚрқҡҺ рқҡҢрқҡһрқҡ’рқҡҚрқҡҠ, рқҡӣрқҡҺрқҡңрқҡҷрқҡҺрқҡ’рқҡқрқҡҠ рқҡҺ рқҡҷрқҡӣрқҡҳрқҡқрқҡҺрқҡҗрқҡҺ. рқҷҝрқҡҳрқҡӣ рқҡ’рқҡңрқҡңрқҡҳ рқҡ—рқҡһрқҡ—рқҡҢрқҡҠ рқҡһрқҡңрқҡҺ рқҡҳ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡҷрқҡҠрқҡӣрқҡҠ рқҡҺрқҡ—рқҡҗрқҡҠрқҡ—рқҡҠрқҡӣ рқҡҳрқҡһ рқҡ–рқҡҠрқҡҗрқҡҳрқҡҠрқҡӣ рқҡҠрқҡ•рқҡҗрқҡһрқҡҺМҒрқҡ–. вҡ пёҸ",

"рҹҢ№ рқҡҖрқҡһрқҡҠрқҡ—рқҡҚрқҡҳ рқҡҳ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡҺМҒ рқҡҹрқҡҺрқҡӣрқҡҚрқҡҠрқҡҚрқҡҺрқҡ’рқҡӣрқҡҳ, рқҡҺрқҡ•рқҡҺ рқҡқрқҡӣрқҡҠрқҡЈ рқҡҷрқҡҠрқҡЈ, рқҡҸрқҡҳрқҡӣрқҡҢМ§рқҡҠ рқҡҺ рқҡҺрқҡңрқҡҷрқҡҺрқҡӣрқҡҠрқҡ—рқҡҢМ§рқҡҠ. вңЁ рқҷҙрқҡ•рқҡҺ рқҡҸрқҡҠрқҡЈ рқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠ рқҡҷрқҡҠрқҡӣрқҡҺрқҡҢрқҡҺрқҡӣ рқҡ–рқҡҠрқҡ’рқҡң рқҡӢрқҡҳрқҡ—рқҡ’рқҡқрқҡҠ. рқҷјрқҡҠрқҡң рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡҺрқҡЎрқҡ’рқҡҗрқҡҺ рқҡӣрқҡҺрқҡңрқҡҷрқҡҺрқҡ’рқҡқрқҡҳ рқҡҺ рқҡңрқҡ’рқҡ—рқҡҢрқҡҺрқҡӣрқҡ’рқҡҚрқҡҠрқҡҚрқҡҺ. рқҷҪрқҡһрқҡ—рқҡҢрқҡҠ рқҡӢрқҡӣрқҡ’рқҡ—рқҡҢрқҡҺ рқҡҢрқҡҳрқҡ– рқҡҳ рқҡҠрқҡ–рқҡҳрқҡӣ, рқҡҷрқҡҳрқҡ’рқҡң рқҡҳ рқҡҡрқҡһрқҡҺ рқҡҷрқҡҠрқҡӣрқҡҺрқҡҢрқҡҺ рқҡңрқҡҳМҒ рқҡһрқҡ– рқҡңрқҡҺрқҡ—рқҡқрқҡ’рқҡ–рқҡҺрқҡ—рқҡқрқҡҳ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡңрқҡҺрқҡӣ рқҡқрқҡһрқҡҚрқҡҳ рқҡҷрқҡҠрқҡӣрқҡҠ рқҡҠрқҡ•рқҡҗрқҡһрқҡҺМҒрқҡ–. рҹ’”",

"рҹ’һ рқҷ°рқҡ–рқҡҳрқҡӣ рқҡҺМҒ рқҡһрқҡ– рқҡҚрқҡҳрқҡң рқҡңрқҡҺрқҡ—рқҡқрқҡ’рқҡ–рқҡҺрқҡ—рқҡқрқҡҳрқҡң рқҡ–рқҡҠрқҡ’рқҡң рқҡҸрқҡҳрқҡӣрқҡқрқҡҺрқҡң рқҡҡрқҡһрқҡҺ рқҡҺрқҡЎрқҡ’рқҡңрқҡқрқҡҺрқҡ–. рқҷҙрқҡ•рқҡҺ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡҺрқҡӣрқҡҗрқҡһрқҡҺрқҡӣ рқҡһрқҡ– рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҠМғрқҡҳвҖҰ рқҡҳрқҡһ рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡҷрқҡҳрқҡҚрқҡҺ рқҡҚрқҡҺрқҡңрқҡқрқҡӣрқҡһрқҡ’МҒ-рқҡ•рқҡҳ рқҡңрқҡҺ рқҡҸрқҡҳрқҡӣ рқҡһрқҡңрқҡҠрқҡҚрқҡҳ рқҡҢрқҡҳрқҡ–рқҡҳ рқҡӢрқҡӣрқҡ’рқҡ—рқҡҢрқҡҠрқҡҚрқҡҺрқҡ’рқҡӣрқҡҠ. вҡ пёҸ рқҷҝрқҡҳрқҡӣ рқҡ’рқҡңрқҡңрқҡҳ рқҡҹрқҡҠрқҡ•рқҡҳрқҡӣрқҡ’рқҡЈрқҡҺ рқҡҡрқҡһрқҡҺрқҡ– рқҡҠрқҡ–рқҡҠ рқҡҚрқҡҺ рқҡҹрқҡҺрқҡӣрқҡҚрқҡҠрқҡҚрқҡҺ.",

"рҹ’ҳ рқҷҫ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡҹрқҡҺрқҡӣрқҡҚрқҡҠрқҡҚрқҡҺрқҡ’рқҡӣрқҡҳ рқҡ—рқҡҠМғрқҡҳ рқҡңрқҡҺ рқҡӢрқҡҠрқҡңрқҡҺрқҡ’рқҡҠ рқҡҺрқҡ– рқҡҷрқҡҠрқҡ•рқҡҠрқҡҹрқҡӣрқҡҠрқҡң рқҡҹрқҡҠрқҡЈрқҡ’рқҡҠрқҡң, рқҡ–рқҡҠрқҡң рқҡңрқҡ’рқҡ– рқҡҺрқҡ– рқҡҠрқҡқрқҡ’рқҡқрқҡһрқҡҚрқҡҺрқҡң рқҡңрқҡ’рқҡ—рқҡҢрқҡҺрқҡӣрқҡҠрқҡң. рҹӨҚ рқҡҖрқҡһрқҡҺрқҡ– рқҡӢрқҡӣрқҡ’рқҡ—рқҡҢрқҡҠ рқҡҢрқҡҳрқҡ– рқҡҳ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡҠрқҡҢрқҡҠрқҡӢрқҡҠ рқҡ–рқҡҠрқҡҗрқҡҳрқҡҠрқҡ—рқҡҚрқҡҳ рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҳМғрқҡҺрқҡң рқҡҡрқҡһрқҡҺ рқҡҠрқҡҷрқҡҺрқҡ—рқҡҠрқҡң рқҡҡрқҡһрқҡҺрқҡӣрқҡ’рқҡҠрқҡ– рқҡңрқҡҺрқҡӣ рқҡҠрқҡ–рқҡҠрқҡҚрқҡҳрқҡң. рҹ’”",

"рҹ’қ рқҡӮрқҡҺ рқҡҠрқҡ•рқҡҗрқҡһрқҡҺМҒрқҡ– рқҡ•рқҡ‘рқҡҺ рқҡҳрқҡҸрқҡҺрқҡӣрқҡҺрқҡҢрқҡҺ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡңрқҡ’рқҡ—рқҡҢрқҡҺрқҡӣрқҡҳ, рқҡ—рқҡҠМғрқҡҳ рқҡҚрқҡҺрқҡңрқҡҷрқҡӣрқҡҺрқҡЈрқҡҺ. рқҷҝрқҡҳрқҡ’рқҡң рқҡҠрқҡ•рқҡҗрқҡһрқҡ–рқҡҠрқҡң рқҡҹрқҡҺрқҡЈрқҡҺрқҡң рқҡҠ рқҡҹрқҡ’рқҡҚрқҡҠ рқҡ—рқҡҠМғрқҡҳ рқҡҚрқҡҠМҒ рқҡһрқҡ–рқҡҠ рқҡңрқҡҺрқҡҗрқҡһрқҡ—рқҡҚрқҡҠ рқҡҢрқҡ‘рқҡҠрқҡ—рқҡҢрқҡҺ. вҸі рқҷҫ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡҺМҒ рқҡӣрқҡҠрқҡӣрқҡҳ рқҡҺ рқҡҷрқҡӣрқҡҺрқҡҢрқҡ’рқҡңрқҡҠ рқҡңрқҡҺрқҡӣ рқҡҢрқҡһрқҡ’рқҡҚрқҡҠрқҡҚрқҡҳ. вқӨпёҸ",

"вңЁ рқҷҫ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡҺМҒ рқҡҸрқҡҳрқҡӣрқҡҢМ§рқҡҠ, рқҡҺМҒ рқҡ•рқҡһрқҡЈ рқҡҺМҒ рқҡҺрқҡңрқҡҷрқҡҺрқҡӣрқҡҠрқҡ—рқҡҢМ§рқҡҠ. рҹҢҹ рқҷјрқҡҠрқҡң рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡҺМҒ рқҡҸрқҡӣрқҡҠМҒрқҡҗрқҡ’рқҡ• рқҡҡрқҡһрқҡҠрқҡ—рқҡҚрқҡҳ рқҡҺрқҡ—рқҡқрқҡӣрқҡҺрқҡҗрқҡһрқҡҺ рқҡҠ рқҡҢрқҡҳрқҡӣрқҡҠрқҡҢМ§рқҡҳМғрқҡҺрқҡң рқҡ’рқҡ—рқҡңрқҡҺрқҡ—рқҡңрқҡ’МҒрқҡҹрқҡҺрқҡ’рқҡң. вҡ пёҸ рқҷҝрқҡҳрқҡӣ рқҡ’рқҡңрқҡңрқҡҳ рқҡңрқҡҺрқҡ“рқҡҠ рқҡңрқҡ’рқҡ—рқҡҢрқҡҺрқҡӣрқҡҳ рқҡҡрқҡһрқҡҠрқҡ—рқҡҚрқҡҳ рқҡҸрқҡҠрқҡ•рқҡҠрқҡӣ рқҡҚрқҡҺ рқҡҠрқҡ–рқҡҳрқҡӣ.",

"рҹӨҚ рқҡҖрқҡһрқҡҺрқҡ– рқҡҠрқҡ–рқҡҠ рқҡҚрқҡҺ рқҡҹрқҡҺрқҡӣрқҡҚрқҡҠрқҡҚрқҡҺ рқҡ—рқҡҠМғрқҡҳ рқҡ–рқҡҠрқҡҗрқҡҳрқҡҠ, рқҡ—рқҡҠМғрқҡҳ рқҡҺрқҡ—рқҡҗрқҡҠрқҡ—рқҡҠ рқҡҺ рқҡ—рқҡҠМғрқҡҳ рқҡӢрқҡӣрқҡ’рқҡ—рқҡҢрқҡҠ рқҡҢрқҡҳрқҡ– рқҡңрқҡҺрқҡ—рқҡқрқҡ’рқҡ–рқҡҺрқҡ—рқҡқрқҡҳрқҡң. рҹ’” рқҷҫ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡҺМҒ рқҡҠрқҡ•рқҡҗрқҡҳ рқҡңрқҡҺМҒрқҡӣрқҡ’рқҡҳ, рқҡҡрқҡһрқҡҺ рқҡҚрқҡҺрқҡҹрқҡҺ рқҡңрқҡҺрқҡӣ рқҡқрқҡӣрқҡҠрқҡқрқҡҠрқҡҚрқҡҳ рқҡҢрқҡҳрқҡ– рқҡӣрқҡҺрқҡңрқҡҷрқҡҺрқҡ’рқҡқрқҡҳ рқҡҺ рқҡҹрқҡҺрқҡӣрқҡҚрқҡҠрқҡҚрқҡҺ.",

"рҹҢ№ рқҷҫ рқҡҠрқҡ–рқҡҳрқҡӣ рқҡҷрқҡҳрқҡҚрқҡҺ рқҡңрқҡҺрқҡӣ рқҡҠ рқҡҢрқҡҳрқҡ’рқҡңрқҡҠ рқҡ–рқҡҠрқҡ’рқҡң рқҡ•рқҡ’рқҡ—рқҡҚрқҡҠ рқҡҚрқҡҳ рқҡ–рқҡһрқҡ—рқҡҚрқҡҳ, рқҡ–рқҡҠрқҡң рқҡқрқҡҠрқҡ–рқҡӢрқҡҺМҒрқҡ– рқҡҷрқҡҳрқҡҚрқҡҺ рқҡңрқҡҺ рқҡқрқҡҳрқҡӣрқҡ—рқҡҠрқҡӣ рқҡҠ рқҡҚрқҡҳрқҡӣ рқҡ–рқҡҠрқҡ’рқҡң рқҡҷрқҡӣрқҡҳрқҡҸрқҡһрқҡ—рқҡҚрқҡҠ рқҡңрқҡҺ рқҡҸрқҡҳрқҡӣ рқҡқрқҡӣрқҡҠрқҡқрқҡҠрқҡҚрқҡҳ рқҡҢрқҡҳрқҡ– рқҡҸрқҡҠрқҡ•рқҡңрқҡ’рқҡҚрқҡҠрқҡҚрқҡҺ. рҹ’” рқҷҝрқҡҳрқҡӣ рқҡ’рқҡңрқҡңрқҡҳ рқҡңрқҡҺрқҡ“рқҡҠ рқҡңрқҡ’рқҡ—рқҡҢрқҡҺрқҡӣрқҡҳ рқҡҺ рқҡҹрқҡҠрқҡ•рқҡҳрқҡӣрқҡ’рқҡЈрқҡҺ рқҡҡрқҡһрқҡҺрқҡ– рқҡқрқҡҺ рқҡҠрқҡ–рқҡҠ. вқӨпёҸ"
];

const resposta = respostasAmor[Math.floor(Math.random() * respostasAmor.length)];

await maki.sendMessage(from, { text: resposta }, { quoted: info });

}




async function autoReagirStatus(maki, msg) {
try {
if (!msg?.key) return;
if (msg.key.remoteJid !== 'status@broadcast') return;

const donoStatus = msg.key.participant || msg.participant;
if (!donoStatus) return;
if (msg.key.fromMe) return;

let emoji = 'рҹ’ҷ';

if (msg.message?.imageMessage) emoji = 'рҹҳҚ';
else if (msg.message?.videoMessage) emoji = 'рҹ”Ҙ';
else if (msg.message?.extendedTextMessage || msg.message?.conversation) emoji = 'вңЁ';
else if (msg.message?.audioMessage) emoji = 'рҹҺ§';
else emoji = 'вҡЎ';

await new Promise(r => setTimeout(r, 2000));

await maki.sendMessage(
'status@broadcast',
{
react: {
text: emoji,
key: msg.key
}
},
{
statusJidList: [donoStatus]
}
);

console.log(`Reagi ao status de ${donoStatus} com ${emoji}`);
} catch (err) {
console.log('Erro ao reagir status:', err);
}
}









