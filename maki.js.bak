case 'dataconta':
case 'datadaconta':
{
if (!q.trim()) return reply(`- Exemplo: ${prefix}dataconta 168274223`);
const id = q.trim();
try {
const { data: json } = await axios.get(`https://world-ecletix.onrender.com/api/datadaconta?id=${encodeURIComponent(id)}`);
if (!json.success || !json.datacriacao) return reply("вқҢ NГЈo foi possГӯvel obter a data de criaГ§ГЈo da conta.");

let texto = json.datacriacao.replace(/https?:\/\/[^\s]+/g, "").trim();
const matchRaridade = texto.match(/(\d{2,3}\.\d{1,2})%/);
const raridade = matchRaridade ? parseFloat(matchRaridade[1]) : null;
const tagRara = raridade && raridade >= 90 ? `рҹ”Ҙ *Conta Ultra Rara (${raridade}%)!*` : "";

const mensagem = `рҹ“… ${texto}${tagRara ? `\n\n${tagRara}` : ""}`;
reply(mensagem);
} catch (err) {
console.error("Erro no comando dataconta:", err);
reply("рҹҡЁ Ocorreu um erro ao buscar a data da conta.");
}
}
break;

case 'primeff':
case 'ffprime':
{
if (!q.trim()) return reply(`- Exemplo: ${prefix}primeff 168274223`);
const id = q.trim();
await reply("рҹ”Қ Verificando conta Prime...");
try {
const { data: json } = await axios.get(`https://world-ecletix.onrender.com/api/primeff?id=${encodeURIComponent(id)}`);
if (!json.success) return reply("вқҢ Esta conta nГЈo possui status Prime ou ocorreu um erro.");

const privilegios = Array.isArray(json.privilegios)
? json.privilegios.map(p => `вҖў ${p}`).join("\n")
: "Nenhum privilГ©gio listado.";

const msg = `вң… Conta Prime encontrada!\n\nрҹҶ” ID: ${json.id}\n\nрҹҺҒ PrivilГ©gios desbloqueados:\n${privilegios}`;
reply(msg);
} catch (err) {
console.error("Erro no comando primeff:", err);
reply("рҹҡЁ Erro ao verificar status Prime.");
}
}
break;

case 'xpff':
case 'lvlff':
case 'lvl100':
{
if (!q.trim() || isNaN(q)) return reply(`- Exemplo: ${prefix}xpff 74`);
const nivel = parseInt(q.trim());
try {
const { data: json } = await axios.get(`https://world-ecletix.onrender.com/api/calcularxp?nivel=${nivel}`);
if (typeof json.xpNecessario !== "number") return reply("вқҢ Erro ao calcular o XP necessГЎrio.");

const xpFalta = Number(json.xpNecessario).toLocaleString("pt-BR");
reply(`рҹ§  Faltam ${xpFalta} de XP para o nГӯvel 100!`);
} catch (err) {
console.error("Erro no comando xpff:", err);
reply("рҹҡЁ Ocorreu um erro ao consultar o XP.");
}
}
break;

