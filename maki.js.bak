await maki
.sendMessage(
to,
{sticker: media},
{
sendEphemeral: true,
contextInfo: { forwardingScore: 50, isForwarded: false },
quoted: selo,
}
)
.catch(async (error) => {
return reply(mess.error());
});
DLT_FL(filess);
DLT_FL(asw);
}
);
});
} catch {
return reply(mess.error());
}
};
