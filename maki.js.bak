// ========= || Jogo da Velha || ======== \\
async function startJogoDaVelha() {
if (!joguinhodavelhajs2.includes(from) && !joguinhodavelhajs.includes(sender)) return;

const texto = budy.toLowerCase().trim();
const numeros = ["1","2","3","4","5","6","7","8","9"];
const caminho = `./arquivos/tictactoe/db/${from}.json`;

if (!fs.existsSync(caminho)) return;

const boardnow = setGame(from);

const jidX = boardnow.X + "@s.whatsapp.net";
const jidO = boardnow.O + "@s.whatsapp.net";

// ====== ACEITAR JOGO ======
if (["s","sim","ok"].includes(texto)) {
if (boardnow.O !== sender.replace("@s.whatsapp.net","")) return;
if (boardnow.status) return;

boardnow.status = true;
fs.writeFileSync(caminho, JSON.stringify(boardnow, null, 2));

const matrix = boardnow._matrix;

return maki.sendMessage(from, {
text:
`*гҖҺ рҹҺ® гҖҸJOGO DA VELHAгҖҺ рҹ•№пёҸ гҖҸ*

вқҢ : @${boardnow.X}
вӯ• : @${boardnow.O}
вҖў Sua vez : @${boardnow.turn === "X" ? boardnow.X : boardnow.O}

${matrix[0][0]}${matrix[0][1]}${matrix[0][2]}
${matrix[1][0]}${matrix[1][1]}${matrix[1][2]}
${matrix[2][0]}${matrix[2][1]}${matrix[2][2]}`,
mentions: [jidX, jidO]
});
}

// ====== RECUSAR JOGO ======
if (["n","nГЈo","no"].includes(texto)) {
if (boardnow.O !== sender.replace("@s.whatsapp.net","")) return;

DLT_FL(caminho);

joguinhodavelhajs.length = 0;
joguinhodavelhajs2.length = 0;

fs.writeFileSync('./arquivos/database/usuarios/joguinhodavelha.json', JSON.stringify(joguinhodavelhajs));
fs.writeFileSync('./arquivos/database/usuarios/joguinhodavelhajs2.json', JSON.stringify(joguinhodavelhajs2));

return maki.sendMessage(from, {
text: `вқҢ @${boardnow.X}, infelizmente seu oponente recusou o desafio.`,
mentions: [jidX]
});
}

// ====== JOGADA ======
if (!numeros.includes(texto)) return;
if (!boardnow.status)
return reply("вҸі O oponente ainda nГЈo aceitou o desafio.");

const vez = boardnow.turn === "X" ? boardnow.X : boardnow.O;
if (vez !== sender.replace("@s.whatsapp.net","")) return;

const moving = validmove(Number(texto), from);
const matrix = moving._matrix;

// ====== EMPATE ======
if (moving.isWin && moving.winner === "SERI") {
reply("рҹӨқ O jogo terminou em empate!");
DLT_FL(caminho);
limparVelha();
return;
}

// ====== VITГ“RIA ======
if (moving.isWin) {
const winner = moving.winner === "O" ? moving.O : moving.X;
const winnerJid = winner + "@s.whatsapp.net";

await maki.sendMessage(from, {
text: `рҹҸҶ ParabГ©ns @${winner}, vocГӘ venceu o *Jogo da Velha*!`,
mentions: [winnerJid]
});

DLT_FL(caminho);
limparVelha();
return;
}

// ====== CONTINUA ======
await maki.sendMessage(from, {
text:
`*гҖҺ рҹҺ® гҖҸJOGO DA VELHAгҖҺ рҹ•№пёҸ гҖҸ*

вқҢ : @${boardnow.X}
вӯ• : @${boardnow.O}
вҖў Sua vez : @${moving.turn === "X" ? moving.X : moving.O}

${matrix[0][0]}${matrix[0][1]}${matrix[0][2]}
${matrix[1][0]}${matrix[1][1]}${matrix[1][2]}
${matrix[2][0]}${matrix[2][1]}${matrix[2][2]}`,
mentions: [jidX, jidO]
});
}

// ====== LIMPEZA ======
function limparVelha() {
joguinhodavelhajs.length = 0;
joguinhodavelhajs2.length = 0;

fs.writeFileSync('./arquivos/database/usuarios/joguinhodavelha.json', JSON.stringify(joguinhodavelhajs));
fs.writeFileSync('./arquivos/database/usuarios/joguinhodavelhajs2.json', JSON.stringify(joguinhodavelhajs2));
}
if (budy2.toLowerCase() === "s" || budy2.toLowerCase() === "sim") {
if (JSON.stringify(namoro2).includes(sender) && namoro2[namoro2.map(i => i.id).indexOf(sender)].idgp == from && isGroup) {
let C14 = namoro2.map(i => i.id).indexOf(sender);
let C12 = namoro1.map(i => i.usu1).indexOf(namoro2[C14].pedido + "@s.whatsapp.net");
namoro1[C12].namorados = true;
const agora = Date.now();
fs.writeFileSync("./arquivos/database/func/namoro1.json", JSON.stringify(namoro1));
namoro1.push({ usu1: sender, usu2: namoro2[C14].pedido, namorados: true, idgp: from, hora: hourofc, data: dattofc, inicio: agora });
fs.writeFileSync("./arquivos/database/func/namoro1.json", JSON.stringify(namoro1));
namoro2.splice(C14, 1);
fs.writeFileSync("./arquivos/database/func/namoro2.json", JSON.stringify(namoro2));
let ppimg;
try {
ppimg = await maki.profilePictureUrl(sender, 'image');
} catch {
ppimg = imgperfil;
}
await maki.sendMessage(from, {
image: { url: ppimg },
caption: mess.namoro(namoro1, C12, sender, prefix),
contextInfo: { ...channeldl, mentionedJid: [namoro1[C12].usu1, sender] }
}, { quoted: selo });
}
}

if (budy2.toLowerCase() === "n" || budy2.toLowerCase().replace("ГЈ", "a") === "nao") {
if (JSON.stringify(namoro2).includes(sender) && namoro2[namoro2.map(i => i.id).indexOf(sender)].idgp == from && isGroup) {
let C14 = namoro2.map(i => i.id).indexOf(sender);
let C12 = namoro1.map(i => i.usu1).indexOf(`${namoro2[C14].pedido}@s.whatsapp.net`);
await maki.sendMessage(from, {text: mess.fora(namoro1, C12, sender, prefix), contextInfo: {...channeldl, mentionedJid: [namoro1[C12].usu1, sender]}}, { quoted: selo });
namoro1.splice(C12, 1);
fs.writeFileSync("./arquivos/database/func/namoro1.json", JSON.stringify(namoro1));
namoro2.splice(C14, 1);
fs.writeFileSync("./arquivos/database/func/namoro2.json", JSON.stringify(namoro2));
}
}

startJogoDaVelha()

//====================вү вү ===============\\

if (isAntiStatus && info.message.groupStatusMentionMessage && isBotGroupAdmins && !isGroupAdmins && !SoDono) {
await sleep(400);
await maki.groupParticipantsUpdate(from, [sender], "remove");
await maki.sendMessage(from, {text: `рҹҡ« *@${sender.split("@")[0]}* рқҷөрқҷҫрқҷё рқҡҒрқҷҙрқҷјрқҷҫрқҡ…рқҷёрқҷірқҷҫ рқҷҝрқҷҫрқҡҒ рқҷјрқҷҙрқҷҪрқҷІрқҷёрқҷҫрқҷҪрқҷ°рқҡҒ рқҷҫ рқҷ¶рқҡҒрқҡ„рқҷҝрқҷҫ рқҷҪрқҷҫрқҡӮ рқҡӮрқҡғрқҷ°рқҡғрқҡ„рқҡӮ рҹ‘Ӣ.`, mentions: [sender]});
await maki.sendMessage(from, {delete: {remoteJid: from, fromMe: false, id: info.key.id, participant: sender}});
return;
};

if (info.message.PaymentRequestMessage || info.message.requestPaymentMessage && isBotGroupAdmins && !isGroupAdmins && !SoDono) {
