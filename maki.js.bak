return reply(`вқҢ *NГЈo hГЎ usuГЎrios VIP na lista.*`);

// Limpa o array VIP
vip.length = 0;

// Salva o arquivo vazio
fs.writeFileSync('./arquivos/database/usuarios/vip.json', JSON.stringify(vip, null, 2));

await maki.sendMessage(
