let teks = `рҹ‘‘ *КҹЙӘsбҙӣбҙҖ бҙ…бҙҮ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸs бҙ ЙӘбҙҳ*
рҹ“Ҡ Total: *${vip.length}*

`;

