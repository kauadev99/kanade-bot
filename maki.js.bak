contextInfo: canalInfo([`${numeroAntigo}@s.whatsapp.net`])
},
{ quoted: selo }
);
}
let numeroNovo = menc_os2 ? menc_os2.split('@')[0] : q.replace(/\D/g,'');
if (!numeroNovo) return reply("*рҹ’« бҙҚбҙҮЙҙбҙ„ЙӘбҙҸЙҙбҙҮ бҙҸ бҙңsбҙңбҙҖКҖЙӘбҙҸ бҙҸ бҙ…ЙӘЙўЙӘбҙӣбҙҮ бҙҸ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ рҹҷҮвҖҚвҷӮпёҸ*");
nescessario[chave] = numeroNovo;
setNes(nescessario);
await maki.sendMessage(
from,
{
text: `*@${numeroNovo} бҙҖЙўбҙҸКҖбҙҖ Т“бҙҖбҙў бҙҳбҙҖКҖбҙӣбҙҮ бҙ…бҙҸ бҙӣЙӘбҙҚбҙҮ бҙ…бҙҸкңұ бҙ…бҙҸЙҙбҙҸкңұ рҹҷ…вҖҚвҷӮпёҸ*`,
contextInfo: canalInfo([menc_os2 || `${numeroNovo}@s.whatsapp.net`])
},
{ quoted: selo }
)
break;
