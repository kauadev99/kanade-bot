rgtakergtake.push(i.usuario);
}
if (rgtakergtake.indexOf(sender) >= 0)
return reply("VocГӘ jГЎ registrou sua marca ДҸagua, nГЈo Г© possГӯvel usar esse comando novamente.");
if (!q.includes("|"))
return reply(
`VocГӘ usou de forma errada, siga o exemplo: *${prefix + command} sb|bot*`
);
if (!TP)
return reply(`VocГӘ esqueceu de preencher o primeiro campo... Ex: *${prefix + command} sb|bot*`);
if (!TP2)
return reply(`VocГӘ esqueceu de preencher o segundo campo... Ex: *${prefix + command} sb|bot*`);
rgtake.push({ usuario: sender, mcdagua1: TP, mcdagua2: TP2 });
fs.writeFileSync(
"./arquivos/database/usuarios/take.json",
JSON.stringify(rgtake, null, 2)
);
reply(
`Sucesso ao concluir o registro... Agora vocГӘ pode usar o comando: *${prefix}take*`
);
break;

case 'rntake':
i8 = rgtake.map((i) => i.usuario).indexOf(sender);
if (i8 < 0)
return reply(
`Como vocГӘ quer renomear algo que vocГӘ nГЈo tem registro?`
);
if (!q.includes("|"))
return reply(
`VocГӘ usou de forma errada, siga o exemplo: *${prefix + command} sb|bot*`
);
var [MARCAD1, MARCAD2] = q.split("|");
if (!MARCAD1)
return reply(
`VocГӘ esqueceu de preencher o primeiro campo... Ex: *${prefix + command} sb|bot*`
);
if (!MARCAD2)
return reply(
`VocГӘ esqueceu de preencher o segundo campo... Ex: *${prefix + command} sb|bot*`
);
rgtake[i8].mcdagua1 = MARCAD1;
rgtake[i8].mcdagua2 = MARCAD2;
fs.writeFileSync(
"./arquivos/database/usuarios/take.json",
JSON.stringify(rgtake, null, 2) + "\n"
);
reply(
`Sua marca ДҸГЎgua foi alterada para *"${MARCAD1}|${MARCAD2}"* com sucesso.`
);
break;

case 'qc':
if(!q) return reply(`- Exemplo: ${prefix+command} ${NomeDoBot}`)
reply(mess.teste());
const text = `${q}`
const username2 = `${pushname}`
try {
ppimg = await maki.profilePictureUrl(sender, 'image')
} catch {
ppimg = imgperfil
}
const { writeExifImg } = require('./configs/lib/exif')
maki.sendImageAsSticker = async (jid, path, options = {}) => {
let buff = Buffer.isBuffer(path) ? path : /^data:.*?\/.*?;base64,/i.test(path) ? Buffer.from(path.split`,`[1], 'base64') : /^https?:\/\//.test(path) ? await (await getBuffer(path)) : fs.existsSync(path) ? fs.readFileSync(path) : Buffer.alloc(0)
let buffer
if (options && (options.packname || options.author)) {
buffer = await writeExifImg(buff, options)
} else {
buffer = await imageToWebp(buff)
}
await maki.sendMessage(jid, { sticker: { url: buffer }, ...options})
return buffer
}
const avatar = `${ppimg}`
const json = { "type": "quote", "format": "png", "backgroundColor": "#000000", "width": 512, "height": 768, "scale": 2, "messages": [{ "entities": [], "avatar": true, "from": { "id": 1, "name": username2, "photo": { "url": avatar }
}, "text": text, "replyMessage": {}
}
]
};
 response = axios.post('https://bot.lyo.su/quote/generate', json, {
headers: {'Content-Type': 'application/json'}
}).then(res => {
const buffer = Buffer.from(res.data.result.image, 'base64')
sendImageAsSticker(maki, from, buffer, selo, { packname: pushname, author: NomeDoBot, 
contextInfo: {...channeldl}
}, {quoted: selo})
})
break


case 'st':
case 'stk':
case 'sticker':
case 's':
(async function () {
try {

await reagir(from, "рҹ’ҷ");
const legenda = ` ${NomeDoBot}`;
const autor = `${pushname}`;

if ((isMedia && info.message.imageMessage) || isQuotedImage) {
const encmedia = isQuotedImage
? info.message.extendedTextMessage?.contextInfo?.quotedMessage?.imageMessage
: info.message.imageMessage;

if (!encmedia?.mimetype)
return reply("*рҹҢ«пёҸ ЙҙГЈбҙҸ Т“бҙҸЙӘ бҙҳбҙҸssГӯбҙ бҙҮКҹ бҙҮЙҙбҙ„бҙҸЙҙбҙӣКҖбҙҖКҖ бҙҖ ЙӘбҙҚбҙҖЙўбҙҮбҙҚ.*");

const rane = getRandom("." + (await getExtension(encmedia.mimetype)));
const buffimg = await getFileBuffer(encmedia, "image");
fs.writeFileSync(rane, buffimg);

const rano = getRandom(".webp");

exec(
`ffmpeg -i ${rane} -vcodec libwebp -filter:v fps=15 -lossless 1 -loop 0 -preset default -an -vsync 0 -s 800:800 ${rano}`,
(err) => {
if (err) {
reply("*рҹ’ҷ бҙҮКҖКҖбҙҸ бҙҖбҙҸ бҙ„бҙҸЙҙбҙ бҙҮКҖбҙӣбҙҮКҖ бҙҖ ЙӘбҙҚбҙҖЙўбҙҮбҙҚ.*");
fs.unlinkSync(rane);
return;
}
fs.unlinkSync(rane);

const json = {
"sticker-pack-name": legenda,
"sticker-pack-publisher": autor,
};

const exifAttr = Buffer.from([
0x49,0x49,0x2a,0x00,0x08,0x00,0x00,0x00,0x01,
0x00,0x41,0x57,0x07,0x00,0x00,0x00,0x00,0x00,
0x16,0x00,0x00,0x00,
]);

const jsonBuff = Buffer.from(JSON.stringify(json), "utf-8");
const exif = Buffer.concat([exifAttr, jsonBuff]);
exif.writeUIntLE(jsonBuff.length, 14, 4);

const nomemeta = `${Math.floor(Math.random() * (99999 - 11111 + 1) + 11111)}.temp.exif`;
fs.writeFileSync(`./${nomemeta}`, exif);

exec(
`webpmux -set exif ${nomemeta} ${rano} -o ${rano}`,
() => {
maki.sendMessage(
from,
{
sticker: fs.readFileSync(rano),
contextInfo: canalInfo([])
},
{ quoted: info }
);
fs.unlinkSync(nomemeta);
fs.unlinkSync(rano);
}
);
}
);

} else if (
(isMedia && info.message.videoMessage?.seconds < 11) ||
(isQuotedVideo &&
info.message.extendedTextMessage?.contextInfo?.quotedMessage
?.videoMessage?.seconds < 11)
) {
const encmedia = isQuotedVideo
? info.message.extendedTextMessage?.contextInfo?.quotedMessage?.videoMessage
: info.message.videoMessage;

if (!encmedia?.mimetype)
return reply("*рҹҢ«пёҸ ЙҙГЈбҙҸ Т“бҙҸЙӘ бҙҳбҙҸssГӯбҙ бҙҮКҹ бҙҮЙҙбҙ„бҙҸЙҙбҙӣКҖбҙҖКҖ бҙҸ бҙ Гӯбҙ…бҙҮбҙҸ.*");

const rane = getRandom("." + (await getExtension(encmedia.mimetype)));
const buffimg = await getFileBuffer(encmedia, "video");
fs.writeFileSync(rane, buffimg);

const rano = getRandom(".webp");

exec(
`ffmpeg -i ${rane} -vcodec libwebp -filter:v fps=15 -lossless 1 -loop 0 -preset default -an -vsync 0 -s 200:200 ${rano}`,
(err) => {
if (err) {
reply("*рҹ«§ бҙҮКҖКҖбҙҸ бҙҖбҙҸ бҙ„бҙҸЙҙбҙ бҙҮКҖбҙӣбҙҮКҖ бҙҸ бҙ Гӯбҙ…бҙҮбҙҸ.*");
fs.unlinkSync(rane);
return;
}
fs.unlinkSync(rane);

const json = {
"sticker-pack-name": legenda,
"sticker-pack-publisher": autor,
};

const exifAttr = Buffer.from([
0x49,0x49,0x2a,0x00,0x08,0x00,0x00,0x00,0x01,
0x00,0x41,0x57,0x07,0x00,0x00,0x00,0x00,0x00,
0x16,0x00,0x00,0x00,
]);

const jsonBuff = Buffer.from(JSON.stringify(json), "utf-8");
const exif = Buffer.concat([exifAttr, jsonBuff]);
exif.writeUIntLE(jsonBuff.length, 14, 4);

const nomemeta = `${Math.floor(Math.random() * (99999 - 11111 + 1) + 11111)}.temp.exif`;
fs.writeFileSync(`./${nomemeta}`, exif);

exec(
`webpmux -set exif ${nomemeta} ${rano} -o ${rano}`,
() => {
maki.sendMessage(
from,
{
sticker: fs.readFileSync(rano),
contextInfo: canalInfo([])
},
{ quoted: info }
);
fs.unlinkSync(nomemeta);
fs.unlinkSync(rano);
}
);
}
);

} else {
reply(
"*рҹ’ҷ *бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙңбҙҚбҙҖ ЙӘбҙҚбҙҖЙўбҙҮбҙҚ бҙҸбҙң бҙ Гӯбҙ…бҙҮбҙҸ бҙ„бҙҸбҙҚ бҙҚбҙҮЙҙбҙҸs бҙ…бҙҮ 10 sбҙҮЙўбҙңЙҙбҙ…бҙҸs бҙҳбҙҖКҖбҙҖ бҙ„КҖЙӘбҙҖКҖ бҙҸ sбҙӣЙӘбҙ„бҙӢбҙҮКҖ.*"
);
}

} catch (e) {
console.log(e);
reply("*вҡ пёҸ КңбҙҸбҙңбҙ бҙҮ бҙңбҙҚ бҙҮКҖКҖбҙҸ ЙӘЙҙбҙҮsбҙҳбҙҮКҖбҙҖбҙ…бҙҸ бҙҖбҙҸ бҙ„КҖЙӘбҙҖКҖ бҙҸ sбҙӣЙӘбҙ„бҙӢбҙҮКҖ.*");
}
})();
break;


//================[ NAMORO ]===========\\

case 'namorar':
case 'pediremnamoro': {
if (!isGroup) return reply(mess.onlyGroup());
if (!menc_os2) return reply("*рҹҢҹ бҙҚбҙҮЙҙбҙ„ЙӘбҙҸЙҙбҙҮ бҙҖ бҙҚбҙҮЙҙsбҙҖЙўбҙҮбҙҚ бҙҸбҙң бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙңбҙҚ бҙңsбҙңбҙҖКҖЙӘбҙҸ бҙ„бҙҸбҙҚ бҙҸ @ бҙ…бҙҮКҹбҙҮ*")
if (botNumberLID.includes(menc_os2)) return reply("*бҙҮбҙң sбҙҸбҙң бҙҖбҙҳбҙҮЙҙбҙҖs бҙңбҙҚбҙҖ бҙҚбҙҖЗ«бҙңЙӘЙҙбҙҖ З«бҙңбҙҮ ЙҙбҙҖбҙҸ бҙӣбҙҮбҙҚ sбҙҮЙҙбҙӣЙӘбҙҚбҙҮЙҙбҙӣбҙҸs.. ЙҙбҙҖбҙҸ бҙҳбҙҸssбҙҸ бҙҳКҖбҙҮбҙҮЙҙбҙ„КңбҙҮКҖ sбҙҮбҙң бҙ бҙҖбҙўЙӘбҙҸ, бҙҳбҙҮбҙ„бҙҖ бҙҖКҹЙўбҙңбҙҮбҙҚ КҖбҙҮбҙҖКҹ бҙҮбҙҚ ЙҙбҙҖбҙҚбҙҸКҖбҙҸ, бҙҮ ЙҙбҙҖбҙҸ бҙңбҙҚ КҖбҙҸКҷбҙҸ. рҹӨҰвҖҚвҷӮпёҸ*");
if (JSON.stringify(namoro2).includes(menc_os2)) return reply(`*бҙҮкңұбҙӣбҙҮ бҙңкңұбҙңбҙҖКҖЙӘбҙҸ бҙҠбҙҖ кң°бҙҸЙӘ бҙ©бҙҮбҙ…ЙӘбҙ…бҙҸ бҙҮбҙҚ ЙҙбҙҖбҙҚбҙҸКҖбҙҸ рҹ’ҒвҖҚвҷӮпёҸ*`);
if (JSON.stringify(namoro1).includes(menc_os2) && namoro1[namoro1.map(i => i.usu1).indexOf(menc_os2)].namorados == false)
return reply(`*бҙҮssбҙҖ бҙҳбҙҮssбҙҸбҙҖ бҙҠбҙҖ бҙҳбҙҮбҙ…ЙӘбҙң бҙҖКҹЙўбҙңбҙҮбҙҚ бҙҚбҙҖЙӘs ЙӘЙҙбҙӣбҙҮКҖбҙҮssбҙҖЙҙбҙӣбҙҮ З«бҙңбҙҮ бҙ бҙҸбҙ„бҙҮ бҙҮбҙҚ ЙҙбҙҖбҙҚбҙҸКҖбҙҸ, sЙӘЙҙбҙӣбҙҸ бҙҚбҙңЙӘбҙӣбҙҸ рҹӨ·вҖҚвҷӮпёҸ*`);
if (JSON.stringify(namoro1).includes(menc_os2) && namoro1[namoro1.map(i => i.usu1).indexOf(menc_os2)].namorados == true)
return reply(`*ЙҙбҙҖбҙҸ бҙҮ бҙҳбҙҸssЙӘбҙ бҙҮКҹ, бҙҳбҙҸЙӘs бҙҖ бҙҚбҙҮsбҙҚбҙҖ бҙҠбҙҖ бҙҮsбҙӣбҙҖ бҙ„бҙҸбҙҚ бҙҸбҙңбҙӣКҖбҙҸ(бҙҖ) рҹ’ҒвҖҚвҷӮпёҸ*`);
if (JSON.stringify(namoro1).includes(sender) && namoro1[namoro1.map(i => i.usu1).indexOf(sender)].namorados == false)
return mention(`*бҙ бҙҸбҙ„бҙҮ бҙҠбҙҖ бҙҳбҙҮбҙ…ЙӘбҙң бҙҖКҹЙўбҙңбҙҮбҙҚ бҙҮбҙҚ ЙҙбҙҖбҙҚбҙҸКҖбҙҸ, бҙҳбҙҖКҖбҙҮ бҙ…бҙҮ КҷКҖЙӘЙҙбҙ„бҙҖКҖ бҙ„бҙҸбҙҚ бҙҸs sбҙҮЙҙбҙӣЙӘбҙҚбҙҮЙҙбҙӣбҙҸs бҙ…бҙҸs бҙҸбҙңбҙӣКҖбҙҸs рҹӨҰвҖҚвҷӮпёҸ*`);
if (JSON.stringify(namoro1).includes(sender) && namoro1[namoro1.map(i => i.usu1).indexOf(sender)].namorados == true)
return mention(`*бҙ бҙҸбҙ„бҙҮ бҙҠбҙҖ бҙҮsбҙӣбҙҖ ЙҙбҙҖбҙҚбҙҸКҖбҙҖЙҙбҙ…бҙҸ бҙҖКҹЙўбҙңбҙҮбҙҚ, бҙҳбҙҖКҖбҙҮ бҙ…бҙҮ sбҙҮКҖ ЙӘЙҙТ“ЙӘбҙҮКҹ бҙҮ sбҙҮбҙҠбҙҖ Т“ЙӘбҙҮКҹ ЙӘЙўбҙңбҙҖКҹ бҙҖ бҙҚЙӘбҙҚ рҹ’ҒвҖҚвҷӮпёҸ*`);
await reagir(from, "рҹ’Қ");
namoro1.push({usu1: sender, usu2: menc_os2.split('@')[0], namorados: false, idgp: from, hora: hourofc, data: dattofc});
fs.writeFileSync("./arquivos/database/func/namoro1.json", JSON.stringify(namoro1));
namoro2.push({id: menc_os2, pedido: sender.split('@')[0], idgp: from});
fs.writeFileSync("./arquivos/database/func/namoro2.json", JSON.stringify(namoro2));
const texto = mess.pedidoNamoro(menc_os2, sender, prefix);
await maki.sendMessage(from, { image: { url: namorar }, caption: texto, contextInfo: { ...channeldl, mentionedJid: [menc_os2, sender] }}, { quoted: selo });
break;
}

case 'cancelar':
case 'cancelarpedido': {
if (!isGroup) return reply(mess.onlyGroup());
const index1 = namoro1.findIndex(i => i.usu1 === sender);
if (index1 === -1) return reply("*бҙҮбҙң бҙ бҙҸбҙң бҙ„бҙҖЙҙбҙ„бҙҮКҹбҙҖКҖ бҙҸ З«бҙңбҙҮ sбҙҮ ЙҙбҙҖбҙҸ бҙӣбҙҮбҙҚ ЙҙбҙҖбҙ…бҙҖ? рҹӨҰвҖҚвҷӮпёҸ*");
if (namoro1[index1].namorados === true)
return reply("*ЙҙбҙҖбҙҸ бҙҮ бҙҳбҙҸssЙӘбҙ бҙҮКҹ бҙ„бҙҖЙҙбҙ„бҙҮКҹбҙҖКҖ бҙҖКҹЙўбҙҸ З«бҙңбҙҮ бҙҠбҙҖ Т“бҙҸЙӘ бҙҖбҙ„бҙҮЙӘбҙӣбҙҸ рҹӨ·вҖҚвҷӮпёҸ*");
const parceiro = namoro1[index1].usu2 + "@s.whatsapp.net";
namoro1.splice(index1, 1);
fs.writeFileSync("./arquivos/database/func/namoro1.json", JSON.stringify(namoro1));
const index2 = namoro2.findIndex(i => i.id === parceiro && i.pedido === sender.split("@")[0]);
if (index2 !== -1) {
namoro2.splice(index2, 1);
fs.writeFileSync("./arquivos/database/func/namoro2.json", JSON.stringify(namoro2));
}
reply("*бҙҳбҙҮбҙ…ЙӘбҙ…бҙҸ бҙ…бҙҮ ЙҙбҙҖбҙҚбҙҸКҖбҙҸ бҙ„бҙҖЙҙбҙ„бҙҮКҹбҙҖбҙ…бҙҸ! рҹ’ҒвҖҚвҷӮпёҸ*");
break;
}

case 'terminar':
case 'terminar_namoro': {
if (!JSON.stringify(namoro1).includes(sender))
return reply(`*бҙ бҙҸбҙ„бҙҮ ЙҙбҙҖбҙҸ бҙҮкңұбҙӣбҙҖ ЙҙбҙҖбҙҚбҙҸКҖбҙҖЙҙбҙ…бҙҸ бҙ„бҙҸбҙҚ ЙҙЙӘЙҙЙўбҙңбҙҮбҙҚ...рҹҷҮвҖҚвҷӮпёҸ*`);
let D1 = namoro1.map(i => i.usu1).indexOf(sender);
if (D1 === -1) D1 = namoro1.map(i => i.usu2).indexOf(sender);
if (D1 === -1)
return reply(`*ЙҙбҙҖбҙҸ бҙҮЙҙбҙ„бҙҸЙҙбҙӣКҖбҙҮЙӘ бҙҸ кңұбҙҮбҙң КҖбҙҮКҹбҙҖбҙ„ЙӘбҙҸЙҙбҙҖбҙҚбҙҮЙҙбҙӣбҙҸ. бҙӣбҙҮЙҙбҙӣбҙҮ бҙ…бҙҮ ЙҙбҙҸбҙ бҙҸ рҹӨ·вҖҚвҷӮпёҸ*`);
const parceiro = namoro1[D1].usu1 === sender ? namoro1[D1].usu2 : namoro1[D1].usu1;
const jidParceiro = parceiro.includes('@s.whatsapp.net') ? parceiro : `${parceiro}@s.whatsapp.net`;
const D2 = namoro1.map(a => a.usu1).indexOf(jidParceiro);
if (D2 !== -1) { namoro1[D2].namorados = false; namoro1.splice(D2, 1);
}
await reply(`*бҙҸ ЙҙбҙҖбҙҚбҙҸКҖбҙҸ кң°бҙҸЙӘ бҙ…бҙҮкңұбҙӣКҖбҙңЙӘМҒбҙ…бҙҸ... бҙ бҙҸбҙ„бҙҮ бҙҖЙўбҙҸКҖбҙҖ бҙҮкңұбҙӣбҙҖ кңұбҙҸКҹбҙӣбҙҮЙӘКҖбҙҸ бҙ…бҙҮ ЙҙбҙҸбҙ бҙҸ!рҹҷҶвҖҚвҷӮпёҸ*`);
await maki.sendMessage(jidParceiro, { text: `*рҹ’” бҙӣбҙҮЙҙКңбҙҸ бҙңбҙҚбҙҖ ЙҙбҙҸбҙӣЙӘМҒбҙ„ЙӘбҙҖ бҙӣКҖЙӘкңұбҙӣбҙҮ... кңұбҙҮбҙң бҙҳбҙҖКҖбҙ„бҙҮЙӘКҖбҙҸ(бҙҖ) бҙҖбҙ„бҙҖКҷбҙҸбҙң бҙ…бҙҮ бҙӣбҙҮКҖбҙҚЙӘЙҙбҙҖКҖ бҙҸ ЙҙбҙҖбҙҚбҙҸКҖбҙҸ...рҹҳ”*\n> *ЙўбҙңбҙҖКҖбҙ…бҙҮ бҙҸкңұ КҷбҙҸЙҙкңұ бҙҚбҙҸбҙҚбҙҮЙҙбҙӣбҙҸкңұ, бҙҚбҙҮкңұбҙҚбҙҸ З«бҙңбҙҮ бҙ…бҙҸбҙҖ...рҹҷҮвҖҚвҷӮпёҸ*`, contextInfo: { ...channeldl, mentionedJid: [sender, jidParceiro] }}, { quoted: selo });
namoro1.splice(D1, 1);
fs.writeFileSync('./arquivos/database/func/namoro1.json', JSON.stringify(namoro1));
break;
}


case 'minhadupla':
case 'dupla': {
if (!isGroup) return reply(mess.onlyGroup())
const userNum = sender.split('@')[0]
const dupla = namoro1.find(i => i.usu1 === sender || i.usu1 === userNum || i.usu2 === sender || i.usu2 === userNum)
if (!dupla) return reply('*бҙ бҙҸбҙ„бҙҮ ЙҙбҙҖбҙҸ бҙҮsбҙӣбҙҖ ЙҙбҙҖбҙҚбҙҸКҖбҙҖЙҙбҙ…бҙҸ ЙҙЙӘЙҙЙўбҙңбҙҮбҙҚ.. рҹӨ·вҖҚвҷӮпёҸ*')
if (!dupla.namorados) return reply('*sбҙҮбҙң бҙҳбҙҮбҙ…ЙӘбҙ…бҙҸ бҙҖЙӘЙҙбҙ…бҙҖ ЙҙбҙҖбҙҸ Т“бҙҸЙӘ бҙҖбҙ„бҙҮЙӘбҙӣбҙҸ.. рҹ’ҒвҖҚвҷӮпёҸ*')
