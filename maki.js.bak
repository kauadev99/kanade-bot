function normalize(jid) {
if (!jid) return null;
let id = jid.replace(/:.*(?=@)/, ''); 
if (id.endsWith('@lid')) {
id = id.replace('@lid', '@s.whatsapp.net');
} else if (!id.endsWith('@s.whatsapp.net')) {
id += '@s.whatsapp.net';
}
return id;
};

