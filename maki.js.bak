preco: 13000,
fome: 85,
pets: ["demonios"],
},
};

if (!item || !comidas[item]) {
return reply(
`вқҢ Comida invГЎlida.\nUse: *${prefix}mercadopet* para ver os alimentos.`
);
}

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user) return reply("вқҢ VocГӘ ainda nГЈo tem conta registrada.");
if (!user.pet) return reply("вқҢ VocГӘ nГЈo possui nenhum pet.");

if (!comidas[item].pets.includes(user.pet.tipo)) {
return reply(`вқҢ Seu pet nГЈo pode comer ${comidas[item].nome}.`);
}

if (user.coins < comidas[item].preco) {
return reply(
`рҹ’ё Coins insuficientes! ${comidas[item].nome} custa ${comidas[item].preco} coins.`
);
}

user.coins -= comidas[item].preco;

// Cria inventГЎrio se nГЈo existir
user.pet.inventario = user.pet.inventario || {};

// Adiciona ou soma o item
if (!user.pet.inventario[item]) {
user.pet.inventario[item] = 1;
} else {
user.pet.inventario[item] += 1;
}

CoinsUpdate(RG_SCOINS);

await reply(
`вң… ${comidas[item].nome} foi comprado e armazenado no *inventГЎrio do seu pet*.\nUse *${prefix}alimentarpet* para alimentar.`
);
break;
}

case 'alimentarpet': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const comida = args[0]?.toLowerCase();
const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet) return reply("вқҢ VocГӘ nГЈo tem um pet.");
if (!comida)
return reply(
`Digite o nome da comida. Ex: ${prefix}alimentarpet peixe`
);

const tabela = {
peixe: { nome: "рҹҚЈ Peixe", fome: 50, pets: ["gato"] },
leite: { nome: "рҹҘӣ Leite", fome: 30, pets: ["gato"] },
osso: { nome: "рҹҰҙ Osso", fome: 40, pets: ["cachorro"] },
racao: { nome: "рҹҘ« RaГ§ГЈo", fome: 60, pets: ["cachorro"] },
alface: { nome: "рҹҘ¬ Alface", fome: 30, pets: ["jabuti"] },
fruta: { nome: "рҹҚҺ Fruta", fome: 50, pets: ["jabuti"] },
sementes: { nome: "рҹҢҫ Sementes", fome: 30, pets: ["periquito"] },
banana: { nome: "рҹҚҢ Banana", fome: 50, pets: ["periquito"] },
carne: { nome: "рҹҘ© Carne mГЎgica", fome: 70, pets: ["dragao"] },
lava: { nome: "рҹ”Ҙ Lava temperada", fome: 100, pets: ["dragao"] },
"pena-de-grifo": {
nome: "рҹӘ¶ Pena de Grifo",
fome: 65,
pets: ["grifo"],
},
"carne-de-caca": {
nome: "рҹҚ– Carne de CaГ§a",
fome: 80,
pets: ["grifo"],
},
"pomo-de-fenix": {
nome: "рҹҚҺ Pomo de FГӘnix",
fome: 70,
pets: ["fenix"],
},
"fogo-sagrado": {
nome: "рҹ”Ҙ Fogo Sagrado",
fome: 90,
pets: ["fenix"],
},
"escama-de-dragao": {
nome: "рҹҗү Escama de DragГЈo",
fome: 80,
pets: ["dragaoDourado"],
},
"fogo-dourado": {
nome: "рҹ”Ҙ Fogo Dourado",
fome: 100,
pets: ["dragaoDourado"],
},
"chifre-de-demonios": {
nome: "рҹ‘№ Chifre de demonios",
fome: 75,
pets: ["demonios"],
},
"nectar-magico": {
nome: "рҹҚҜ NГ©ctar MГЎgico",
fome: 85,
pets: ["demonios"],
},
};

const pet = user.pet;
const inventario = pet.inventario || {};

if (!tabela[comida])
return reply(`вқҢ Comida invГЎlida. Veja em ${prefix}mercadopet`);

if (!tabela[comida].pets.includes(pet.tipo)) {
return reply(
`вҡ пёҸ Seu pet (${pet.tipo}) nГЈo pode comer ${tabela[comida].nome}.`
);
}

if (!inventario[comida] || inventario[comida] <= 0) {
return reply(
`вқҢ VocГӘ nГЈo tem ${tabela[comida].nome} no inventГЎrio. Compre com: ${prefix}comprarcomida ${comida}`
);
}

inventario[comida]--;
pet.fome = Math.min(100, (pet.fome || 0) + tabela[comida].fome);
pet.tempoUltimaAlimentacao = Date.now();

CoinsUpdate(RG_SCOINS);
await reply(
`вң… Seu *${pet.tipo}* comeu ${tabela[comida].nome} e agora estГЎ com *${pet.fome}%* de fome!`
);
break;
}

case 'inventariopet': {
if (!isGroup) return reply(mess.onlyGroup());
const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet) return reply("вқҢ VocГӘ ainda nГЈo tem pet.");

const inventario = user.pet.inventario || {};
if (Object.keys(inventario).length === 0)
return reply(
"рҹҚҪпёҸ Seu inventГЎrio estГЎ vazio. Compre comidas com /comprarcomida"
);

const nomesComidas = {
peixe: "рҹҚЈ Peixe",
leite: "рҹҘӣ Leite",
osso: "рҹҰҙ Osso",
racao: "рҹҘ« RaГ§ГЈo",
alface: "рҹҘ¬ Alface",
fruta: "рҹҚҺ Fruta",
sementes: "рҹҢҫ Sementes",
banana: "рҹҚҢ Banana",
carne: "рҹҘ© Carne mГЎgica",
lava: "рҹ”Ҙ Lava temperada",
"pena-de-grifo": "рҹӘ¶ Pena de Grifo",
"carne-de-caca": "рҹҚ– Carne de CaГ§a",
"pomo-de-fenix": "рҹҚҺ Pomo de FГӘnix",
"fogo-sagrado": "рҹ”Ҙ Fogo Sagrado",
"escama-de-dragao": "рҹҗү Escama de DragГЈo",
"fogo-dourado": "рҹ”Ҙ Fogo Dourado",
"chifre-de-demonios": "рҹ‘№ Chifre de demГҙnios",
"nectar-magico": "рҹҚҜ NГ©ctar MГЎgico",
};

let msg = `рҹҺ’ *Seu InventГЎrio de Comidas:*\n\n`;

for (const [item, qtd] of Object.entries(inventario)) {
const nome = nomesComidas[item] || item;
msg += `рҹҚұ ${nome}: ${qtd}\n`;
}

await reply(msg);
break;
}

case 'venderpet':
{
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("вқҢ VocГӘ nГЈo possui nenhum pet.");

const valores = {
gato: 3000,
cachorro: 2000,
jabuti: 1000,
periquito: 4000,
dragao: 20000,
};

const tipo = user.pet.tipo;
const precoTotal = valores[tipo];
const valorVenda = Math.floor(precoTotal * 0.5); // 50% do valor original

if (!args[0]) {
// Pergunta confirmacao com valor
user.querVenderPet = true;
CoinsUpdate(RG_SCOINS);
return reply(
`вҡ пёҸ VocГӘ quer mesmo vender seu *${tipo}* por *${valorVenda} coins*? Responda *venderpet sim* para confirmar.`
);
}

if (args[0].toLowerCase() === "sim") {
if (!user.querVenderPet)
return reply(
"VocГӘ precisa iniciar a venda primeiro. Use o comando *venderpet* para comeГ§ar."
);

user.coins = (user.coins || 0) + valorVenda; // soma o valor vendido com coins atuais
delete user.pet; // remove o pet
delete user.querVenderPet; // limpa flag

CoinsUpdate(RG_SCOINS);
return reply(
`рҹҗҫ VocГӘ vendeu seu *${tipo}* por *${valorVenda} coins*.\nAgora vocГӘ tem *${user.coins} coins*.\nVolte sempre ao Pet Shop!`
);
}

// Qualquer outro argumento
return reply(
"Comando invГЎlido. Se quiser vender seu pet, responda *venderpet sim* para confirmar."
);
}
break;

case 'verpet': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("вқҢ VocГӘ ainda nГЈo possui nenhum pet.");

const agora = Date.now();

// Verificar se pet estГЎ dormindo
if (user.pet.dormindo && agora < user.pet.dormindo) {
return await maki.sendMessage(
from,
{
image: { url: "https://files.catbox.moe/5gy92x.jpg" },
caption: `рҹҗҫ *Seu pet estГЎ dormindo...*\n\nрҹӣҢ ZzZz...`,
mentions: [sender],
},
{ quoted: info }
);
}

// Dados bГЎsicos
const {
tipo,
apelido,
fome,
tempoUltimaAlimentacao,
tempoUltimoBanho,
tempoUltimoPasseio,
tempoUltimaMissao,
criadoEm,
afeto = 0,
nivel = 1,
xp = 0,
} = user.pet;

// Habilidades Гәnicas por tipo
const habilidades = {
cachorro: "рҹ‘ғ Fareja moedas escondidas",
gato: "рҹ§¶ Brinca sozinho e ganha XP extra",
jabuti: "рҹӣЎпёҸ Resiste mais Г  fome",
periquito: "рҹ•ҠпёҸ Imita falas engraГ§adas do grupo",
dragao: "рҹ”Ҙ Solta labaredas e assusta ladrГөes de coins",

fenix: "вҷ»пёҸ Revive automaticamente ao morrer",
grifo: "рҹҰ… Pode fazer missГөes voando (mais rГЎpidas)",
axolote: "рҹ’§ Cura-se sozinho se machucar",
demonios: "рҹ‘№ Causa azar aos rivais em batalhas",
dragaoDourado: "рҹ’° Multiplica coins achados em missГөes",

// EvoluГӯdos
gatoMistico: "вңЁ Ganha XP extra e habilidades mГӯsticas",
loboGuardiao: "рҹҗә Defende seu dono em batalhas",
tartarugaGigante: "рҹҗў Super resistente e lento",
falcao: "рҹҰ… Voa rГЎpido e traz presentes",
};
const habilidadePet =
habilidades[tipo] || "рҹҺІ Nenhuma habilidade especial.";

// Fome e morte
const horasSemAlimentar =
(agora - tempoUltimaAlimentacao) / (1000 * 60 * 60);
if (horasSemAlimentar > 24) {
delete user.pet;
CoinsUpdate(RG_SCOINS);
return reply(
`рҹ’Җ Seu pet *${tipo}* morreu por falta de comida...`
);
}

const fomeAtual = Math.max(
0,
Math.floor(100 - horasSemAlimentar * 4)
);
user.pet.fome = fomeAtual;

const hBanho = tempoUltimoBanho
? Math.floor((agora - tempoUltimoBanho) / (1000 * 60 * 60))
: "Nunca";
const hPasseio = tempoUltimoPasseio
? Math.floor((agora - tempoUltimoPasseio) / (1000 * 60 * 60))
: "Nunca";

// Гҡltima missГЈo
let textoMissao = "Nunca fez missГЈo";
if (tempoUltimaMissao) {
const minutosPassados = Math.floor(
(agora - tempoUltimaMissao) / (1000 * 60)
);
textoMissao =
minutosPassados < 60
? `Гҡltima missГЈo hГЎ ${minutosPassados} minuto(s)`
: `Гҡltima missГЈo hГЎ ${Math.floor(minutosPassados / 60)} hora(s)`;
}

// Carinho
const intervaloCarinho = 60 * 60 * 1000;
if (!user.pet.carinhoHistorico) user.pet.carinhoHistorico = [];
user.pet.carinhoHistorico = user.pet.carinhoHistorico.filter(
(ts) => agora - ts < intervaloCarinho
);
const carinhosRestantes = Math.max(
0,
2 - user.pet.carinhoHistorico.length
);

// ConstruГ§ГЈo
const intervaloConstrucao = 60 * 60 * 1000;
if (!user.pet.construcaoHistorico)
user.pet.construcaoHistorico = [];
user.pet.construcaoHistorico = user.pet.construcaoHistorico.filter(
(ts) => agora - ts < intervaloConstrucao
);
const construcoesFeitas = user.pet.construcaoHistorico.length;

// Nivelamento automГЎtico
while (user.pet.xp >= user.pet.nivel * 100) {
user.pet.xp -= user.pet.nivel * 100;
user.pet.nivel += 1;
}

// NГӯvel e XP
const xpAtual = user.pet.xp || 0;
const xpMax = user.pet.nivel * 100;

// Afinidade
let afinidade = "Baixa";
if (user.pet.afeto >= 100) afinidade = "Alta";
else if (user.pet.afeto >= 50) afinidade = "MГ©dia";

// Humor
let humor = "рҹҳҗ Normal";
if (fomeAtual >= 80 && hBanho !== "Nunca" && hPasseio !== "Nunca")
humor = "рҹҳҖ Feliz";
else if (
fomeAtual < 40 ||
hBanho === "Nunca" ||
hPasseio === "Nunca"
)
humor = "рҹҳһ Triste";

// Pet raro ou comum
const petsRaros = [
"dragaoDourado",
"fenix",
"demonios",
"grifo",
"axolote",
];
const isRaro = petsRaros.includes(tipo);

// Imagem dos pets comuns, evoluГӯdos e raros
const imagensComuns = {
gato: "https://files.catbox.moe/aqc0xg.jpg",
cachorro: "https://files.catbox.moe/yd4a0j.jpg",
jabuti: "https://files.catbox.moe/8l7t7q.jpg",
periquito: "https://files.catbox.moe/4dwms2.jpg",
dragao: "https://files.catbox.moe/no3p8x.jpg",
};

const imagensEvoluidos = {
gatoMistico: "https://files.catbox.moe/5cjj9x.jpg", // gato mГӯstico
loboGuardiao: "https://files.catbox.moe/b1wsbt.jpg", // lobo guardiГЈo
tartarugaGigante: "https://files.catbox.moe/9jas30.jpg", // jabuti gigante
falcao: "https://files.catbox.moe/cf87ne.jpg", // falcГЈo
};

const imagensRaros = {
dragaoDourado: "https://files.catbox.moe/58t7uv.jpg",
fenix: "https://files.catbox.moe/knxwuo.jpg",
demonios: "https://files.catbox.moe/fkhec1.jpg",
grifo: "https://files.catbox.moe/ijpu52.jpg",
axolote: "https://files.catbox.moe/thjxcq.jpg",
};

// Escolhe a imagem do pet: evoluГӯdo > raro > comum
let imagem;
if (imagensEvoluidos[tipo]) {
imagem = imagensEvoluidos[tipo];
} else if (petsRaros.includes(tipo)) {
imagem = imagensRaros[tipo];
} else {
imagem = imagensComuns[tipo];
}

const nomePet = apelido
? `${apelido} (${tipo.toUpperCase()})`
: tipo.toUpperCase();
const idadeDias = criadoEm
? Math.floor((agora - criadoEm) / (1000 * 60 * 60 * 24))
: "Desconhecida";

const texto = `рҹҗҫ *Seu Pet: ${nomePet}*
рҹҸ·пёҸ Tipo: ${isRaro ? "Pet Raro" : "Pet Comum"}
рҹ§¬ Habilidade: ${habilidadePet}
рҹ“Ҷ Idade: ${idadeDias} dia(s)
рҹ“Ҡ NГӯvel: ${user.pet.nivel}
рҹ“Ҳ XP: ${xpAtual}/${xpMax}
вқӨпёҸ Afinidade: ${afinidade}
рҹҳҠ Humor: ${humor}

рҹҚ— Fome: ${fomeAtual}%
рҹ§ј Banho: ${hBanho === "Nunca" ? "Nunca" : `${hBanho}h atrГЎs`}
рҹҡ¶ Passeio: ${hPasseio === "Nunca" ? "Nunca" : `${hPasseio}h atrГЎs`}
вҸ° AlimentaГ§ГЈo: ${Math.floor(horasSemAlimentar)}h atrГЎs
рҹҺҜ ${textoMissao}

рҹ’һ Carinhos disponГӯveis: ${carinhosRestantes}/2
рҹҸ—пёҸ ConstruГ§Гөes feitas: ${construcoesFeitas}/3`;

if (imagem) {
await maki.sendMessage(
from,
{
image: { url: imagem },
caption: texto,
mentions: [sender],
},
{ quoted: info }
);
} else {
await reply(texto);
}

CoinsUpdate(RG_SCOINS);
break;
}

case 'banhopet': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("вқҢ VocГӘ ainda nГЈo tem um pet.");

const agora = Date.now();
user.pet.tempoUltimoBanho = user.pet.tempoUltimoBanho || 0;

const tempoDesdeUltimo =
(agora - user.pet.tempoUltimoBanho) / (1000 * 60 * 60);
if (tempoDesdeUltimo < 6)
return reply(
`рҹ•җ Seu pet ainda estГЎ limpo! Tente novamente em ${Math.ceil(6 - tempoDesdeUltimo)}h.`
);

user.pet.tempoUltimoBanho = agora;

// XP e NГӯvel
user.pet.experiencia = user.pet.experiencia || 0;
user.pet.nivel = user.pet.nivel || 1;
user.pet.experiencia += 50;

const xpNecessario = user.pet.nivel * 100;
if (user.pet.experiencia >= xpNecessario) {
user.pet.nivel += 1;
user.pet.experiencia -= xpNecessario;
await reply(`рҹҺү Seu pet subiu para o nГӯvel ${user.pet.nivel}!`);
}

CoinsUpdate(RG_SCOINS);
await reply(
`рҹӣҒ Seu *${user.pet.tipo}* tomou banho e ganhou +50 XP!`
);
break;
}

case 'passearpet': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("вқҢ VocГӘ ainda nГЈo tem um pet.");

const agora = Date.now();
user.pet.tempoUltimoPasseio = user.pet.tempoUltimoPasseio || 0;

const horas =
(agora - user.pet.tempoUltimoPasseio) / (1000 * 60 * 60);
if (horas < 6)
return reply(
`рҹҗҫ Seu pet estГЎ cansado! Pode passear novamente em ${Math.ceil(6 - horas)}h.`
);

user.pet.tempoUltimoPasseio = agora;

// Recompensa entre 100 e 400 coins
const recompensa = Math.floor(Math.random() * 301) + 100;
user.coins += recompensa;

// XP e nГӯvel
user.pet.experiencia = (user.pet.experiencia || 0) + 50;
user.pet.nivel = user.pet.nivel || 1;

const xpNecessario = user.pet.nivel * 100;
if (user.pet.experiencia >= xpNecessario) {
user.pet.experiencia -= xpNecessario;
user.pet.nivel++;
}

CoinsUpdate(RG_SCOINS);
await reply(
`рҹҡ¶ Seu *${user.pet.tipo}* passeou alegremente e encontrou *${recompensa} coins* no caminho! рҹӘҷ\nрҹҶҷ Ganhou +50 XP`
);
break;
}
case 'apelidopet': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("вқҢ VocГӘ nГЈo tem pet para renomear.");

const apelido = args.join(" ").trim();
if (!apelido)
return reply(
"вқҢ Informe o apelido novo. Exemplo: " +
prefix +
"apelidopet Fofinho"
);

const custo = 500;
if (user.coins < custo)
return reply(
`рҹ’ё VocГӘ precisa de ${custo} coins para trocar o apelido do pet.`
);

user.coins -= custo;
user.pet.apelido = apelido;

CoinsUpdate(RG_SCOINS);
await reply(
`вң… Apelido do seu pet agora Г©: *${apelido}* (custou ${custo} coins)`
);
break;
}

case 'doarpet': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const mentions =
info.message.extendedTextMessage?.contextInfo?.mentionedJid || [];
if (mentions.length === 0)
return reply(
"вқҢ Mencione o usuГЎrio para quem deseja doar o pet."
);

const alvo = mentions[0];
const argsPet = args[1];
if (!argsPet)
return reply(
"вқҢ Informe o tipo do pet que deseja doar. Exemplo: " +
prefix +
"doarpet @user gato"
);

// Procura dono atual do pet
let donoPet = null;
let petIndex = -1;

const grupoUsers = RG_SCOINS[ID_G_COINS]?.usus;
for (let i = 0; i < grupoUsers.length; i++) {
if (grupoUsers[i].pet && grupoUsers[i].pet.tipo === argsPet) {
donoPet = grupoUsers[i];
petIndex = i;
break;
}
}
if (!donoPet)
return reply(
`вқҢ Nenhum usuГЎrio deste grupo possui um pet do tipo ${argsPet}.`
);

// Verifica se dono do pet Г© o dono do bot (sender)
if (donoPet.id !== sender)
return reply("вқҢ VocГӘ sГі pode doar pets que vocГӘ possui.");

// Procura usuГЎrio alvo para receber o pet
let userAlvo = grupoUsers.find((u) => u.id === alvo);
if (!userAlvo) {
// Se nГЈo existir, cria registro
userAlvo = { id: alvo, coins: 0, pet: null };
grupoUsers.push(userAlvo);
}

if (userAlvo.pet) return reply("вқҢ O usuГЎrio jГЎ possui um pet.");

// Passa o pet para o novo dono
userAlvo.pet = donoPet.pet;
donoPet.pet = null;

CoinsUpdate(RG_SCOINS);
await reply(
`вң… Pet do tipo *${argsPet}* doado para @${alvo.split("@")[0]} com sucesso!`
);
break;
}

case 'lojararos': {
if (!isVip) return reply(mess.onlyVipUser());
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const petsRaros = {
dragaoDourado: { nome: "рҹҗү DragГЈo Dourado", preco: 40000 },
fenix: { nome: "рҹ”Ҙ FГӘnix", preco: 35000 },
demonios: { nome: "рҹ‘№ Demonios", preco: 55000 },
grifo: { nome: "рҹҰ… Grifo", preco: 38000 },
axolote: { nome: "рҹҗҹ Axolote", preco: 30000 },
};

const escolha = args[0]?.toLowerCase();
if (!escolha || !petsRaros[escolha]) {
let msg = `рҹҗҫ *Lojinha de Pets Raros*\n\nPets disponГӯveis:\n`;
for (const p in petsRaros) {
msg += `${petsRaros[p].nome} - ${petsRaros[p].preco} coins\n`;
}
msg += `\nUse: ${prefix}lojararos <nome_do_pet>`;
return reply(msg);
}

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user) return reply("вқҢ VocГӘ ainda nГЈo tem conta registrada.");

if (user.pet)
return reply(
"вқҢ VocГӘ jГЎ possui um pet. Venda ou solte seu pet atual antes de comprar outro."
);

const petEscolhido = petsRaros[escolha];
if (user.coins < petEscolhido.preco)
return reply(
`вқҢ Coins insuficientes. ${petEscolhido.nome} custa ${petEscolhido.preco} coins.`
);

user.coins -= petEscolhido.preco;
user.pet = {
tipo: escolha,
nome: petEscolhido.nome,
fome: 100,
afeto: 0, // afinidade inicial
nivel: 1, // nГӯvel inicial
criadoEm: Date.now(), // data de criaГ§ГЈo para idade
tempoUltimaAlimentacao: Date.now(),
tempoUltimoBanho: null,
tempoUltimoPasseio: null,
tempoMissao: null,
tempoUltimaMissao: null,
apelido: null,
nomeExibicao: null,
};

CoinsUpdate(RG_SCOINS);
await reply(
`рҹҺү ParabГ©ns! VocГӘ comprou o pet raro *${petEscolhido.nome}* por ${petEscolhido.preco} coins.`
);
break;
}

case 'petmissao': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("вқҢ VocГӘ nГЈo tem um pet para enviar em missГЈo.");

const agora = Date.now();
const duracao = 15 * 60 * 1000; // 15 minutos

if (
user.pet.tempoMissao &&
agora < user.pet.tempoMissao + duracao
) {
const restante = (
(user.pet.tempoMissao + duracao - agora) /
60000
).toFixed(1);
return reply(
`вҸі Seu pet ainda estГЎ em missГЈo. Aguarde mais ${restante} minuto(s).`
);
}

user.pet.tempoMissao = agora;
CoinsUpdate(RG_SCOINS);

reply(
`рҹҡҖ Seu pet partiu para uma missГЈo de 15 minutos! Espere pelo retorno dele...`
);

setTimeout(async () => {
const resultado = Math.floor(Math.random() * 100);
let textoFinal = "";
let coinsGanhos = 0;

if (resultado < 50) {
coinsGanhos = Math.floor(Math.random() * 401) + 100; // 100 a 500
user.coins += coinsGanhos;
textoFinal = `рҹҰҙ *MissГЈo concluГӯda!*\nSeu *${user.pet.tipo}* voltou da missГЈo e encontrou *${coinsGanhos} coins*!`;
} else if (resultado < 80) {
textoFinal = `рҹ’Ө *MissГЈo fracassada!*\nSeu *${user.pet.tipo}* voltou sem encontrar nada...`;
} else {
textoFinal = `рҹҳҝ *Pet machucado!*\nSeu *${user.pet.tipo}* voltou da missГЈo machucado e precisa de descanso.`;
}

// Adiciona 50 XP
user.pet.xp = (user.pet.xp || 0) + 50;

// Recalcula o nГӯvel
user.pet.nivel = Math.floor(user.pet.xp / 100) + 1;

user.pet.tempoUltimaMissao = Date.now();
CoinsUpdate(RG_SCOINS);

await maki.sendMessage(
from,
{
text: `@${sender.split("@")[0]} ${textoFinal}\nрҹ“Ҡ XP total: ${user.pet.xp} | NГӯvel: ${user.pet.nivel}`,
mentions: [sender],
},
{ quoted: info }
);
}, duracao);

break;
}

case 'rankpets': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

// PreГ§os dos pets
const precosPets = {
gato: 3000,
cachorro: 2000,
jabuti: 1000,
periquito: 4000,
dragao: 20000,
dragaoDourado: 40000,
fenix: 35000,
demonios: 55000,
grifo: 38000,
axolote: 30000,
};

// Junta todos os usuГЎrios com pets de todos os grupos
let todosUsuarios = [];

for (const grupoKey of Object.keys(RG_SCOINS)) {
const grupo = RG_SCOINS[grupoKey];
if (!grupo?.usus) continue;

// filtra usuГЎrios com pet e id
const usuariosComPet = grupo.usus.filter(
(u) => u.pet?.tipo && u.id
);

// adiciona com preГ§o do pet
usuariosComPet.forEach((u) => {
todosUsuarios.push({
id: u.id,
tipo: u.pet.tipo,
apelido: u.pet.apelido || "Sem apelido",
preco: precosPets[u.pet.tipo] || 0,
});
});
}

if (todosUsuarios.length === 0)
return reply("Nenhum pet encontrado.");

// Ordena pelo preГ§o desc
todosUsuarios.sort((a, b) => b.preco - a.preco);

// Pega os top 5
const top5 = todosUsuarios.slice(0, 5);

// Monta a mensagem com bordas
let msg = `в•”в•җв•ҢвңҜв•Ңв•җвҠұГ—вҠ°рҹҗҫ RANKING PETS рҹҗҫвҠұГ—вҠ°в•җв•ҢвңҜв•Ңв•җв•—\n\n`;
let mentionsIds = [];

top5.forEach((u, i) => {
msg +=
`гҖҺ ${i + 1}Вә гҖҸвҶҙ\n` +
`в•”в•җв•ҢвңҜв•Ңв•җвҠұГ—вҠ°в•җв•ҢвңҜв•Ңв•җв•—\n` +
`в•‘рҹ‘Ө UsuГЎrio: @${u.id.split("@")[0]}\n` +
`в•‘рҹҗҫ Pet: ${u.apelido}\n` +
`в•‘рҹ’Һ Tipo: ${u.tipo.toUpperCase()}\n` +
`в•‘рҹ’° Valor: ${u.preco} coins\n` +
`в•ҡв•җв•ҢвңҜв•Ңв•җвҠұГ—вҠ°в•җв•ҢвңҜв•Ңв•җв•қ\n\n`;
mentionsIds.push(u.id);
});

await maki.sendMessage(
from,
{ text: msg, mentions: mentionsIds },
{ quoted: info }
);

break;
}

case 'carinhopet': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("вқҢ VocГӘ ainda nГЈo possui nenhum pet.");

const agora = Date.now();
const intervaloCarinho = 60 * 60 * 1000; // 1 hora

if (!user.pet.carinhoHistorico) user.pet.carinhoHistorico = [];

// Limpa os carinhos mais antigos (mais de 1 hora)
user.pet.carinhoHistorico = user.pet.carinhoHistorico.filter(
(ts) => agora - ts < intervaloCarinho
);

const carinhosFeitos = user.pet.carinhoHistorico.length;
const carinhosRestantes = Math.max(0, 2 - carinhosFeitos);

if (carinhosRestantes === 0) {
return reply(
`рҹҳҝ VocГӘ jГЎ fez os 2 carinhos permitidos nessa hora. Tente novamente mais tarde.`
);
}

user.pet.carinhoHistorico.push(agora);
user.pet.xp = (user.pet.xp || 0) + 50;
user.pet.nivel = Math.floor(user.pet.xp / 100) + 1;
user.pet.afeto = (user.pet.afeto || 0) + 10;

CoinsUpdate(RG_SCOINS);

await reply(
`рҹҺҲ VocГӘ fez um carinho em seu pet *${user.pet.tipo}*!\nрҹ“Ҳ Ganhou +50 XP e +10 de afeto!\nрҹ’һ Carinhos restantes nesta hora: ${carinhosRestantes - 1}/2`
);
break;
}

case 'petconstruir': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("рҹҗҫ VocГӘ ainda nГЈo tem um pet.");

const agora = Date.now();
const umaHora = 60 * 60 * 1000;
const limite = 3;

user.pet.construcoes =
user.pet.construcoes?.filter((t) => agora - t < umaHora) || [];
if (user.pet.construcoes.length >= limite) {
const restante = Math.ceil(
(umaHora - (agora - user.pet.construcoes[0])) / 60000
);
return reply(
`рҹ§ұ Seu pet jГЎ construiu ${limite}x nesta hora!\nвҸі Tente novamente em *${restante} minuto(s)*.`
);
}

user.pet.construcoes.push(agora);
const pet = user.pet;
const xpGanhos = 100;

// Fases da construГ§ГЈo, com muitos emojis de casas e ГЎrvores
const fases = [
`рҹ”Ё *Iniciando a obra...*

рҹ§ұ рҹ§ұ рҹ§ұ

рҹ§ұ рҹ§ұ рҹ§ұ рҹ§ұ
`,

`рҹҸ—пёҸ *Levantando paredes...*

рҹ§ұрҹҸ  рҹ§ұрҹҸ  рҹ§ұрҹҸ 

рҹ§ұрҹҸ  рҹ§ұрҹҸ  рҹ§ұрҹҸ  рҹ§ұрҹҸ 
`,

`рҹҢҝ *Adicionando jardins e ГЎrvores...*

рҹҸ рҹҢі рҹҸ рҹҢІ рҹҸ рҹҢі

рҹ§ұрҹҸ рҹҢҙ рҹ§ұрҹҸ рҹҢі рҹ§ұрҹҸ рҹҢҙ рҹ§ұрҹҸ рҹҢі
`,

`рҹҸ  *Construindo casas...*

рҹҸ рҹҸ рҹҸ  рҹҸ рҹҸ рҹҸ  рҹҸ рҹҸ рҹҸ 

рҹҸ рҹҸ рҹҸ  рҹҸ рҹҸ рҹҸ  рҹҸ рҹҸ рҹҸ  рҹҸ рҹҸ рҹҸ 
`,

`рҹҸЎ *Base crescendo...*

рҹҸЎрҹҸЎрҹҸЎ рҹҸЎрҹҸЎрҹҸЎ рҹҸЎрҹҸЎрҹҸЎ

рҹҸЎрҹҸЎрҹҸЎ рҹҸЎрҹҸЎрҹҸЎ рҹҸЎрҹҸЎрҹҸЎ рҹҸЎрҹҸЎрҹҸЎ
`,

`рҹҢҶ *Adicionando prГ©dios altos...*

рҹҸўрҹҸўрҹҸў рҹҸўрҹҸўрҹҸў рҹҸўрҹҸўрҹҸў

рҹҸўрҹҸўрҹҸў рҹҸўрҹҸўрҹҸў рҹҸўрҹҸўрҹҸў рҹҸўрҹҸўрҹҸў
`,

`рҹҢҹ *Finalizando detalhes e luzes...*

рҹҸўрҹҸўрҹҸў рҹҸЎрҹҸЎрҹҸЎ рҹҸ рҹҸ рҹҸ 

рҹҢірҹҸўрҹҸЎ рҹҢІрҹҸЎрҹҸ  рҹҢҙрҹҸ рҹҸў рҹҢірҹҸЎрҹҸ 
`,
];

const mensagem = await maki.sendMessage(
from,
{
text: `рҹӣ пёҸ Seu pet *${pet.tipo}* comeГ§ou a construir uma base magnГӯfica...\n*Aguarde os andamentos da obra...*`,
mentions: [sender],
},
{ quoted: info }
);

let etapa = 0;
const intervalo = setInterval(async () => {
if (etapa >= fases.length) {
clearInterval(intervalo);

pet.xp = (pet.xp || 0) + xpGanhos;
pet.nivel = Math.floor(pet.xp / 100) + 1;
CoinsUpdate(RG_SCOINS);

return await maki.sendMessage(
from,
{
text: `рҹҸ—пёҸ *ConstruГ§ГЈo ConcluГӯda!*

рҹҗҫ Pet: *${pet.tipo}*
рҹ“Ҳ Ganhou: *+${xpGanhos} XP*
рҹҺҜ Total XP: *${pet.xp}* | рҹҸ… NГӯvel: *${pet.nivel}*`,
mentions: [sender],
},
{ quoted: info }
);
}

await maki.sendMessage(from, {
edit: mensagem.key,
text: fases[etapa],
});

etapa++;
}, 3000); // aproximadamente 20 segundos no total

break;
}

case 'dormirpet': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("вқҢ VocГӘ ainda nГЈo possui um pet.");

const agora = Date.now();

if (user.pet.dormindo && agora < user.pet.dormindo) {
return reply("рҹҳҙ Seu pet jГЎ estГЎ dormindo.");
}

const tempoSono = 60 * 60 * 1000; // 1 hora
user.pet.dormindo = agora + tempoSono;

CoinsUpdate(RG_SCOINS);

return reply(
`рҹӣҸпёҸ *Seu pet foi dormir!*\nDurante o sono ele nГЈo poderГЎ executar comandos como: /verpet, /passearpet, /petmissao, etc.\n\nPara acordar, use: */acordarpet*`
);
break;
}

case 'acordarpet': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("вқҢ VocГӘ ainda nГЈo possui um pet.");

const agora = Date.now();

if (!user.pet.dormindo || agora >= user.pet.dormindo) {
return reply("рҹҹў Seu pet jГЎ estГЎ acordado.");
}

delete user.pet.dormindo;

CoinsUpdate(RG_SCOINS);

return reply(
"рҹҢ… Seu pet acordou! Ele agora pode realizar atividades normalmente."
);
break;
}

case 'petrealeza': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`вҡ пёҸ O sistema de coins precisa estar ativo para esse comando.`
);

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("вқҢ VocГӘ ainda nГЈo possui um pet.");

const { tipo, nivel = 1, xp = 0, afeto = 0 } = user.pet;

const raros = [
"dragaoDourado",
"fenix",
"grifo",
"demonios",
"axolote",
];
const isRaro = raros.includes(tipo);
const bonusRaridade = isRaro ? 100 : 0;

// CГЎlculo de fama
const fama =
nivel * 3 +
Math.floor(xp / 20) +
Math.floor(afeto / 5) +
bonusRaridade;

// Definir tГӯtulo com base na fama
let titulo = "рҹҗҫ CamponГӘs";
if (fama >= 50) titulo = "рҹҺ–пёҸ Cavaleiro Real";
if (fama >= 100) titulo = "рҹҸ° Lorde Feudal";
if (fama >= 150) titulo = "рҹ‘‘ Rei dos Pets";
if (fama >= 250) titulo = "рҹҢҹ Imperador Supremo";
if (fama >= 400) titulo = "рҹҰ„ Lenda Celestial";
if (fama >= 600) titulo = "рҹҢҢ Divindade Petversal";

// Mensagem final
const msg = `рҹҗҫ *Realeza do Seu Pet* рҹҗҫ

рҹ“ӣ *Nome do Pet:* ${user.pet.apelido || tipo.toUpperCase()}
рҹҺ–пёҸ *TГӯtulo de Nobreza:* ${titulo}
рҹ“Ҳ *Fama Real:* ${fama} pontos

рҹҸ·пёҸ *Tipo:* ${tipo} ${isRaro ? "вңЁ (Raro)" : ""}
рҹ“Ҡ *NГӯvel:* ${nivel}
рҹҢҹ *XP:* ${xp}
рҹ’һ *Afinidade:* ${afeto}

рҹ”® *Quanto mais XP, afinidade e raridade, mais nobreza seu pet conquista!*
`;

reply(msg);
break;
}
case 'diariopet': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("вқҢ VocГӘ ainda nГЈo tem um pet.");

if (!user.pet.diario) user.pet.diario = [];
if (!user.pet.ultimoDiario) user.pet.ultimoDiario = 0;

const agora = Date.now();
const umDia = 24 * 60 * 60 * 1000;

if (agora - user.pet.ultimoDiario < umDia) {
const proximoUso = new Date(user.pet.ultimoDiario + umDia);
return reply(
`вҸі VocГӘ sГі pode usar o diГЎrio do pet uma vez por dia.\nTente novamente em: ${proximoUso.toLocaleString("pt-BR")}`
);
}

const eventos = [
"Seu pet brincou alegremente no parque.",
"Seu pet encontrou uma moeda escondida!",
"Seu pet dormiu uma soneca gostosa.",
"Seu pet comeu muito e estГЎ satisfeito.",
"Seu pet fez novos amigos no grupo.",
"Seu pet ganhou um prГӘmio por bom comportamento.",
"Seu pet ficou curioso e explorou a casa.",
"Seu pet ajudou um amigo em apuros.",
"Seu pet estГЎ um pouco cansado hoje.",
"Seu pet fez um truque novo para vocГӘ.",
];

const eventoHoje =
eventos[Math.floor(Math.random() * eventos.length)];
const hoje = new Date().toLocaleDateString("pt-BR");

user.pet.diario.push({ data: hoje, evento: eventoHoje });
if (user.pet.diario.length > 10) user.pet.diario.shift();

user.pet.ultimoDiario = agora;

CoinsUpdate(RG_SCOINS);

let msg = `рҹ“” *DiГЎrio do seu Pet (${user.pet.tipo.toUpperCase()}):*\n\n`;
for (const entry of user.pet.diario.slice().reverse()) {
msg += `рҹ“… ${entry.data} - ${entry.evento}\n`;
}

await reply(msg);
break;
}

case 'evoluirpet': {
if (!RG_SCOINS[ID_G_COINS] || !RG_SCOINS[ID_G_COINS].usus)
return reply("вқҢ Banco de dados nГЈo carregado para este grupo.");

const user = RG_SCOINS[ID_G_COINS].usus.find(
(u) => u.id === sender
);
if (!user || !user.pet)
return reply("вқҢ VocГӘ ainda nГЈo tem um pet.");

const evolucoes = {
gato: { novo: "gatoMistico", lvl: 5 },
cachorro: { novo: "loboGuardiao", lvl: 5 },
jabuti: { novo: "tartarugaGigante", lvl: 5 },
periquito: { novo: "falcao", lvl: 5 },
};

const atual = user.pet.tipo;

// Bloquear pets que jГЎ sГЈo evoluГӯdos ou que sГЈo pets raros
const petsNaoEvolutiveis = [
"gatoMistico",
"loboGuardiao",
"tartarugaGigante",
"falcao",
"dragao",
"fenix",
"grifo",
"axolote",
"demonios",
"dragaoDourado",
];

if (petsNaoEvolutiveis.includes(atual))
return reply("вқҢ Este pet nГЈo pode evoluir.");

if (!evolucoes[atual]) return reply("вқҢ Seu pet nГЈo tem evoluГ§ГЈo.");

const reqNivel = evolucoes[atual].lvl;
if (user.pet.nivel < reqNivel)
return reply(
`вқҢ Seu pet precisa estar no nГӯvel ${reqNivel} para evoluir.`
);

user.pet.tipo = evolucoes[atual].novo;
user.pet.nivel = 1;
user.pet.xp = 0;

CoinsUpdate(RG_SCOINS);
await reply(
`рҹҺү ParabГ©ns! Seu pet evoluiu para *${evolucoes[atual].novo.toUpperCase()}*!`
);
break;
}

case 'petbatalha': {
if (!isGroup) return reply(mess.onlyGroup());
const mentions =
info.message.extendedTextMessage?.contextInfo?.mentionedJid || [];
if (mentions.length === 0)
return reply("вқҢ Mencione o usuГЎrio para batalhar.");

const alvo = mentions[0];
const user1 = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
const user2 = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === alvo
);

if (!user1?.pet || !user2?.pet)
return reply("вқҢ Ambos precisam ter pets para batalhar.");

// Verificar se o desafiante tem pelo menos 2000 coins
if (user1.coins < 2000)
return reply(
"вқҢ VocГӘ precisa de pelo menos 2000 coins para iniciar uma batalha."
);

const agora = Date.now();
const intervaloLimite = 3 * 60 * 60 * 1000; // 3 horas em ms
const maxBatalhas = 3;

if (!user1.pet.batalhaHistorico) user1.pet.batalhaHistorico = [];

// Limpar histГіrico antigo
user1.pet.batalhaHistorico = user1.pet.batalhaHistorico.filter(
(ts) => agora - ts < intervaloLimite
);

if (user1.pet.batalhaHistorico.length >= maxBatalhas) {
return reply(
`вқҢ VocГӘ jГЎ fez ${maxBatalhas} batalhas nas Гәltimas 3 horas. Tente novamente depois.`
);
}

// Registrar essa batalha no histГіrico
user1.pet.batalhaHistorico.push(agora);

// Cobrando os 2000 coins
user1.coins -= 2000;

// Calcular forГ§a
const forГ§a1 =
(user1.pet.nivel || 1) + Math.floor(Math.random() * 10);
const forГ§a2 =
(user2.pet.nivel || 1) + Math.floor(Math.random() * 10);

let resultado = "";

if (forГ§a1 > forГ§a2) {
user1.pet.xp = (user1.pet.xp || 0) + 100;
resultado = `рҹҸҶ Seu pet *${user1.pet.tipo}* venceu a batalha!\n\nрҹҸ… Recompensa: +100 XP`;
} else if (forГ§a2 > forГ§a1) {
user2.pet.xp = (user2.pet.xp || 0) + 100;
resultado = `вқҢ Seu pet perdeu...\n\nO pet de @${alvo.split("@")[0]} venceu e ganhou +100 XP!`;
} else {
resultado = "вҡ”пёҸ Empate! Nenhum dos pets ganhou XP.";
}

CoinsUpdate(RG_SCOINS);
await reply(resultado);
break;
}

case 'eventopet': {
const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user?.pet) return reply("вқҢ VocГӘ ainda nГЈo tem um pet.");

const agora = Date.now();
const intervaloLimite = 2 * 60 * 60 * 1000; // 2 horas em ms
const maxUsos = 5;

if (!user.pet.eventopetHistorico) user.pet.eventopetHistorico = [];

// Limpar histГіrico antigo
user.pet.eventopetHistorico = user.pet.eventopetHistorico.filter(
(ts) => agora - ts < intervaloLimite
);

// Verificar se jГЎ atingiu o limite
if (user.pet.eventopetHistorico.length >= maxUsos) {
return reply(
`вқҢ VocГӘ jГЎ usou o comando *eventoPet* ${maxUsos} vezes nas Гәltimas 2 horas. Tente novamente depois.`
);
}

// Adicionar o uso atual ao histГіrico
user.pet.eventopetHistorico.push(agora);

const eventos = [
"Seu pet achou um baГә e ganhou 300 coins!",
"Seu pet ficou doente... Precisa de descanso.",
"Seu pet trouxe um presente: +50 XP!",
"Seu pet ficou bravo hoje... perdeu -10 de afeto.",
"Seu pet ficou muito feliz! +20 de afeto.",
];

const sorteio = eventos[Math.floor(Math.random() * eventos.length)];

if (!user.pet.ultimoAumentoAfeto) user.pet.ultimoAumentoAfeto = 0;
const limiteAfetoIntervalo = 2 * 60 * 60 * 1000; // 2 horas
function tentarAumentarAfeto(pontos) {
if (agora - user.pet.ultimoAumentoAfeto >= limiteAfetoIntervalo) {
user.pet.afeto = (user.pet.afeto || 0) + Math.min(pontos, 5);
user.pet.ultimoAumentoAfeto = agora;
}
}

if (sorteio.includes("300 coins")) {
user.coins += 300;
tentarAumentarAfeto(5);
}
if (sorteio.includes("+50 XP")) {
user.pet.xp = (user.pet.xp || 0) + 50;
tentarAumentarAfeto(5);
}
if (sorteio.includes("+20 de afeto")) {
user.pet.afeto = (user.pet.afeto || 0) + 20;
tentarAumentarAfeto(5);
}
if (sorteio.includes("-10 de afeto")) {
user.pet.afeto = Math.max(0, (user.pet.afeto || 0) - 10);
}

CoinsUpdate(RG_SCOINS);
await reply(
`рҹҺІ Evento: ${sorteio}\nвқӨпёҸ Afinidade atual: ${user.pet.afeto}`
);
break;
}



case 'rankcoins': {
