case 'mae': {
try {

if (!q) return reply('вқҢ Digite o nome da mГЈe\nEx: .mae Maria');

reply('рҹ”Һ Buscando dados...');

const axios = require('axios');

let res = await axios.get(`https://zero-two-apis.com.br/consultas/serasa/mae?query=${encodeURIComponent(q)}&apikey=OFF_KYY`);

if (!res.data.status) return reply('вқҢ Nenhum resultado');

let bruto = res.data.resultado.data.data;

// рҹ”Ҙ separa linhas
let linhas = bruto.split('\n').filter(x => x.trim() !== '');

// рҹ”Ҙ organiza em blocos (CPF + NOME + NASCIMENTO)
let resultados = [];

for (let i = 0; i < linhas.length; i++) {
if (linhas[i].includes('CPF')) {

let cpf = linhas[i].split('вҺҜ')[1]?.trim();
let nome = linhas[i + 1]?.split('вҺҜ')[1]?.trim();
let nasc = linhas[i + 2]?.split('вҺҜ')[1]?.trim();

resultados.push({ cpf, nome, nasc });
}
}

let texto = `рҹ‘© CONSULTA MГғE

рҹ“Ң Nome buscado: ${q}
рҹ“Ҡ Resultados: ${resultados.length}

в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ`;

resultados.slice(0, 10).forEach((p, i) => {

texto += `

рҹ‘Ө ${i + 1}Вә Resultado
вҖў Nome: ${p.nome}
вҖў CPF: ${p.cpf}
вҖў Nascimento: ${p.nasc}
в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ`;

});

texto += `\nвҡ пёҸ Mostrando apenas 10 resultados`;

reply(texto);

} catch (e) {
console.log(e);
reply('вқҢ Erro ao buscar');
}

break;
}

