: `*бҙҮxбҙҳЙӘКҖбҙҖ бҙҮбҙҚ ${v.dias} бҙ…ЙӘбҙҖ${v.dias > 1 ? 's' : ''}*`
}`
).join('\n\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n\n');

// рҹ”Ҙ AQUI estГЎ o segredo
