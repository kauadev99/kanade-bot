);

const userData = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!userData) return reply(`*VocГӘ nГЈo possui registro de coins.*`);

const precoBomba = 150;

if (userData.coins < precoBomba) {
return reply(
