reagir(from, "вң…");
return reply('*бҙҚЙӘбҙ…ЙӘбҙҖ кңұбҙҖКҹбҙ бҙҖ КҹбҙҸбҙ„бҙҖКҹбҙҚбҙҮЙҙбҙӣбҙҮ бҙ„бҙҸбҙҚ кңұбҙңбҙ„бҙҮкңұкңұбҙҸ рҹҷҶвҖҚвҷӮпёҸ*');
}
if (i) {
reagir(from, "вҸі");
const buffer = await getFileBuffer(i, 'image');
if (fs.existsSync(videoPath)) fs.unlinkSync(videoPath);
fs.writeFileSync(imagemPath, buffer);
reagir(from, "вң…");
return reply('*бҙҚЙӘбҙ…ЙӘбҙҖ кңұбҙҖКҹбҙ бҙҖ КҹбҙҸбҙ„бҙҖКҹбҙҚбҙҮЙҙбҙӣбҙҮ бҙ„бҙҸбҙҚ кңұбҙңбҙ„бҙҮкңұкңұбҙҸ рҹ’ҒвҖҚвҷӮпёҸ*');
}
reply('*бҙҮЙӘ бҙҚбҙҮsбҙӣКҖбҙҮ, бҙҚбҙҖЙҙбҙ…бҙҮ бҙңбҙҚбҙҖ ЙӘбҙҚбҙҖЙўбҙҮбҙҚ бҙҸбҙң бҙ ЙӘМҒбҙ…бҙҮбҙҸ бҙҳКҖбҙҖ бҙҚЙӘбҙҚ бҙҚбҙңбҙ…бҙҖКҖ бҙҸ бҙҚбҙҮЙҙбҙң рҹҷҮвҖҚвҷӮпёҸ*');
}
break;
case 'setprefix':
if (args.length < 1) return;
if (!SoDono && !isnit && !issupre && !ischyt && !info.key.fromMe)
return reply(mess.onlyOwner());
