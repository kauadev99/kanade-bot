if (['blockcmdgp','unblockcmdgp','blockcmdg','unblockcmdg','listblockcmdgp','listbcmdgp','listbcmdglobal'].includes(cmd))
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҮкңұбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ ЙҙбҙҖМғбҙҸ бҙҳбҙҸбҙ…бҙҮ кңұбҙҮКҖ КҷКҹбҙҸЗ«бҙңбҙҮбҙҖбҙ…бҙҸ.*`)

if (getComandoBlock(from).includes(cmd))
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҮкңұбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ бҙҠбҙҖМҒ бҙҮкңұбҙӣбҙҖМҒ КҷКҹбҙҸЗ«бҙңбҙҮбҙҖбҙ…бҙҸ.*`)

await addComandos(from, cmd)

reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ "${cmd}" кң°бҙҸЙӘ КҷКҹбҙҸЗ«бҙңбҙҮбҙҖбҙ…бҙҸ ЙҙбҙҮкңұбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ.*`)
}
break


case 'unblockcmdgp': {
if (!isGroup) return reply(mess.onlyGroup())
if (!isGroupAdmins) return reply(mess.onlyAdmins())

if (!args[0])
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | ЙӘЙҙТ“бҙҸКҖбҙҚбҙҮ бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ З«бҙңбҙҮ бҙ…бҙҮкңұбҙҮбҙҠбҙҖ бҙ…бҙҮкңұКҷКҹбҙҸЗ«бҙңбҙҮбҙҖКҖ.*`)

let cmd = args[0].toLowerCase()

if (!getComandoBlock(from).includes(cmd))
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҮкңұбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ ЙҙбҙҖМғбҙҸ бҙҮкңұбҙӣбҙҖМҒ КҷКҹбҙҸЗ«бҙңбҙҮбҙҖбҙ…бҙҸ.*`)

await deleteComandos(from, cmd)

reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ "${cmd}" кң°бҙҸЙӘ бҙ…бҙҮкңұКҷКҹбҙҸЗ«бҙңбҙҮбҙҖбҙ…бҙҸ ЙҙбҙҮкңұбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ.*`)
}
break


case 'listblockcmdgp':
case 'listbcmdgp': {
if (!isGroup) return reply(mess.onlyGroup())

let lista = getComandoBlock(from)

if (!lista || lista.length === 0)
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | ЙҙбҙҖМғбҙҸ бҙҮxЙӘкңұбҙӣбҙҮ ЙҙбҙҮЙҙКңбҙңбҙҚ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ КҷКҹбҙҸЗ«бҙңбҙҮбҙҖбҙ…бҙҸ ЙҙбҙҮкңұбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ.*`)

let texto = `гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | КҹЙӘкңұбҙӣбҙҖ бҙ…бҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸкңұ КҷКҹбҙҸЗ«бҙңбҙҮбҙҖбҙ…бҙҸкңұ*
\n*рҹ“Ң бҙӣбҙҸбҙӣбҙҖКҹ:* ${lista.length}\n\n`

lista.forEach((cmd, index) => {
texto += `вһӨ *${index + 1}.* ${prefix}${cmd}\n`
})

await maki.sendMessage(from, { text: texto.trim() }, { quoted: selo })
}
break


case 'blockcmdg': {
if (!SoDono) return reply(mess.onlyOwner())

if (!args[0])
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | ЙӘЙҙТ“бҙҸКҖбҙҚбҙҮ бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ З«бҙңбҙҮ бҙ…бҙҮкңұбҙҮбҙҠбҙҖ КҷКҹбҙҸЗ«бҙңбҙҮбҙҖКҖ ЙўКҹбҙҸКҷбҙҖКҹбҙҚбҙҮЙҙбҙӣбҙҮ.*`)

let cmd = args[0].toLowerCase()

if (isblockCmdG.includes(cmd))
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҮкңұбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ бҙҠбҙҖМҒ бҙҮкңұбҙӣбҙҖМҒ ЙҙбҙҖ КҹЙӘкңұбҙӣбҙҖ ЙўКҹбҙҸКҷбҙҖКҹ.*`)

isblockCmdG.push(cmd)
fs.writeFileSync('./configs/INFO_DADOS/nescessario.json', JSON.stringify(nescessario, null, 2))

reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ "${cmd}" кң°бҙҸЙӘ бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖбҙ…бҙҸ ЙҙбҙҖ КҹЙӘкңұбҙӣбҙҖ ЙўКҹбҙҸКҷбҙҖКҹ.*`)
}
break


case 'unblockcmdg': {
if (!SoDono) return reply(mess.onlyOwner())

if (!args[0])
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | ЙӘЙҙТ“бҙҸКҖбҙҚбҙҮ бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ З«бҙңбҙҮ бҙ…бҙҮкңұбҙҮбҙҠбҙҖ КҖбҙҮбҙҚбҙҸбҙ бҙҮКҖ бҙ…бҙҖ КҹЙӘкңұбҙӣбҙҖ ЙўКҹбҙҸКҷбҙҖКҹ.*`)

let cmd = args[0].toLowerCase()

if (!isblockCmdG.includes(cmd))
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҮкңұбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ ЙҙбҙҖМғбҙҸ бҙҮкңұбҙӣбҙҖМҒ ЙҙбҙҖ КҹЙӘкңұбҙӣбҙҖ ЙўКҹбҙҸКҷбҙҖКҹ.*`)

let index = isblockCmdG.indexOf(cmd)
if (index !== -1) isblockCmdG.splice(index, 1)

fs.writeFileSync('./configs/INFO_DADOS/nescessario.json', JSON.stringify(nescessario, null, 2))

reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ "${cmd}" кң°бҙҸЙӘ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҸ бҙ…бҙҖ КҹЙӘкңұбҙӣбҙҖ ЙўКҹбҙҸКҷбҙҖКҹ.*`)
}
break


case 'listbcmdglobal': {
if (!isblockCmdG || isblockCmdG.length === 0)
return reply(`гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | ЙҙбҙҖМғбҙҸ бҙҮxЙӘкңұбҙӣбҙҮ ЙҙбҙҮЙҙКңбҙңбҙҚ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ КҷКҹбҙҸЗ«бҙңбҙҮбҙҖбҙ…бҙҸ ЙўКҹбҙҸКҷбҙҖКҹбҙҚбҙҮЙҙбҙӣбҙҮ.*`)

let texto = `гҖҢрҹ’ҷгҖҚ
- *рҹ§Ҡ | КҹЙӘкңұбҙӣбҙҖ ЙўКҹбҙҸКҷбҙҖКҹ бҙ…бҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸкңұ КҷКҹбҙҸЗ«бҙңбҙҮбҙҖбҙ…бҙҸкңұ*
\n*рҹ“Ң бҙӣбҙҸбҙӣбҙҖКҹ:* ${isblockCmdG.length}\n\n`

isblockCmdG.forEach((cmd, index) => {
texto += `вһӨ *${index + 1}.* ${prefix}${cmd}\n`
})

await maki.sendMessage(from, { text: texto.trim() }, { quoted: selo })
}
break

case 'antiddd':
case 'anti_ddd':
case 'anti-ddd':
if (!isGroup) return await reply(mess.onlyGroup());
if (!isGroupAdmins) return await reply(mess.onlyAdmins());
if (!isBotGroupAdmins) return await reply(mess.onlyBotAdmin());

// Alterna automaticamente o estado do antiDDD
if (dataGp[0].ANTI_DDD.active) {
dataGp[0].ANTI_DDD.active = false;
setGp(dataGp);
await reply('*бҙҸ КҖбҙҮбҙ„бҙңКҖsбҙҸ Т“бҙҸЙӘ бҙ…бҙҮsбҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ ЙҙбҙҸ ЙўКҖбҙңбҙҳбҙҸ рҹҷ…вҖҚвҷӮпёҸ*');
} else {
dataGp[0].ANTI_DDD.active = true;
setGp(dataGp);
await reply('*бҙҸ КҖбҙҮбҙ„бҙңКҖsбҙҸ бҙҖЙҙбҙӣЙӘбҙ…бҙ…бҙ… Т“бҙҸЙӘ бҙҖбҙӣЙӘбҙ бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ ЙҙбҙҸ ЙўКҖбҙңбҙҳбҙҸ рҹҷҮвҖҚвҷӮпёҸ*');
}
break;
case 'antiddd-list': {
if (!isGroup) return reply("*вқҢ вҖў бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙңsбҙҖбҙ…бҙҸ бҙҮбҙҚ ЙўКҖбҙңбҙҳбҙҸs*");
if (!isAntiDDD) 
return reply(`вҡ пёҸ вҖў бҙҳбҙҖКҖбҙҖ бҙңsбҙҖКҖ бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ, бҙҖбҙӣЙӘбҙ бҙҮ бҙҸ *antiddd*.\nрҹ’Ў вҖў бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ: *${prefix}antiddd 1*`);

const lista = dataGp[0].ANTI_DDD.listaProibidos;
if (lista.length < 1)
return reply(`рҹ“ӯ вҖў ЙҙГЈбҙҸ бҙҮxЙӘsбҙӣбҙҮ ЙҙбҙҮЙҙКңбҙңбҙҚ *DDD бҙҳКҖбҙҸЙӘКҷЙӘбҙ…бҙҸ* ЙҙбҙҮsбҙӣбҙҮ ЙўКҖбҙңбҙҳбҙҸ.\nрҹ‘ү вҖў бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҮ бҙ„бҙҸбҙҚ: *${prefix}add_ddd 21*`);

const texto =
`в•ӯв”ҖгҖҺ рҹ’ҷ гҖҸ*рқҗҖрқҗҚрқҗ“рқҗҲ-рқҗғрқҗғрқҗғ рқҗӢрқҗҲрқҗ’рқҗ“рқҗҖ*гҖҺ рҹ’ҷ гҖҸв”Җв•®
 рҹ’¬ вҖў ЙўКҖбҙңбҙҳбҙҸ: *${groupName}*
 рҹ“Ҡ вҖў бҙӣбҙҸбҙӣбҙҖКҹ: *${lista.length}*

${lista.map((v, i) => `в”Ӯ рҹ’ҷ вҖў ${i + 1}. *${v}*`).join("\n")}
`;

await reply(texto);
}
break;

case 'add_ddd': {
if (!isGroup) return reply("*вқҢ вҖў бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙңsбҙҖбҙ…бҙҸ бҙҮбҙҚ ЙўКҖбҙңбҙҳбҙҸs*");
if (!isGroupAdmins) return reply("*вқҢ вҖў бҙҖбҙҳбҙҮЙҙбҙҖs бҙҖбҙ…бҙҚЙӘЙҙs бҙҳбҙҸбҙ…бҙҮбҙҚ бҙңsбҙҖКҖ бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ*");
if (!isAntiDDD) 
return reply(`вҡ пёҸ вҖў бҙҖбҙӣЙӘбҙ бҙҮ бҙҸ *antiddd* бҙҳбҙҖКҖбҙҖ бҙңsбҙҖКҖ бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ.\nрҹ‘ү вҖў бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ: *${prefix}antiddd 1*`);
if (!q || !q.trim()) 
return reply(`вқҢ вҖў ЙӘЙҙТ“бҙҸКҖбҙҚбҙҮ бҙҸ *DDD* З«бҙңбҙҮ бҙ…бҙҮsбҙҮбҙҠбҙҖ бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖКҖ.\nрҹ’Ў вҖў бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ: *${prefix}add_ddd 21*`);

const ddd = q.trim();
if (ddd.length !== 2 || isNaN(ddd))
return reply(`вқҢ вҖў бҙңбҙҚ *DDD* бҙҳбҙҸssбҙңЙӘ *2 бҙ…ГӯЙўЙӘбҙӣбҙҸs* ЙҙбҙңбҙҚбҙҮМҒКҖЙӘбҙ„бҙҸs.\nрҹ“Ң вҖў бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ: *81* (Pernambuco)`);

if (dataGp[0].ANTI_DDD.listaProibidos.includes(ddd))
return reply(`вҡ пёҸ вҖў бҙҸ DDD *${ddd}* бҙҠбҙҖМҒ бҙҮsбҙӣбҙҖМҒ ЙҙбҙҖ КҹЙӘsбҙӣбҙҖ.\nрҹ“Ӣ вҖў бҙ бҙҮбҙҠбҙҖ: *${prefix}antiddd-list*`);

if (arrayDDDs.includes(ddd))
return reply(`вқҢ вҖў DDD *${ddd}* бҙҮМҒ ЙӘЙҙбҙ бҙҖМҒКҹЙӘбҙ…бҙҸ бҙҸбҙң ЙҙбҙҖМғбҙҸ бҙҮxЙӘsбҙӣбҙҮ.`);

dataGp[0].ANTI_DDD.listaProibidos.push(ddd);
setGp(dataGp);

await reply(
`рҹ’ҷ вҖў бҙ…бҙ…бҙ… *${ddd}* бҙҖбҙ…ЙӘбҙ„ЙӘбҙҸЙҙбҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ!\nрҹҡ« вҖў ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸs бҙ…бҙҮ *${extractStateFromDDD(ddd)}* sбҙҮКҖбҙҖМғбҙҸ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҸs.`
);
}
break;

case 'delete_ddd':
case 'del_ddd':
case 'rm_ddd': {
if (!isGroup) return reply("*вқҢ вҖў бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙңsбҙҖбҙ…бҙҸ бҙҮбҙҚ ЙўКҖбҙңбҙҳбҙҸs*");
if (!isGroupAdmins) return reply("*вқҢ вҖў бҙҖбҙҳбҙҮЙҙбҙҖs бҙҖбҙ…бҙҚЙӘЙҙs бҙҳбҙҸбҙ…бҙҮбҙҚ бҙңsбҙҖКҖ бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ*");
if (!isAntiDDD) 
return reply(`вҡ пёҸ вҖў бҙҖбҙӣЙӘбҙ бҙҮ бҙҸ *antiddd* бҙҳбҙҖКҖбҙҖ бҙңsбҙҖКҖ бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ.\nрҹ‘ү вҖў бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ: *${prefix}antiddd 1*`);
if (!q || !q.trim())
return reply(`вқҢ вҖў ЙӘЙҙТ“бҙҸКҖбҙҚбҙҮ бҙҸ DDD З«бҙңбҙҮ бҙ…бҙҮsбҙҮбҙҠбҙҖ КҖбҙҮбҙҚбҙҸбҙ бҙҮКҖ.\nрҹ’Ў вҖў бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ: *${prefix + command} 84*`);

const ddd = q.trim();
if (ddd.length !== 2 || isNaN(ddd))
return reply(`вқҢ вҖў бҙ…ЙӘЙўЙӘбҙӣбҙҮ бҙҖбҙҳбҙҮЙҙбҙҖs *1 DDD бҙҳбҙҸКҖ бҙ бҙҮбҙў*.\nрҹ“Ң вҖў бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ: *${prefix + command} 84*`);

const lista = dataGp[0].ANTI_DDD.listaProibidos;
if (lista.length === 0)
return reply(`рҹ“ӯ вҖў бҙҖ КҹЙӘsбҙӣбҙҖ бҙҮsбҙӣбҙҖМҒ бҙ бҙҖбҙўЙӘбҙҖ.`);

if (!lista.includes(ddd))
return reply(`вқҢ вҖў бҙҸ DDD *${ddd}* ЙҙбҙҖМғбҙҸ бҙҮsбҙӣбҙҖМҒ ЙҙбҙҖ КҷКҹбҙҖбҙ„бҙӢКҹЙӘsбҙӣ.\nрҹ“Ӣ вҖў бҙ„бҙҸЙҙsбҙңКҹбҙӣбҙҮ: *${prefix}antiddd-list*`);

dataGp[0].ANTI_DDD.listaProibidos = lista.filter(d => d !== ddd);
setGp(dataGp);

await reply(
`рҹ’ҷ вҖў бҙ…бҙ…бҙ… *${ddd}* КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҸ!\nрҹ”“ вҖў ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸs бҙ…бҙҮ *${extractStateFromDDD(ddd)}* бҙҖЙўбҙҸКҖбҙҖ sбҙҮКҖбҙҖМғбҙҸ бҙҳбҙҮКҖбҙҚЙӘбҙӣЙӘбҙ…бҙҸs.`
);
}
break;

