case 'bang': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isGroupAdmins) return reply(mess.onlyAdmins());
if (!SoDono) return reply(mess.onlyOwner());
if (!isBotGroupAdmins) return reply(mess.onlyBotAdmin());

if (!q || (q !== 'local' && q !== 'global')) {
return reply(`*бҙңsбҙҮ: КҷбҙҖЙҙЙў КҹбҙҸбҙ„бҙҖКҹ* вҖ” КҷбҙҖЙҙ бҙ…бҙҖ КҹЙӘsбҙӣбҙҖ ЙҙбҙҮЙўКҖбҙҖ КҹбҙҸбҙ„бҙҖКҹ\n*бҙҸбҙң: КҷбҙҖЙҙЙў ЙўКҹбҙҸКҷбҙҖКҹ* вҖ” КҷбҙҖЙҙ бҙ…бҙҖ КҹЙӘsбҙӣбҙҖ ЙҙбҙҮЙўКҖбҙҖ ЙўКҹбҙҸКҷбҙҖКҹ`);
}

try {
const lista = q === 'local' ? dataGp[0].listanegra : listanegraG;
const numerosNegros = lista.map(n => n.replace(/[^0-9]/g, ''));
const banidos = [];

for (const membro of groupMembers) {
const membroNormalizado = normalizar(membro.id);
const numero = membroNormalizado.replace(/[^0-9]/g, '');
const isInLista = numerosNegros.includes(numero);
const isNotAdmin = !membro.admin;
const isNotBot = membroNormalizado !== normalizar(maki.user.id);

if (isInLista && isNotAdmin && isNotBot) {
banidos.push(membroNormalizado);
}
}

if (banidos.length === 0) {
return reply(`*ЙҙбҙҖбҙҸ бҙҮЙҙбҙ„бҙҸЙҙбҙӣКҖбҙҮЙӘ ЙҙбҙҮЙҙКңбҙңбҙҚ бҙҚбҙҮбҙҚКҷКҖбҙҸ бҙ…бҙҖ КҹЙӘкңұбҙӣбҙҖ ${q.toUpperCase()} рҹӨ·вҖҚвҷӮпёҸ*`);
}

await maki.groupParticipantsUpdate(from, banidos, 'remove');

await maki.sendMessage(from, {
text: `*КҷбҙҖЙҙЙӘ бҙңбҙҚ бҙӣбҙҸбҙӣбҙҖКҹ бҙ…бҙҮ ${banidos.length} ЙӘЙҙЙӘбҙҚЙӘЙўбҙҸ(кңұ) бҙ…бҙҖ КҹЙӘкңұбҙӣбҙҖ ${q.toUpperCase()} рҹҷҮвҖҚвҷӮпёҸ*`,
contextInfo: canalInfo([])
}, { quoted: selo });

} catch (e) {
console.error(e);
reply('*бҙҮКҖКҖбҙҸ бҙҖбҙҸ КҷбҙҖЙҙЙӘКҖ бҙҸкңұ ЙӘЙҙЙӘбҙҚЙӘЙўбҙҸкңұ рҹӨ·вҖҚвҷӮпёҸ*');
}

break;
}

case 'listbang': {
if (!isGroup) return reply(mess.onlyGroup());
if (!SoDono) return reply(mess.onlyOwner());
if (!listanegraG || listanegraG.length < 1)
return reply('*ЙҙбҙҮЙҙКңбҙңбҙҚ ЙӘЙҙЙӘбҙҚЙӘЙўбҙҸ бҙҚбҙҖКҖбҙ„бҙҖбҙ…бҙҸ рҹҷҶвҖҚвҷӮпёҸ*');

let resposta = 'вӣ“пёҸ *КҹЙӘsбҙӣбҙҖ ЙҙбҙҮЙўКҖбҙҖ ЙўКҹбҙҸКҷбҙҖКҹ*\n\n';
let mencGlobal = [];

for (let [index, jid] of listanegraG.entries()) {
const numero = jid.replace(/[^0-9]/g, '');
resposta += `*${index + 1}.* @${numero}\n`;
mencGlobal.push(jid);
}

await maki.sendMessage(from, {
text: resposta,
contextInfo: canalInfo(mencGlobal)
}, { quoted: selo });

break;
}

