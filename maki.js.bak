case 'getbio':
case 'getb': {
if (!menc_os2 && !q) return reply(`*рҹҢӘпёҸ бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҸ бҙңкңұбҙңбҙҖКҖЙӘбҙҸ бҙҸбҙң бҙ…ЙӘЙўЙӘбҙӣбҙҮ бҙҸ ЙҙбҙңбҙҚбҙҮКҖбҙҸ бҙ„бҙҸбҙҚ бҙҸбҙң кңұбҙҮбҙҚ бҙҸ @*`);
reply("*бҙ©бҙҮЙўбҙҖЙҙбҙ…бҙҸ бҙҖ КҷЙӘбҙҸЙўКҖбҙҖкң°ЙӘбҙҖ бҙ…бҙҸ бҙңкңұбҙңбҙҖКҖЙӘбҙҸ бҙҖЙўбҙңбҙҖКҖбҙ…бҙҮ бҙңбҙҚ бҙҚбҙҸбҙҚбҙҮЙҙбҙӣбҙҸ вңЁ*");
try {
let numero = menc_os2 ? menc_os2.split('@')[0] : q.replace(/\D/g, '');
const getbb = `${numero}@s.whatsapp.net`;
let recadoW;
try {
const recadoUser = await maki.fetchStatus(getbb);
recadoW = recadoUser[0]?.status?.status || "*privado*";
} catch {
recadoW = "*privado*";
}
const jidParaMencionar = menc_os2 ? menc_os2 : `${numero}@s.whatsapp.net`;
await maki.sendMessage(
from,
{
text: `*рҹ—ҝ | КҷЙӘбҙҸЙўКҖбҙҖкң°ЙӘбҙҖ бҙ…бҙҸ бҙңкңұбҙңбҙҖКҖЙӘбҙҸ:* @${numero}\nвҖў\n> ${recadoW}`,
contextInfo: { ...channeldl, mentionedJid: [jidParaMencionar] }
},
{ quoted: selo }
);
} catch (e) {
console.log(e);
reply(mess.error());
}
}
break;

case 'getperfil': {
if (!menc_os2 && !q) return reply(`*рҹҢӘпёҸ бҙҚбҙҖКҖЗ«бҙңбҙҮ бҙҸ бҙңкңұбҙңбҙҖКҖЙӘбҙҸ бҙҸбҙң бҙ…ЙӘЙўЙӘбҙӣбҙҮ бҙҸ ЙҙбҙңбҙҚбҙҮКҖбҙҸ бҙ„бҙҸбҙҚ бҙҸбҙң кңұбҙҮбҙҚ бҙҸ @*`);
let numero = menc_os2 ? menc_os2.split('@')[0] : q.replace(/\D/g, '');
reply("*бҙ©бҙҮЙўбҙҖЙҙбҙ…бҙҸ бҙҸ бҙ©бҙҮКҖкң°ЙӘКҹ бҙ…бҙҸ бҙңкңұбҙңбҙҖКҖЙӘбҙҸ бҙҖЙўбҙңбҙҖКҖбҙ…бҙҮ бҙңбҙҚ бҙҚбҙҸбҙҚбҙҮЙҙбҙӣбҙҸ рҹҷҮвҖҚвҷӮпёҸ*");
let ppimgUrl;
try {
ppimgUrl = await maki.profilePictureUrl(`${numero}@s.whatsapp.net`, 'image');
} catch {
ppimgUrl = imgperfil;
}
const jidParaMencionar = menc_os2 ? menc_os2 : `${numero}@s.whatsapp.net`;
await maki.sendMessage(
from,
{
image: { url: ppimgUrl },
caption: `*вҡЎ | бҙ©бҙҮКҖкң°ЙӘКҹ бҙ…бҙҸ бҙңкңұбҙңбҙҖКҖЙӘбҙҸ:* @${numero}\n> *рҹ—ҝ кңұбҙҮ бҙ„бҙҖкңұбҙҸ бҙ бҙҸбҙ„бҙҮ З«бҙңбҙҮЙӘКҖбҙҖ бҙ©бҙҮЙўбҙҖКҖ бҙҖ КҷЙӘбҙҸЙўКҖбҙҖкң°ЙӘбҙҖ бҙ…бҙҸ бҙңкңұбҙңбҙҖКҖЙӘбҙҸ бҙңкңұбҙҮ бҙҸ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ:* ${prefix}getbio`,
contextInfo: { ...channeldl, mentionedJid: [jidParaMencionar] }
},
{ quoted: selo }
);
}
break;

case 'r':
case 'reiniciar': {
if (!SoDono) return reply(mess.onlyOwner())

await reply(
"*бҙҸбҙӢбҙҖКҸ бҙҚбҙҮsбҙӣКҖбҙҮ, ЙӘКҖбҙҮЙӘ КҖбҙҮЙӘЙҙЙӘбҙ„ЙӘбҙҖКҖ, бҙҖЙўбҙңбҙҖКҖбҙ…бҙҮ бҙңбҙҚ бҙҚбҙҸбҙҚбҙҮЙҙбҙӣбҙҸ... рҹҷҮвҖҚвҷӮпёҸ*"
)
await new Promise(resolve => setTimeout(resolve, 2000))
process.exit(0)
}
break

case 'channel':
case 'setchannel': {
if (!SoDono && !isnit && !info.key.fromMe) return reply(mess.onlyOwner());

if (!args[0])
return reply(`- *бҙҮsбҙӣбҙҖ Т“бҙҖКҹбҙӣбҙҖЙҙбҙ…бҙҸ бҙҸ бҙ„бҙҖЙҙбҙҖКҹ.. рҹӨ·вҖҚвҷӮпёҸ*
> вңЁвҶ’ *бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ: ${prefix+command} <link do canal>*
> рҹҡ« вҶ’ *бҙ©бҙҖКҖбҙҖ бҙ…бҙҮкңұбҙҖбҙӣЙӘбҙ бҙҖКҖ бҙңкңұбҙҮ: ${prefix+command} 0*`);

// вқҢ se for nГәmero diferente de 0
if (!isNaN(args[0]) && args[0] !== "0")
return reply(`рҹҡ« *бҙҸбҙҳГ§ГЈбҙҸ ЙӘЙҙбҙ бҙҖМҒКҹЙӘбҙ…бҙҖ!*
> рҹҡ« вҶ’ *бҙ©бҙҖКҖбҙҖ бҙ…бҙҮкңұбҙҖбҙӣЙӘбҙ бҙҖКҖ бҙңкңұбҙҮ: ${prefix+command} 0*`);

if (args[0] === "0") {
setting.channeldl = "0@newsletter";
fs.writeFileSync('./configs/INFO_DADOS/settings.json', JSON.stringify(setting, null, 2));
return reply(`*бҙ„КңбҙҖЙҙЙҙбҙҮКҹ бҙ…бҙҮкңұбҙҖбҙӣЙӘбҙ бҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ кңұбҙңбҙ„бҙҮкңұкңұбҙҸ кңұбҙҮЙҙКңбҙҸКҖ(бҙҖ)! рҹҷҮвҖҚвҷӮпёҸ*`);
}

// вқҢ se nГЈo for link
if (!args[0].includes("whatsapp.com/channel") && !args[0].includes("wa.me/channel"))
return reply(`рҹҡ« *бҙҸбҙҳГ§ГЈбҙҸ ЙӘЙҙбҙ бҙҖМҒКҹЙӘбҙ…бҙҖ!*
> рҹҡ« вҶ’ *бҙ©бҙҖКҖбҙҖ бҙ…бҙҮкңұбҙҖбҙӣЙӘбҙ бҙҖКҖ бҙңкңұбҙҮ: ${prefix+command} 0*`);

let DylanModz = q.trim()
.replace(/.*whatsapp\.com\/channel\//, '')
.replace(/.*wa\.me\/channel\//, '')
.split(/[\/?\s]/)[0];

if (!DylanModz) return reply(mess.error());

try {
const meta = await maki.newsletterMetadata("invite", DylanModz);
const jidReal = meta?.jid || meta?.id;
if (!jidReal) return reply(mess.error());

setting.channeldl = jidReal;
fs.writeFileSync('./configs/INFO_DADOS/settings.json', JSON.stringify(setting, null, 2));

reply(`- *бҙ„КңбҙҖЙҙЙҙбҙҮКҹ бҙҖбҙӣЙӘбҙ бҙҸ бҙ„бҙҸбҙҚ кңұбҙңбҙ„бҙҮкңұкңұбҙҸ кңұбҙҮЙҙКңбҙҸКҖ(бҙҖ) вңЁ*
> *рҹҘҮ вҶ’ ЙӘбҙ…: ${jidReal}*
> *рҹ–ҮпёҸ вҶ’ КҹЙӘЙҙбҙӢ: ${args[0]}*`);
} catch (e) {
console.log(e);
reply(mess.error());
}
}
break;
case 'nome-bot':
if (!SoDono && !isnit && !info.key.fromMe)
return reply(mess.onlyOwner());
setting.NomeDoBot = q.trim();
fs.writeFileSync("./configs/INFO_DADOS/settings.json", JSON.stringify(setting, null, 2));
reply(`вңЁ *бҙҸ ЙҙбҙҸбҙҚбҙҮ бҙ…бҙҸ КҷбҙҸбҙӣ Т“бҙҸЙӘ бҙҖКҹбҙӣбҙҮКҖбҙҖбҙ…бҙҸ бҙ„бҙҸбҙҚ sбҙңбҙ„бҙҮssбҙҸ бҙҳбҙҖКҖбҙҖ:* ${setting.NomeDoBot}`);
break;

case 'nick-dono':
if (!SoDono && !isnit && !info.key.fromMe)
return reply(mess.onlyOwner());
setting.ownerName = q.trim();
fs.writeFileSync(
"./configs/INFO_DADOS/settings.json",
JSON.stringify(setting, null, 2)
);
reply(`рҹ‘‘ *бҙҸ ЙҙЙӘбҙ„бҙӢ бҙ…бҙҸ бҙ…бҙҸЙҙбҙҸ Т“бҙҸЙӘ бҙ„бҙҸЙҙТ“ЙӘЙўбҙңКҖбҙҖбҙ…бҙҸ бҙҳбҙҖКҖбҙҖ:* ${setting.ownerName}`);
