await maki.groupParticipantsUpdate(from, [sender], "remove");
await maki.sendMessage(from, {text: `рҹҡ« *@${sender.split("@")[0]}* foi removido por enviar mensagem de pagamento.`, mentions: [sender]});
await maki.sendMessage(from, {delete: {remoteJid: from, fromMe: false, id: info.key.id, participant: sender}});
