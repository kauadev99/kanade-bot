);
const userAlvo = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === alvo
);

if (!userRemetente)
return reply(`*VocГӘ nГЈo possui registro de coins.*`);
if (!userAlvo)
return reply(
`*O usuГЎrio mencionado nГЈo possui registro de coins.*`
);

if (userRemetente.bombas <= 0)
return reply(
`рҹ’Ј VocГӘ nГЈo possui bombas para usar. Compre usando ${prefix}comprarbomba`
);

// Verifica se o alvo estГЎ com escudo ativo (e ainda vГЎlido)
const agora = Date.now();
if (userAlvo.escudo && userAlvo.escudo > agora) {
return reply(
`рҹӣЎпёҸ O usuГЎrio @${alvo.split("@")[0]} estГЎ protegido por um escudo! Seu ataque foi bloqueado.`
);
}

// Calcula roubo fixo (exemplo 30% das coins do alvo)
const valorRoubo = Math.floor(userAlvo.coins * 0.3);

if (valorRoubo <= 0) {
return reply(
`*O alvo nГЈo tem coins suficientes para serem roubadas.*`
);
}

// Executa roubo
userAlvo.coins -= valorRoubo;
userRemetente.coins += valorRoubo;

// Consome a bomba
userRemetente.bombas -= 1;

CoinsUpdate(RG_SCOINS);

const mensagemSucesso = `
рҹ’Ј *Bomba usada!*
VocГӘ roubou *${valorRoubo} N-Coins* de @${alvo.split("@")[0]}.
Seu saldo atual: *${userRemetente.coins} N-Coins*.
Saldo do alvo: *${userAlvo.coins} N-Coins*.
`;

await mention(mensagemSucesso.trim());

break;
}

