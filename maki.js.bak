case 'banfake':
case 'banfakes':
if (!isGroup) return reply("*вқҢ вҖў бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙңsбҙҖбҙ…бҙҸ бҙҮбҙҚ ЙўКҖбҙңбҙҳбҙҸs*");
if (!isGroupAdmins) return reply("*вқҢ вҖў бҙҖбҙҳбҙҮЙҙбҙҖs бҙҖбҙ…бҙҚЙӘЙҙs бҙҳбҙҸбҙ…бҙҮбҙҚ бҙңsбҙҖКҖ бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ*");

reagir(from, "рҹҡ«");

try {
let grpmdt = await maki.groupMetadata(from);
const membros_ = grpmdt.participants;
const groupAdmins_ = getGroupAdmins(membros_);

const normalizar = alvo => {
if (alvo?.includes('@lid') && membros_) {
 return membros_.find(v => v.lid === alvo)?.jid || alvo;
}
return alvo;
};

let caixa = [];

for (let membro of membros_) {
const participante = normalizar(membro.id);
const numero = participante.split("@")[0];

// вқ— NГЈo remover dono, bot ou admin
if (
 participante !== botNumber &&
 !numerodono.includes(participante) &&
 !groupAdmins_.includes(participante) &&
 !numero.startsWith("55") // NГәmero que NГғO Г© brasileiro = fake
) {
 caixa.push(participante);
}
}

if (caixa.length === 0) {
return reply("*рҹӨ·вҖҚвҷӮпёҸ вҖў ЙҙГЈбҙҸ бҙҮxЙӘsбҙӣбҙҮ ЙҙбҙҮЙҙКңбҙңбҙҚ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ Т“бҙҖбҙӢбҙҮ ЙҙбҙҮssбҙҮ ЙўКҖбҙңбҙҳбҙҸ!*");
}

reply(`*рҹҡ« вҖў КҖбҙҮбҙҚбҙҸбҙ бҙҮЙҙбҙ…бҙҸ ${caixa.length} ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ(s) Т“бҙҖбҙӢбҙҮ...*`);

// рҹ”Ғ Remover lentamente para evitar ban do WhatsApp
for (let i = 0; i < caixa.length; i++) {
await sleep(1000);
await maki.groupParticipantsUpdate(from, [caixa[i]], 'remove');
}

reply(`*вң”пёҸ вҖў КҖбҙҮбҙҚбҙҸбҙ„М§ГЈбҙҸ бҙ„бҙҸЙҙбҙ„КҹбҙңЙӘМҒбҙ…бҙҖ!*\nрҹ“Ө вҖў бҙӣбҙҸбҙӣбҙҖКҹ КҖбҙҮбҙҚбҙҸбҙ ЙӘбҙ…бҙҸs: *${caixa.length}*`);

} catch (e) {
console.error(e);
reply("*вқҢ вҖў бҙҮКҖКҖбҙҸ бҙҖбҙҸ бҙҳКҖбҙҸбҙ„бҙҮssбҙҖКҖ бҙҖ КҖбҙҮбҙҚбҙҸбҙ„М§ГЈбҙҸ бҙ…бҙҸs Т“бҙҖбҙӢбҙҮs!*");
}
break;
// ============================ LISTA FAKE ============================

// ============================ LISTA DE NГҡMEROS FAKES ============================

case 'listafake':
case 'listafakes':
if (!isGroup) return reply("*вқҢ вҖў бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ кң°бҙңЙҙбҙ„ЙӘбҙҸЙҙбҙҖ бҙҮбҙҚ ЙўКҖбҙңбҙҳбҙҸs*");
if (!isGroupAdmins && !SoDono) return reply("*вқҢ вҖў бҙҖбҙҳбҙҮЙҙбҙҖs бҙҖбҙ…бҙҚЙӘЙҙs бҙҳбҙҸбҙ…бҙҮбҙҚ бҙңsбҙҖКҖ бҙҮкңұбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ*");
if (!isBotGroupAdmins) return reply("*вқҢ вҖў бҙҮбҙң бҙҳКҖбҙҮбҙ„ЙӘsбҙҸ sбҙҮКҖ бҙҖбҙ…бҙҚЙӘЙҙ бҙҳбҙҖКҖбҙҖ бҙҚбҙҮбҙ„КңбҙҮКҖ ЙҙбҙҸs бҙҚбҙҮбҙҚКҷКҖбҙҸs!*");

reagir(from, "рҹҮәрҹҮё");

try {
let grpmdt = await maki.groupMetadata(from);
const membros_ = grpmdt.participants;

const normalizar = alvo => membros_.find(v => v.lid === alvo)?.jid || alvo;

let teks = `рҹҮәрҹҮё *бҙңsбҙңбҙҖМҒКҖЙӘбҙҸs бҙ„бҙҸбҙҚ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ кң°бҙҖбҙӢбҙҮ (ЙҙбҙҖМғбҙҸ КҷКҖбҙҖsЙӘКҹбҙҮЙӘКҖбҙҸ):*\n`;
let men = [];

for (let membro of membros_) {
const participante = normalizar(membro.id);
const numero = participante.split("@")[0];

if (!numero.startsWith("55") && participante !== botNumber) {
 teks += `вһӨ @${numero}\n`;
 men.push(participante);
}
}

if (!men.length) return reply("рҹӨ·вҖҚвҷӮпёҸ вҖў ЙҙбҙҖМғбҙҸ КңбҙҖМҒ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸкңұ кң°бҙҖбҙӢбҙҮкңұ ЙҙбҙҸ ЙўКҖбҙңбҙҳбҙҸ.");

teks += `\nрҹҮәрҹҮё *бҙӣбҙҸбҙӣбҙҖКҹ:* ${men.length}`;

await maki.sendMessage(from, { text: teks, mentions: men }, { quoted: selo });

} catch (e) {
console.error(e);
reply("вқҢ вҖў бҙҸбҙ„бҙҸКҖКҖбҙҮбҙң бҙңбҙҚ бҙҮКҖКҖбҙҸ бҙҖбҙҸ бҙҳКҖбҙҸбҙ„бҙңКҖбҙҖКҖ бҙҸs бҙҚбҙҮбҙҚКҷКҖбҙҸs!");
}
break;


// ============================ LISTA DE BRASILEIROS ============================

case 'listabr':
case 'brlist':
if (!isGroup) return reply("*вқҢ вҖў бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ кң°бҙңЙҙбҙ„ЙӘбҙҸЙҙбҙҖ бҙҮбҙҚ ЙўКҖбҙңбҙҳбҙҸs*");
if (!isGroupAdmins && !SoDono) return reply("*вқҢ вҖў бҙҖбҙҳбҙҮЙҙбҙҖs бҙҖбҙ…бҙҚЙӘЙҙs бҙҳбҙҸбҙ…бҙҮбҙҚ бҙңsбҙҖКҖ бҙҮкңұбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ*");
if (!isBotGroupAdmins) return reply("*вқҢ вҖў бҙҮбҙң бҙҳКҖбҙҮбҙ„ЙӘsбҙҸ sбҙҮКҖ бҙҖбҙ…бҙҚЙӘЙҙ бҙҳбҙҖКҖбҙҖ бҙҚбҙҮбҙ„КңбҙҮКҖ ЙҙбҙҸs бҙҚбҙҮбҙҚКҷКҖбҙҸs!*");

reagir(from, "рҹҮ§рҹҮ·");

try {
let grpmdt = await maki.groupMetadata(from);
const membros_ = grpmdt.participants;

const normalizar = alvo => membros_.find(v => v.lid === alvo)?.jid || alvo;

let teks = `рҹҮ§рҹҮ· *бҙңsбҙңбҙҖМҒКҖЙӘбҙҸs бҙ„бҙҸбҙҚ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ КҷКҖбҙҖsЙӘКҹбҙҮЙӘКҖбҙҸ:* \n`;
let men = [];

for (let membro of membros_) {
const participante = normalizar(membro.id);
const numero = participante.split("@")[0];

if (numero.startsWith("55") && participante !== botNumber) {
 teks += `вһӨ @${numero}\n`;
 men.push(participante);
}
}

if (!men.length) return reply("рҹӨ·вҖҚвҷӮпёҸ вҖў ЙҙбҙҖМғбҙҸ бҙҮxЙӘsбҙӣбҙҮЙҙ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸs КҷКҖбҙҖsЙӘКҹбҙҮЙӘКҖбҙҸs ЙҙбҙҸ ЙўКҖбҙңбҙҳбҙҸ!");

teks += `\nрҹҮ§рҹҮ· *бҙӣбҙҸбҙӣбҙҖКҹ:* ${men.length}`;

await maki.sendMessage(from, { text: teks, mentions: men }, { quoted: selo });

} catch (e) {
console.error(e);
reply("вқҢ вҖў бҙҸбҙ„бҙҸКҖКҖбҙҮбҙң бҙңбҙҚ бҙҮКҖКҖбҙҸ бҙҖбҙҸ бҙҳКҖбҙҸбҙ„бҙңКҖбҙҖКҖ бҙҸs бҙҚбҙҮбҙҚКҷКҖбҙҸs!");
}
break;
// ============================ LISTA POR DDI (CГ“DIGO DE PAГҚS) ============================

case 'listaddi':
case 'ddilist':
if (!isGroup) return reply("*вқҢ вҖў бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙңsбҙҖбҙ…бҙҸ бҙҮбҙҚ ЙўКҖбҙңбҙҳбҙҸs*");
if (!isGroupAdmins) return reply("*вқҢ вҖў бҙҖбҙҳбҙҮЙҙбҙҖs бҙҖбҙ…бҙҚЙӘЙҙs бҙҳбҙҸбҙ…бҙҮбҙҚ бҙңsбҙҖКҖ бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ*");

if (!q || isNaN(q)) {
return reply(`рҹ“Ң вҖў ЙӘЙҙТ“бҙҸКҖбҙҚбҙҮ бҙҸ бҙ„бҙҸМҒбҙ…ЙӘЙўбҙҸ бҙ…бҙҮ бҙңбҙҚ бҙҳбҙҖЙӘМҒs (*DDI*).\nрҹ’Ў вҖў бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ:\n*${prefix}listaddi 55*`);
}

try {
const grpmdt = await maki.groupMetadata(from);
const membros_ = grpmdt.participants;
const normalizar = alvo => membros_.find(v => v.lid === alvo)?.jid || alvo;

let teks = `рҹҢҚ *бҙңsбҙңбҙҖМҒКҖЙӘбҙҸs бҙ„бҙҸбҙҚ бҙ…бҙ…ЙӘ +${q} бҙҮЙҙбҙ„бҙҸЙҙбҙӣКҖбҙҖбҙ…бҙҸs:*\n`;
let men = [];

for (let membro of membros_) {
const participante = normalizar(membro.id);
const numero = participante.split("@")[0];

if (numero.startsWith(q) && participante !== botNumber) {
 teks += `вһӨ @${numero}\n`;
 men.push(participante);
}
}

if (!men.length) {
return reply(`вқҢ вҖў ЙҙбҙҮЙҙКңбҙңбҙҚ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ бҙ„бҙҸбҙҚ *DDI +${q}* Т“бҙҸЙӘ бҙҮЙҙбҙ„бҙҸЙҙбҙӣКҖбҙҖбҙ…бҙҸ.`);
}

await maki.sendMessage(from, { text: teks, mentions: men }, { quoted: selo });

} catch (error) {
console.error(error);
reply("вқҢ вҖў бҙҸбҙ„бҙҸКҖКҖбҙҮбҙң бҙңбҙҚ бҙҮКҖКҖбҙҸ бҙҖбҙҸ КҹЙӘsбҙӣбҙҖКҖ бҙҸs ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸs.");
}
break;

// ============================ LISTA POR DDD ============================

case 'listaddd':
case 'dddlist':
if (!isGroup) return reply("*вқҢ вҖў бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙңsбҙҖбҙ…бҙҸ бҙҮбҙҚ ЙўКҖбҙңбҙҳбҙҸs*");
if (!isGroupAdmins) return reply("*вқҢ вҖў бҙҖбҙҳбҙҮЙҙбҙҖs бҙҖбҙ…бҙҚЙӘЙҙs бҙҳбҙҸбҙ…бҙҮбҙҚ бҙңsбҙҖКҖ бҙҮsбҙӣбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ*");

if (!q || isNaN(q)) {
return reply(`рҹ“Ң вҖў ЙӘЙҙТ“бҙҸКҖбҙҚбҙҮ бҙңбҙҚ *DDD* бҙ бҙҖМҒКҹЙӘбҙ…бҙҸ.\nрҹ’Ў вҖў бҙҮxбҙҮбҙҚбҙҳКҹбҙҸ:\n*${prefix}listaddd 91*`);
}

try {
const grpmdt = await maki.groupMetadata(from);
const membros_ = grpmdt.participants;
const normalizar = alvo => membros_.find(v => v.lid === alvo)?.jid || alvo;

let teks = `рҹ“һ *бҙңsбҙңбҙҖМҒКҖЙӘбҙҸs бҙ„бҙҸбҙҚ бҙ…бҙ…бҙ… ${q}:*\n`;
let men = [];

for (let membro of membros_) {
const participante = normalizar(membro.id);
const numero = participante.split("@")[0];

if (numero.startsWith(`55${q}`) && participante !== botNumber) {
 teks += `вһӨ @${numero}\n`;
 men.push(participante);
}
}

if (!men.length) {
return reply(`вқҢ вҖў ЙҙбҙҮЙҙКңбҙңбҙҚ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ бҙ„бҙҸбҙҚ *DDD ${q}* Т“бҙҸЙӘ бҙҮЙҙбҙ„бҙҸЙҙбҙӣКҖбҙҖбҙ…бҙҸ.`);
}

await maki.sendMessage(from, { text: teks, mentions: men }, { quoted: selo });

} catch (error) {
console.error(error);
reply("вқҢ вҖў бҙҸбҙ„бҙҸКҖКҖбҙҮбҙң бҙңбҙҚ бҙҮКҖКҖбҙҸ бҙҖбҙҸ КҹЙӘsбҙӣбҙҖКҖ бҙҸs ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸs.");
}
break;

case 'donos': {
await reagir(from, "рҹҺү")

try {

let donosJid = [
numero_dono1 + "@s.whatsapp.net",
numero_dono2 + "@s.whatsapp.net",
numero_dono3 + "@s.whatsapp.net",
