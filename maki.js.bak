const fs = require('fs')
const caminhoArquivo = "./maki.js"
const codigo = fs.readFileSync(caminhoArquivo, "utf8")
const nome = q.trim()

function escaparRegex(texto) {
return texto.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
}

function getCase(nomeCase) {
const nomeEscapado = escaparRegex(nomeCase)
const regex = new RegExp(
`case\\s+['"\`]${nomeEscapado}['"\`]\\s*:[\\s\\S]*?break\\s*;?`,
'g'
)

const match = codigo.match(regex)
if (match && match[0]) return match[0]

throw new Error("Case nГЈo encontrada")
}

const resultado = getCase(nome)

await maki.sendMessage(from, {
document: Buffer.from(resultado, 'utf8'),
mimetype: 'application/javascript',
fileName: `${nome}.js`,
caption: `рҹ“Ӯ Aqui estГЎ a case *${nome}* pronta pra copiar`
}, { quoted: info })

} catch (error) {
console.log(error)
reply(
`рҹ’ҷ *A CASE NГғO FOI ENCONTRADA!*  
вңҚпёҸ Verifique se o nome foi escrito corretamente.`
)
}
}
break

