dattofc != SYSTEM_COIN.VerificarCampo(sender, "data")
) {

const alvo = info.key.participant || sender;

await maki.sendMessage(from, {
text: `
вҶі ${tempo} вҶқ @${alvo.split("@")[0]} вҶҙ

 вҖў VocГӘ acaba de ganhar *50 N-Coins* pela primeira mensagem do dia рҹ’«

вҶі Caso queira saber mais, use o *${prefix}menucoins* ou *${prefix}menupets* рҹ’•
-`,
mentions: [alvo]
});

SYSTEM_COIN.Adicionar_2(sender, 50, "data", dattofc);

RG_US = RG_SCOINS[ID_G_COINS].usus.find((i) => i.id === sender);
Object.assign(RG_US.chances, { cassino: 0, minerar: 0 });

CoinsUpdate(RG_SCOINS);
}
}

