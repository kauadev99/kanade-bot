if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const mentions =
info.message.extendedTextMessage?.contextInfo?.mentionedJid || [];
if (mentions.length === 0)
return reply(`рҹ‘Ө Mencione o usuГЎrio que vocГӘ quer tentar matar.`);

const alvo = mentions[0];
const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
const userAlvo = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === alvo
);

if (!user)
return reply(`вқҢ VocГӘ nГЈo estГЎ registrado no sistema de coins.`);
if (!userAlvo)
return reply(
`вқҢ O usuГЎrio mencionado nГЈo estГЎ registrado no sistema de coins.`
);

if (!user.itens?.arma)
return reply(
`рҹ”« VocГӘ nГЈo tem uma arma! Use *${prefix}comprararma* primeiro.`
);

// Verifica escudo com tempo (proteГ§ГЈo ativa)
if (userAlvo.pocaoProtecao) {
const agora = Date.now();
const expiracao = userAlvo.pocaoProtecaoExpira || 0;
if (agora < expiracao) {
return reply(
`рҹӣЎпёҸ O usuГЎrio @${alvo.split("@")[0]} estГЎ protegido por um escudo e nГЈo pode ser eliminado agora.`
);
} else {
delete userAlvo.pocaoProtecao;
delete userAlvo.pocaoProtecaoExpira;
CoinsUpdate(RG_SCOINS);
}
}

const multaEscudo = 1000;

if (userAlvo.itens?.escudo) {
if (user.coins >= multaEscudo) {
user.coins -= multaEscudo;
await reply(
`рҹӣЎпёҸ O alvo estГЎ com escudo!\nрҹ’ё VocГӘ perdeu *${multaEscudo} coins* tentando matar ele.`
);
} else {
await reply(
`рҹӣЎпёҸ O alvo estГЎ com escudo!\nрҹ’ё VocГӘ tentou matar, mas nem tinha *${multaEscudo} coins* para pagar a penalidade... tomou prejuГӯzo moral.`
);
}

delete user.itens.arma;
CoinsUpdate(RG_SCOINS);
return;
}

// Mata com sucesso
userAlvo.coins = 0;
delete user.itens.arma;
CoinsUpdate(RG_SCOINS);

await reply(
`рҹ’Ҙ VocГӘ matou @${alvo.split("@")[0]} e ele perdeu *TODOS* os coins!`,
{ mentions: [alvo] }
);

break;
}
case 'comprarpet': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const tipo = args[0]?.toLowerCase();
const pets = {
gato: { preco: 3000 },
cachorro: { preco: 2000 },
jabuti: { preco: 1000 },
periquito: { preco: 4000 },
dragao: { preco: 20000 },
};

if (!tipo || !pets[tipo]) {
return reply(`рҹҗҫ *PET SHOP - Escolha um pet para comprar:*\n
рҹҗұ gato - 3000 coins
рҹҗ¶ cachorro - 2000 coins
рҹҗў jabuti - 1000 coins
рҹҗҰ periquito - 4000 coins
рҹҗү dragГЈo - 20000 coins

Exemplo: ${prefix}comprarpet gato`);
}

const user = RG_SCOINS[ID_G_COINS]?.usus.find(
(u) => u.id === sender
);
if (!user) return reply("вқҢ VocГӘ ainda nГЈo tem conta registrada.");

if (user.pet)
return reply(
`вқҢ VocГӘ jГЎ tem um pet! Use ${prefix}venderpet para vender o atual.`
);

const preco = pets[tipo].preco;
if (user.coins < preco)
return reply(
`рҹ’ё VocГӘ nГЈo tem coins suficientes. O pet ${tipo} custa ${preco} coins.`
);

user.coins -= preco;
user.pet = {
tipo,
fome: 100,
tempoUltimaAlimentacao: Date.now(),
tempoUltimoBanho: null,
tempoUltimoPasseio: null,
criadoEm: Date.now(), // рҹҶ• idade
afeto: 0, // рҹҶ• afinidade
nivel: 1, // рҹҶ• nГӯvel
};

CoinsUpdate(RG_SCOINS);
await reply(
`вң… VocГӘ adotou um *${tipo}*! Cuide bem dele ou ele pode morrer de fome рҹҗҫ`
);
break;
}

case 'mercadopet': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

let msg = `рҹҗҫ *бҙҚбҙҮКҖбҙ„бҙҖбҙ…бҙҸ бҙҳбҙҮбҙӣ* - Comidas disponГӯveis:\n\n`;

msg += `рҹҗұ *GATO*\nрҹҚЈ Peixe (+50 fome) - 300 coins\nрҹҘӣ Leite (+30 fome) - 150 coins\n\n`;
msg += `рҹҗ¶ *CACHORRO*\nрҹҰҙ Osso (+40 fome) - 250 coins\nрҹҘ« RaГ§ГЈo (+60 fome) - 400 coins\n\n`;
msg += `рҹҗў *JABUTI*\nрҹҘ¬ Alface (+30 fome) - 200 coins\nрҹҚҺ Fruta (+50 fome) - 300 coins\n\n`;
msg += `рҹҗҰ *PERIQUITO*\nрҹҢҫ Sementes (+30 fome) - 200 coins\nрҹҚҢ Banana (+50 fome) - 350 coins\n\n`;
msg += `рҹҗү *DRAGГғO*\nрҹҘ© Carne mГЎgica (+70 fome) - 1000 coins\nрҹ”Ҙ Lava temperada (+100 fome) - 2000 coins\n\n`;

msg += `рҹҰ… *GRIFO*\nрҹӘ¶ Pena de Grifo (+65 fome) - 9000 coins\nрҹҚ– Carne de CaГ§a (+80 fome) - 11000 coins\n\n`;
msg += `рҹ”Ҙ *FГҠNIX*\nрҹҚҺ Pomo de FГӘnix (+70 fome) - 10000 coins\nрҹ”Ҙ Fogo Sagrado (+90 fome) - 15000 coins\n\n`;
msg += `рҹҗү *DRAGГғO DOURADO*\nрҹҗү Escama de DragГЈo (+80 fome) - 15000 coins\nрҹ”Ҙ Fogo Dourado (+100 fome) - 20000 coins\n\n`;
msg += `рҹ‘№ *DEMONIO*\nрҹ‘№ Chifre de demonios (+75 fome) - 12000 coins\nрҹҚҜ NГ©ctar MГЎgico (+85 fome) - 13000 coins\n\n`;

msg += `рҹӣ’ Use: ${prefix}comprarcomida <nome_da_comida>`;

await reply(msg);
break;
}

case 'comprarcomida': {
if (!isGroup) return reply(mess.onlyGroup());
if (!isModoCoins)
return reply(
`*бҙҮssбҙҮ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ sбҙҸМҒ бҙҳбҙҸбҙ…бҙҮ sбҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ xбҙңбҙҖЙҙбҙ…бҙҸ бҙҸ sЙӘбҙӣбҙҮбҙҚбҙҖ ${prefix}бҙҚбҙҸбҙ…бҙҸбҙ„бҙҸЙӘЙҙs бҙҮsбҙӣЙӘбҙ бҙҮКҖ бҙҖбҙӣЙӘбҙ бҙҸ рҹӨ·рҹҸ»вҖҚвҷӮпёҸ*`
);

const item = args[0]?.toLowerCase();
const comidas = {
peixe: { nome: "рҹҚЈ Peixe", preco: 300, fome: 50, pets: ["gato"] },
