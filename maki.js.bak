} else {
encmedia = await sendImageAsSticker2(maki, from, buffer, selo, { packname: packnameStk, author: authorSticker, contextInfo: canalInfo([]) });
}
await DLT_FL(encmedia);
} catch (e) {
console.log(e);
reply("Erro ao gerar figurinha.");
}
}
