return reply("рҹ’ҷ ЙҙбҙңМҒбҙҚбҙҮКҖбҙҸ ЙӘЙҙбҙ бҙҖМҒКҹЙӘбҙ…бҙҸ.")

let blcp = numero + "@s.whatsapp.net"

if (ban.includes(blcp))
return reply(`гҖҢрҹ§ҠгҖҚ
- *рҹ’ҷ | бҙҮкңұбҙӣбҙҮ бҙңsбҙңбҙҖМҒКҖЙӘбҙҸ бҙҠбҙҖМҒ бҙҮкңұбҙӣбҙҖМҒ ЙҙбҙҖ КҹЙӘкңұбҙӣбҙҖ бҙ…бҙҮ КҷКҹбҙҸЗ«бҙңбҙҮЙӘбҙҸ.*`)

ban.push(blcp)
fs.writeFileSync('./arquivos/database/usuarios/banned.json', JSON.stringify(ban, null, 2))

await maki.sendMessage(from, {
