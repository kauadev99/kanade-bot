if (!lista.length)
return reply('*ЙҙбҙҖМғбҙҸ КңбҙҖ бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸкңұ кңұбҙҮбҙҚ бҙҳКҖбҙҮкң°ЙӘxбҙҸ КҖбҙҮЙўЙӘкңұбҙӣКҖбҙҖбҙ…бҙҸкңұ рҹ’ҒвҖҚвҷӮпёҸ*');

await reagir(from, "рҹ—ҝ");

let msg = 'в•ӯвқҲЦҹв”Ғрҹ’ҷв”ҒЦҹвң§вҠ°вқ–вҠұр–Өҗвң§в”ҒЦҹв”Ғрҹ’ҷв”ҒЦҹвқҲв•®Цҙ\n';
lista.forEach((item) => {
msg += `в”ғр–ӨҗрқҶјЛҡаҰ”а§ЈНЎНңаҜҖНңвқҘрҹ’ҷв–ё кңұбҙҮбҙҚ бҙҳКҖбҙҮкң°ЙӘxбҙҸ\nв•ҺвҶі *${item.cmdSemPrefixo}*\n`;
msg += `в”ғр–ӨҗрқҶјЛҡаҰ”а§ЈНЎНңаҜҖНңвқҘрҹ’ҷв–ё бҙ„бҙҸбҙҚбҙҖЙҙбҙ…бҙҸ КҖбҙҮбҙҖКҹ\nв•ҺвҶі *${prefix + item.comandoOriginal}*\n`;
});
msg += `в•°вқҲЦҹв”Ғрҹ’ҷв”ҒЦҹвң§вҠ°вқ–вҠұр–Өҗвң§в”ҒЦҹв”Ғрҹ’ҷв”ҒЦҹвқҲв•Ҝ\n- ${NomeDoBot}\n- р–Өҗр–Өҗр–Өҗр–Өҗр–Өҗ`;

const caminhoVideo = './configs/LOGOS/fotomenu.mp4';

await maki.sendMessage(from, {
video: fs.readFileSync(caminhoVideo),
caption: msg,
gifPlayback: true,
contextInfo: { ...channeldl }
}, { quoted: selo });

} catch (e) {
console.error(e);
await maki.sendMessage(from, { text: mess.error() }, { quoted: selo });
}
}
break;

case 'gethtml':
if(!q || !isUrl(args[0])) return reply(`Modo de uso: ${prefix+command} link do site`)
try {
await replyWithReaction(`*бҙҮЙҙбҙ ЙӘбҙҖЙҙбҙ…бҙҸ бҙҮбҙҚ sбҙҮбҙң бҙҳбҙ  рҹҷҮвҖҚвҷӮпёҸ*`, {react: {text: 'вң…', key: info.key}});
axios.get(args[0], { headers: {"user-agent": "Mozilla/5.0 (Linux; Android 10) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/105.0.5195.136 Mobile Safari/537.36"}}).then(async (res) => {
let htmlData = typeof res.data === 'object' ? JSON.stringify(res.data, null, 2) : res.data
htmlData = htmlData.replace(/В В В  /g, '').replace(/></g, '>\n<').replace(/> </g, '>\n<')
await maki.sendMessage(sender, {document: Buffer.from(htmlData), fileName: q+`.html`, mimetype: 'text/html'}, {quoted: selo})}).catch(e => {return reply(mess.error())})
} catch (e) {
console.log(e)
reply(mess.error())
}
break

