case 'rg': {
try {
if(!q) return reply(`рҹ’ҷ Kanade diz...\n\nрҹ”Һ Use: ${prefix}rg 0000000`)

let res = await fetchJson(`https://zero-two-apis.com.br/consultas/serasa/rg?query=${q}&apikey=OFF_KYY`)

if(!res?.status) return reply("рҹ’” NГЈo encontrei nada... tenta novamente рҹ’ӯ")

let raw = res.resultado.data.data
let linhas = raw.split('\n')

// рҹ”Һ pegar linha especГӯfica
const get = (txt) => linhas.find(l => l.startsWith(txt)) || "NГЈo consta"

// рҹ”Һ pegar grupo
const getGroup = (title) => {
let i = linhas.findIndex(l => l.includes(title))
if(i === -1) return []
let arr = []
for(let x = i+1; x < linhas.length; x++){
if(linhas[x].includes(': (')) break
arr.push(linhas[x])
}
return arr
}

// рҹ“Ҡ dados principais
let nome = get("NOME")
let cpf = get("CPF")
let sexo = get("SEXO")
let nasc = get("NASCIMENTO")
let mae = get("NOME MГғE")
let pai = get("NOME PAI")
let estado = get("ESTADO CIVIL")
let renda = get("RENDA")
let score = get("SCORE")
let status = get("STATUS NA RECEITA")

// рҹ“Ұ grupos completos
let telefones = getGroup("TELEFONES")
let emails = getGroup("EMAILS")
let enderecos = getGroup("ENDERECOS")
let bancos = getGroup("BANCOS")
let parentes = getGroup("PARENTES")

let txt = `
в•ӯв”Ғв”Ғв”ҒгҖ” рҹ’ҷ KANADE RG FULL рҹ’ҷ гҖ•в”Ғв”Ғв”Ғв¬Ј
в”ғ рҹ‘Ө *${nome}*
в”ғ рҹ”Һ *${cpf}*
в”ғ рҹҡ» *${sexo}*
в”ғ рҹҺӮ *${nasc}*
в”ғ рҹ‘©вҖҚрҹ‘Ұ *${mae}*
в”ғ рҹ‘ЁвҖҚрҹ‘Ұ *${pai}*
в”ғ рҹ’Қ *${estado}*
в”ғ рҹ’° *${renda}*
в”ғ рҹ“Ҡ *${score}*
в”ғ рҹ§ҫ *${status}*
в”ғ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

в”ғ рҹ“һ *Telefones (${telefones.length}):*
${telefones.map(t => `в”ғ ${t}`).join('\n') || "в”ғ NГЈo consta"}

в”ғ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
в”ғ рҹ“§ *Emails (${emails.length}):*
${emails.map(e => `в”ғ ${e}`).join('\n') || "в”ғ NГЈo consta"}

в”ғ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
в”ғ рҹҸҰ *Bancos:*
${bancos.map(b => `в”ғ ${b}`).join('\n') || "в”ғ NГЈo consta"}

в”ғ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
в”ғ рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§ *Parentes:*
${parentes.map(p => `в”ғ ${p}`).join('\n') || "в”ғ NГЈo consta"}

в”ғ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
в”ғ рҹ“Қ *EndereГ§os (${enderecos.length}):*
${enderecos.map(e => `в”ғ ${e}`).join('\n') || "в”ғ NГЈo consta"}

в•°в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв¬Ј

рҹ’ҷ Kanade diz...
"Quanto mais profundo vocГӘ olha... mais descobre."
`

await maki.sendMessage(from, {
image: { url: "https://tokito-apis.site/4d32e3.jpg" },
caption: txt,
footer: "рҹ’ҷ KANADE V4",
buttons: [
{
buttonId: prefix + "menu",
buttonText: { displayText: "рҹ’ҷ MENU рҹ’ҷ" }
}
],
headerType: 6,
viewOnce: false
}, { quoted: info })

} catch (e) {
console.log(e)
reply("рҹ’” Erro na consulta... tenta novamente рҹ’ӯ")
}
}
break;

