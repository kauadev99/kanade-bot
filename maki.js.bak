buffer453 = fs.readFileSync(ran)
await maki.sendMessage(from, {video: buffer453, mimetype: 'video/mp4'}, {quoted: selo})
DLT_FL(ran)
})
} else {
reply("Marque um vГӯdeo..")
}
break 

